---
import Layout from '../layouts/Layout.astro';
import Toast from '../components/Toast.astro';
import ModalAlert from '../components/ModalAlert.astro';
---

<Layout title="Login - yukNgaji">
    <div class="px-8 py-12 flex flex-col h-full justify-center min-h-screen">
        
        <div class="mb-12 text-center">
            <div class="w-20 h-20 bg-green-100 rounded-2xl mx-auto flex items-center justify-center mb-6 shadow-sm border border-green-200">
                <i class="fa-solid fa-book-quran text-4xl text-green-600"></i>
            </div>
            <h1 class="text-3xl font-bold text-gray-800 mb-2">yukNgaji</h1>
            <p class="text-gray-500 text-sm">Selamat datang, silakan masuk ke akun Anda.</p>
        </div>

        <form id="loginForm" class="space-y-6">
            <div class="space-y-1">
                <label class="text-sm font-medium text-gray-700 ml-1">Username</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <i class="fa-regular fa-user text-gray-400"></i>
                    </div>
                    <input type="text" id="username" required
                        class="w-full pl-11 pr-4 py-3.5 bg-white border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all shadow-sm" 
                        placeholder="Masukkan username"
                    >
                </div>
            </div>

            <div class="space-y-1">
                <label class="text-sm font-medium text-gray-700 ml-1">Password</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <i class="fa-solid fa-lock text-gray-400"></i>
                    </div>
                    <input type="password" id="password" required
                        class="w-full pl-11 pr-4 py-3.5 bg-white border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all shadow-sm" 
                        placeholder="Masukkan password"
                    >
                </div>
            </div>

            <button type="submit" id="btnSubmit" 
                class="w-full py-3.5 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-xl shadow-md shadow-green-600/30 transition-all active:scale-[0.98] flex justify-center items-center mt-4">
                <span>Masuk Sekarang</span>
                <i class="fa-solid fa-arrow-right ml-2 text-sm"></i>
            </button>
        </form>

    </div>

    <Toast />
    <ModalAlert />
</Layout>

<script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    // Logika komunikasi dengan Backend
    document.getElementById('loginForm')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const username = (document.getElementById('username') as HTMLInputElement).value;
        const password = (document.getElementById('password') as HTMLInputElement).value;
        const btn = document.getElementById('btnSubmit');

        // Loading state
        const originalBtnText = btn.innerHTML;
        btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i>';
        btn.setAttribute('disabled', 'true');

        try {
            // Tembak endpoint Backend kamu (pastikan backend jalan di port 3000)
            const response = await fetch(`${API_URL}/api/login`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, password })
            });

            const data = await response.json();

            if (response.ok) {
                // Simpan token ke localStorage
                localStorage.setItem('token', data.data.token);
                localStorage.setItem('user', JSON.stringify(data.data));

                // Panggil Toast bawaan window (lihat di file Toast.astro)
                window.showToast('info', 'Berhasil', 'Login berhasil, mengalihkan...');
                
                // Redirect ke dashboard (bisa disesuaikan nanti)
                setTimeout(() => {
                    window.location.href = '/dashboard'; 
                }, 1500);
            } else {
                // Panggil Modal Danger kalau gagal
                window.showModal('danger', 'Login Gagal', data.message || 'Username atau password salah.');
            }
        } catch (error) {
            window.showModal('danger', 'Error Jaringan', 'Gagal terhubung ke server backend.');
        } finally {
            // Reset button
            btn.innerHTML = originalBtnText;
            btn.removeAttribute('disabled');
        }
    });
</script>