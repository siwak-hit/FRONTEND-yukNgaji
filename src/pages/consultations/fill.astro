        else { btnConfirm.disabled = false; btnConfirm.className = 'flex-1 py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-2xl shadow-lg shadow-indigo-600/30 active:scale-95 transition-all text-sm'; btnConfirm.innerText = 'Beli Sekarang'; }
