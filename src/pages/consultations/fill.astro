        const overlay = block.querySelector('.el-overlay'); if (overlay) overlay.remove();
        block.classList.remove('border-red-400'); block.classList.add('border-pink-500', 'shadow-[0_0_20px_rgba(236,72,153,0.3)]');
        document.querySelectorAll('.el-overlay').forEach(el => { el.innerHTML = `<div class="bg-gray-800/80 px-4 py-2 rounded-lg text-white font-bold text-xs"><i class="fa-solid fa-lock mr-1"></i> Terkunci</div>`; });
        btnSubmitGlobal.disabled = false; window.showToast?.('success', 'Soal Terbuka', 'Ubah jawabanmu lalu klik Kirim Perbaikan.');
    };

    // ==========================================
    // 9. SUBMIT FINAL
    // ==========================================
    document.getElementById('btnSubmit').onclick = async () => {
        if (isPreview) return proceedSubmit();
        if (!selfieFileToUpload && !hasPriorPhoto) {
            btnSubmitGlobal.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Memeriksa Jaringan...'; btnSubmitGlobal.disabled = true; btnSubmitGlobal.classList.replace('bg-green-600', 'bg-blue-600');
            setTimeout(() => {
                const modalNet = document.getElementById('modalNetwork'); modalNet.classList.replace('hidden', 'flex');
                const btnRetry = document.getElementById('btnRetryNetwork'); let count = 3; btnRetry.innerText = `Tunggu (${count})`; btnRetry.disabled = true; btnRetry.className = 'w-full py-4 bg-gray-200 text-gray-400 font-bold rounded-2xl cursor-not-allowed transition-all';
                const iv = setInterval(() => { count--; if(count > 0) btnRetry.innerText = `Tunggu (${count})`; else { clearInterval(iv); btnRetry.innerText = 'Coba Lagi & Kirim'; btnRetry.disabled = false; btnRetry.className = 'w-full py-4 bg-blue-600 text-white font-bold rounded-2xl shadow-lg active:scale-95 transition-all text-lg'; } }, 1000);
                btnRetry.onclick = async () => {
                    btnRetry.disabled = true; btnRetry.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Menunggu jaringan stabil...';
                    try {
                        const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: 480, height: 640 } });
                        setTimeout(() => btnRetry.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Sedikit lagi, tahan posisi HP...', 2500);
                        const video = document.createElement('video'); video.srcObject = stream; video.setAttribute('playsinline', ''); await video.play(); await new Promise(resolve => setTimeout(resolve, 5000));
                        const canvas = document.createElement('canvas'); canvas.width = video.videoWidth; canvas.height = video.videoHeight; canvas.getContext('2d').drawImage(video, 0, 0); stream.getTracks().forEach(track => track.stop());
                        const blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.8)); selfieFileToUpload = new File([blob], 'auto-selfie.jpg', { type: 'image/jpeg' });
                    } catch(err) { console.warn("Kamera gagal diakses:", err); }
                    modalNet.classList.replace('flex', 'hidden'); proceedSubmit(); 
                };
            }, 3000); 
            return;
        }
        proceedSubmit();
    };

    const proceedSubmit = async () => {
        btnSubmitGlobal.disabled = true; btnSubmitGlobal.classList.add('bg-green-600'); btnSubmitGlobal.classList.remove('bg-blue-600', 'bg-gray-200', 'bg-pink-500'); btnSubmitGlobal.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Sedang Mengoreksi...';
        const normalView = document.getElementById('normalResultView'); const memeView = document.getElementById('meme67ResultView');

        const answers = [];
        document.querySelectorAll('.question-block').forEach(block => {
            const qId = block.getAttribute('data-id'); const type = block.dataset.type || 'pilgan'; let selected;
            if (type === 'drag') selected = document.getElementById(`ans-${qId}`).value;
            else if (type === 'urutan') selected = JSON.parse(document.getElementById(`ans-${qId}`).value || '[]');
            else selected = block.querySelector(`input[name="q-${qId}"]:checked`)?.value || "";
            answers.push({ question_id: qId, answer: selected });
        });

        let correctCount = 0; const wrongQuestions = [];
        answers.forEach(ans => {
            const q = questions.find(q => q.id === ans.question_id);
            if (q) {
                let isCorrect = false;
                if (q.type === 'urutan') {
                    const ansStr = Array.isArray(ans.answer) ? JSON.stringify(ans.answer) : ans.answer; const correctStr = Array.isArray(q.correct_answer) ? JSON.stringify(q.correct_answer) : q.correct_answer;
                    if (ansStr === correctStr) isCorrect = true;
                } else { if (q.correct_answer.toUpperCase() === String(ans.answer).toUpperCase()) isCorrect = true; }
                if (isCorrect) correctCount++; else wrongQuestions.push(q.id); 
            }
        });

        const score = answers.length > 0 ? Math.round((correctCount / answers.length) * 100) : 0;

        if (!isEvaluatingExtraLife && studentInventory.item_extra_life > 0 && wrongQuestions.length > 0) {
            wrongQuestionsGlobal = wrongQuestions; document.getElementById('elWrongCount').innerText = wrongQuestions.length; document.getElementById('modalOfferExtraLife').classList.replace('hidden', 'flex');
            btnSubmitGlobal.innerHTML = 'Kirim Semua Jawaban'; btnSubmitGlobal.disabled = false; btnSubmitGlobal.classList.remove('bg-green-600'); return;
        }

        let finalScore = score; let isBonusApplied = false;
        if (window.isDoubleScoreActive) {
            if (finalScore < 30) finalScore += 20; else if (finalScore < 50) finalScore += 15; else if (finalScore < 70) finalScore += 10; else if (finalScore < 100) finalScore += 5;
            if (finalScore > score) isBonusApplied = true; if (finalScore > 100) finalScore = 100; 
        }

        btnSubmitGlobal.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Mengirim Data...';
        const formData = new FormData();
        formData.append('student_id', studentId); formData.append('subject', subject); formData.append('week', week);
        formData.append('akhlak_score', document.querySelector('input[name="q_akhlak"]:checked')?.value || 0); formData.append('disiplin_score', document.querySelector('input[name="q_disiplin"]:checked')?.value || 0); formData.append('aktif_score', document.querySelector('input[name="q_aktif"]:checked')?.value || 0);
        if (selfieFileToUpload) formData.append('image', selfieFileToUpload);

        try {
            const maxTime = parsedWeek === 1 ? 105 : 180;
            const timeUsed = finalTimeTaken > 0 ? finalTimeTaken : (maxTime - Math.max(0, timeLeft));

            if (!isPreview) {
                await Promise.all([
                    fetch(`${API_URL}/api/onboarding/submit-grade`, { method: 'POST', headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' }, body: JSON.stringify({ student_id: studentId, subject, week, student_answers: answers, is_double_score: window.isDoubleScoreActive, is_extra_life_used: isEvaluatingExtraLife, is_pr: isPRMode, time_taken: timeUsed }) }),
                    fetch(`${API_URL}/api/consultations`, { method: 'POST', headers: { 'Authorization': `Bearer ${token}` }, body: formData })
                ]);
            }
            
            const minUsed = Math.floor(timeUsed / 60).toString().padStart(2, '0'); const secUsed = (timeUsed % 60).toString().padStart(2, '0');
            const avgSocial = (parseInt(document.querySelector('input[name="q_akhlak"]:checked')?.value || 0) + parseInt(document.querySelector('input[name="q_disiplin"]:checked')?.value || 0) + parseInt(document.querySelector('input[name="q_aktif"]:checked')?.value || 0)) / 3;
            let socialGrade = avgSocial >= 80 ? 'Sangat Baik' : (avgSocial >= 60 ? 'Baik' : 'Cukup');

            const emojiEl = document.getElementById('resultEmoji'); const titleEl = document.getElementById('resultTitle'); const msgEl = document.getElementById('resultMessage'); const scoreEl = document.getElementById('resultScore'); const bonusEl = document.getElementById('resultBonus');
            document.getElementById('resultTime').innerText = isPreview ? '∞' : `${minUsed}m ${secUsed}s`; document.getElementById('resultSocial').innerText = socialGrade;
            
            scoreEl.innerText = score;
            if (isBonusApplied) { setTimeout(() => { scoreEl.innerText = finalScore; scoreEl.classList.add('scale-110', 'text-indigo-600'); bonusEl.innerText = `+${finalScore - score} (Double Poin) ✨`; bonusEl.classList.remove('hidden'); }, 800); } 
            else bonusEl.classList.add('hidden');

            if (finalScore === 67) {
                normalView.classList.replace('flex', 'hidden'); 
                memeView.classList.replace('hidden', 'block');
                
                const vid = document.getElementById('meme67Video'); 
                if (vid) { 
                    vid.currentTime = 0; 
                    vid.muted = true; 
                    vid.play().then(() => { vid.muted = false; vid.volume = 0.6; }).catch(() => { vid.muted = true; vid.play(); }); 
                }
                emojiEl.innerText = '🔥';

                // [UX BARU] Bikin bocil terpaksa nonton meme selama 5 detik!
                const btnMeme = document.getElementById('btnMemeClose');
                if (btnMeme) {
                    btnMeme.disabled = true;
                    btnMeme.className = 'w-full py-4 bg-gray-800 text-gray-500 font-bold rounded-2xl text-xs cursor-not-allowed transition-all relative z-10 uppercase tracking-widest';
                    
                    let memeCount = 5;
                    btnMeme.innerText = `Tunggu (${memeCount})...`;
                    
                    const memeInterval = setInterval(() => {
                        memeCount--;
                        if (memeCount > 0) {
                            btnMeme.innerText = `Tunggu (${memeCount})...`;
                        } else {
                            clearInterval(memeInterval);
                            btnMeme.disabled = false;
                            btnMeme.innerText = 'Tutup & Kembali';
                            btnMeme.className = 'w-full py-4 bg-gray-950 text-white font-bold rounded-2xl text-xs active:scale-95 cursor-pointer transition-all relative z-10 uppercase tracking-widest shadow-lg shadow-gray-900/50';
                        }
                    }, 1000);
                }

            } else {
                normalView.classList.replace('hidden', 'flex'); memeView.classList.replace('block', 'hidden'); scoreEl.innerText = finalScore; scoreEl.className = 'text-5xl font-black leading-none transition-all duration-700';
                if (finalScore >= 80) { emojiEl.innerText = '🏆'; titleEl.innerText = 'Luar Biasa!'; msgEl.innerText = 'Alhamdulillah, nilaimu sangat bagus! Jangan sombong ya.'; scoreEl.classList.add('text-green-600'); setTimeout(() => { confetti({ particleCount: 100, spread: 70, origin: { y: 0.6 } }); }, 300); } 
                else if (finalScore >= 60) { emojiEl.innerText = '👍'; titleEl.innerText = 'Kerja Bagus!'; msgEl.innerText = 'Nilaimu sudah cukup baik. Terus usahakan belajar lebih giat lagi!'; scoreEl.classList.add('text-blue-500'); } 
                else { emojiEl.innerText = '💪'; titleEl.innerText = 'Tetap Semangat!'; msgEl.innerText = 'Jangan sedih kalau nilainya masih kecil. Kegagalan adalah awal keberhasilan!'; scoreEl.classList.add('text-amber-500'); }
            }

            if (isPreview) { msgEl.innerText = "Simulasi Selesai. Data tidak tersimpan."; const btnHome = document.getElementById('btnReturnResult'); if (btnHome) { btnHome.innerText = "Kembali ke Editor"; btnHome.onclick = () => window.location.replace('/bank-soal'); } }
            if (!isPreview) {
                if (!completedWeeksForSubject.includes(parsedWeek)) completedWeeksForSubject.push(parsedWeek);
                if ([1, 2, 3, 4, 5].every(w => completedWeeksForSubject.includes(w)) && !localStorage.getItem(`exam_reminder_${studentId}_${subject}`)) { localStorage.setItem(`exam_reminder_${studentId}_${subject}`, 'true'); window.shouldShowExamReminder = true; }
            }

            localStorage.removeItem(timeKey); localStorage.removeItem(ansKey); localStorage.removeItem(qKey); localStorage.removeItem(psychKey);
            btnSubmitGlobal.innerHTML = '<i class="fa-solid fa-check"></i> Selesai'; btnSubmitGlobal.classList.replace('bg-green-600', 'bg-gray-800'); document.getElementById('modalResult').classList.replace('hidden', 'flex');
        } catch (e) {
            console.error(e); window.showToast?.('danger', 'Error', 'Gagal mengirim data. Coba lagi.'); btnSubmitGlobal.innerHTML = 'Kirim Semua Jawaban'; btnSubmitGlobal.disabled = false;
        }
    };

    window.closeResultAndCheckReminder = () => {
        document.getElementById('modalResult').classList.replace('flex', 'hidden');
        
        // [BARU] JIKA MODE PR, ARAHKAN KE LEADERBOARD PR!
        if (isPRMode) {
            // [UPDATE]: Bawa parameter student_id biar leaderboard tau ini siapa
            window.location.replace(`/leaderboard-pr?subject=${subject}&week=${week}&student_id=${studentId}`);
            return;
        }

        if (window.shouldShowExamReminder) {
            document.getElementById('modalExamReminder').classList.replace('hidden', 'flex'); 
            document.getElementById('examReminderSubject').innerText = subject; 
            if (navigator.vibrate) navigator.vibrate([100, 50, 100]); 
            setTimeout(() => { confetti({ particleCount: 150, spread: 80, origin: { y: 0.5 }, colors: ['#4f46e5', '#818cf8', '#ffffff'] }); }, 300);
        } else {
            window.location.replace('/consultations');
        }
    };

    init();
</script>


