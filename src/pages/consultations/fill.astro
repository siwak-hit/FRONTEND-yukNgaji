            }
        } else previewItem(itemKey);
    };

    const updateShopUI = () => {
        const displayPoin = document.getElementById('currentPoinDisplay'); if (displayPoin) displayPoin.innerText = studentWallet;
        Object.keys(ITEM_DB).forEach(key => {
            const btn = document.getElementById(`btn-shop-${key}`); if (!btn) return;
            const isOwned = studentInventory[key] > 0; const isBought = boughtItemsThisSession[key];
            const titleEl = btn.querySelector('.item-title'); const priceEl = btn.querySelector('.item-price');
            const oldBadge = btn.querySelector('.qty-badge'); if (oldBadge) oldBadge.remove();
            btn.className = "h-24 bg-white rounded-2xl border border-gray-100 flex flex-col items-center justify-center transition-all group relative"; btn.disabled = false;
            
            if (isOwned) {
                if (key === 'item_extra_life') { btn.classList.add('bg-pink-50', 'border-pink-300', 'cursor-default'); titleEl.innerText = "AKTIF OTOMATIS"; titleEl.className = "text-[8px] font-black text-pink-700 mt-1 uppercase tracking-wider item-title"; priceEl.innerText = ""; btn.disabled = true; } 
                else { btn.classList.add('bg-indigo-50', 'border-indigo-300', 'cursor-pointer'); titleEl.innerText = "PAKAI SEKARANG"; titleEl.className = "text-[8px] font-black text-indigo-700 mt-1 uppercase tracking-wider item-title"; priceEl.innerText = ""; }
                const newBadge = document.createElement('span'); newBadge.className = "qty-badge absolute -top-2 -right-2 bg-indigo-600 text-white text-[10px] font-black w-5 h-5 rounded-full flex items-center justify-center border-2 border-white shadow-md"; newBadge.innerText = studentInventory[key]; btn.appendChild(newBadge);
            } else if (isBought || studentWallet < ITEM_DB[key].price) {
                btn.classList.add('bg-gray-100', 'border-gray-200', 'opacity-50', 'grayscale', 'cursor-not-allowed'); titleEl.className = "text-[10px] font-bold text-gray-700 mt-1 item-title"; priceEl.innerText = isBought ? "HABIS" : `💰 ${ITEM_DB[key].price}`; btn.disabled = true;
            } else {
                btn.classList.add('hover:bg-indigo-50', 'hover:border-indigo-200', 'active:scale-95', 'cursor-pointer', 'shadow-sm'); titleEl.className = "text-[10px] font-bold text-gray-700 mt-1 item-title"; priceEl.innerText = ITEM_DB[key].price + " Poin";
            }
