                const btnText = p.has_shield ? 'Aman 🛡️' : (isBroke ? '0 Poin 😅' : 'SERANG ⚔️');
                const btnClass = isDisabled ? 'bg-gray-200 text-gray-400 cursor-not-allowed' : 'bg-red-500 text-white hover:bg-red-600 active:scale-95 shadow-md shadow-red-500/30';
                
                return `
                    <div class="flex items-center justify-between p-3 rounded-xl border ${isDisabled ? 'bg-gray-50 border-gray-100 opacity-70' : 'bg-white border-red-100 shadow-sm transition-all hover:border-red-200'}">
