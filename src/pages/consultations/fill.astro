        const intv = setInterval(() => { count--; if(count>0) text.innerText = count; else { clearInterval(intv); document.getElementById('countdownOverlay').classList.add('hidden'); startTest(true); } }, 1000);
    };

    const startTest = (isNewSession = true) => {
        // [UPDATE] Logika ketat per-sesi untuk menyembunyikan Miaw
        if (isNewSession) {
            window.isMiawHidden = document.getElementById('toggleHideMiaw')?.checked || false;
            if (window.isMiawHidden) sessionStorage.setItem(`hide_miaw_${studentId}_${subject}_${week}`, 'true');
        } else {
            // Kalau murid refresh halaman, ambil statusnya dari memori sementara
            window.isMiawHidden = sessionStorage.getItem(`hide_miaw_${studentId}_${subject}_${week}`) === 'true';
        }

        const shopWrapper = document.getElementById('shopDrawerWrapper');
        if (shopWrapper) { shopWrapper.style.transform = 'translateY(100%)'; shopWrapper.style.opacity = '0'; setTimeout(() => { shopWrapper.style.display = 'none'; }, 500); }
        document.getElementById('testContent').classList.remove('hidden');
        
        const header = document.getElementById('mainHeader');
        header.classList.add('-translate-y-full', 'opacity-0');
        setTimeout(() => { 
            header.classList.add('hidden'); 
            header.classList.remove('sticky');
        }, 500);

        document.getElementById('floatingTimer').classList.replace('hidden', 'flex');

        isQuizStarted = true; updateShopUI(); updateTimerUI();
        warned30 = false; warned10 = false;

        // [UPDATE] Eksekusi kemunculan atau penonaktifan Miaw
        if (window.MiawMascot) {
            if (window.isMiawHidden) {
                // Matikan paksa fungsinya agar tidak bersuara/nongol di sesi PR ini
                window.MiawMascot.show = () => {};
                window.MiawMascot.say = () => {};
                const mascotContainer = document.getElementById('mascotContainer') || document.querySelector('.mascot-wrapper');
                if (mascotContainer) mascotContainer.style.display = 'none';
            } else {
                setTimeout(() => window.MiawMascot.show(), 500);
            }
        }

        if (isNewSession) localStorage.setItem(timeKey, Date.now() + (timeLeft * 1000));
        if (timeLeft <= 0) return;
        
        timerInterval = setInterval(() => {
            timeLeft = Math.floor((localStorage.getItem(timeKey) - Date.now()) / 1000); 
            updateTimerUI();
            
            if (timeLeft === 30 && !warned30) {
                warned30 = true;
                if(window.MiawMascot) window.MiawMascot.say('large', `Awas <strong>${currentStudentName}</strong>! Waktu tinggal <strong>30 detik</strong> lagi!`, null, 'warning', 5000);
            }
            if (timeLeft === 10 && !warned10) {
                warned10 = true;
                if(window.MiawMascot) window.MiawMascot.say('large', `AYO CEPETAN <strong>${currentStudentName}</strong>!!!! Tinggal 10 detik!`, null, 'warning', 5000);
            }

            if (timeLeft <= 0) { 
                timeLeft = 0; 
                finalTimeTaken = parsedWeek === 1 ? 90 : 180; 
                clearInterval(timerInterval); 
                if (!isEvaluatingExtraLife) disableAcademicSection(); 
            }
        }, 1000);
    };


