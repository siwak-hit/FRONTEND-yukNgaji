        try {
            if (isPreview) {
                await new Promise(r => setTimeout(r, 600)); studentWallet += 50; hasClaimedBonusGlobal = true; localStorage.setItem(`bonus_claimed_${studentId}`, 'true'); updateShopUI(); document.getElementById('modalWelcomeBonus').classList.replace('flex', 'hidden'); window.showToast?.('success', 'Bonus Cair!', '50 Poin gratis berhasil ditambahkan ke dompetmu.'); return;
            }
            const res = await fetch(`${API_URL}/api/shop/claim-bonus`, { method: 'POST', headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' }, body: JSON.stringify({ student_id: studentId }) });
