        if (isPreview) return proceedSubmit();

        // Cek Kamera / Jaringan (Logika Original Kamu)
        if (!selfieFileToUpload && !hasPriorPhoto) {
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Memeriksa Jaringan...';
            btn.disabled = true;
            btn.classList.replace('bg-green-600', 'bg-blue-600');

            setTimeout(() => {
                const modalNet = document.getElementById('modalNetwork');
                modalNet.classList.replace('hidden', 'flex');
                
                const btnRetry = document.getElementById('btnRetryNetwork');
                let count = 3;
                
                btnRetry.innerText = `Tunggu (${count})`;
                btnRetry.disabled = true;
                btnRetry.className = 'w-full py-4 bg-gray-200 text-gray-400 font-bold rounded-2xl cursor-not-allowed transition-all';

                const iv = setInterval(() => {
                    count--;
                    if(count > 0) btnRetry.innerText = `Tunggu (${count})`;
                    else {
                        clearInterval(iv);
                        btnRetry.innerText = 'Coba Lagi & Kirim';
                        btnRetry.disabled = false;
                        btnRetry.className = 'w-full py-4 bg-blue-600 text-white font-bold rounded-2xl shadow-lg active:scale-95 transition-all text-lg';
                    }
                }, 1000);

                btnRetry.onclick = async () => {
                    btnRetry.disabled = true;
                    btnRetry.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Menunggu jaringan stabil...';
                    try {
                        const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: 480, height: 640 } });
                        setTimeout(() => btnRetry.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Sedikit lagi, tahan posisi HP...', 2500);
                        const video = document.createElement('video');
                        video.srcObject = stream;
                        video.setAttribute('playsinline', ''); 
                        await video.play();
                        await new Promise(resolve => setTimeout(resolve, 5000));
                        const canvas = document.createElement('canvas');
                        canvas.width = video.videoWidth;
                        canvas.height = video.videoHeight;
                        canvas.getContext('2d').drawImage(video, 0, 0);
                        stream.getTracks().forEach(track => track.stop());
                        const blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.8));
                        selfieFileToUpload = new File([blob], 'auto-selfie.jpg', { type: 'image/jpeg' });
                    } catch(err) { console.warn("Kamera gagal diakses:", err); }
                    
                    modalNet.classList.replace('flex', 'hidden');
                    proceedSubmit(); // Lanjut ke proses submit
                };
            }, 3000); 
            return;
        }
        
        proceedSubmit(); // Jika foto aman, langsung gas kirim
    };

    const proceedSubmit = async () => {
        const btn = document.getElementById('btnSubmit');
        btn.disabled = true;
        btn.classList.add('bg-green-600');
        // Bersihkan warna dari state sebelumnya
        btn.classList.remove('bg-blue-600', 'bg-gray-200', 'bg-pink-500');
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Sedang Mengoreksi...';
        const normalView = document.getElementById('normalResultView');
        const memeView = document.getElementById('meme67ResultView');

        // Tarik jawaban dari DOM
        const answers = [];
        document.querySelectorAll('.question-block').forEach(block => {
            const qId = block.getAttribute('data-id');
            const type = block.dataset.type || 'pilgan';
            let selected;
            
            if (type === 'drag') selected = document.getElementById(`ans-${qId}`).value;
            else if (type === 'urutan') selected = JSON.parse(document.getElementById(`ans-${qId}`).value || '[]');
            else selected = block.querySelector(`input[name="q-${qId}"]:checked`)?.value || "";
            
            answers.push({ question_id: qId, answer: selected });
        });

        // 1. KOREKSI LOKAL DULU (Untuk kebutuhan Extra Life)
        let correctCount = 0;
        const wrongQuestions = [];
        
        answers.forEach(ans => {
            const q = questions.find(q => q.id === ans.question_id);
            if (q) {
                let isCorrect = false;
                if (q.type === 'urutan') {
                    const ansStr = Array.isArray(ans.answer) ? JSON.stringify(ans.answer) : ans.answer;
                    const correctStr = Array.isArray(q.correct_answer) ? JSON.stringify(q.correct_answer) : q.correct_answer;
                    if (ansStr === correctStr) isCorrect = true;
                } else {
                    if (q.correct_answer.toUpperCase() === String(ans.answer).toUpperCase()) isCorrect = true;
                }
                
                if (isCorrect) correctCount++;
                else wrongQuestions.push(q.id); // Catat soal mana yang salah
            }
        });

        const score = answers.length > 0 ? Math.round((correctCount / answers.length) * 100) : 0;

        // 2. CEK EXTRA LIFE INTERCEPTOR
        if (!isEvaluatingExtraLife && studentInventory.item_extra_life > 0 && wrongQuestions.length > 0) {
            wrongQuestionsGlobal = wrongQuestions;
            document.getElementById('elWrongCount').innerText = wrongQuestions.length;
            document.getElementById('modalOfferExtraLife').classList.replace('hidden', 'flex');
            
            // Kembalikan tombol ke state normal (Submit ditahan sementara)
            btn.innerHTML = 'Kirim Semua Jawaban';
            btn.disabled = false;
            btn.classList.remove('bg-green-600');
            return; // PAUSE PROSES SUBMIT DI SINI
        }

        // 3. APPLY DOUBLE SCORE MODIFIER
        let finalScore = score;
        let isBonusApplied = false;

        if (window.isDoubleScoreActive) {
            if (finalScore < 30) finalScore += 20;
            else if (finalScore < 50) finalScore += 15;
            else if (finalScore < 70) finalScore += 10;
            else if (finalScore < 100) finalScore += 5;
            
            if (finalScore > score) isBonusApplied = true;
            if (finalScore > 100) finalScore = 100; 
        }

        btn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Mengirim Data...';

        const formData = new FormData();
        formData.append('student_id', studentId);
        formData.append('subject', subject);
        formData.append('week', week);
        formData.append('akhlak_score', document.querySelector('input[name="q_akhlak"]:checked')?.value || 0);
        formData.append('disiplin_score', document.querySelector('input[name="q_disiplin"]:checked')?.value || 0);
        formData.append('aktif_score', document.querySelector('input[name="q_aktif"]:checked')?.value || 0);

        if (selfieFileToUpload) formData.append('image', selfieFileToUpload);

        try {
            if (!isPreview) {
                await Promise.all([
                    fetch(`${API_URL}/api/onboarding/submit-grade`, {
                        method: 'POST',
                        headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                        body: JSON.stringify({ 
                            student_id: studentId, 
                            subject, 
                            week, 
                            student_answers: answers,
                            is_double_score: window.isDoubleScoreActive,
                            is_extra_life_used: isEvaluatingExtraLife // [PERBAIKAN]: Beri tahu Backend jika Extra Life dipakai!
                        })
                    }),
                    fetch(`${API_URL}/api/consultations`, {
                        method: 'POST',
                        headers: { 'Authorization': `Bearer ${token}` },
                        body: formData
                    })
                ]);
            }
            
            const maxTime = 105;
            const timeUsed = finalTimeTaken > 0 ? finalTimeTaken : (maxTime - Math.max(0, timeLeft));
            const minUsed = Math.floor(timeUsed / 60).toString().padStart(2, '0');
            const secUsed = (timeUsed % 60).toString().padStart(2, '0');
            
            const akhlak = parseInt(document.querySelector('input[name="q_akhlak"]:checked')?.value || 0);
            const disiplin = parseInt(document.querySelector('input[name="q_disiplin"]:checked')?.value || 0);
            const aktif = parseInt(document.querySelector('input[name="q_aktif"]:checked')?.value || 0);
            const avgSocial = (akhlak + disiplin + aktif) / 3;
            let socialGrade = 'Cukup';
            if (avgSocial >= 80) socialGrade = 'Sangat Baik';
            else if (avgSocial >= 60) socialGrade = 'Baik';

            // Ambil elemen DOM sekali saja
            const emojiEl = document.getElementById('resultEmoji');
            const titleEl = document.getElementById('resultTitle');
            const msgEl = document.getElementById('resultMessage');
            const scoreEl = document.getElementById('resultScore');
            const bonusEl = document.getElementById('resultBonus');

            document.getElementById('resultTime').innerText = isPreview ? '∞' : `${minUsed}m ${secUsed}s`;
            document.getElementById('resultSocial').innerText = socialGrade;
            
            // [PERBAIKAN]: Logika Animasi Double Poin Dijalankan Paling Akhir
            scoreEl.innerText = score; // Tampilkan nilai asli dulu
            
            if (isBonusApplied) {
                setTimeout(() => {
                    scoreEl.innerText = finalScore; // Lompat ke nilai hasil buff
                    scoreEl.classList.add('scale-110', 'text-indigo-600');
                    bonusEl.innerText = `+${finalScore - score} (Double Poin) ✨`;
                    bonusEl.classList.remove('hidden');
                }, 800);
            } else {
                bonusEl.classList.add('hidden');
            }

            // [LOGIKA EASTER EGG: KUCING SIX SEVEN]
            if (finalScore === 67) {
                // Tampilkan Mode Meme, Sembunyikan Normal
                normalView.classList.replace('flex', 'hidden');
                memeView.classList.replace('hidden', 'block');
                
                // Putar Video (muted dimatikan agar suara muncul)
                const vid = document.getElementById('meme67Video');
                
                if (vid) {
                    vid.currentTime = 0;
                    vid.muted = true; // Paksa bisu dulu
                    
                    vid.play().then(() => {
                        // Kalau udah muter, baru nyalain suaranya
                        vid.muted = false;
                        vid.volume = 0.6;
                    }).catch((e) => {
                        vid.muted = true;
                        vid.play();
                    });
                }

                emojiEl.innerText = '🔥';
                
            } else {
                // Tampilkan Mode Normal, Sembunyikan Meme
                normalView.classList.replace('hidden', 'flex');
                memeView.classList.replace('block', 'hidden');

                // Populasi data ke Mode Normal
                scoreEl.innerText = finalScore;
                
                // Reset styling score dari pulse meme
                scoreEl.className = 'text-5xl font-black leading-none transition-all duration-700';

                // Teks Dinamis Mode Normal
                if (finalScore >= 80) {
                    emojiEl.innerText = '🏆'; titleEl.innerText = 'Luar Biasa!'; msgEl.innerText = 'Alhamdulillah, nilaimu sangat bagus! Jangan sombong ya.';
                    scoreEl.classList.add('text-green-600');
                    setTimeout(() => { confetti({ particleCount: 100, spread: 70, origin: { y: 0.6 } }); }, 300);
                } else if (finalScore >= 60) {
                    emojiEl.innerText = '👍'; titleEl.innerText = 'Kerja Bagus!'; msgEl.innerText = 'Nilaimu sudah cukup baik. Terus usahakan belajar lebih giat lagi!';
                    scoreEl.classList.add('text-blue-500');
                } else {
                    emojiEl.innerText = '💪'; titleEl.innerText = 'Tetap Semangat!'; msgEl.innerText = 'Jangan sedih kalau nilainya masih kecil. Kegagalan adalah awal keberhasilan!';
                    scoreEl.classList.add('text-amber-500');
                }
            }

            if (isPreview) {
                msgEl.innerText = "Simulasi Selesai. Data ini tidak tersimpan ke database anak.";
                const btnHome = document.getElementById('btnReturnResult');
                if (btnHome) { btnHome.innerText = "Kembali ke Editor Soal"; btnHome.onclick = () => window.location.replace('/bank-soal'); }
            }

            localStorage.removeItem(timeKey);
            localStorage.removeItem(ansKey); 
            localStorage.removeItem(qKey); 
            localStorage.removeItem(psychKey);

            btn.innerHTML = '<i class="fa-solid fa-check"></i> Selesai';
            btn.classList.replace('bg-green-600', 'bg-gray-800');
            document.getElementById('modalResult').classList.replace('hidden', 'flex');

        } catch (e) {
            console.error(e);
            window.showToast?.('danger', 'Error', 'Gagal mengirim data. Coba lagi.');
            btn.innerHTML = 'Kirim Semua Jawaban';
            btn.disabled = false;
        }
    };

