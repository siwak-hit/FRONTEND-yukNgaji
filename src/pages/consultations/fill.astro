        const vignette = document.getElementById('shieldVignette');
        if (vignette) window.isShieldActive && isQuizStarted ? vignette.classList.replace('opacity-0', 'opacity-100') : vignette.classList.replace('opacity-100', 'opacity-0');
        const floatingItems = document.getElementById('floatingItems');
