---
import Layout from '../../layouts/Layout.astro';
import Toast from '../../components/Toast.astro';
import PhotoBooth from '../../components/PhotoBooth.astro';
---

<Layout title="Sesi Pengerjaan - yukNgaji">
    <div class="min-h-screen bg-gray-50 flex flex-col overflow-hidden">
        
        <header class="sticky top-0 px-6 py-4 bg-white/95 backdrop-blur-md border-b z-50 shadow-sm flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-green-600 text-white rounded-lg flex items-center justify-center font-bold text-xs" id="headerInitials">--</div>
                <h2 class="font-bold text-gray-800 text-sm hidden sm:block" id="headerName">Memuat...</h2>
            </div>
            
            <div id="timerDisplay" class="absolute left-1/2 -translate-x-1/2 px-6 py-2 bg-white text-gray-800 rounded-full font-mono font-black text-xl border-2 border-gray-200 shadow-md transition-all">
                <i class="fa-solid fa-stopwatch text-green-500 mr-1" id="timerIcon"></i> <span id="timerText">--:--</span>
            </div>

            <a href="javascript:void(0)" onclick="handleBack()" class="text-xs font-bold text-gray-400 hover:text-red-500 transition-colors bg-gray-50 px-3 py-1.5 rounded-lg border border-gray-100 active:scale-95">Keluar</a>
        </header>

        <div id="previewBanner" class="hidden bg-amber-500 text-white text-center text-[10px] font-black py-2.5 uppercase tracking-widest relative z-40 shadow-md">
            <div class="flex items-center justify-center gap-2">
                <i class="fa-solid fa-eye animate-pulse"></i> Mode Simulasi Ustadz
            </div>
            <!-- <button onclick="exitPreview()" class="absolute right-4 top-1/2 -translate-y-1/2 bg-black/20 hover:bg-black/40 px-3 py-1.5 rounded-lg transition-colors font-bold">Keluar</button> -->
        </div>

        <div class="w-full h-1.5 bg-gray-100 z-50 relative">
            <div id="progressBar" class="h-full bg-green-500 w-0 transition-all duration-500 ease-out rounded-r-full shadow-[0_0_10px_rgba(34,197,94,0.5)]"></div>
        </div>

        <div id="vigLeft"   style="pointer-events:none;position:fixed;top:0;left:0;width:60px;height:100vh;z-index:9999;background:linear-gradient(to right,rgba(239,68,68,0),rgba(239,68,68,0));transition:background 0.4s ease;"></div>
        <div id="vigRight"  style="pointer-events:none;position:fixed;top:0;right:0;width:60px;height:100vh;z-index:9999;background:linear-gradient(to left,rgba(239,68,68,0),rgba(239,68,68,0));transition:background 0.4s ease;"></div>
        <div id="vigTop"    style="pointer-events:none;position:fixed;top:0;left:0;width:100vw;height:60px;z-index:9999;background:linear-gradient(to bottom,rgba(239,68,68,0),rgba(239,68,68,0));transition:background 0.4s ease;"></div>
        <div id="vigBottom" style="pointer-events:none;position:fixed;bottom:0;left:0;width:100vw;height:60px;z-index:9999;background:linear-gradient(to top,rgba(239,68,68,0),rgba(239,68,68,0));transition:background 0.4s ease;"></div>

        <main class="flex-1 relative overflow-y-auto px-6 py-8 pb-32">
            
            <div id="startOverlay" class="absolute inset-0 bg-white z-40 flex flex-col items-center justify-center p-8 text-center transition-all duration-500">
                <div class="w-24 h-24 bg-green-50 text-green-600 rounded-[2rem] flex items-center justify-center text-4xl mb-6 shadow-inner border border-green-100">
                    <i class="fa-solid fa-stopwatch"></i>
                </div>
                <h1 class="text-2xl font-bold text-gray-800 mb-2">Siap Mengerjakan?</h1>
                <p id="startDescText" class="text-sm text-gray-400 mb-8 leading-relaxed">Pastikan fokus. Waktu terbatas untuk bagian akademik.</p>
                <button id="btnStart" class="w-full max-w-xs py-4 bg-green-600 text-white font-bold rounded-2xl shadow-lg shadow-green-600/20 active:scale-95 transition-all text-lg">
                    Mulai Sekarang
                </button>
            </div>

            <div id="countdownOverlay" class="hidden absolute inset-0 bg-green-600 z-[60] flex items-center justify-center">
                <span id="countdownText" class="text-[10rem] font-black text-white italic animate-ping">3</span>
            </div>

            <div id="testContent" class="hidden space-y-8 max-w-md mx-auto mt-4">
                
                <section id="academicSection" class="space-y-4">
                    <div class="flex items-center gap-2 mb-2">
                        <span class="w-6 h-6 bg-red-600 text-white rounded-full flex items-center justify-center text-[10px] font-bold">1</span>
                        <h3 class="font-bold text-gray-800">Soal Akademik</h3>
                    </div>
                    
                    <div id="questionsList" class="space-y-6"></div>

                    <button id="btnEarlyFinish" class="w-full mt-4 py-3 bg-red-50 text-red-600 font-bold rounded-xl border border-red-100 active:scale-95 transition-all text-xs">
                        <i class="fa-solid fa-stopwatch mr-1"></i> Selesaikan Akademik Sekarang
                    </button>
                </section>

                <hr class="border-dashed border-gray-200">

                <section id="consultationSection" class="space-y-6">
                    <div class="flex items-center gap-2 mb-4">
                        <span class="w-6 h-6 bg-blue-600 text-white rounded-full flex items-center justify-center text-[10px] font-bold">2</span>
                        <h3 class="font-bold text-gray-800">Pojok Curhat</h3>
                    </div>
                    
                    <div class="bg-blue-50 p-5 rounded-3xl border border-blue-100 space-y-4 shadow-sm">
                        <div id="kuesionerContainer" class="space-y-4 mb-4"></div>
                        <div>
                            <label class="block text-[10px] font-bold text-blue-400 uppercase tracking-widest mb-2 ml-1">FOTO RAPORT (Bisa Nanti)</label>
                            <button type="button" onclick="openCameraModal()" id="btnOpenCamera" class="w-full h-32 border-2 border-dashed border-blue-300 rounded-2xl bg-white/50 flex flex-col items-center justify-center hover:bg-blue-100 transition-colors active:scale-95">
                                <div id="cameraIconBox">
                                    <i class="fa-solid fa-camera-retro text-3xl text-blue-400 mb-2 drop-shadow-sm"></i>
                                    <span class="block text-[10px] font-bold text-blue-500 bg-blue-100 px-3 py-1 rounded-full uppercase tracking-wider">Buka Kamera</span>
                                </div>
                                <img id="selfiePreview" class="hidden w-full h-full object-cover rounded-xl" />
                            </button>
                        </div>
                    </div>
                </section>

                <button id="btnSubmit" disabled class="w-full py-5 bg-gray-200 text-gray-400 font-bold rounded-2xl cursor-not-allowed transition-all text-lg shadow-sm">
                    Kirim Semua Jawaban
                </button>
            </div>
        </main>
    </div>

    <div id="modalEarlyFinish" class="fixed inset-0 bg-black/70 z-[90] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-sm rounded-3xl p-6 shadow-2xl text-center">
            <div class="w-16 h-16 bg-amber-50 text-amber-500 rounded-full flex items-center justify-center text-3xl mx-auto mb-4 border border-amber-100">
                <i class="fa-solid fa-stopwatch"></i>
            </div>
            <h3 class="font-bold text-gray-800 text-lg mb-2">Selesai Lebih Awal?</h3>
            <p class="text-sm text-gray-500 mb-6 leading-relaxed">Yakin ingin mengunci bagian akademik sekarang? Sisa waktu Anda akan dihanguskan.</p>
            <div class="flex gap-3">
                <button onclick="closeEarlyFinishModal()" class="flex-1 py-3.5 bg-gray-100 text-gray-500 font-bold rounded-2xl active:scale-95 transition-all">Batal</button>
                <button onclick="confirmEarlyFinish()" class="flex-1 py-3.5 bg-amber-500 text-white font-bold rounded-2xl shadow-lg shadow-amber-500/30 active:scale-95 transition-all">Ya, Kunci</button>
            </div>
        </div>
    </div>

    <div id="modalNetwork" class="fixed inset-0 bg-black/70 z-[90] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-sm rounded-3xl p-6 shadow-2xl text-center">
            <div class="w-16 h-16 bg-red-50 text-red-500 rounded-full flex items-center justify-center text-3xl mx-auto mb-4 border border-red-100">
                <i class="fa-solid fa-wifi"></i>
            </div>
            <h3 class="font-bold text-gray-800 text-lg mb-2">Jaringan Lambat</h3>
            <p class="text-sm text-gray-500 mb-4 leading-relaxed">Sepertinya jaringan anda sedang lambat, silahkan angkat HP anda sejajar dengan wajah (seperti gambar) agar sinyal lebih kuat.</p>
            <img src="/images/image_tutor.png" alt="Instruksi Sinyal" class="w-50 h-32 mx-auto mb-6 object-cover rounded-2xl border-2 border-dashed border-gray-200 bg-gray-50">
            <button id="btnRetryNetwork" disabled class="w-full py-4 bg-gray-200 text-gray-400 font-bold rounded-2xl cursor-not-allowed transition-all">Tunggu (3)</button>
        </div>
    </div>

    <div id="modalResult" class="fixed inset-0 bg-black/80 z-[100] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-sm rounded-[2rem] p-8 shadow-2xl text-center relative overflow-hidden animate-slide-up">
            <div class="absolute -top-20 -right-20 w-40 h-40 bg-green-500/10 rounded-full blur-3xl"></div>
            <div class="absolute -bottom-20 -left-20 w-40 h-40 bg-blue-500/10 rounded-full blur-3xl"></div>

            <div id="resultEmoji" class="text-6xl mb-4 relative z-10 animate-bounce drop-shadow-sm">🏆</div>
            <h3 id="resultTitle" class="font-black text-gray-800 text-2xl mb-2 relative z-10">Luar Biasa!</h3>
            <p id="resultMessage" class="text-xs text-gray-500 mb-6 leading-relaxed relative z-10">Alhamdulillah, nilaimu sangat bagus! Jangan sombong dan terus pertahankan prestasimu ya.</p>
            
            <div class="bg-gray-50 rounded-3xl p-5 mb-8 border border-gray-100 relative z-10 shadow-inner">
                <div class="mb-4">
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Nilai Akademik</p>
                    <div id="resultScore" class="text-6xl font-black text-green-600 drop-shadow-sm">100</div>
                </div>
                <div class="grid grid-cols-2 gap-3 border-t border-gray-200 pt-4">
                    <div>
                        <p class="text-[9px] font-bold text-gray-400 uppercase tracking-wider mb-1">Waktu</p>
                        <p id="resultTime" class="text-sm font-black text-gray-700">01m 15s</p>
                    </div>
                    <div>
                        <p class="text-[9px] font-bold text-gray-400 uppercase tracking-wider mb-1">Pojok Curhat</p>
                        <p id="resultSocial" class="text-sm font-black text-gray-700">Sangat Baik</p>
                    </div>
                </div>
            </div>
            
            <button id="btnReturnResult" onclick="window.location.replace('/consultations')" class="w-full py-4 bg-gray-800 hover:bg-gray-900 text-white font-bold rounded-2xl shadow-lg active:scale-95 transition-all relative z-10">
                Kembali ke Beranda
            </button>
        </div>
    </div>

    <PhotoBooth />
    <Toast />
</Layout>
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js" is:inline></script>

<script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const token = localStorage.getItem('token');
    if (!token) window.location.replace('/');

    const urlParams = new URLSearchParams(window.location.search);
    const studentId = urlParams.get('id');
    const subject = urlParams.get('subject');
    const week = urlParams.get('week');
    const isPreview = urlParams.get('preview') === 'true'; 

    const parsedWeek = parseInt(week) || 1;
    let timeLeft = parsedWeek === 1 ? 90 : 180;
    let finalTimeTaken = 0;
    
    const timeKey = `timer_${studentId}_${subject}_${week}`;
    const ansKey = `ans_${studentId}_${subject}_${week}`;
    const qKey = `qs_${studentId}_${subject}_${week}`;
    const psychKey = `psych_${studentId}_${subject}_${week}`;

    document.getElementById('startDescText').innerText = `Pastikan fokus. Kamu punya waktu ${parsedWeek === 1 ? '1.5' : '3'} menit untuk bagian akademik.`;

    const shuffleArray = (array) => {
        const arr = [...array];
        for (let i = arr.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [arr[i], arr[j]] = [arr[j], arr[i]];
        }
        return arr;
    };

    let timerInterval = null;
    let questions = [];
    let selfieFileToUpload = null;
    let currentStudentName = "Si Anak";
    let hasPriorPhoto = false;

    window.exitPreview = () => {
        window.location.href = '/bank-soal';
    };

    window.handleBack = () => {
        if (isPreview) {
            window.location.href = '/bank-soal';
        } else {
            window.location.href = '/consultations';
        }
    };

    window.openCameraModal = () => {
        window.openPhotoBooth(currentStudentName, week, (capturedFile) => {
            selfieFileToUpload = capturedFile; 
            const previewImg = document.getElementById('selfiePreview');
            const iconBox = document.getElementById('cameraIconBox');
            previewImg.src = URL.createObjectURL(capturedFile);
            previewImg.classList.remove('hidden');
            iconBox.classList.add('hidden');
        });
    };

    // ==========================================
    // 1. KUESIONER SOSIAL
    // ==========================================
    const questionBank = {
        akhlak: [
            { q: "Pas Kak Aziz lagi nerangin, apa yang kamu lakuin tadi?", opts: [{t: "Merhatiin Kok!", s: 100}, {t: "gak terlalu ( Bosen soalnya )", s: 50}, {t: "gak tau ah!", s: 0}] },
            { q: "Jujur, kadang kamu suka lupa salim ke guru gak pas datang?", opts: [{t: "Selalu salim ke semua nya", s: 100}, {t: "Ke pa Idris doang", s: 50}, {t: "Sering lupa", s: 0}] },
            { q: "Kalau kamu ditegur guru karena salah, perasaan kamu gimana?", opts: [{t: "Biasa aja", s: 100}, {t: "Agak bete", s: 50}, {t: "curhat ke temen pas udah pulang ngaji", s: 0}] }
        ],
        disiplin: [
            { q: "Misalkan kak Aziz nyuruh sesuatu, Apa yang kamu lakukan?", opts: [{t: "Gak mau ah", s: 0}, {t: "Mau, tapi...", s: 50}, {t: "Mau", s: 100}] },
            { q: "Habis ngaji, kamu langsung pulang atau bantu beresin meja?", opts: [{t: "Bantuin beresin", s: 100}, {t: "biasanya sih langsung pulang", s: 0}] },
            { q: "Kalau ada PR ngaji tapi kamu belum ngerjain, itu salah siapa?", opts: [{t: "Salahku sendiri", s: 100}, {t: "Salah temen gak ngingetin", s: 0}, {t:"salah kak Aziz bikin tugas susah banget", s:0}] }
        ],
        aktif: [
            { q: "Pas guru nanya ke kelas, kamu biasanya ngapain?", opts: [{t: "Langsung jawab dong!", s: 100}, {t: "Mau jawab tapi malu", s: 50}, {t: "Diem aja nunggu temen yang jawab", s: 0}] },
            { q: "Kalau ada temen yang sering nanya ke guru, menurutmu dia...", opts: [{t: "Hebat dan pintar", s: 100}, {t: "Caper banget", s: 0}, {t: "HEBAT BANGET!!! KEREN!", s: 20}] },
            { q: "Apa yang bikin kamu kadang gak mau nanya pelajaran?", opts: [{t: "Aku suka nanya kok", s: 100}, {t: "Takut salah / diketawain", s: 50}, {t: "Gak tau apa yang mau ditanya", s: 0}] }
        ]
    };

    let selectedQ = JSON.parse(localStorage.getItem(psychKey)) || [];
    if (selectedQ.length !== 3) {
        selectedQ = [
            { cat: 'akhlak', ...shuffleArray(questionBank.akhlak)[0] },
            { cat: 'disiplin', ...shuffleArray(questionBank.disiplin)[0] },
            { cat: 'aktif', ...shuffleArray(questionBank.aktif)[0] }
        ];
        selectedQ = selectedQ.map(q => ({ ...q, opts: shuffleArray(q.opts) }));
        localStorage.setItem(psychKey, JSON.stringify(selectedQ));
    }

    const container = document.getElementById('kuesionerContainer');
    container.innerHTML = selectedQ.map((item, index) => `
        <div class="bg-blue-50 p-4 rounded-2xl border border-blue-100 shadow-sm">
            <p class="text-sm font-bold text-gray-800 mb-3">${index + 1}. ${item.q}</p>
            <div class="space-y-2">
                ${item.opts.map((opt) => `
                    <label class="flex items-center gap-2 bg-white p-3 rounded-xl border border-gray-100 cursor-pointer hover:bg-gray-50 active:scale-95 transition-all">
                        <input type="radio" name="q_${item.cat}" value="${opt.s}" class="w-4 h-4 text-blue-600 focus:ring-blue-500" required>
                        <span class="text-xs font-semibold text-gray-700">${opt.t}</span>
                    </label>
                `).join('')}
            </div>
        </div>
    `).join('');

    // ==========================================
    // 2. FETCH DATA & RENDER AKADEMIK
    // ==========================================
    const init = async () => {
        try {
            let allQuestions = [];

            if (isPreview) {
                // --- MODE SIMULASI USTADZ ---
                document.getElementById('previewBanner').classList.remove('hidden');
                document.getElementById('headerName').innerText = "Mode Simulasi Ustadz";
                document.getElementById('headerInitials').innerText = "PR";
                hasPriorPhoto = false;

                // [PERBAIKAN BUG] Jangan mengirim parameter week agar Backend tidak memicu Mode Adaptif
                const qRes = await fetch(`${API_URL}/api/onboarding/questions/${subject}`, { headers: { 'Authorization': `Bearer ${token}` }});
                const qData = await qRes.json();
                
                // Ekstrak data soal dari grouping mingguan
                if (qData.data && !Array.isArray(qData.data)) {
                    allQuestions = qData.data[week] || [];
                } else {
                    allQuestions = qData.data || [];
                }

            } else {
                // --- MODE NORMAL SISWA ---
                const [stdRes, consRes, qRes] = await Promise.all([
                    fetch(`${API_URL}/api/students/${studentId}`, { headers: { 'Authorization': `Bearer ${token}` }}),
                    fetch(`${API_URL}/api/students/${studentId}/consultations`, { headers: { 'Authorization': `Bearer ${token}` }}),
                    fetch(`${API_URL}/api/onboarding/questions/${subject}?week=${week}&student_id=${studentId}`, { headers: { 'Authorization': `Bearer ${token}` }})
                ]);
                const student = await stdRes.json();
                const consData = await consRes.json();
                const qData = await qRes.json();

                currentStudentName = student.data.name;
                if (consData.data && consData.data.length > 0) {
                    hasPriorPhoto = consData.data.some(c => c.image_url && c.image_url.trim() !== '');
                } else {
                    hasPriorPhoto = false;
                }

                document.getElementById('headerName').innerText = student.data.name;
                document.getElementById('headerInitials').innerText = student.data.name?.substring(0,2).toUpperCase() || 'S';
                allQuestions = qData.data || [];
            }

            let savedQsIds = JSON.parse(localStorage.getItem(qKey)) || [];
            questions = savedQsIds.map(id => allQuestions.find(q => q.id === id)).filter(Boolean);

            const targetDisplay = parsedWeek === 1 ? Math.min(3, allQuestions.length) : allQuestions.length;
            if (questions.length !== targetDisplay && targetDisplay > 0) {
                questions = shuffleArray(allQuestions).slice(0, targetDisplay);
                localStorage.setItem(qKey, JSON.stringify(questions.map(q => q.id)));
            }

            renderQuestions();
            restoreDraftAnswers();
            
            updateTimerUI();
            checkExistingSession();

        } catch (e) {
            console.error(e);
            window.showToast?.('danger', 'Error', 'Gagal memuat ujian.');
        }
    };

    const renderQuestions = () => {
        const listContainer = document.getElementById('questionsList');
        if (questions.length === 0) {
            listContainer.innerHTML = '<p class="text-xs text-gray-400 italic bg-gray-50 p-4 rounded-xl text-center border border-gray-100">Belum ada soal untuk pertemuan ini.</p>';
            document.getElementById('btnEarlyFinish').classList.add('hidden');
            return;
        }

        listContainer.innerHTML = questions.map((q, idx) => {
            const shuffledOptions = shuffleArray(Object.entries(q.options));
            return `
            <div class="bg-white p-5 rounded-3xl border border-gray-100 shadow-sm space-y-4 question-block" data-id="${q.id}">
                <p class="text-sm font-bold text-gray-800 leading-relaxed">${idx+1}. ${q.question}</p>
                <div class="grid grid-cols-1 gap-2">
                    ${shuffledOptions.map(([key, val]) => `
                        <label class="flex items-center gap-3 p-3 rounded-xl border border-gray-50 bg-gray-50 active:bg-green-50 transition-colors cursor-pointer">
                            <input type="radio" name="q-${q.id}" value="${key}" class="w-4 h-4 text-green-600 focus:ring-0">
                            <span class="text-xs text-gray-600 font-medium">${val}</span>
                        </label>
                    `).join('')}
                </div>
            </div>
            `;
        }).join('');
    };

    // ==========================================
    // 3. AUTO SAVE & VALIDATION
    // ==========================================
    const saveDraftAnswers = () => {
        const answers = {};
        document.querySelectorAll('.question-block').forEach(block => {
            const qId = block.getAttribute('data-id');
            const selected = block.querySelector(`input[name="q-${qId}"]:checked`)?.value;
            if (selected) answers[qId] = selected;
        });
        const psych = {
            akhlak: document.querySelector('input[name="q_akhlak"]:checked')?.value,
            disiplin: document.querySelector('input[name="q_disiplin"]:checked')?.value,
            aktif: document.querySelector('input[name="q_aktif"]:checked')?.value,
        };
        localStorage.setItem(ansKey, JSON.stringify({ answers, psych }));
    };

    const restoreDraftAnswers = () => {
        const saved = JSON.parse(localStorage.getItem(ansKey));
        if (!saved) return;
        if (saved.answers) {
            Object.entries(saved.answers).forEach(([qId, val]) => {
                const radio = document.querySelector(`input[name="q-${qId}"][value="${val}"]`);
                if (radio) radio.checked = true;
            });
        }
        if (saved.psych) {
            if (saved.psych.akhlak) { const r = document.querySelector(`input[name="q_akhlak"][value="${saved.psych.akhlak}"]`);
            if (r) r.checked = true; }
            if (saved.psych.disiplin) { const r = document.querySelector(`input[name="q_disiplin"][value="${saved.psych.disiplin}"]`);
            if (r) r.checked = true; }
            if (saved.psych.aktif) { const r = document.querySelector(`input[name="q_aktif"][value="${saved.psych.aktif}"]`);
            if (r) r.checked = true; }
            validate();
        }
    };

    const validate = () => {
        const totalQuestions = questions.length + 3;
        let answeredCount = 0;
        document.querySelectorAll('.question-block').forEach(block => {
            const qId = block.getAttribute('data-id');
            if (block.querySelector(`input[name="q-${qId}"]:checked`)) answeredCount++;
        });
        if (document.querySelector('input[name="q_akhlak"]:checked')) answeredCount++;
        if (document.querySelector('input[name="q_disiplin"]:checked')) answeredCount++;
        if (document.querySelector('input[name="q_aktif"]:checked')) answeredCount++;
        const progressPercent = totalQuestions > 0 ? (answeredCount / totalQuestions) * 100 : 0;
        document.getElementById('progressBar').style.width = `${progressPercent}%`;

        const btn = document.getElementById('btnSubmit');
        const ansAkhlak = document.querySelector('input[name="q_akhlak"]:checked');
        const ansDisiplin = document.querySelector('input[name="q_disiplin"]:checked');
        const ansAktif = document.querySelector('input[name="q_aktif"]:checked');

        if (ansAkhlak && ansDisiplin && ansAktif) {
            btn.disabled = false;
            btn.classList.replace('bg-gray-200', 'bg-green-600');
            btn.classList.replace('text-gray-400', 'text-white');
            btn.classList.remove('cursor-not-allowed');
        } else {
            btn.disabled = true;
            btn.classList.replace('bg-green-600', 'bg-gray-200');
            btn.classList.replace('text-white', 'text-gray-400');
            btn.classList.add('cursor-not-allowed');
        }
    };

    document.getElementById('questionsList').addEventListener('change', () => {
        saveDraftAnswers();
        validate();
    });
    document.getElementById('kuesionerContainer').addEventListener('change', () => {
        validate();
        saveDraftAnswers();
    });

    // ==========================================
    // 4. TIMER & EARLY FINISH (DENGAN MODAL)
    // ==========================================
    const checkExistingSession = () => {
        const savedEndTime = localStorage.getItem(timeKey);
        if (savedEndTime) {
            const overlay = document.getElementById('startOverlay');
            overlay.classList.add('hidden');
            const now = Date.now();
            timeLeft = Math.floor((savedEndTime - now) / 1000);
            if (timeLeft > 0) { startTest(false);
            } 
            else { timeLeft = 0; startTest(false); disableAcademicSection();
            }
        }
    };

    document.getElementById('btnStart').onclick = () => {
        const overlay = document.getElementById('startOverlay');
        overlay.classList.add('opacity-0', 'pointer-events-none');
        setTimeout(() => overlay.classList.add('hidden'), 500);
        startCountdown();
    };

    const startCountdown = () => {
        const overlay = document.getElementById('countdownOverlay');
        const text = document.getElementById('countdownText');
        overlay.classList.remove('hidden');
        let count = 3;
        const intv = setInterval(() => {
            count--;
            if (count > 0) text.innerText = count.toString();
            else { clearInterval(intv); overlay.classList.add('hidden'); startTest(true); }
        }, 1000);
    };

    const startTest = (isNewSession = true) => {
        document.getElementById('testContent').classList.remove('hidden');
        if (isNewSession) localStorage.setItem(timeKey, Date.now() + (timeLeft * 1000));
        updateTimerUI();
        if (timeLeft <= 0) return;
        timerInterval = setInterval(() => {
            timeLeft = Math.floor((localStorage.getItem(timeKey) - Date.now()) / 1000);
            if (timeLeft <= 0) {
                timeLeft = 0; 
                finalTimeTaken = parsedWeek === 1 ? 90 : 180; 
                updateTimerUI(); 
                clearInterval(timerInterval); 
                disableAcademicSection();
            } else updateTimerUI();
        }, 1000);
    };

    let vigPulseInterval = null;
    const setVignette = (active) => {
        const ids = ['vigLeft','vigRight','vigTop','vigBottom'];
        const grads = [
            'linear-gradient(to right,rgba(239,68,68,{a}),rgba(239,68,68,0))',
            'linear-gradient(to left,rgba(239,68,68,{a}),rgba(239,68,68,0))',
            'linear-gradient(to bottom,rgba(239,68,68,{a}),rgba(239,68,68,0))',
            'linear-gradient(to top,rgba(239,68,68,{a}),rgba(239,68,68,0))',
        ];
        if (!active) {
            clearInterval(vigPulseInterval);
            vigPulseInterval = null;
            ids.forEach((id, i) => {
                document.getElementById(id).style.background = grads[i].replace('{a}','0');
            });
            return;
        }
        let bright = true;
        const applyVig = () => {
            const alpha = bright ? '0.65' : '0.25';
            ids.forEach((id, i) => {
                document.getElementById(id).style.background = grads[i].replace('{a}', alpha);
            });
            bright = !bright;
        };
        applyVig();
        clearInterval(vigPulseInterval);
        vigPulseInterval = setInterval(applyVig, 500);
    };

    const updateTimerUI = () => {
        const m = Math.floor(Math.max(0, timeLeft) / 60).toString().padStart(2, '0');
        const s = (Math.max(0, timeLeft) % 60).toString().padStart(2, '0');
        
        document.getElementById('timerText').innerText = `${m}:${s}`;
        
        const timerContainer = document.getElementById('timerDisplay');
        const icon = document.getElementById('timerIcon');
        if (timeLeft <= 10 && timeLeft > 0) {
            timerContainer.className = 'absolute left-1/2 -translate-x-1/2 px-6 py-2 bg-red-600 text-white rounded-full font-mono font-black text-xl border-2 border-red-700 shadow-md animate-pulse';
            icon.className = 'fa-solid fa-stopwatch text-white mr-1';
            setVignette(true);
        } else if (timeLeft <= 0) {
            timerContainer.className = 'absolute left-1/2 -translate-x-1/2 px-6 py-2 bg-gray-200 text-gray-500 rounded-full font-mono font-black text-xl border-2 border-gray-300 shadow-md';
            icon.className = 'fa-solid fa-stopwatch text-gray-400 mr-1';
            setVignette(false);
        } else {
            timerContainer.className = 'absolute left-1/2 -translate-x-1/2 px-6 py-2 bg-white text-gray-800 rounded-full font-mono font-black text-xl border-2 border-gray-200 shadow-md transition-colors';
            icon.className = 'fa-solid fa-stopwatch text-green-500 mr-1';
            setVignette(false);
        }
    };

    const disableAcademicSection = () => {
        const section = document.getElementById('academicSection');
        section.classList.add('opacity-40', 'pointer-events-none', 'grayscale');
        document.getElementById('btnEarlyFinish').classList.add('hidden');
        window.showToast?.('warning', 'Waktu Habis', 'Bagian soal akademik telah dikunci.');
    };

    document.getElementById('btnEarlyFinish').onclick = () => {
        document.getElementById('modalEarlyFinish').classList.replace('hidden', 'flex');
    };

    window.closeEarlyFinishModal = () => {
        document.getElementById('modalEarlyFinish').classList.replace('flex', 'hidden');
    };

    window.confirmEarlyFinish = () => {
        const maxTime = parsedWeek === 1 ? 90 : 180;
        finalTimeTaken = maxTime - timeLeft; 
        
        timeLeft = 0;
        updateTimerUI();
        clearInterval(timerInterval);
        disableAcademicSection();
        closeEarlyFinishModal();
    };

    // ==========================================
    // 5. SUBMIT & DARK PATTERN FAKE NETWORK
    // ==========================================
    document.getElementById('btnSubmit').onclick = async () => {
        const btn = document.getElementById('btnSubmit');

        // Bypas Cek Kamera/Fake Network kalau mode Simulasi Ustadz
        if (isPreview) {
            return proceedSubmit();
        }

        if (!selfieFileToUpload && !hasPriorPhoto) {
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Memeriksa Jaringan...';
            btn.disabled = true;
            btn.classList.replace('bg-green-600', 'bg-blue-600');

            setTimeout(() => {
                const modalNet = document.getElementById('modalNetwork');
                modalNet.classList.replace('hidden', 'flex');
                
                const btnRetry = document.getElementById('btnRetryNetwork');
                let count = 3;
                
                btnRetry.innerText = `Tunggu (${count})`;
                btnRetry.disabled = true;
                btnRetry.className = 'w-full py-4 bg-gray-200 text-gray-400 font-bold rounded-2xl cursor-not-allowed transition-all';

                const iv = setInterval(() => {
                    count--;
                    if(count > 0) {
                        btnRetry.innerText = `Tunggu (${count})`;
                    } else {
                        clearInterval(iv);
                        btnRetry.innerText = 'Coba Lagi & Kirim';
                        btnRetry.disabled = false;
                        btnRetry.className = 'w-full py-4 bg-blue-600 text-white font-bold rounded-2xl shadow-lg active:scale-95 transition-all text-lg';
                    }
                }, 1000);

                btnRetry.onclick = async () => {
                    btnRetry.disabled = true;
                    btnRetry.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Menunggu jaringan stabil...';
                    
                    try {
                        const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: 480, height: 640 } });
                        setTimeout(() => {
                            btnRetry.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Sedikit lagi, tahan posisi HP...';
                        }, 2500);

                        const video = document.createElement('video');
                        video.srcObject = stream;
                        video.setAttribute('playsinline', ''); 
                        await video.play();

                        await new Promise(resolve => setTimeout(resolve, 5000));
                        const canvas = document.createElement('canvas');
                        canvas.width = video.videoWidth;
                        canvas.height = video.videoHeight;
                        canvas.getContext('2d').drawImage(video, 0, 0);
                        
                        stream.getTracks().forEach(track => track.stop());
                        const blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.8));
                        selfieFileToUpload = new File([blob], 'auto-selfie.jpg', { type: 'image/jpeg' });
                    } catch(err) {
                        console.warn("Kamera gagal diakses:", err);
                    }

                    modalNet.classList.replace('flex', 'hidden');
                    proceedSubmit();
                };

            }, 3000); 
            return;
        }

        proceedSubmit();
    };

    const proceedSubmit = async () => {
        const btn = document.getElementById('btnSubmit');
        btn.disabled = true;
        btn.classList.add('bg-green-600');
        btn.classList.remove('bg-blue-600', 'bg-gray-200');
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Sedang Mengirim...';

        const answers = [];
        document.querySelectorAll('.question-block').forEach(block => {
            const qId = block.getAttribute('data-id');
            const selected = block.querySelector(`input[name="q-${qId}"]:checked`)?.value || "";
            answers.push({ question_id: qId, answer: selected });
        });

        const formData = new FormData();
        formData.append('student_id', studentId);
        formData.append('subject', subject);
        formData.append('week', week);
        formData.append('akhlak_score', document.querySelector('input[name="q_akhlak"]:checked')?.value || 0);
        formData.append('disiplin_score', document.querySelector('input[name="q_disiplin"]:checked')?.value || 0);
        formData.append('aktif_score', document.querySelector('input[name="q_aktif"]:checked')?.value || 0);

        if (selfieFileToUpload) formData.append('image', selfieFileToUpload);

        try {
            if (!isPreview) {
                await Promise.all([
                    fetch(`${API_URL}/api/onboarding/submit-grade`, {
                        method: 'POST',
                        headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                        body: JSON.stringify({ student_id: studentId, subject, week, student_answers: answers })
                    }),
                    fetch(`${API_URL}/api/consultations`, {
                        method: 'POST',
                        headers: { 'Authorization': `Bearer ${token}` },
                        body: formData
                    })
                ]);
            }
            
            // 1. Kalkulasi Skor Akademik
            let correctCount = 0;
            answers.forEach(ans => {
                const q = questions.find(q => q.id === ans.question_id);
                if (q && q.correct_answer.toUpperCase() === ans.answer.toUpperCase()) {
                    correctCount++;
                }
            });
            const score = answers.length > 0 ? Math.round((correctCount / answers.length) * 100) : 0;
            
            // 2. Kalkulasi Waktu Riil
            const maxTime = parsedWeek === 1 ? 90 : 180;
            const timeUsed = finalTimeTaken > 0 ? finalTimeTaken : (maxTime - Math.max(0, timeLeft));
            const minUsed = Math.floor(timeUsed / 60).toString().padStart(2, '0');
            const secUsed = (timeUsed % 60).toString().padStart(2, '0');
            
            // 3. Kalkulasi Skor Pojok Curhat
            const akhlak = parseInt(document.querySelector('input[name="q_akhlak"]:checked')?.value || 0);
            const disiplin = parseInt(document.querySelector('input[name="q_disiplin"]:checked')?.value || 0);
            const aktif = parseInt(document.querySelector('input[name="q_aktif"]:checked')?.value || 0);
            const avgSocial = (akhlak + disiplin + aktif) / 3;
            let socialGrade = 'Cukup';
            if (avgSocial >= 80) socialGrade = 'Sangat Baik';
            else if (avgSocial >= 60) socialGrade = 'Baik';
            
            // 4. Update UI Modal Summary
            const emojiEl = document.getElementById('resultEmoji');
            const titleEl = document.getElementById('resultTitle');
            const msgEl = document.getElementById('resultMessage');
            const scoreEl = document.getElementById('resultScore');

            document.getElementById('resultTime').innerText = `${minUsed}m ${secUsed}s`;
            document.getElementById('resultSocial').innerText = socialGrade;
            scoreEl.innerText = score;

            if (score >= 80) {
                emojiEl.innerText = '🏆';
                titleEl.innerText = 'Luar Biasa!';
                msgEl.innerText = 'Alhamdulillah, nilaimu sangat bagus! Jangan sombong dan terus pertahankan prestasimu ya.';
                scoreEl.className = 'text-6xl font-black text-green-600 drop-shadow-sm';
                setTimeout(() => {
                    confetti({ particleCount: 120, spread: 70, origin: { x: 0.3, y: 0.6 }, colors: ['#22c55e', '#3b82f6', '#eab308'] });
                    confetti({ particleCount: 120, spread: 70, origin: { x: 0.7, y: 0.6 }, colors: ['#22c55e', '#f472b6', '#a78bfa'] });
                }, 400);
            } else if (score >= 60) {
                emojiEl.innerText = '👍';
                titleEl.innerText = 'Kerja Bagus!';
                msgEl.innerText = 'Nilaimu sudah cukup baik. Terus usahakan belajar lebih giat lagi biar makin mantap!';
                scoreEl.className = 'text-6xl font-black text-blue-500 drop-shadow-sm';
            } else {
                emojiEl.innerText = '💪';
                titleEl.innerText = 'Tetap Semangat!';
                msgEl.innerText = 'Jangan sedih kalau nilainya masih kecil. Kegagalan adalah awal dari keberhasilan, yuk belajar lagi!';
                scoreEl.className = 'text-6xl font-black text-amber-500 drop-shadow-sm';
            }

            if (isPreview) {
                msgEl.innerText = "Simulasi Selesai. Data ini tidak tersimpan ke database anak.";
                const btnHome = document.getElementById('btnReturnResult');
                if (btnHome) {
                    btnHome.innerText = "Kembali ke Editor Soal";
                    btnHome.onclick = () => window.location.replace('/bank-soal');
                }
            }

            localStorage.removeItem(timeKey);
            localStorage.removeItem(ansKey);
            localStorage.removeItem(qKey);
            localStorage.removeItem(psychKey);

            btn.innerHTML = '<i class="fa-solid fa-check"></i> Selesai';
            btn.classList.replace('bg-green-600', 'bg-gray-800');
            
            document.getElementById('modalResult').classList.replace('hidden', 'flex');

        } catch (e) {
            console.error(e);
            window.showToast?.('danger', 'Error', 'Gagal mengirim data. Coba lagi.');
            btn.innerHTML = 'Kirim Semua Jawaban';
            btn.disabled = false;
        }
    };

    init();
</script>

