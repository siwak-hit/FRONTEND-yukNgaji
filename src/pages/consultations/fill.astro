---
import Layout from '../../layouts/Layout.astro';
import Toast from '../../components/Toast.astro';
import PhotoBooth from '../../components/PhotoBooth.astro';
import Mascot from '../../components/Mascot.astro';
---

<Layout title="Sesi Pengerjaan - yukNgaji">
    <div class="min-h-screen bg-gray-50 flex flex-col overflow-hidden relative">
        
        <header id="mainHeader" class="sticky top-0 px-6 py-4 bg-white/95 backdrop-blur-md border-b z-[80] shadow-sm flex items-center justify-between transition-all duration-500 transform translate-y-0">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-green-600 text-white rounded-lg flex items-center justify-center font-bold text-xs" id="headerInitials">--</div>
                <h2 class="font-bold text-gray-800 text-sm hidden sm:block" id="headerName">Memuat...</h2>
            </div>
            
            <div id="headerTimerDisplay" class="absolute left-1/2 -translate-x-1/2 px-6 py-2 bg-white text-gray-800 rounded-full font-mono font-black text-xl border-2 border-gray-200 shadow-md transition-all">
                <i class="fa-solid fa-stopwatch text-green-500 mr-1" id="headerTimerIcon"></i> <span id="headerTimerText">--:--</span>
            </div>

            <a href="javascript:void(0)" onclick="handleBack()" class="text-xs font-bold text-gray-400 hover:text-red-500 transition-colors bg-gray-50 px-3 py-1.5 rounded-lg border border-gray-100 active:scale-95">Keluar</a>
        </header>

        <div id="floatingTimer" onclick="toggleFloatingTimer()" class="fixed top-6 right-6 z-[250] hidden flex-row items-center bg-white rounded-full shadow-[0_5px_15px_rgba(0,0,0,0.1)] border border-gray-100 cursor-pointer transition-all duration-300 p-1 hover:scale-105">
            <div class="relative w-9 h-9 flex items-center justify-center rounded-full flex-shrink-0" id="timerRing" style="background: conic-gradient(#16a34a 100%, #f3f4f6 0%);">
                <div class="w-[26px] h-[26px] bg-white rounded-full flex items-center justify-center absolute z-10">
                    <i class="fa-solid fa-stopwatch text-green-600 text-[11px] transition-colors" id="floatTimerIcon"></i>
                </div>
            </div>
            <div id="timerTextContainer" class="overflow-hidden transition-all duration-300 w-[50px] ml-1 flex items-center justify-center">
                <span id="timerTextFloat" class="font-mono font-black text-gray-800 text-sm">--:--</span>
            </div>
        </div>

        <div id="floatingItems" onclick="toggleFloatingItems()" class="fixed top-[4.5rem] right-6 z-[250] hidden flex-row-reverse items-center bg-white rounded-full shadow-[0_5px_15px_rgba(0,0,0,0.1)] border border-gray-100 cursor-pointer transition-all duration-300 p-1 hover:scale-105">
            <div class="relative w-9 h-9 flex items-center justify-center rounded-full flex-shrink-0 bg-indigo-50 border border-indigo-100 z-10">
                <i class="fa-solid fa-box text-indigo-500 text-xs transition-transform" id="floatItemsIcon"></i>
            </div>
            <div id="itemsTextContainer" class="overflow-hidden transition-all duration-300 max-w-0 opacity-0 flex items-center justify-end gap-1.5 h-9">
                </div>
        </div>

        <div id="shopDrawerWrapper" class="fixed bottom-0 left-0 w-full z-[350] flex flex-col items-center pointer-events-none overflow-hidden">
            <div id="shopDrawerInner" class="w-full max-w-md flex flex-col items-center transform translate-y-[calc(100%-40px)] transition-transform duration-500 ease-out">
                
                <button id="btnToggleDrawer" onclick="toggleShopDrawer()" class="h-[40px] pointer-events-auto bg-indigo-600 text-white px-8 rounded-t-2xl shadow-[0_-5px_15px_rgba(79,70,229,0.3)] flex items-center justify-center gap-2 hover:bg-indigo-700 active:bg-indigo-800 transition-all border-x border-t border-indigo-400/50 outline-none">
                    <i id="shopDrawerIcon" class="fa-solid fa-store transition-transform duration-300"></i>
                    <span class="font-black text-[11px] tracking-widest uppercase">Toko Item</span>
                </button>
                
                <div id="shopDrawerContent" class="pointer-events-auto w-full bg-white/95 backdrop-blur-xl rounded-t-[2rem] p-6 shadow-[0_-10px_40px_rgba(0,0,0,0.2)] border-t border-gray-200">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="font-black text-gray-800 text-lg"><i class="fa-solid fa-basket-shopping text-indigo-500 mr-1"></i> Pasar Sihir</h3>
                        <div class="bg-amber-100 px-3 py-1.5 rounded-xl border border-amber-200 flex items-center gap-1.5 shadow-inner">
                            <span class="text-[9px] font-bold text-amber-700 uppercase tracking-wider">Saldo:</span>
                            <span class="text-sm">💰</span>
                            <span id="currentPoinDisplay" class="text-base font-black text-amber-600 drop-shadow-sm">0</span>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-2 gap-3 mb-2 pb-4">
                        <button id="btn-shop-item_double_score" onclick="handleShopClick('item_double_score')" class="h-24 bg-gray-50 rounded-2xl border border-gray-100 flex flex-col items-center justify-center hover:bg-indigo-50 active:scale-95 transition-all group relative">
                            <span class="text-3xl mb-1 drop-shadow-md group-hover:scale-110 transition-transform">✨</span>
                            <span class="text-[10px] font-bold text-gray-700 mt-1 item-title">Double Poin</span>
                            <span class="text-[10px] font-black text-amber-500 mt-1 item-price">50 Poin</span>
                        </button>
                        <button id="btn-shop-item_serang" onclick="handleShopClick('item_serang')" class="h-24 bg-gray-50 rounded-2xl border border-gray-100 flex flex-col items-center justify-center hover:bg-red-50 active:scale-95 transition-all group relative">
                            <span class="text-3xl mb-1 drop-shadow-md group-hover:scale-110 transition-transform">⚔️</span>
                            <span class="text-[10px] font-bold text-gray-700 mt-1 item-title">Serang Teman</span>
                            <span class="text-[10px] font-black text-amber-500 mt-1 item-price">100 Poin</span>
                        </button>
                        <button id="btn-shop-item_perisai" onclick="handleShopClick('item_perisai')" class="h-24 bg-gray-50 rounded-2xl border border-gray-100 flex flex-col items-center justify-center hover:bg-blue-50 active:scale-95 transition-all group relative">
                            <span class="text-3xl mb-1 drop-shadow-md group-hover:scale-110 transition-transform">🛡️</span>
                            <span class="text-[10px] font-bold text-gray-700 mt-1 item-title">Perisai</span>
                            <span class="text-[10px] font-black text-amber-500 mt-1 item-price">75 Poin</span>
                        </button>
                        <button id="btn-shop-item_extra_life" onclick="handleShopClick('item_extra_life')" class="h-24 bg-gray-50 rounded-2xl border border-gray-100 flex flex-col items-center justify-center hover:bg-pink-50 active:scale-95 transition-all group relative">
                            <span class="text-3xl mb-1 drop-shadow-md group-hover:scale-110 transition-transform">💖</span>
                            <span class="text-[10px] font-bold text-gray-700 mt-1 item-title">Extra Life</span>
                            <span class="text-[10px] font-black text-amber-500 mt-1 item-price">150 Poin</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div id="previewBanner" class="hidden w-full bg-amber-500 text-white text-[10px] font-black py-3 uppercase tracking-widest z-[150] shadow-md px-6 flex items-center justify-center transition-all duration-500 relative">
            <div class="flex items-center gap-2">
                <i class="fa-solid fa-eye animate-pulse"></i> Mode Simulasi Ustadz
            </div>
            <button id="bannerExitBtn" onclick="exitPreview()" class="hidden absolute right-6 bg-black/20 hover:bg-black/40 px-3 py-1.5 rounded-lg transition-colors font-bold text-white cursor-pointer active:scale-95">Keluar</button>
        </div>

        <div class="w-full h-1.5 bg-gray-100 z-50 relative">
            <div id="progressBar" class="h-full bg-green-500 w-0 transition-all duration-500 ease-out rounded-r-full shadow-[0_0_10px_rgba(34,197,94,0.5)]"></div>
        </div>

        <div id="vigLeft"   style="pointer-events:none;position:fixed;top:0;left:0;width:60px;height:100vh;z-index:9999;background:linear-gradient(to right,rgba(239,68,68,0),rgba(239,68,68,0));transition:background 0.4s ease;"></div>
        <div id="vigRight"  style="pointer-events:none;position:fixed;top:0;right:0;width:60px;height:100vh;z-index:9999;background:linear-gradient(to left,rgba(239,68,68,0),rgba(239,68,68,0));transition:background 0.4s ease;"></div>
        <div id="vigTop"    style="pointer-events:none;position:fixed;top:0;left:0;width:100vw;height:60px;z-index:9999;background:linear-gradient(to bottom,rgba(239,68,68,0),rgba(239,68,68,0));transition:background 0.4s ease;"></div>
        <div id="vigBottom" style="pointer-events:none;position:fixed;bottom:0;left:0;width:100vw;height:60px;z-index:9999;background:linear-gradient(to top,rgba(239,68,68,0),rgba(239,68,68,0));transition:background 0.4s ease;"></div>
        
        <div id="shieldVignette" class="fixed inset-0 pointer-events-none z-[110] transition-all duration-1000 opacity-0" style="box-shadow: inset 0 0 120px rgba(59, 130, 246, 0.5); border: 6px solid rgba(59, 130, 246, 0.4);"></div>

        <main class="flex-1 relative overflow-y-auto px-6 py-8 pb-32">
            
            <div id="startOverlay" class="absolute inset-0 bg-white z-[120] flex flex-col items-center justify-center p-8 text-center transition-all duration-500">
                <div class="w-24 h-24 bg-green-50 text-green-600 rounded-[2rem] flex items-center justify-center text-4xl mb-6 shadow-inner border border-green-100">
                    <i class="fa-solid fa-stopwatch"></i>
                </div>
                <h1 class="text-2xl font-bold text-gray-800 mb-2">Siap Mengerjakan?</h1>
                <p id="startDescText" class="text-sm text-gray-400 mb-8 leading-relaxed">Pastikan fokus. Waktu terbatas untuk bagian akademik.</p>
                <button id="btnStart" class="w-full max-w-xs py-4 bg-green-600 text-white font-bold rounded-2xl shadow-lg shadow-green-600/20 active:scale-95 transition-all text-lg">
                    Mulai Sekarang
                </button>
            </div>

            <div id="countdownOverlay" class="hidden fixed inset-0 bg-green-600 z-[9999] flex items-center justify-center">
                <span id="countdownText" class="text-[10rem] font-black text-white italic animate-ping">3</span>
            </div>

            <div id="testContent" class="hidden space-y-8 max-w-md mx-auto mt-4">
                
                <section id="academicSection" class="space-y-4">
                    <div class="flex items-center gap-2 mb-2">
                        <span class="w-6 h-6 bg-red-600 text-white rounded-full flex items-center justify-center text-[10px] font-bold">1</span>
                        <h3 class="font-bold text-gray-800">Soal Akademik</h3>
                    </div>
                    
                    <div id="questionsList" class="space-y-6"></div>

                    <button id="btnEarlyFinish" class="w-full mt-4 py-3 bg-red-50 text-red-600 font-bold rounded-xl border border-red-100 active:scale-95 transition-all text-xs">
                        <i class="fa-solid fa-stopwatch mr-1"></i> Selesaikan Akademik Sekarang
                    </button>
                </section>

                <hr class="border-dashed border-gray-200">

                <section id="consultationSection" class="space-y-6">
                    <div class="flex items-center gap-2 mb-4">
                        <span class="w-6 h-6 bg-blue-600 text-white rounded-full flex items-center justify-center text-[10px] font-bold">2</span>
                        <h3 class="font-bold text-gray-800">Pojok Curhat</h3>
                    </div>
                    
                    <div class="bg-blue-50 p-5 rounded-3xl border border-blue-100 space-y-4 shadow-sm">
                        <div id="kuesionerContainer" class="space-y-4 mb-4"></div>
                        <div>
                            <label class="block text-[10px] font-bold text-blue-400 uppercase tracking-widest mb-2 ml-1">FOTO RAPORT (Bisa Nanti)</label>
                            <button type="button" onclick="openCameraModal()" id="btnOpenCamera" class="w-full h-32 border-2 border-dashed border-blue-300 rounded-2xl bg-white/50 flex flex-col items-center justify-center hover:bg-blue-100 transition-colors active:scale-95">
                                <div id="cameraIconBox">
                                    <i class="fa-solid fa-camera-retro text-3xl text-blue-400 mb-2 drop-shadow-sm"></i>
                                    <span class="block text-[10px] font-bold text-blue-500 bg-blue-100 px-3 py-1 rounded-full uppercase tracking-wider">Buka Kamera</span>
                                </div>
                                <img id="selfiePreview" class="hidden w-full h-full object-cover rounded-xl" />
                            </button>
                        </div>
                    </div>
                </section>

                <button id="btnSubmit" disabled class="w-full py-5 bg-gray-200 text-gray-400 font-bold rounded-2xl cursor-not-allowed transition-all text-lg shadow-sm mb-12">
                    Kirim Semua Jawaban
                </button>
            </div>
        </main>
    </div>

    <div id="modalEarlyFinish" class="fixed inset-0 bg-black/70 z-[400] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-sm rounded-3xl p-6 shadow-2xl text-center">
            <div class="w-16 h-16 bg-amber-50 text-amber-500 rounded-full flex items-center justify-center text-3xl mx-auto mb-4 border border-amber-100">
                <i class="fa-solid fa-stopwatch"></i>
            </div>
            <h3 class="font-bold text-gray-800 text-lg mb-2">Selesai Lebih Awal?</h3>
            <p class="text-sm text-gray-500 mb-6 leading-relaxed">Yakin ingin mengunci bagian akademik sekarang? Sisa waktu Anda akan dihanguskan.</p>
            <div class="flex gap-3">
                <button onclick="closeEarlyFinishModal()" class="flex-1 py-3.5 bg-gray-100 text-gray-500 font-bold rounded-2xl active:scale-95 transition-all">Batal</button>
                <button onclick="confirmEarlyFinish()" class="flex-1 py-3.5 bg-amber-500 text-white font-bold rounded-2xl shadow-lg shadow-amber-500/30 active:scale-95 transition-all">Ya, Kunci</button>
            </div>
        </div>
    </div>

    <div id="modalNetwork" class="fixed inset-0 bg-black/70 z-[400] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-sm rounded-3xl p-6 shadow-2xl text-center">
            <div class="w-16 h-16 bg-red-50 text-red-500 rounded-full flex items-center justify-center text-3xl mx-auto mb-4 border border-red-100">
                <i class="fa-solid fa-wifi"></i>
            </div>
            <h3 class="font-bold text-gray-800 text-lg mb-2">Jaringan Lambat</h3>
            <p class="text-sm text-gray-500 mb-4 leading-relaxed">Sepertinya jaringan anda sedang lambat, silahkan angkat HP anda sejajar dengan wajah (seperti gambar) agar sinyal lebih kuat.</p>
            <img src="/images/image_tutor.png" alt="Instruksi Sinyal" class="w-50 h-32 mx-auto mb-6 object-cover rounded-2xl border-2 border-dashed border-gray-200 bg-gray-50">
            <button id="btnRetryNetwork" disabled class="w-full py-4 bg-gray-200 text-gray-400 font-bold rounded-2xl cursor-not-allowed transition-all">Tunggu (3)</button>
        </div>
    </div>

    <div id="modalBuyItem" class="fixed inset-0 bg-black/60 z-[400] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-sm rounded-[2rem] p-6 shadow-2xl text-center">
            <div id="buyItemIcon" class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center text-4xl mx-auto mb-4 border border-gray-100 shadow-inner">❓</div>
            <h3 id="buyItemName" class="font-black text-gray-800 text-xl mb-1">Nama Item</h3>
            <p id="buyItemPrice" class="text-amber-500 font-bold text-sm mb-4">💰 0 Poin</p>
            <div class="bg-gray-50 p-4 rounded-2xl border border-gray-100 mb-6 flex justify-center items-center">
                <p id="buyItemDesc" class="text-xs text-gray-600 leading-relaxed font-medium text-center">Deskripsi item akan muncul di sini.</p>
            </div>
            <div class="flex gap-3">
                <button onclick="closeBuyModal()" class="flex-1 py-3.5 bg-gray-100 text-gray-500 font-bold rounded-2xl active:scale-95 transition-all text-sm">Batal</button>
                <button id="btnConfirmBuy" onclick="executeBuyItem()" class="flex-1 py-3.5 bg-indigo-600 text-white font-bold rounded-2xl shadow-lg shadow-indigo-600/30 active:scale-95 transition-all text-sm">Beli Sekarang</button>
            </div>
        </div>
    </div>

    <div id="modalAttack" class="fixed inset-0 bg-black/60 z-[400] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-sm rounded-[2rem] p-6 shadow-2xl flex flex-col max-h-[80vh]">
            <div class="text-center mb-4">
                <div class="w-16 h-16 bg-red-50 text-red-500 rounded-full flex items-center justify-center text-3xl mx-auto mb-2 border border-red-100 shadow-inner">⚔️</div>
                <h3 class="font-black text-gray-800 text-xl">Serang Teman</h3>
                <p class="text-[10px] text-gray-500 font-medium mt-1">Pilih 1 teman untuk dicuri poinnya (Maks. 50 Poin)</p>
            </div>
            <div id="attackTargetList" class="flex-1 overflow-y-auto space-y-2 pr-1 mb-4"></div>
            <button onclick="document.getElementById('modalAttack').classList.replace('flex', 'hidden')" class="w-full py-3.5 bg-gray-100 text-gray-500 font-bold rounded-2xl active:scale-95 transition-all text-sm">Batal</button>
        </div>
    </div>

    <div id="modalVictim" class="fixed inset-0 bg-red-900/60 z-[450] hidden items-center justify-center p-4 backdrop-blur-md transition-opacity">
        <div class="bg-white w-full max-w-sm rounded-[2rem] p-6 shadow-2xl text-center border-4 border-red-500 transform scale-100 animate-bounce-short">
            <div class="w-24 h-24 bg-red-100 text-red-600 rounded-full flex items-center justify-center text-5xl mx-auto mb-4 border border-red-200 shadow-inner">😱</div>
            <h3 class="font-black text-red-600 text-2xl mb-1 uppercase tracking-widest">GAWAT!</h3>
            <p class="text-gray-700 text-sm font-bold mb-4">Anda telah diserang oleh <br><span id="victimAttackerName" class="text-red-500 text-xl font-black">---</span></p>
            <div class="bg-red-50 p-4 rounded-2xl border border-red-100 mb-6">
                <p class="text-xs text-red-800 font-bold">Sebanyak <span id="victimPointsLost" class="text-red-600 text-lg mx-1">0</span> poin Anda berhasil dicuri!</p>
                <p class="text-[10px] text-red-500 mt-2 italic">Saran: Lain kali beli item 🛡️ Perisai sebelum mulai ngerjain agar poinmu aman.</p>
            </div>
            <button onclick="window.closeVictimModal()" class="w-full py-3.5 bg-red-600 text-white font-black uppercase tracking-widest rounded-2xl shadow-lg shadow-red-600/30 active:scale-95 transition-all text-sm">Saya Mengerti</button>
        </div>
    </div>

    <div id="modalOfferExtraLife" class="fixed inset-0 bg-black/80 z-[500] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-sm rounded-[2rem] p-6 shadow-2xl text-center border-4 border-pink-400">
            <div class="w-20 h-20 bg-pink-50 text-pink-500 rounded-full flex items-center justify-center text-4xl mx-auto mb-4 border border-pink-100 shadow-inner">💖</div>
            <h3 class="font-black text-gray-800 text-xl mb-1">Tunggu Dulu!</h3>
            <p class="text-sm text-gray-600 mb-4">Kamu memiliki <span id="elWrongCount" class="font-black text-red-500 text-xl">0</span> jawaban yang salah.</p>
            <div class="bg-pink-50 p-4 rounded-2xl border border-pink-100 mb-6">
                <p class="text-xs text-pink-700 font-bold leading-relaxed">Gunakan Extra Life untuk membuka gembok dan memperbaiki 1 jawabanmu sebelum dikirim permanen!</p>
            </div>
            <div class="flex gap-3">
                <button onclick="declineExtraLife()" class="flex-1 py-3.5 bg-gray-100 text-gray-500 font-bold rounded-2xl active:scale-95 transition-all text-sm">Tidak, Kirim Saja</button>
                <button onclick="acceptExtraLife()" class="flex-1 py-3.5 bg-pink-500 text-white font-black rounded-2xl shadow-lg shadow-pink-500/30 active:scale-95 transition-all text-sm">Ya, Gunakan 💖</button>
            </div>
        </div>
    </div>

    <div id="modalWelcomeBonus" class="fixed inset-0 bg-black/60 z-[700] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-sm rounded-[2rem] p-6 shadow-2xl text-center border-4 border-amber-400 transform scale-100 animate-bounce-short">
            <div class="w-20 h-20 bg-amber-50 text-amber-500 rounded-full flex items-center justify-center text-4xl mx-auto mb-4 border border-amber-100 shadow-inner">🎁</div>
            <h3 class="font-black text-gray-800 text-2xl mb-1">Kejutan Spesial!</h3>
            <p class="text-sm text-gray-600 mb-6 leading-relaxed">Mumpung Kak Aziz lagi baik, kamu dikasih <span class="font-black text-amber-500 text-lg">50 Poin</span> pertama secara GRATIS buat modal belanja!</p>
            
            <div class="flex gap-3">
                <button onclick="declineBonus()" class="flex-1 py-3.5 bg-gray-100 text-gray-500 font-bold rounded-2xl active:scale-95 transition-all text-xs uppercase tracking-wider">Abaikan<br>(Gak Butuh)</button>
                <button id="btnAcceptBonus" onclick="acceptBonus()" class="flex-1 py-3.5 bg-amber-500 text-white font-black rounded-2xl shadow-lg shadow-amber-500/30 active:scale-95 transition-all text-sm">Ambil Poinnya!</button>
            </div>
        </div>
    </div>

    <div id="modalResult" class="fixed inset-0 bg-black/90 z-[500] hidden items-center justify-center p-4 backdrop-blur-md overflow-y-auto">
        
        <div id="meme67ResultView" class="hidden w-full max-w-xs aspect-[9/16] rounded-[2rem] shadow-2xl relative overflow-hidden animate-slide-up border-4 border-gray-900 bg-black my-auto mx-auto">
            
            <video id="meme67Video" src="/video/cat-67.mp4" preload="auto" playsinline loop muted class="absolute inset-0 w-full h-full object-cover"></video>
            
            <div class="absolute bottom-0 inset-x-0 p-6 pt-16 flex flex-col justify-end bg-gradient-to-t from-white via-white/95 to-transparent text-center">
                
                <div class="text-5xl mb-3 relative z-10 animate-bounce">🔥</div>
                <h3 class="font-black text-gray-950 text-2xl mb-1 uppercase tracking-widest relative z-10">SIX SEVEN!!</h3>
                <p class="text-[10px] font-bold text-purple-800 mb-5 leading-relaxed relative z-10 px-2">Wah! Nilai kamu pas banget 67! Dapet salam perayaan dari MIAW!</p>
                
                <div class="text-6xl font-black text-purple-600 mb-6 drop-shadow-sm animate-pulse relative z-10">67</div>

                <button onclick="window.location.replace('/consultations')" class="w-full py-4 bg-gray-950 text-white font-bold rounded-2xl text-xs active:scale-95 transition-all relative z-10 uppercase tracking-widest">
                    Tutup & Kembali
                </button>
            </div>
        </div>

        <div id="normalResultView" class="flex flex-col bg-white w-full max-w-sm rounded-[2rem] p-7 text-center animate-slide-up my-auto mx-auto relative overflow-hidden">
            <div id="resultEmoji" class="text-5xl mb-2 animate-bounce">🏆</div>
            <h3 id="resultTitle" class="font-black text-gray-800 text-xl mb-1">Luar Biasa!</h3>
            <p id="resultMessage" class="text-[10px] text-gray-400 font-bold mb-5 leading-relaxed">Alhamdulillah, nilaimu sangat bagus!</p>
            
            <div class="bg-gray-50 rounded-3xl p-4 mb-6 border border-gray-100 shadow-inner relative z-10">
                <p class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-1">Nilai Akhir</p>
                <div id="resultScore" class="text-5xl font-black text-green-600 leading-none">100</div>
                <div id="resultBonus" class="hidden text-[9px] font-black text-indigo-500 mt-2 bg-indigo-50 inline-block px-3 py-1 rounded-full border border-indigo-100">
                    +0 (Double Poin) ✨
                </div>
                
                <div class="grid grid-cols-2 gap-2 border-t border-gray-200 mt-4 pt-4 relative z-10">
                    <div>
                        <p class="text-[8px] font-black text-gray-400 uppercase">Waktu</p>
                        <p id="resultTime" class="text-xs font-black text-gray-700">--:--</p>
                    </div>
                    <div>
                        <p class="text-[8px] font-black text-gray-400 uppercase">Karakter</p>
                        <p id="resultSocial" class="text-xs font-black text-gray-700">Baik</p>
                    </div>
                </div>
            </div>
            
            <button onclick="window.location.replace('/consultations')" class="w-full py-3.5 bg-gray-800 text-white font-bold rounded-2xl text-xs active:scale-95 transition-all uppercase tracking-widest">
                Tutup & Kembali
            </button>
        </div>

    </div>

    <Mascot />
    <PhotoBooth />
    <div class="relative z-[99999]">
        <Toast />
    </div>
</Layout>

<style>
    @keyframes bounce-short {
        0%, 100% { transform: translateY(0) scale(1); }
        50% { transform: translateY(-10px) scale(1.02); }
    }
    .animate-bounce-short { animation: bounce-short 0.5s ease-in-out 1; }

</style>

<style is:global>
    .toast-container, [id^="toast"] {
        z-index: 99999 !important;
    }
</style>
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js" is:inline></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js" is:inline></script>

<script>
    // 1. HAPUS TOTAL TOMBOL MASCOT DARI DOM (Agar tidak jadi elemen gaib)
    const mascotBtn = document.getElementById('btnToggleCat');
    if (mascotBtn) mascotBtn.remove();

    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const token = localStorage.getItem('token');
    if (!token) window.location.replace('/');

    const urlParams = new URLSearchParams(window.location.search);
    const studentId = urlParams.get('id');
    const subject = urlParams.get('subject');
    const week = urlParams.get('week');
    const isPreview = urlParams.get('preview') === 'true'; 

    const parsedWeek = parseInt(week) || 1;
    let timeLeft = parsedWeek === 1 ? 105 : 180; // 1 menit 45 detik untuk pekan 1, 3 menit untuk pekan lain
    let finalTimeTaken = 0;
    
    const timeKey = `timer_${studentId}_${subject}_${week}`;
    const ansKey = `ans_${studentId}_${subject}_${week}`;
    const qKey = `qs_${studentId}_${subject}_${week}`;
    const psychKey = `psych_${studentId}_${subject}_${week}`;

    const shuffleArray = (array) => {
        const arr = [...array];
        for (let i = arr.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [arr[i], arr[j]] = [arr[j], arr[i]];
        }
        return arr;
    };

    let timerInterval = null;
    let questions = [];
    let selfieFileToUpload = null;
    let currentStudentName = "Si Anak";
    let hasPriorPhoto = false;
    let isDirty = false;

    // ==========================================
    // STATE GAMIFIKASI & SHOP (HARGA RESET NORMAL)
    // ==========================================
    let studentWallet = 0;
    let studentInventory = {};
    let selectedItemToBuy = null;
    let boughtItemsThisSession = { item_double_score: false, item_serang: false, item_perisai: false, item_extra_life: false };
    
    window.isDoubleScoreActive = false;
    window.isShieldActive = false;
    let isEvaluatingExtraLife = false;
    let wrongQuestionsGlobal = [];
    let isQuizStarted = false;

    // Database Harga (Statis, tanpa inflasi)
    const ITEM_DB = {
        item_double_score: { name: "Double Poin", price: 50, icon: "✨", desc: "Sihir rahasia untuk mendongkrak nilaimu di akhir ujian! Semakin kecil nilaimu, semakin besar tambahan poin yang akan kamu dapatkan." },
        item_serang: { name: "Serang Teman", price: 100, icon: "⚔️", desc: "Jailin temanmu dengan mencuri poin dari saldo dompet mereka! Teman yang pakai perisai tidak bisa diserang." },
        item_perisai: { name: "Perisai", price: 75, icon: "🛡️", desc: "Gunakan pelindung ajaib ini agar poinmu aman dari pencurian teman-temanmu. Otomatis aktif setelah dibeli!" },
        item_extra_life: { name: "Extra Life", price: 150, icon: "💖", desc: "Kesempatan kedua bagaikan mukjizat! Memungkinkanmu memperbaiki satu jawaban salah. Aktif otomatis setelah dibeli!" }
    };
    
    // Fungsi Toggle Tombol Shop & Ganti Icon
    window.toggleShopPanel = () => {
        document.getElementById('shopPanel').classList.toggle('-translate-x-[calc(100%-3.5rem)]');
        const icon = document.getElementById('shopToggleIcon');
        icon.style.transform = 'scale(0) rotate(180deg)';
        setTimeout(() => {
            icon.classList.contains('fa-cart-shopping') ? icon.classList.replace('fa-cart-shopping', 'fa-xmark') : icon.classList.replace('fa-xmark', 'fa-cart-shopping');
            icon.style.transform = 'scale(1) rotate(0deg)';
        }, 150);
    };

    window.toggleShopDrawer = () => {
        const inner = document.getElementById('shopDrawerInner');
        const icon = document.getElementById('shopDrawerIcon');
        const btn = document.getElementById('btnToggleDrawer');

        if (inner.classList.contains('translate-y-[calc(100%-40px)]')) {
            inner.classList.replace('translate-y-[calc(100%-40px)]', 'translate-y-0');
            icon.classList.replace('fa-store', 'fa-chevron-down');
            btn.classList.replace('h-[40px]', 'h-[48px]');
            btn.classList.add('bg-indigo-800');

            const hasClaimed = localStorage.getItem(`bonus_claimed_${studentId}`);
            if (!hasClaimed) {
                setTimeout(() => { document.getElementById('modalWelcomeBonus').classList.replace('hidden', 'flex'); }, 300);
            }
        } else {
            inner.classList.replace('translate-y-0', 'translate-y-[calc(100%-40px)]');
            icon.classList.replace('fa-chevron-down', 'fa-store');
            btn.classList.replace('h-[48px]', 'h-[40px]');
            btn.classList.remove('bg-indigo-800');
        }
    };

    // --- LOGIKA KLAIM BONUS WELCOME ---
    window.declineBonus = () => {
        localStorage.setItem(`bonus_claimed_${studentId}`, 'true');
        document.getElementById('modalWelcomeBonus').classList.replace('flex', 'hidden');
    };
    
    window.acceptBonus = async () => {
        const btn = document.getElementById('btnAcceptBonus');
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>'; btn.disabled = true;

        try {
            if (isPreview) {
                await new Promise(r => setTimeout(r, 600));
                studentWallet += 50;
                localStorage.setItem(`bonus_claimed_${studentId}`, 'true');
                updateShopUI();
                document.getElementById('modalWelcomeBonus').classList.replace('flex', 'hidden');
                window.showToast?.('success', 'Bonus Cair!', '50 Poin gratis berhasil ditambahkan ke dompetmu.');
                return;
            }

            const res = await fetch(`${API_URL}/api/shop/claim-bonus`, {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify({ student_id: studentId })
            });

            const data = await res.json();
            if (data.status === 'success') {
                studentWallet = data.data.poin;
                localStorage.setItem(`bonus_claimed_${studentId}`, 'true');
                updateShopUI();
                document.getElementById('modalWelcomeBonus').classList.replace('flex', 'hidden');
                window.showToast?.('success', 'Bonus Cair!', '50 Poin gratis berhasil ditambahkan ke dompetmu.');
            } else throw new Error(data.message);
        } catch (error) {
            window.showToast?.('danger', 'Gagal', error.message);
            btn.innerText = 'Ambil Poinnya!'; btn.disabled = false;
        }
    };

    window.toggleFloatingTimer = () => {
        const container = document.getElementById('timerTextContainer');
        if (container.classList.contains('w-[50px]')) {
            container.classList.replace('w-[50px]', 'w-0');
            container.classList.add('opacity-0', '-ml-1');
        } else {
            container.classList.replace('w-0', 'w-[50px]');
            container.classList.remove('opacity-0', '-ml-1');
        }
    };

    window.toggleFloatingItems = () => {
        const container = document.getElementById('itemsTextContainer');
        const icon = document.getElementById('floatItemsIcon');
        if (container.classList.contains('max-w-0')) {
            container.classList.replace('max-w-0', 'max-w-[120px]');
            container.classList.remove('opacity-0');
            container.classList.add('px-2', 'mr-1');
            icon.classList.add('scale-110', 'text-indigo-600');
        } else {
            container.classList.replace('max-w-[120px]', 'max-w-0');
            container.classList.add('opacity-0');
            container.classList.remove('px-2', 'mr-1');
            icon.classList.remove('scale-110', 'text-indigo-600');
        }
    };

    window.exitPreview = () => { window.location.href = '/bank-soal'; };
    window.handleBack = () => {
        if (isDirty) {
            if(confirm("Anda memiliki data yang belum dikirim. Yakin ingin keluar?")) {
                if (isPreview) exitPreview();
                else window.location.href = '/consultations';
            }
        } else {
            if (isPreview) exitPreview();
            else window.location.href = '/consultations';
        }
    };

    window.openCameraModal = () => {
        window.openPhotoBooth(currentStudentName, week, (capturedFile) => {
            selfieFileToUpload = capturedFile; 
            const previewImg = document.getElementById('selfiePreview');
            const iconBox = document.getElementById('cameraIconBox');
            previewImg.src = URL.createObjectURL(capturedFile);
            previewImg.classList.remove('hidden');
            iconBox.classList.add('hidden');
        });
    };

    // ==========================================
    // 1. KUESIONER SOSIAL
    // ==========================================
    const questionBank = {
        akhlak: [
            { q: "Pas Kak Aziz lagi nerangin, apa yang kamu lakuin tadi?", opts: [{t: "Merhatiin Kok!", s: 100}, {t: "gak terlalu ( Bosen soalnya )", s: 50}, {t: "gak tau ah!", s: 0}] },
            { q: "Jujur, kadang kamu suka lupa salim ke guru gak pas datang?", opts: [{t: "Selalu salim ke semua nya", s: 100}, {t: "Ke pa Idris doang", s: 50}, {t: "Sering lupa", s: 0}] },
            { q: "Kalau kamu ditegur guru karena salah, perasaan kamu gimana?", opts: [{t: "Biasa aja", s: 100}, {t: "Agak bete", s: 50}, {t: "curhat ke temen pas udah pulang ngaji", s: 0}] }
        ],
        disiplin: [
            { q: "Misalkan kak Aziz nyuruh sesuatu, Apa yang kamu lakukan?", opts: [{t: "Gak mau ah", s: 0}, {t: "Mau, tapi...", s: 50}, {t: "Mau", s: 100}] },
            { q: "Habis ngaji, kamu langsung pulang atau bantu beresin meja?", opts: [{t: "Bantuin beresin", s: 100}, {t: "biasanya sih langsung pulang", s: 0}] },
            { q: "Kalau ada PR ngaji tapi kamu belum ngerjain, itu salah siapa?", opts: [{t: "Salahku sendiri", s: 100}, {t: "Salah temen gak ngingetin", s: 0}, {t:"salah kak Aziz bikin tugas susah banget", s:0}] }
        ],
        aktif: [
            { q: "Pas guru nanya ke kelas, kamu biasanya ngapain?", opts: [{t: "Langsung jawab dong!", s: 100}, {t: "Mau jawab tapi malu", s: 50}, {t: "Diem aja nunggu temen yang jawab", s: 0}] },
            { q: "Kalau ada temen yang sering nanya ke guru, menurutmu dia...", opts: [{t: "Hebat dan pintar", s: 100}, {t: "Caper banget", s: 0}, {t: "HEBAT BANGET!!! KEREN!", s: 20}] },
            { q: "Apa yang bikin kamu kadang gak mau nanya pelajaran?", opts: [{t: "Aku suka nanya kok", s: 100}, {t: "Takut salah / diketawain", s: 50}, {t: "Gak tau apa yang mau ditanya", s: 0}] }
        ]
    };

    let selectedQ = JSON.parse(localStorage.getItem(psychKey)) || [];
    if (selectedQ.length !== 3) {
        selectedQ = [
            { cat: 'akhlak', ...shuffleArray(questionBank.akhlak)[0] },
            { cat: 'disiplin', ...shuffleArray(questionBank.disiplin)[0] },
            { cat: 'aktif', ...shuffleArray(questionBank.aktif)[0] }
        ];
        selectedQ = selectedQ.map(q => ({ ...q, opts: shuffleArray(q.opts) }));
        localStorage.setItem(psychKey, JSON.stringify(selectedQ));
    }

    const container = document.getElementById('kuesionerContainer');
    container.innerHTML = selectedQ.map((item, index) => `
        <div class="bg-blue-50 p-4 rounded-2xl border border-blue-100 shadow-sm">
            <p class="text-sm font-bold text-gray-800 mb-3">${index + 1}. ${item.q}</p>
            <div class="space-y-2">
                ${item.opts.map((opt) => `
                    <label class="flex items-center gap-2 bg-white p-3 rounded-xl border border-gray-100 cursor-pointer hover:bg-gray-50 active:scale-95 transition-all">
                        <input type="radio" name="q_${item.cat}" value="${opt.s}" class="w-4 h-4 text-blue-600 focus:ring-blue-500" required>
                        <span class="text-xs font-semibold text-gray-700">${opt.t}</span>
                    </label>
                `).join('')}
            </div>
        </div>
    `).join('');

    // ==========================================
    // 2. FETCH DATA & RENDER AKADEMIK
    // ==========================================
    const init = async () => {
        try {
            let allQuestions = [];
            
            if (isPreview) {
                localStorage.removeItem(timeKey);
                localStorage.removeItem(ansKey);
                localStorage.removeItem(qKey);
                localStorage.removeItem(psychKey);

                document.getElementById('previewBanner').classList.remove('hidden');
                
                // [PERBAIKAN 1]: Set Nama & Inisial untuk Mode Preview
                document.getElementById('headerName').innerText = "Mode Simulasi";
                document.getElementById('headerInitials').innerText = "PR";
                document.getElementById('startDescText').innerText = "Mode Simulasi. Kamu bisa ngetes Shop & Hitung Mundur.";
                hasPriorPhoto = false;

                studentWallet = 500;
                studentInventory = { item_double_score: 0, item_serang: 0, item_perisai: 0, item_extra_life: 0 };
                const poinDisplay = document.getElementById('currentPoinDisplay');
                if(poinDisplay) poinDisplay.innerText = studentWallet;

                const qRes = await fetch(`${API_URL}/api/onboarding/questions/${subject}`, { headers: { 'Authorization': `Bearer ${token}` }});
                const qData = await qRes.json();
                if (qData.data && !Array.isArray(qData.data)) allQuestions = qData.data[week] || [];
                else allQuestions = qData.data || [];
            } else {
                document.getElementById('startDescText').innerText = `Pastikan fokus. Kamu punya waktu 1 menit 45 detik untuk mengerjakan 6 soal pilihan.`;
                const [stdRes, consRes, qRes] = await Promise.all([
                    fetch(`${API_URL}/api/students/${studentId}`, { headers: { 'Authorization': `Bearer ${token}` }}),
                    fetch(`${API_URL}/api/students/${studentId}/consultations`, { headers: { 'Authorization': `Bearer ${token}` }}),
                    fetch(`${API_URL}/api/onboarding/questions/${subject}?week=${week}&student_id=${studentId}`, { headers: { 'Authorization': `Bearer ${token}` }})
                ]);
                
                const student = await stdRes.json();
                const consData = await consRes.json();
                const qData = await qRes.json();
                currentStudentName = student.data.name?.split(' ')[0] || "Anak Baik";
                
                if (consData.data && consData.data.length > 0) hasPriorPhoto = consData.data.some(c => c.image_url && c.image_url.trim() !== '');
                else hasPriorPhoto = false;

                document.getElementById('headerName').innerText = student.data.name;
                document.getElementById('headerInitials').innerText = student.data.name?.substring(0,2).toUpperCase() || 'S';
                allQuestions = qData.data || [];

                if (student.data) {
                    // Sinkronisasi dengan kolom database yang baru ditambahkan
                    studentWallet = Number(student.data.poin) || 0; 
                    studentInventory = {
                        item_double_score: student.data.item_double_score || 0,
                        item_serang: student.data.item_serang || 0,
                        item_perisai: student.data.item_perisai || 0,
                        item_extra_life: student.data.item_extra_life || 0
                    };

                    // Update status bonus agar tidak muncul terus
                    if (student.data.has_claimed_bonus) {
                        localStorage.setItem(`bonus_claimed_${studentId}`, 'true');
                    }
                    
                    document.getElementById('currentPoinDisplay').innerText = studentWallet;
                }
            }

            const targetDisplay = 6;
            if (isPreview) {
                questions = shuffleArray(allQuestions).slice(0, Math.min(targetDisplay, allQuestions.length));
            } else {
                let savedQsIds = JSON.parse(localStorage.getItem(qKey)) || [];
                questions = savedQsIds.map(id => allQuestions.find(q => q.id === id)).filter(Boolean);
                if (questions.length === 0 && allQuestions.length > 0) {
                    questions = shuffleArray(allQuestions).slice(0, Math.min(targetDisplay, allQuestions.length));
                    localStorage.setItem(qKey, JSON.stringify(questions.map(q => q.id)));
                }
            }

            if (window.MiawMascot) {
                await window.MiawMascot.init({
                    mode: 'peek',
                    animations: {
                        PEEK_IN: { path: '/CAT LOTTIE/SHOWING CAT.json', loop: false, speed: 1.0, lottieDuration: 3000, data: null },
                        PEEK_IDLE: { path: '/CAT LOTTIE/IDDLE SHOW.json', loop: true, speed: 1.0, lottieDuration: 5000, data: null },
                        PEEK_OUT: { path: '/CAT LOTTIE/BACK TO HIDDEN.json', loop: false, speed: 1.0, lottieDuration: 3000, data: null }
                    },
                    texts: {
                        entering: () => `Haloo <strong>${currentStudentName}</strong>! Aku temenin ngerjain soal ya miaw~`,
                        idleArrive: () => `Semangat ngerjainnya <strong>${currentStudentName}</strong>, jangan buru-buru!`,
                        idlePhrases: [
                            // KEPINTARAN 1: Tahu Item yang Dipakai
                            () => {
                                let items = [];
                                if (window.isShieldActive) items.push("Perisai 🛡️");
                                if (window.isDoubleScoreActive) items.push("Double Poin ✨");
                                if (studentInventory.item_extra_life > 0) items.push("Extra Life 💖");
                                if (items.length > 0) return `Ciee <strong>${currentStudentName}</strong> lagi pakai item <strong>${items.join(', ')}</strong> nih... Pasti dapet nilai bagus!`;
                                return `Jangan tegang ya <strong>${currentStudentName}</strong> miaw~`;
                            },
                            // KEPINTARAN 2: Tahu Jawaban Murid & Meragukannya (Komedian)
                            () => {
                                const answeredBlocks = Array.from(document.querySelectorAll('.question-block')).filter(b => {
                                    const type = b.dataset.type || 'pilgan';
                                    if (type === 'drag') return document.getElementById(`ans-${b.dataset.id}`)?.value !== '';
                                    else if (type === 'urutan') return JSON.parse(document.getElementById(`ans-${b.dataset.id}`)?.value || '[]').length > 0;
                                    else return b.querySelector(`input:checked`) !== null;
                                });
                                if (answeredBlocks.length > 0) {
                                    const randomBlock = answeredBlocks[Math.floor(Math.random() * answeredBlocks.length)];
                                    const qIndex = Array.from(document.querySelectorAll('.question-block')).indexOf(randomBlock) + 1;
                                    let ansText = "itu";
                                    const type = randomBlock.dataset.type || 'pilgan';
                                    
                                    if (type === 'pilgan') {
                                        const checked = randomBlock.querySelector(`input:checked`);
                                        if (checked) {
                                            let text = checked.nextElementSibling.innerText.trim();
                                            ansText = text.length > 15 ? text.substring(0, 15) + '...' : text;
                                        }
                                    } else if (type === 'tf') {
                                        const checked = randomBlock.querySelector(`input:checked`);
                                        if (checked) ansText = checked.value === 'A' ? 'BENAR' : 'SALAH';
                                    } else if (type === 'urutan') {
                                        ansText = "urutan itu";
                                    }
                                    return `Hah, masa nomer <strong>${qIndex}</strong> jawabannya <strong>${ansText}</strong>? Coba cek lagi deh <strong>${currentStudentName}</strong>...`;
                                }
                                return `Udah sampai mana nih ngisinya? Jangan lupa teliti ya <strong>${currentStudentName}</strong>.`;
                            },
                            // KEPINTARAN 3: Tahu Sisa Waktu
                            () => {
                                const timeStr = isPreview ? "tak terbatas" : `${Math.floor(Math.max(0, timeLeft) / 60)} menit ${Math.max(0, timeLeft) % 60} detik`;
                                return `Miaw... pelan-pelan aja isinya <strong>${currentStudentName}</strong>, masih ada waktu <strong>${timeStr}</strong> kok.`;
                            }
                        ],
                        warnings: [ () => `Miaw... kok aku dicuekin terus sih <strong>${currentStudentName}</strong>?` ],
                        dismissNormal: () => `Yaudah deh <strong>${currentStudentName}</strong>.. Aku ngumpet dulu Miaw~`,
                        callNormalArrive: () => `Bosan ih.. aku temenin kamu lagi ya <strong>${currentStudentName}</strong>`
                    }
                });
            }

            renderQuestions();
            restoreDraftAnswers();
            updateTimerUI(); 
            checkExistingSession();
            updateShopUI();
            if (!isPreview) checkRealNotifications();
        } catch (e) {
            console.error(e);
            window.showToast?.('danger', 'Error', 'Gagal memuat ujian.');
        }
    };
    // --- RENDERER TIPE SOAL ---
    const renderQuestions = () => {
        const listContainer = document.getElementById('questionsList');
        if (questions.length === 0) {
            listContainer.innerHTML = '<p class="text-xs text-gray-400 italic bg-gray-50 p-4 rounded-xl text-center border border-gray-100">Belum ada soal untuk pertemuan ini.</p>';
            document.getElementById('btnEarlyFinish').classList.add('hidden');
            return;
        }

        listContainer.innerHTML = questions.map((q, idx) => {
            const type = q.type || 'pilgan';
            if (type === 'drag') return renderDragDropQuestion(q, idx);
            if (type === 'tf') return renderTrueFalseQuestion(q, idx);
            if (type === 'urutan') return renderUrutanQuestion(q, idx); 
            return renderPilganQuestion(q, idx);
        }).join('');

        initSortables();
    };

    const generateMediaHtml = (q) => {
        if (!q.image_url) return '';
        return `
            <div class="relative rounded-2xl overflow-hidden border border-gray-100 shadow-sm bg-gray-100 flex items-center justify-center min-h-[80px]">
                <div class="img-skeleton absolute inset-0 bg-gray-100 animate-pulse flex items-center justify-center">
                    <i class="fa-solid fa-image text-gray-300 text-2xl"></i>
                </div>
                <img src="${q.image_url.trim()}"
                     class="relative w-full h-auto max-h-56 object-contain mx-auto opacity-0 transition-opacity duration-300"
                     alt="Visual Soal"
                     onload="this.classList.replace('opacity-0','opacity-100');this.previousElementSibling.style.display='none';"
                     onerror="this.closest('.relative').style.display='none'">
            </div>
        `;
    };

    const renderPilganQuestion = (q, idx) => {
        const shuffledOptions = shuffleArray(Object.entries(q.options));
        return `
        <div class="bg-white p-5 rounded-3xl border border-gray-100 shadow-sm space-y-4 question-block" data-id="${q.id}" data-type="pilgan">
            <p class="text-sm font-bold text-gray-800 leading-relaxed">${idx+1}. ${q.question}</p>
            ${generateMediaHtml(q)}
            <div class="grid grid-cols-1 gap-2">
                ${shuffledOptions.map(([key, val]) => `
                    <label class="flex items-center gap-3 p-3 rounded-xl border border-gray-50 bg-gray-50 active:bg-green-50 transition-colors cursor-pointer has-[:checked]:bg-green-50 has-[:checked]:border-green-300">
                        <input type="radio" name="q-${q.id}" value="${key}" class="w-4 h-4 text-green-600 focus:ring-0">
                        <span class="text-xs text-gray-600 font-medium">${val}</span>
                    </label>
                `).join('')}
            </div>
        </div>`;
    };

    const renderTrueFalseQuestion = (q, idx) => {
        return `
        <div class="bg-white p-5 rounded-3xl border border-gray-100 shadow-sm space-y-4 question-block" data-id="${q.id}" data-type="tf">
            <p class="text-sm font-bold text-gray-800 leading-relaxed text-center mb-2">${idx+1}. ${q.question}</p>
            ${generateMediaHtml(q)}
            <div class="grid grid-cols-2 gap-3">
                <label class="flex flex-col items-center justify-center p-4 rounded-2xl border-2 border-gray-100 cursor-pointer has-[:checked]:bg-green-50 has-[:checked]:border-green-400 transition-all hover:bg-gray-50">
                    <input type="radio" name="q-${q.id}" value="A" class="hidden">
                    <i class="fa-solid fa-check text-4xl text-green-500 mb-2 drop-shadow-sm"></i>
                    <span class="font-black text-gray-700 tracking-widest uppercase">BENAR</span>
                </label>
                <label class="flex flex-col items-center justify-center p-4 rounded-2xl border-2 border-gray-100 cursor-pointer has-[:checked]:bg-red-50 has-[:checked]:border-red-400 transition-all hover:bg-gray-50">
                    <input type="radio" name="q-${q.id}" value="B" class="hidden">
                    <i class="fa-solid fa-xmark text-4xl text-red-500 mb-2 drop-shadow-sm"></i>
                    <span class="font-black text-gray-700 tracking-widest uppercase">SALAH</span>
                </label>
            </div>
        </div>`;
    };

    const renderDragDropQuestion = (q, idx) => {
        let blankIdx = 0;
        const questionHtml = (q.question || '').replace(/\[BLANK\]/g, () => {
            const html = `<span class="blank-slot inline-block min-w-[70px] h-8 border-b-2 border-dashed border-indigo-400 bg-indigo-50 mx-1 text-center font-black text-indigo-700 align-middle cursor-pointer text-xs leading-8 shadow-inner px-2 rounded-t-lg transition-colors hover:bg-indigo-100" data-q="${q.id}" data-index="${blankIdx}" onclick="removeBlank(this)"></span>`;
            blankIdx++;
            return html;
        });
        const shuffledOptions = shuffleArray(Object.entries(q.options));
        
        return `
        <div class="bg-white p-5 rounded-3xl border border-gray-100 shadow-sm space-y-4 question-block" data-id="${q.id}" data-type="drag">
            <div class="flex gap-2">
                <span class="text-sm font-bold text-gray-800">${idx+1}.</span>
                <p class="text-sm font-bold text-gray-800 leading-relaxed flex-1">${questionHtml}</p>
            </div>
            ${generateMediaHtml(q)}
            <div class="mt-4 p-4 bg-indigo-50/50 rounded-2xl border border-indigo-100 shadow-inner">
                <p class="text-[10px] font-bold text-indigo-400 mb-3 uppercase tracking-widest flex items-center gap-1.5"><i class="fa-solid fa-hand-pointer"></i> Ketuk kata di bawah untuk mengisi:</p>
                <div class="flex flex-wrap gap-2">
                    ${shuffledOptions.map(([k, v]) => `
                        <button type="button" class="word-btn px-4 py-2.5 bg-white border border-indigo-200 text-indigo-700 text-xs font-black rounded-xl shadow-sm hover:bg-indigo-50 active:scale-95 transition-all" data-key="${k}" onclick="fillBlank('${q.id}', this)">${v}</button>
                    `).join('')}
                </div>
            </div>
            <input type="hidden" name="q-${q.id}" id="ans-${q.id}" value="">
        </div>`;
    };

    const renderUrutanQuestion = (q, idx) => {
        const URUTAN_COLORS = [
            { bg: '#fef9c3', text: '#854d0e', border: '#fde68a' }, 
            { bg: '#dbeafe', text: '#1e3a8a', border: '#93c5fd' }, 
            { bg: '#dcfce7', text: '#14532d', border: '#86efac' }, 
            { bg: '#ffedd5', text: '#7c2d12', border: '#fdba74' }, 
        ];

        const arrUrutan = Array.isArray(q.options) ? [...q.options] : Object.values(q.options);
        const itemsWithId = arrUrutan.map((text, i) => ({ text, num: i + 1 }));
        const shuffled = shuffleArray([...itemsWithId]);

        const numberCardsHtml = shuffled.map((item) => {
            const color = URUTAN_COLORS[(item.num - 1) % URUTAN_COLORS.length];
            return `
                <div class="flex-1 max-w-[56px] min-w-[38px] h-14 rounded-xl flex items-center justify-center text-xl font-black cursor-grab select-none transition-all duration-200 active:cursor-grabbing border-2 border-b-[6px] active:border-b-2 active:translate-y-1 touch-none urutan-card" 
                     style="background-color: ${color.bg}; color: ${color.text}; border-color: ${color.border}; border-bottom-color: rgba(0,0,0,0.15);"
                     data-val="${item.text.replace(/"/g, '&quot;')}">
                    ${item.num}
                </div>`;
        }).join('');

        const keteranganHtml = arrUrutan.map((text, i) => {
            const color = URUTAN_COLORS[i % URUTAN_COLORS.length];
            return `
                <label class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-100 shadow-sm cursor-pointer hover:bg-gray-50 transition-colors group">
                    <input type="checkbox" class="peer w-5 h-5 rounded-md border-gray-200 text-teal-600 focus:ring-teal-500 cursor-pointer">
                    <span class="w-7 h-7 rounded-lg flex items-center justify-center font-black shrink-0 text-xs peer-checked:opacity-30 transition-opacity" 
                          style="background-color: ${color.bg}; color: ${color.text}; border: 1px solid ${color.border};">
                        ${i + 1}
                    </span>
                    <span class="flex-1 text-xs font-semibold text-gray-700 leading-relaxed peer-checked:text-gray-400 peer-checked:line-through transition-all uppercase tracking-tight">
                        ${text}
                    </span>
                    <i class="fa-solid fa-check text-teal-500 opacity-0 peer-checked:opacity-100 transition-opacity text-xs"></i>
                </label>
            `;
        }).join('');

        return `
        <div class="bg-white p-5 rounded-3xl border border-gray-100 shadow-sm space-y-4 question-block" data-id="${q.id}" data-type="urutan">
            <div class="flex justify-between items-start gap-4">
                <p class="text-sm font-bold text-gray-800 leading-relaxed">${idx+1}. ${q.question}</p>
                <span class="px-2 py-1 bg-teal-50 text-teal-600 text-[9px] font-black rounded-lg border border-teal-100 uppercase tracking-tighter shrink-0">Puzzle</span>
            </div>
            
            ${generateMediaHtml(q)}

            <div class="p-6 bg-gray-50 border-2 border-dashed border-gray-200 rounded-3xl flex flex-col items-center gap-4">
                <div class="w-full flex justify-between items-center px-2 text-[9px] font-black text-gray-400 uppercase tracking-widest select-none">
                    <span class="flex items-center gap-1"><i class="fa-solid fa-play text-[8px]"></i> Mulai</span>
                    <div class="flex-1 border-t-2 border-dotted border-gray-200 mx-4 relative">
                        <i class="fa-solid fa-chevron-right absolute right-[-2px] top-[-5px] text-[10px]"></i>
                    </div>
                    <span>Selesai</span>
                </div>

                <div id="sortable-${q.id}" class="sortable-list flex flex-nowrap justify-center items-center gap-2 sm:gap-3 w-full min-h-[70px]">
                    ${numberCardsHtml}
                </div>
            </div>

            <div class="border border-gray-100 rounded-2xl overflow-hidden bg-gray-50/50">
                <button type="button" 
                        onclick="this.nextElementSibling.classList.toggle('hidden'); this.querySelector('.arrow').classList.toggle('rotate-180');"
                        class="w-full flex items-center justify-between p-4 text-left outline-none">
                    <div class="flex items-center gap-2">
                        <i class="fa-solid fa-list-ol text-teal-500 text-xs"></i>
                        <span class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Keterangan Angka</span>
                    </div>
                    <i class="fa-solid fa-chevron-down text-gray-300 text-[10px] transition-transform arrow"></i>
                </button>
                <div class="px-4 pb-4 space-y-2 hidden">
                    <p class="text-[9px] text-gray-400 italic mb-2">*Klik kotak untuk mencoret jawaban yang sudah yakin.</p>
                    <div class="grid grid-cols-1 gap-2">
                        ${keteranganHtml}
                    </div>
                </div>
            </div>

            <input type="hidden" name="q-${q.id}" id="ans-${q.id}" value='${JSON.stringify(shuffled.map(s => s.text)).replace(/"/g, '&quot;')}'>
        </div>`;
    };

    const initSortables = () => {
        if (typeof Sortable === 'undefined') return;
        document.querySelectorAll('.sortable-list').forEach(list => {
            const block = list.closest('.question-block');
            const qId = block.dataset.id;

            new Sortable(list, {
                animation: 350,
                direction: 'horizontal',
                easing: 'cubic-bezier(0.34, 1.56, 0.64, 1)', 
                ghostClass: 'sortable-ghost',
                dragClass: 'sortable-drag',
                swapThreshold: 0.7, 
                onEnd: () => {
                    isDirty = true;
                    const items = Array.from(list.children).map(li => li.dataset.val);
                    document.getElementById(`ans-${qId}`).value = JSON.stringify(items);
                    saveDraftAnswers();
                    validate();
                }
            });
        });
    };

    // --- LOGIKA TAP UNTUK MENGISI DRAG & DROP ---
    window.fillBlank = (qId, btn) => {
        isDirty = true;
        const block = document.querySelector(`.question-block[data-id="${qId}"]`);
        const emptySlot = block.querySelector('.blank-slot:empty');
        if (emptySlot) {
            emptySlot.innerText = btn.innerText;
            emptySlot.dataset.key = btn.dataset.key;
            btn.classList.add('hidden'); 
            updateDragAnswer(qId, block);
        } else {
            window.showToast?.('warning', 'Penuh', 'Ketuk jawaban di atas untuk menghapusnya terlebih dahulu.');
        }
    };

    window.removeBlank = (slot) => {
        isDirty = true;
        if (!slot.innerText) return;
        const qId = slot.dataset.q;
        const block = document.querySelector(`.question-block[data-id="${qId}"]`);
        const key = slot.dataset.key;
        
        const btn = block.querySelector(`.word-btn[data-key="${key}"]`);
        if (btn) btn.classList.remove('hidden');
        
        slot.innerText = '';
        delete slot.dataset.key;
        updateDragAnswer(qId, block);
    };

    window.updateDragAnswer = (qId, block) => {
        const slots = Array.from(block.querySelectorAll('.blank-slot'));
        const keys = slots.map(s => s.dataset.key || '').join(',');
        document.getElementById(`ans-${qId}`).value = keys;
        
        saveDraftAnswers();
        validate();
    };

    // ==========================================
    // 3. AUTO SAVE & VALIDATION
    // ==========================================
    const saveDraftAnswers = () => {
        const answers = {};
        document.querySelectorAll('.question-block').forEach(block => {
            const qId = block.getAttribute('data-id');
            const type = block.dataset.type || 'pilgan';
            let selected;
            
            if (type === 'drag') {
                selected = document.getElementById(`ans-${qId}`).value;
            } else if (type === 'urutan') { 
                selected = JSON.parse(document.getElementById(`ans-${qId}`).value || '[]');
            } else {
                selected = block.querySelector(`input[name="q-${qId}"]:checked`)?.value;
            }
            if (selected) answers[qId] = selected;
        });

        const psych = {
            akhlak: document.querySelector('input[name="q_akhlak"]:checked')?.value,
            disiplin: document.querySelector('input[name="q_disiplin"]:checked')?.value,
            aktif: document.querySelector('input[name="q_aktif"]:checked')?.value,
        };
        localStorage.setItem(ansKey, JSON.stringify({ answers, psych }));
    };

    const restoreDraftAnswers = () => {
        const saved = JSON.parse(localStorage.getItem(ansKey));
        if (!saved) return;
        
        if (saved.answers) {
            Object.entries(saved.answers).forEach(([qId, val]) => {
                const block = document.querySelector(`.question-block[data-id="${qId}"]`);
                if (!block) return;
                const type = block.dataset.type || 'pilgan';
                
                if (type === 'drag') {
                    const keys = val.split(',');
                    const slots = block.querySelectorAll('.blank-slot');
                    keys.forEach((k, i) => {
                        if (k && slots[i]) {
                            const btn = block.querySelector(`.word-btn[data-key="${k}"]`);
                            if (btn) {
                                slots[i].innerText = btn.innerText;
                                slots[i].dataset.key = k;
                                btn.classList.add('hidden');
                            }
                        }
                    });
                    document.getElementById(`ans-${qId}`).value = val;
                } else if (type === 'urutan') { 
                    const list = document.getElementById(`sortable-${qId}`);
                    if (list && Array.isArray(val)) {
                        val.forEach(text => {
                            const li = Array.from(list.children).find(el => el.dataset.val === text);
                            if (li) list.appendChild(li); 
                        });
                        document.getElementById(`ans-${qId}`).value = JSON.stringify(val);
                    }
                } else {
                    const radio = document.querySelector(`input[name="q-${qId}"][value="${val}"]`);
                    if (radio) radio.checked = true;
                }
            });
        }
        if (saved.psych) {
            if (saved.psych.akhlak) { const r = document.querySelector(`input[name="q_akhlak"][value="${saved.psych.akhlak}"]`); if (r) r.checked = true; }
            if (saved.psych.disiplin) { const r = document.querySelector(`input[name="q_disiplin"][value="${saved.psych.disiplin}"]`); if (r) r.checked = true; }
            if (saved.psych.aktif) { const r = document.querySelector(`input[name="q_aktif"][value="${saved.psych.aktif}"]`); if (r) r.checked = true; }
            validate();
        }
    };

    const validate = () => {
        const totalQuestions = questions.length + 3;
        let answeredCount = 0;
        
        document.querySelectorAll('.question-block').forEach(block => {
            const qId = block.getAttribute('data-id');
            const type = block.dataset.type || 'pilgan';
            if (type === 'drag') {
                const val = document.getElementById(`ans-${qId}`).value;
                const requiredLen = block.querySelectorAll('.blank-slot').length;
                const filledLen = val.split(',').filter(Boolean).length;
                if (filledLen === requiredLen && requiredLen > 0) answeredCount++;
            } else if (type === 'urutan') { 
                answeredCount++;
            } else {
                if (block.querySelector(`input[name="q-${qId}"]:checked`)) answeredCount++;
            }
        });
        if (document.querySelector('input[name="q_akhlak"]:checked')) answeredCount++;
        if (document.querySelector('input[name="q_disiplin"]:checked')) answeredCount++;
        if (document.querySelector('input[name="q_aktif"]:checked')) answeredCount++;
        
        const progressPercent = totalQuestions > 0 ? (answeredCount / totalQuestions) * 100 : 0;
        document.getElementById('progressBar').style.width = `${progressPercent}%`;

        const btn = document.getElementById('btnSubmit');
        const ansAkhlak = document.querySelector('input[name="q_akhlak"]:checked');
        const ansDisiplin = document.querySelector('input[name="q_disiplin"]:checked');
        const ansAktif = document.querySelector('input[name="q_aktif"]:checked');

        if (ansAkhlak && ansDisiplin && ansAktif) {
            btn.disabled = false;
            btn.classList.replace('bg-gray-200', 'bg-green-600');
            btn.classList.replace('text-gray-400', 'text-white');
            btn.classList.remove('cursor-not-allowed');
        } else {
            btn.disabled = true;
            btn.classList.replace('bg-green-600', 'bg-gray-200');
            btn.classList.replace('text-white', 'text-gray-400');
            btn.classList.add('cursor-not-allowed');
        }
    };

    document.getElementById('questionsList').addEventListener('change', () => { isDirty = true; saveDraftAnswers(); validate(); window.MiawMascot?.resetTimer(); });
    document.getElementById('kuesionerContainer').addEventListener('change', () => { isDirty = true; validate(); saveDraftAnswers(); window.MiawMascot?.resetTimer(); });

    // ==========================================
    // 4. TIMER & EARLY FINISH
    // ==========================================
    const checkExistingSession = () => {
        if (isPreview) return;

        const savedEndTime = localStorage.getItem(timeKey);
        if (savedEndTime) {
            const overlay = document.getElementById('startOverlay');
            overlay.classList.add('hidden');
            const now = Date.now();
            timeLeft = Math.floor((savedEndTime - now) / 1000);
            if (timeLeft > 0) { startTest(false); } 
            else { timeLeft = 0; startTest(false); disableAcademicSection(); }
        }
    };

    document.getElementById('btnStart').onclick = () => {
        const overlay = document.getElementById('startOverlay');
        overlay.classList.add('opacity-0', 'pointer-events-none');
        
        // [UPDATE 3]: HANCURKAN SHOP DRAWER SETELAH TOMBOL MULAI DIKLIK
        const shopWrapper = document.getElementById('shopDrawerWrapper');
        if (shopWrapper) {
            shopWrapper.style.transform = 'translateY(100%)';
            shopWrapper.style.opacity = '0';
            setTimeout(() => { shopWrapper.style.display = 'none'; }, 500);
        }

        setTimeout(() => overlay.classList.add('hidden'), 500);
        startCountdown(); 
    };

    const startCountdown = () => {
        const overlay = document.getElementById('countdownOverlay');
        const text = document.getElementById('countdownText');
        overlay.classList.remove('hidden');
        let count = 3;
        const intv = setInterval(() => {
            count--;
            if (count > 0) text.innerText = count.toString();
            else { clearInterval(intv); overlay.classList.add('hidden'); startTest(true); }
        }, 1000);
    };

    const startTest = (isNewSession = true) => {
        document.getElementById('testContent').classList.remove('hidden');
        
        // Hapus Header
        const header = document.getElementById('mainHeader');
        header.classList.add('-translate-y-full', 'opacity-0');
        setTimeout(() => { header.classList.add('hidden'); }, 500); 
        
        // Munculkan Tombol Keluar & Pindah Banner ke Paling Atas
        if (isPreview) {
            const bannerBtn = document.getElementById('bannerExitBtn');
            const banner = document.getElementById('previewBanner');
            if (bannerBtn) bannerBtn.classList.remove('hidden');
            if (banner) banner.classList.add('sticky', 'top-0');
        }

        // Munculkan Capsule Timer di Kanan Atas
        const fTimer = document.getElementById('floatingTimer');
        fTimer.classList.remove('hidden');
        fTimer.classList.add('flex');

        isQuizStarted = true;
        updateShopUI(); 
        updateTimerUI(); 
        
        if (window.MiawMascot) setTimeout(() => { window.MiawMascot.show(); }, 500);

        // [PERBAIKAN 2A]: Timer tidak lagi kita return(stop) di mode preview, agar kamu bisa ngetes warna ring hijaunya!
        
        if (isNewSession) localStorage.setItem(timeKey, Date.now() + (timeLeft * 1000));
        if (timeLeft <= 0) return;
        timerInterval = setInterval(() => {
            timeLeft = Math.floor((localStorage.getItem(timeKey) - Date.now()) / 1000);
            if (timeLeft <= 0) {
                timeLeft = 0; finalTimeTaken = parsedWeek === 1 ? 90 : 180; 
                updateTimerUI(); clearInterval(timerInterval); disableAcademicSection();
            } else updateTimerUI();
        }, 1000);
    };

    // ==========================================
    // LOGIKA SERANGAN (ATTACK MODAL)
    // ==========================================
    window.openAttackModal = async () => {
        const listContainer = document.getElementById('attackTargetList');
        listContainer.innerHTML = '<div class="text-center p-4 text-xs text-gray-400"><i class="fa-solid fa-spinner fa-spin text-xl mb-2"></i><br>Mencari target...</div>';
        document.getElementById('modalAttack').classList.replace('hidden', 'flex');

        try {
            let peers = [];
            if (isPreview) {
                await new Promise(r => setTimeout(r, 800)); // Simulasi mikir
                peers = [
                    { id: '1', name: 'Ahmad Fauzan', has_shield: false },
                    { id: '2', name: 'Zaskia Adya', has_shield: true },
                    { id: '3', name: 'Rizky Billar', has_shield: false },
                ];
            } else {
                // Di BE nanti kamu harus buat endpoint GET /api/shop/peers?student_id=xx
                const res = await fetch(`${API_URL}/api/shop/peers?student_id=${studentId}`, { headers: { 'Authorization': `Bearer ${token}` }});
                const data = await res.json();
                peers = data.data || [];
            }

            if (peers.length === 0) {
                listContainer.innerHTML = '<p class="text-xs text-gray-500 text-center italic mt-4">Belum ada teman yang bisa diserang.</p>';
                return;
            }

            listContainer.innerHTML = peers.map(p => {
                const isProtected = p.has_shield;
                return `
                <div class="flex items-center justify-between p-3 rounded-xl border ${isProtected ? 'bg-blue-50/50 border-blue-100 opacity-60' : 'bg-gray-50 border-gray-100'}">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full flex items-center justify-center font-bold text-xs ${isProtected ? 'bg-blue-200 text-blue-700' : 'bg-gray-200 text-gray-600'}">
                            ${p.name.substring(0,2).toUpperCase()}
                        </div>
                        <div>
                            <p class="text-xs font-bold text-gray-800">${p.name}</p>
                            ${isProtected ? '<p class="text-[9px] font-bold text-blue-500"><i class="fa-solid fa-shield"></i> Terlindungi</p>' : '<p class="text-[9px] text-gray-400">Rentan diserang</p>'}
                        </div>
                    </div>
                    <button ${isProtected ? 'disabled' : `onclick="executeAttack('${p.id}', '${p.name}')"`} 
                            class="px-3 py-1.5 rounded-lg text-xs font-black transition-all ${isProtected ? 'bg-gray-200 text-gray-400 cursor-not-allowed' : 'bg-red-500 text-white hover:bg-red-600 active:scale-95 shadow-md shadow-red-500/30'}">
                        ${isProtected ? 'Aman' : 'SERANG'}
                    </button>
                </div>
                `;
            }).join('');

        } catch (e) {
            listContainer.innerHTML = '<p class="text-xs text-red-500 text-center mt-4">Gagal memuat daftar teman.</p>';
        }
    };

    window.executeAttack = async (targetId, targetName) => {
        if (!confirm(`Yakin ingin menyerang ${targetName}?`)) return;
        
        document.getElementById('modalAttack').classList.replace('flex', 'hidden');
        try {
            if (isPreview) {
                window.showToast?.('success', 'CRITTIICAL HIT!', `Kamu berhasil mencuri 50 Poin dari ${targetName}!`);
                studentInventory.item_serang -= 1;
                studentWallet += 50; 
                updateShopUI();
                return;
            }

            // Integrasi ke BE (Sesuai kode shopController.js yang kita buat di Tahap 1)
            const res = await fetch(`${API_URL}/api/shop/attack`, {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify({ actor_id: studentId, target_id: targetId })
            });
            const data = await res.json();
            
            if(data.status === 'success') {
                window.showToast?.('success', 'Serangan Selesai', data.message);
                // Refresh data dompet setelah menyerang
                studentInventory.item_serang -= 1;
                // Idealnya ambil saldo terbaru dari API, tapi kita asumsikan dapat +50
                if(data.message.includes('berhasil')) studentWallet += 50; 
                updateShopUI();
            } else throw new Error(data.message);

        } catch(e) {
            window.showToast?.('danger', 'Serangan Gagal', e.message);
        }
    };

    // ==========================================
    // LOGIKA NOTIFIKASI KORBAN (REAL)
    // ==========================================
    let unreadLogIds = [];

    window.checkRealNotifications = async () => {
        try {
            const res = await fetch(`${API_URL}/api/shop/notifications?student_id=${studentId}`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const data = await res.json();
            
            if (data.status === 'success' && data.data.length > 0) {
                const logs = data.data;
                unreadLogIds = logs.map(l => l.id); // Simpan ID untuk ditandai sudah dibaca nanti
                
                // Gabungkan jika diserang oleh banyak orang sekaligus
