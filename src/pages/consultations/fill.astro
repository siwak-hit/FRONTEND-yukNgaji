            </div>
            
            <!-- [UPDATE] Panggil fungsi closeResult... agar bisa redirect ke Leaderboard PR -->
            <button onclick="closeResultAndCheckReminder()" class="w-full py-3.5 bg-gray-800 text-white font-bold rounded-2xl text-xs active:scale-95 transition-all uppercase tracking-widest">
