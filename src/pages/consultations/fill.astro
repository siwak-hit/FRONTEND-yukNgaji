    <Mascot />
    <PhotoBooth />
    <div class="relative z-[99999]">
        <Toast />
    </div>
</Layout>

<style>
    @keyframes bounce-short {
        0%, 100% { transform: translateY(0) scale(1); }
        50% { transform: translateY(-10px) scale(1.02); }
    }
    .animate-bounce-short { animation: bounce-short 0.5s ease-in-out 1; }
</style>

<style is:global>
    .toast-container, [id^="toast"] { z-index: 99999 !important; }
</style>

<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js" is:inline></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js" is:inline></script>


<script>
    // ==========================================
    // 1. CONFIG & GLOBAL STATE 
    // ==========================================
    const mascotBtn = document.getElementById('btnToggleCat');
    if (mascotBtn) mascotBtn.remove();

    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const urlParams = new URLSearchParams(window.location.search);
    
    // --- [FIX BUG 401] LOGIKA TANGKAP TOKEN PR ---
    const rawPrToken = urlParams.get('pr_token');
    // Cegah Javascript membaca string "null" sebagai token asli
    const paramPrToken = (rawPrToken && rawPrToken !== 'null') ? rawPrToken : null; 
    
    const isPRMode = urlParams.get('pr') === 'true' || !!paramPrToken;
    
    let token = localStorage.getItem('token');
    
    // Jika masuk dari link WA (bawa pr_token), simpan ke sessionStorage biar gak hilang pas refresh
    if (paramPrToken) {
        token = paramPrToken;
        sessionStorage.setItem('temp_pr_token', paramPrToken);
    } else if (sessionStorage.getItem('temp_pr_token') && sessionStorage.getItem('temp_pr_token') !== 'null') {
        token = sessionStorage.getItem('temp_pr_token');
    }

    const isPreview = urlParams.get('preview') === 'true'; 

    // Usir kalau gak punya token Ustadz DAN gak punya token PR
    if (!token && !isPreview) window.location.replace('/');

    // Jika ini Mode PR, ganti teks tombol "Keluar" di header
    if (isPRMode) {
        const exitBtn = document.querySelector('a[onclick="handleBack()"]');
        if (exitBtn) {
            exitBtn.innerText = "Tutup";
            exitBtn.classList.replace('text-gray-400', 'text-indigo-400');
            exitBtn.onclick = () => window.close(); // Usaha nutup tab otomatis
        }
        document.getElementById('prSettings').classList.remove('hidden');
        document.getElementById('startTitleText').innerText = "Siap Ngerjain PR?";
        
        // [UPDATE] Tambahkan extra padding bottom dan izin scroll vertikal biar gak mentok
        document.getElementById('startOverlay').classList.add('pb-16', 'overflow-y-auto');
    }

    const studentId = urlParams.get('id');
    const subject = urlParams.get('subject');
    const week = urlParams.get('week');
    const parsedWeek = parseInt(week) || 1;

    const timeKey = `timer_${studentId}_${subject}_${week}`;
    const ansKey = `ans_${studentId}_${subject}_${week}`;
    const qKey = `qs_${studentId}_${subject}_${week}`;
    const psychKey = `psych_${studentId}_${subject}_${week}`;

    let questions = [];
    let timeLeft = parsedWeek === 1 ? 105 : 180; 
    let finalTimeTaken = 0;
    let timerInterval = null;
    let selfieFileToUpload = null;
    let currentStudentName = "Si Anak";
    let hasPriorPhoto = false;
    let isDirty = false;
    let isQuizStarted = false;
    let completedWeeksForSubject = [];
    window.shouldShowExamReminder = false;

    let warned30 = false;
    let warned10 = false;

    // State Gamifikasi
    let studentWallet = 0;
    let studentInventory = { item_double_score: 0, item_serang: 0, item_perisai: 0, item_extra_life: 0 };
    let selectedItemToBuy = null;
    let boughtItemsThisSession = { item_double_score: false, item_serang: false, item_perisai: false, item_extra_life: false };
    window.isDoubleScoreActive = false;
    window.isShieldActive = false;
    let isEvaluatingExtraLife = false;
    let wrongQuestionsGlobal = [];
    let hasClaimedBonusGlobal = false;
    let unreadLogIds = [];

    const ITEM_DB = {
        item_double_score: { name: "Double Poin", price: 50, icon: "✨", desc: "Mendongkrak nilaimu di akhir ujian! Semakin kecil nilaimu, semakin besar tambahan poinnya." },
        item_serang: { name: "Serang Teman", price: 100, icon: "⚔️", desc: "Curi poin dari saldo dompet teman! Teman yang pakai perisai tidak bisa diserang." },
        item_perisai: { name: "Perisai", price: 75, icon: "🛡️", desc: "Aman dari pencurian teman-temanmu. Otomatis aktif setelah dibeli!" },
        item_extra_life: { name: "Extra Life", price: 150, icon: "💖", desc: "Kesempatan kedua! Memungkinkanmu memperbaiki satu jawaban salah. Aktif otomatis!" }
    };

    const elHeaderTimerText = document.getElementById('headerTimerText');
    const elFloatText = document.getElementById('timerTextFloat');
    const elTimerRing = document.getElementById('timerRing');
    const elFloatTimerIcon = document.getElementById('floatTimerIcon');
    const elHeaderTimerIcon = document.getElementById('headerTimerIcon');
    const elHeaderTimerDisplay = document.getElementById('headerTimerDisplay');
    const btnSubmitGlobal = document.getElementById('btnSubmit');
    const elProgressBar = document.getElementById('progressBar');

    // ==========================================
    // 2. UTILITY & UI FUNCTIONS
    // ==========================================
    const shuffleArray = (array) => {
        const arr = [...array];
        for (let i = arr.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [arr[i], arr[j]] = [arr[j], arr[i]];
        }
        return arr;
    };

    const debounce = (func, wait) => {
        let timeout;
        return function(...args) { clearTimeout(timeout); timeout = setTimeout(() => func.apply(this, args), wait); };
    };

    const setVignette = (active) => {
        let vig = document.getElementById('dangerVignetteOverlay');
        if (!vig) {
            vig = document.createElement('div');
            vig.id = 'dangerVignetteOverlay';
            vig.className = 'fixed inset-0 pointer-events-none transition-opacity duration-1000 z-[75] opacity-0';
            vig.style.background = 'radial-gradient(circle, transparent 50%, rgba(239, 68, 68, 0.15) 80%, rgba(239, 68, 68, 0.35) 100%)';
            vig.style.boxShadow = 'inset 0 0 120px rgba(239,68,68,0.4)';
            document.body.appendChild(vig);
        }
        
        if (active) {
            vig.classList.replace('opacity-0', 'opacity-100');
            document.body.classList.add('animate-pulse');
        } else {
            vig.classList.replace('opacity-100', 'opacity-0');
            document.body.classList.remove('animate-pulse');
        }
    };

    let globalConfirmCallback = null;
    window.showConfirm = (title, message, onConfirm, type = 'primary') => {
        document.getElementById('confirmGlobalTitle').innerText = title;
        document.getElementById('confirmGlobalMessage').innerText = message;
        const btnYes = document.getElementById('btnConfirmGlobalYes');
        const iconBox = document.getElementById('confirmGlobalIconBox');
        const icon = document.getElementById('confirmGlobalIcon');
        const modalBox = document.getElementById('modalConfirmBox');
        
        if (type === 'danger') {
            btnYes.className = 'flex-1 py-3.5 bg-red-600 hover:bg-red-700 text-white font-bold rounded-2xl shadow-lg shadow-red-600/30 active:scale-95 transition-all text-sm';
            iconBox.className = 'w-20 h-20 bg-red-50 text-red-500 rounded-full flex items-center justify-center text-4xl mx-auto mb-4 border border-red-100 shadow-inner';
            icon.className = 'fa-solid fa-triangle-exclamation';
            modalBox.className = 'bg-white w-full max-w-sm rounded-[2rem] p-6 shadow-2xl text-center transform scale-100 animate-bounce-short border-4 border-red-400';
        } else {
            btnYes.className = 'flex-1 py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-2xl shadow-lg shadow-indigo-600/30 active:scale-95 transition-all text-sm';
            iconBox.className = 'w-20 h-20 bg-indigo-50 text-indigo-500 rounded-full flex items-center justify-center text-4xl mx-auto mb-4 border border-indigo-100 shadow-inner';
            icon.className = 'fa-solid fa-circle-question';
            modalBox.className = 'bg-white w-full max-w-sm rounded-[2rem] p-6 shadow-2xl text-center transform scale-100 animate-bounce-short border-4 border-indigo-400';
        }
        globalConfirmCallback = onConfirm;
        const modal = document.getElementById('modalConfirmGlobal');
        modal.classList.replace('hidden', 'flex');
        setTimeout(() => modal.classList.replace('opacity-0', 'opacity-100'), 10);
    };

    document.getElementById('btnConfirmGlobalCancel').onclick = () => {
        const modal = document.getElementById('modalConfirmGlobal');
        modal.classList.replace('opacity-100', 'opacity-0');
        setTimeout(() => modal.classList.replace('flex', 'hidden'), 300);
        globalConfirmCallback = null;
    };
    document.getElementById('btnConfirmGlobalYes').onclick = () => {
        const modal = document.getElementById('modalConfirmGlobal');
        modal.classList.replace('opacity-100', 'opacity-0');
        setTimeout(() => modal.classList.replace('flex', 'hidden'), 300);
        if (globalConfirmCallback) globalConfirmCallback();
    };

    const executeExit = () => {
        localStorage.removeItem(timeKey);
        if (isPreview) window.location.href = '/bank-soal';
        else window.location.href = '/consultations';
    };

    window.handleBack = () => {
        if (isDirty) window.showConfirm('Keluar Sekarang?', 'Anda memiliki data yang belum dikirim. Yakin ingin keluar?', () => executeExit(), 'danger');
        else executeExit();
    };
    window.exitPreview = executeExit;
    window.closeBuyModal = () => document.getElementById('modalBuyItem').classList.replace('flex', 'hidden');
    window.closeExamReminder = executeExit;

    window.toggleFloatingTimer = () => {
        const container = document.getElementById('timerTextContainer');
        if (container.classList.contains('w-[50px]')) {
            container.classList.replace('w-[50px]', 'w-0'); container.classList.add('opacity-0', '-ml-1');
        } else {
            container.classList.replace('w-0', 'w-[50px]'); container.classList.remove('opacity-0', '-ml-1');
        }
    };

    window.toggleFloatingItems = () => {
        const container = document.getElementById('itemsTextContainer');
        const icon = document.getElementById('floatItemsIcon');
        if (container.classList.contains('max-w-0')) {
            container.classList.replace('max-w-0', 'max-w-[120px]'); container.classList.remove('opacity-0');
            container.classList.add('px-2', 'mr-1'); icon.classList.add('scale-110', 'text-indigo-600');
        } else {
            container.classList.replace('max-w-[120px]', 'max-w-0'); container.classList.add('opacity-0');
            container.classList.remove('px-2', 'mr-1'); icon.classList.remove('scale-110', 'text-indigo-600');
        }
    };

    window.openCameraModal = () => {
        window.openPhotoBooth(currentStudentName, week, (capturedFile) => {
            selfieFileToUpload = capturedFile; 
            const previewImg = document.getElementById('selfiePreview');
            const iconBox = document.getElementById('cameraIconBox');
            previewImg.src = URL.createObjectURL(capturedFile);
            previewImg.classList.remove('hidden');
            iconBox.classList.add('hidden');
        });
    };

    // ==========================================
    // 3. INIT & FETCH DATA
    // ==========================================
    const init = async () => {
        try {
            setupKuesionerSosial();
            let allQuestions = [];

            // [FIX UX] Tampilkan Spinner Animasi dan Gembok Tombol Submit
            const qListContainer = document.getElementById('questionsList');
            if (qListContainer) {
                qListContainer.innerHTML = `
                    <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm flex flex-col items-center justify-center text-center">
                        <i class="fa-solid fa-spinner fa-spin text-5xl text-green-500 mb-4"></i>
                        <h3 class="font-black text-gray-800 text-lg mb-1">Tunggu Sebentar...</h3>
                        <p class="text-xs text-gray-400 font-bold">Mempersiapkan soal dari Ustadz!</p>
                    </div>
                `;
            }
            if (btnSubmitGlobal) {
                btnSubmitGlobal.disabled = true;
                btnSubmitGlobal.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Menyiapkan Ujian...';
            }

            if (isPreview) {
                localStorage.removeItem(timeKey); localStorage.removeItem(ansKey);
                localStorage.removeItem(qKey); localStorage.removeItem(psychKey);

                document.getElementById('previewBanner').classList.remove('hidden');
                document.getElementById('headerName').innerText = "Mode Simulasi";
                document.getElementById('headerInitials').innerText = "PR";
                document.getElementById('startDescText').innerText = "Mode Simulasi. Kamu bisa ngetes Shop & Hitung Mundur.";
                studentWallet = 500;
                
                const qRes = await fetch(`${API_URL}/api/onboarding/questions/${subject}`, { headers: { 'Authorization': `Bearer ${token}` }});
                const qData = await qRes.json();
                allQuestions = Array.isArray(qData.data) ? qData.data : (qData.data[week] || []);
            } else {
                const menit = Math.floor(timeLeft / 60);
                const detik = timeLeft % 60;
                const teksWaktu = detik > 0 ? `${menit} menit ${detik} detik` : `${menit} menit`;
                document.getElementById('startDescText').innerText = `Pastikan fokus. Kamu punya waktu ${teksWaktu} untuk mengerjakan soal.`;
                const [stdRes, consRes, qRes] = await Promise.all([
                    fetch(`${API_URL}/api/students/${studentId}`, { headers: { 'Authorization': `Bearer ${token}` }}),
                    fetch(`${API_URL}/api/students/${studentId}/consultations`, { headers: { 'Authorization': `Bearer ${token}` }}),
                    fetch(`${API_URL}/api/onboarding/questions/${subject}?week=${week}&student_id=${studentId}`, { headers: { 'Authorization': `Bearer ${token}` }})
                ]);
                
                const student = await stdRes.json();
                const consData = await consRes.json();
                const qData = await qRes.json();

                if (!student || !student.data) {
                    window.showToast?.('danger', 'Akses Ditolak', 'Sesi telah berakhir atau Anda tidak memiliki akses ke ujian ini.');
                    setTimeout(() => window.location.replace('/'), 2000);
                    return; // Hentikan script di sini agar tidak error ke bawah
                }

                currentStudentName = student.data.name?.split(' ')[0] || "Anak Baik";
                if (consData.data) {
                    completedWeeksForSubject = consData.data.filter(c => c.subject === subject).map(c => parseInt(c.week));
                    hasPriorPhoto = consData.data.some(c => c.image_url && c.image_url.trim() !== '');
                }

                document.getElementById('headerName').innerText = student.data.name;
                document.getElementById('headerInitials').innerText = student.data.name?.substring(0,2).toUpperCase() || 'S';
                allQuestions = qData.data || [];

                if (student.data) {
                    studentWallet = Number(student.data.poin) || 0; 
                    studentInventory = {
                        item_double_score: student.data.item_double_score || 0,
                        item_serang: student.data.item_serang || 0,
                        item_perisai: student.data.item_perisai || 0,
                        item_extra_life: student.data.item_extra_life || 0
                    };
                    window.isShieldActive = student.data.is_shield_active || false;
                    if (student.data.has_claimed_bonus) {
                        hasClaimedBonusGlobal = true;
                        localStorage.setItem(`bonus_claimed_${studentId}`, 'true');
                    }
                }
            }

            const targetDisplay = 6;
            if (isPreview) {
                questions = shuffleArray(allQuestions).slice(0, Math.min(targetDisplay, allQuestions.length));
            } else {
                let savedQsIds = JSON.parse(localStorage.getItem(qKey)) || [];
                questions = savedQsIds.map(id => allQuestions.find(q => q.id === id)).filter(Boolean);
                if (questions.length === 0 && allQuestions.length > 0) {
                    questions = shuffleArray(allQuestions).slice(0, Math.min(targetDisplay, allQuestions.length));
                    localStorage.setItem(qKey, JSON.stringify(questions.map(q => q.id)));
                }
            }

            updateTimerUI();
            
            if (window.MiawMascot){
                await window.MiawMascot.init({
                    mode: 'peek',
                    animations: { 
                        PEEK_IN: { path: '/CAT LOTTIE/SHOWING CAT.json', loop: false, speed: 1.0, lottieDuration: 3000 },
                        PEEK_OUT: { path: '/CAT LOTTIE/BACK TO HIDDEN.json', loop: false, speed: 1.2, lottieDuration: 2000 },
                        IDLE: { path: '/CAT LOTTIE/IDDLE SHOW.json', loop: true, speed: 1.0 },
                        CLICK: { path: '/CAT LOTTIE/BACK TO HIDDEN.json', loop: false, speed: 1.0, lottieDuration: 1500 }
                        },
                    texts: { 
                        entering: () => `Haloo <strong>${currentStudentName}</strong>! Semangat ngerjain tugasnya ya!`, 
                        idleArrive: () => {
                            const menit = Math.floor(timeLeft / 60);
                            if (menit > 0) return `Miaw! Sisa waktu tinggal <strong>${menit} menit</strong> lagi! Jangan sampai kehabisan.`;
                            return `Gawat <strong>${currentStudentName}</strong>! Waktunya kurang dari semenit, buruan!`;
                        }, 
                        idlePhrases: [
                            () => {
                                if (timeLeft <= 10) return `AYO CEPETAN <strong>${currentStudentName}</strong>!!!! Tinggal ${timeLeft} detik!`;
                                if (timeLeft <= 30) return `Awas <strong>${currentStudentName}</strong>! Waktunya tinggal ${timeLeft} detik lagi!`;
                                const menit = Math.floor(timeLeft / 60);
                                if (menit > 0 && menit <= 2) return `Ayo cepetan <strong>${currentStudentName}</strong>! Waktunya sisa <strong>${menit} menitan</strong> lho!`;
                                
                                if (window.isDoubleScoreActive) return `Asiik! Sihir <strong>Double Poin ✨</strong> lagi aktif! Maksimalkan nilaimu <strong>${currentStudentName}</strong>!`;
                                if (window.isShieldActive) return `Miaw! Tenang aja <strong>${currentStudentName}</strong>, <strong>Perisai 🛡️</strong> kamu siap menahan serangan!`;
                                if (studentInventory.item_extra_life > 0) return `Kamu pegang <strong>Extra Life 💖</strong>! Santai aja <strong>${currentStudentName}</strong>, nanti bisa perbaiki 1 yang salah.`;
                                return `Fokus <strong>${currentStudentName}</strong>! Teliti lagi jawabannya ya!`;
                            },
                            () => `Miaw! <strong>${currentStudentName}</strong>, kalau bingung dilewatin dulu aja!`,
                            () => window.isShieldActive ? `Poinmu aman <strong>${currentStudentName}</strong> karena ada <strong>Perisai 🛡️</strong>!` : `Hati-hati <strong>${currentStudentName}</strong>, koinmu bisa dicuri kalau nggak beli <strong>Perisai 🛡️</strong>!`,
                            () => {
                                const answeredBlocks = [];
                                document.querySelectorAll('.question-block').forEach((block, index) => {
                                    const qId = block.dataset.id; const type = block.dataset.type || 'pilgan'; let answerText = null;
                                    if (type === 'pilgan' || type === 'tf') {
                                        const checked = block.querySelector(`input[name="q-${qId}"]:checked`);
                                        if (checked) { if (type === 'tf') answerText = checked.value === 'A' ? 'BENAR' : 'SALAH'; else { const span = checked.nextElementSibling; if (span) answerText = span.innerText; } }
                                    } else if (type === 'drag') {
                                        const slots = block.querySelectorAll('.blank-slot'); let answered = []; slots.forEach(s => { if (s.innerText) answered.push(s.innerText); }); if (answered.length > 0) answerText = answered.join(' ');
                                    } else if (type === 'urutan') {
                                        const val = document.getElementById(`ans-${qId}`)?.value; if (val && val !== '[]' && val !== '') answerText = "susunan puzzle yang itu";
                                    }
                                    if (answerText) answeredBlocks.push({ nomor: index + 1, jawaban: answerText });
                                });
                                if (answeredBlocks.length > 0) {
                                    const randomPick = answeredBlocks[Math.floor(Math.random() * answeredBlocks.length)];
                                    let textJawaban = randomPick.jawaban; if (textJawaban.length > 25) textJawaban = textJawaban.substring(0, 25) + '...';
                                    const doubtPhrases = [
                                        `Hah masa nomor <strong>${randomPick.nomor}</strong> jawabannya <strong>"${textJawaban}"</strong> sih... coba cek lagi deh <strong>${currentStudentName}</strong>!`,
                                        `Miaw! Yakin nomor <strong>${randomPick.nomor}</strong> itu <strong>"${textJawaban}"</strong>? Kayaknya ada yang aneh deh...`,
                                        `Psst <strong>${currentStudentName}</strong>, masa nomor <strong>${randomPick.nomor}</strong> jawabannya <strong>"${textJawaban}"</strong>? Diteliti lagi coba!`
                                    ];
                                    return doubtPhrases[Math.floor(Math.random() * doubtPhrases.length)];
                                }
                                return `Ayo mulai kerjain <strong>${currentStudentName}</strong>! Miaw tungguin nih!`;
                            }
                        ] 
                    }
                });
            }

            renderQuestions();
            restoreDraftAnswers();
            checkExistingSession();
            updateShopUI();
            if (!isPreview) checkRealNotifications();

            validate();

            const btnStartLobby = document.getElementById('btnStart');
            if (btnStartLobby) {
                btnStartLobby.disabled = false;
                btnStartLobby.innerHTML = 'Mulai Sekarang <i class="fa-solid fa-rocket ml-1"></i>';
                btnStartLobby.className = 'w-full max-w-xs py-4 bg-green-600 hover:bg-green-700 text-white font-bold rounded-2xl shadow-lg shadow-green-600/30 active:scale-95 transition-all text-lg flex items-center justify-center gap-2';
            }

        } catch (e) {
            console.error(e); 
            window.showToast?.('danger', 'Error', 'Gagal memuat Tugas.');
            // Kalau gagal fetch data, ganti teks tombol jadi error biar anak tau
            const btnStartLobby = document.getElementById('btnStart');
            if (btnStartLobby) {
                btnStartLobby.innerHTML = '<i class="fa-solid fa-triangle-exclamation"></i> Gagal Memuat Data';
                btnStartLobby.classList.replace('text-gray-400', 'text-red-500');
                btnStartLobby.classList.replace('bg-gray-200', 'bg-red-100');
            }
        }
    };

    // ==========================================
    // 4. SOAL & RENDER HTML
    // ==========================================
    const setupKuesionerSosial = () => {
        const qBank = {
            akhlak: [
                { q: "Pas Kak Aziz lagi nerangin, apa yang kamu lakuin tadi?", opts: [{t: "Merhatiin Kok!", s: 100}, {t: "gak terlalu ( Bosen soalnya )", s: 50}, {t: "gak tau ah!", s: 0}] },
                { q: "Jujur, kadang kamu suka lupa salim ke guru gak pas datang?", opts: [{t: "Selalu salim ke semua nya", s: 100}, {t: "Ke pa Idris doang", s: 50}, {t: "Sering lupa", s: 0}] },
                { q: "Kalau kamu ditegur guru karena salah, perasaan kamu gimana?", opts: [{t: "Biasa aja", s: 100}, {t: "Agak bete", s: 50}, {t: "curhat ke temen pas udah pulang ngaji", s: 0}] }
            ],
            disiplin: [
                { q: "Misalkan kak Aziz nyuruh sesuatu, Apa yang kamu lakukan?", opts: [{t: "Gak mau ah", s: 0}, {t: "Mau, tapi...", s: 50}, {t: "Mau", s: 100}] },
                { q: "Habis ngaji, kamu langsung pulang atau bantu beresin meja?", opts: [{t: "Bantuin beresin", s: 100}, {t: "biasanya sih langsung pulang", s: 0}] },
                { q: "Kalau ada PR ngaji tapi kamu belum ngerjain, itu salah siapa?", opts: [{t: "Salahku sendiri", s: 100}, {t: "Salah temen gak ngingetin", s: 0}, {t:"salah kak Aziz bikin tugas susah banget", s:0}] }
            ],
            aktif: [
                { q: "Pas guru nanya ke kelas, kamu biasanya ngapain?", opts: [{t: "Langsung jawab dong!", s: 100}, {t: "Mau jawab tapi malu", s: 50}, {t: "Diem aja nunggu temen yang jawab", s: 0}] },
                { q: "Kalau ada temen yang sering nanya ke guru, menurutmu dia...", opts: [{t: "Hebat dan pintar", s: 100}, {t: "Caper banget", s: 0}, {t: "HEBAT BANGET!!! KEREN!", s: 20}] },
                { q: "Apa yang bikin kamu kadang gak mau nanya pelajaran?", opts: [{t: "Aku suka nanya kok", s: 100}, {t: "Takut salah / diketawain", s: 50}, {t: "Gak tau apa yang mau ditanya", s: 0}] }
            ]
        };

        let selectedQ = JSON.parse(localStorage.getItem(psychKey)) || [];
        if (selectedQ.length !== 3) {
            selectedQ = [ { cat: 'akhlak', ...shuffleArray(qBank.akhlak)[0] }, { cat: 'disiplin', ...shuffleArray(qBank.disiplin)[0] }, { cat: 'aktif', ...shuffleArray(qBank.aktif)[0] } ];
            selectedQ = selectedQ.map(q => ({ ...q, opts: shuffleArray(q.opts) }));
            localStorage.setItem(psychKey, JSON.stringify(selectedQ));
        }

        const container = document.getElementById('kuesionerContainer');
        if(container) {
            container.innerHTML = selectedQ.map((item, index) => `
                <div class="bg-blue-50 p-4 rounded-2xl border border-blue-100 shadow-sm">
                    <p class="text-sm font-bold text-gray-800 mb-3">${index + 1}. ${item.q}</p>
                    <div class="space-y-2">
                        ${item.opts.map((opt) => `
                            <label class="flex items-center gap-2 bg-white p-3 rounded-xl border border-gray-100 cursor-pointer hover:bg-gray-50 active:scale-95 transition-all">
                                <input type="radio" name="q_${item.cat}" value="${opt.s}" class="w-4 h-4 text-blue-600 focus:ring-blue-500" required>
                                <span class="text-xs font-semibold text-gray-700">${opt.t}</span>
                            </label>
                        `).join('')}
                    </div>
                </div>
            `).join('');
        }
    };

    const generateMediaHtml = (q) => {
        if (!q.image_url) return '';
        return `
            <div class="relative rounded-2xl overflow-hidden border border-gray-100 shadow-sm bg-gray-100 flex items-center justify-center min-h-[80px]">
                <div class="img-skeleton absolute inset-0 bg-gray-100 animate-pulse flex items-center justify-center"><i class="fa-solid fa-image text-gray-300 text-2xl"></i></div>
                <img src="${q.image_url.trim()}" class="relative w-full h-auto max-h-56 object-contain mx-auto opacity-0 transition-opacity duration-300" alt="Visual Soal" onload="this.classList.replace('opacity-0','opacity-100');this.previousElementSibling.style.display='none';" onerror="this.closest('.relative').style.display='none'">
            </div>`;
    };

    const renderPilganQuestion = (q, idx) => {
        const shuffledOptions = shuffleArray(Object.entries(q.options));
        return `<div class="bg-white p-5 rounded-3xl border border-gray-100 shadow-sm space-y-4 question-block" data-id="${q.id}" data-type="pilgan"><p class="text-sm font-bold text-gray-800 leading-relaxed">${idx+1}. ${q.question}</p>${generateMediaHtml(q)}<div class="grid grid-cols-1 gap-2">${shuffledOptions.map(([key, val]) => `<label class="flex items-center gap-3 p-3 rounded-xl border border-gray-50 bg-gray-50 active:bg-green-50 transition-colors cursor-pointer has-[:checked]:bg-green-50 has-[:checked]:border-green-300"><input type="radio" name="q-${q.id}" value="${key}" class="w-4 h-4 text-green-600 focus:ring-0"><span class="text-xs text-gray-600 font-medium">${val}</span></label>`).join('')}</div></div>`;
    };

    const renderTrueFalseQuestion = (q, idx) => `<div class="bg-white p-5 rounded-3xl border border-gray-100 shadow-sm space-y-4 question-block" data-id="${q.id}" data-type="tf"><p class="text-sm font-bold text-gray-800 leading-relaxed text-center mb-2">${idx+1}. ${q.question}</p>${generateMediaHtml(q)}<div class="grid grid-cols-2 gap-3"><label class="flex flex-col items-center justify-center p-4 rounded-2xl border-2 border-gray-100 cursor-pointer has-[:checked]:bg-green-50 has-[:checked]:border-green-400 transition-all hover:bg-gray-50"><input type="radio" name="q-${q.id}" value="A" class="hidden"><i class="fa-solid fa-check text-4xl text-green-500 mb-2 drop-shadow-sm"></i><span class="font-black text-gray-700 tracking-widest uppercase">BENAR</span></label><label class="flex flex-col items-center justify-center p-4 rounded-2xl border-2 border-gray-100 cursor-pointer has-[:checked]:bg-red-50 has-[:checked]:border-red-400 transition-all hover:bg-gray-50"><input type="radio" name="q-${q.id}" value="B" class="hidden"><i class="fa-solid fa-xmark text-4xl text-red-500 mb-2 drop-shadow-sm"></i><span class="font-black text-gray-700 tracking-widest uppercase">SALAH</span></label></div></div>`;

    const renderDragDropQuestion = (q, idx) => {
        let blankIdx = 0;
        const qHtml = (q.question || '').replace(/\[BLANK\]/g, () => `<span class="blank-slot inline-block min-w-[70px] h-8 border-b-2 border-dashed border-indigo-400 bg-indigo-50 mx-1 text-center font-black text-indigo-700 align-middle cursor-pointer text-xs leading-8 shadow-inner px-2 rounded-t-lg transition-colors hover:bg-indigo-100" data-q="${q.id}" data-index="${blankIdx++}" onclick="removeBlank(this)"></span>`);
        const opts = shuffleArray(Object.entries(q.options));
        return `<div class="bg-white p-5 rounded-3xl border border-gray-100 shadow-sm space-y-4 question-block" data-id="${q.id}" data-type="drag"><div class="flex gap-2"><span class="text-sm font-bold text-gray-800">${idx+1}.</span><p class="text-sm font-bold text-gray-800 leading-relaxed flex-1">${qHtml}</p></div>${generateMediaHtml(q)}<div class="mt-4 p-4 bg-indigo-50/50 rounded-2xl border border-indigo-100 shadow-inner"><p class="text-[10px] font-bold text-indigo-400 mb-3 uppercase tracking-widest flex items-center gap-1.5"><i class="fa-solid fa-hand-pointer"></i> Ketuk kata di bawah:</p><div class="flex flex-wrap gap-2">${opts.map(([k, v]) => `<button type="button" class="word-btn px-4 py-2.5 bg-white border border-indigo-200 text-indigo-700 text-xs font-black rounded-xl shadow-sm hover:bg-indigo-50 active:scale-95 transition-all" data-key="${k}" onclick="fillBlank('${q.id}', this)">${v}</button>`).join('')}</div></div><input type="hidden" name="q-${q.id}" id="ans-${q.id}" value=""></div>`;
    };

    const renderUrutanQuestion = (q, idx) => {
        const colors = [{ bg: '#fef9c3', text: '#854d0e', border: '#fde68a' }, { bg: '#dbeafe', text: '#1e3a8a', border: '#93c5fd' }, { bg: '#dcfce7', text: '#14532d', border: '#86efac' }, { bg: '#ffedd5', text: '#7c2d12', border: '#fdba74' }];
        const arr = Array.isArray(q.options) ? [...q.options] : Object.values(q.options);
        const shuffled = shuffleArray(arr.map((text, i) => ({ text, num: i + 1 })));
        const cards = shuffled.map((item) => `<div class="flex-1 max-w-[56px] min-w-[38px] h-14 rounded-xl flex items-center justify-center text-xl font-black cursor-grab select-none transition-all duration-200 active:cursor-grabbing border-2 border-b-[6px] active:border-b-2 active:translate-y-1 touch-none urutan-card" style="background-color: ${colors[(item.num - 1) % 4].bg}; color: ${colors[(item.num - 1) % 4].text}; border-color: ${colors[(item.num - 1) % 4].border};" data-val="${item.text.replace(/"/g, '&quot;')}">${item.num}</div>`).join('');
        return `<div class="bg-white p-5 rounded-3xl border border-gray-100 shadow-sm space-y-4 question-block" data-id="${q.id}" data-type="urutan"><div class="flex justify-between items-start gap-4"><p class="text-sm font-bold text-gray-800 leading-relaxed">${idx+1}. ${q.question}</p><span class="px-2 py-1 bg-teal-50 text-teal-600 text-[9px] font-black rounded-lg border border-teal-100 uppercase tracking-tighter shrink-0">Puzzle</span></div>${generateMediaHtml(q)}<div class="p-6 bg-gray-50 border-2 border-dashed border-gray-200 rounded-3xl flex flex-col items-center gap-4"><div class="sortable-list flex flex-nowrap justify-center items-center gap-2 sm:gap-3 w-full min-h-[70px]" id="sortable-${q.id}">${cards}</div></div><input type="hidden" name="q-${q.id}" id="ans-${q.id}" value='${JSON.stringify(shuffled.map(s => s.text)).replace(/"/g, '&quot;')}'></div>`;
    };

    const renderQuestions = () => {
        const container = document.getElementById('questionsList');
        if (questions.length === 0) {
            container.innerHTML = '<p class="text-xs text-gray-400 italic bg-gray-50 p-4 rounded-xl text-center border border-gray-100">Belum ada soal untuk pertemuan ini.</p>';
            document.getElementById('btnEarlyFinish').classList.add('hidden');
            return;
        }
        container.innerHTML = questions.map((q, idx) => {
            if (q.type === 'drag') return renderDragDropQuestion(q, idx);
            if (q.type === 'tf') return renderTrueFalseQuestion(q, idx);
            if (q.type === 'urutan') return renderUrutanQuestion(q, idx); 
            return renderPilganQuestion(q, idx);
        }).join('');
        
        if (typeof Sortable !== 'undefined') {
            document.querySelectorAll('.sortable-list').forEach(list => {
                const qId = list.closest('.question-block').dataset.id;
                new Sortable(list, {
                    animation: 350, delay: 150, delayOnTouchOnly: true, ghostClass: 'sortable-ghost', dragClass: 'sortable-drag',
                    onEnd: () => {
                        isDirty = true;
                        document.getElementById(`ans-${qId}`).value = JSON.stringify(Array.from(list.children).map(li => li.dataset.val));
                        executeAutoSave();
                    }
                });
            });
        }
    };

    window.fillBlank = (qId, btn) => {
        isDirty = true; const block = document.querySelector(`.question-block[data-id="${qId}"]`);
        const emptySlot = block.querySelector('.blank-slot:empty');
        if (emptySlot) { emptySlot.innerText = btn.innerText; emptySlot.dataset.key = btn.dataset.key; btn.classList.add('hidden'); updateDragAnswer(qId, block); }
    };
    window.removeBlank = (slot) => {
        isDirty = true; if (!slot.innerText) return;
        const qId = slot.dataset.q; const block = document.querySelector(`.question-block[data-id="${qId}"]`);
        const btn = block.querySelector(`.word-btn[data-key="${slot.dataset.key}"]`); if (btn) btn.classList.remove('hidden');
        slot.innerText = ''; delete slot.dataset.key; updateDragAnswer(qId, block);
    };
    const updateDragAnswer = (qId, block) => {
        document.getElementById(`ans-${qId}`).value = Array.from(block.querySelectorAll('.blank-slot')).map(s => s.dataset.key || '').join(',');
        executeAutoSave();
    };

// ==========================================
    // 5. VALIDATION & AUTO-SAVE (UX UPDATED)
    // ==========================================
    const validate = () => {
        const totalQs = questions.length + 3; let answered = 0;
        document.querySelectorAll('.question-block').forEach(block => {
            const qId = block.dataset.id; const type = block.dataset.type || 'pilgan';
            if (type === 'drag') {
                const reqLen = block.querySelectorAll('.blank-slot').length;
                if (document.getElementById(`ans-${qId}`).value.split(',').filter(Boolean).length === reqLen && reqLen > 0) answered++;
            } else if (type === 'urutan') answered++;
            else if (block.querySelector(`input[name="q-${qId}"]:checked`)) answered++;
        });
        if (document.querySelector('input[name="q_akhlak"]:checked')) answered++;
        if (document.querySelector('input[name="q_disiplin"]:checked')) answered++;
        if (document.querySelector('input[name="q_aktif"]:checked')) answered++;
        
        if(elProgressBar) elProgressBar.style.width = `${totalQs > 0 ? (answered / totalQs) * 100 : 0}%`;

        // [UX BARU] Logika Validasi Bertingkat (Anti Asal Kirim)
        const isAllAnswered = answered >= totalQs;
        const reviewContainer = document.getElementById('reviewCheckboxContainer');
        const checkReview = document.getElementById('checkReview');

        if (isAllAnswered) {
            // 1. Soal beres? Munculin Kotak Janji
            if (reviewContainer.classList.contains('hidden')) {
                reviewContainer.classList.remove('hidden');
                setTimeout(() => reviewContainer.classList.remove('opacity-0', 'translate-y-4'), 10);
            }
            
            // 2. Tombol Kirim HANYA nyala kalau kotak janji dicentang
            if (checkReview && checkReview.checked) {
                btnSubmitGlobal.disabled = false;
                // [FIX BUG] Kembalikan teks tombol ke kondisi semula, buang spinnernya!
                btnSubmitGlobal.innerHTML = 'Kirim Semua Jawaban';
                if (!isEvaluatingExtraLife) {
                    btnSubmitGlobal.classList.replace('bg-gray-200', 'bg-green-600'); 
                    btnSubmitGlobal.classList.replace('text-gray-400', 'text-white'); 
                    btnSubmitGlobal.classList.remove('cursor-not-allowed');
                }
            } else {
                btnSubmitGlobal.disabled = true;
                // [FIX BUG] Ubah teks biar jelas kenapa belum bisa diklik
                btnSubmitGlobal.innerHTML = '<i class="fa-solid fa-lock mr-1"></i> Centang Janji di Atas';
                if (!isEvaluatingExtraLife) {
                    btnSubmitGlobal.classList.replace('bg-green-600', 'bg-gray-200'); 
                    btnSubmitGlobal.classList.replace('text-white', 'text-gray-400'); 
                    btnSubmitGlobal.classList.add('cursor-not-allowed');
                }
            }
        } else {
            // Kalau ada jawaban yang mendadak dikosongin lagi, tarik balik kotaknya
            reviewContainer.classList.add('opacity-0', 'translate-y-4');
            setTimeout(() => reviewContainer.classList.add('hidden'), 300);
            if (checkReview) checkReview.checked = false; // Reset centangnya
            
            btnSubmitGlobal.disabled = true;
            // [FIX BUG] Teks saat masih ada soal yang kosong
            btnSubmitGlobal.innerHTML = 'Kirim Semua Jawaban';
            if (!isEvaluatingExtraLife) {
                btnSubmitGlobal.classList.replace('bg-green-600', 'bg-gray-200'); 
                btnSubmitGlobal.classList.replace('text-white', 'text-gray-400'); 
                btnSubmitGlobal.classList.add('cursor-not-allowed');
            }
        }
    };

    // Dengarkan saat anak menceklis/un-ceklis kotak janji
    document.getElementById('checkReview')?.addEventListener('change', validate);

    // [UX BARU] Delay Konfirmasi agar anak tidak double tap
    document.getElementById('btnEarlyFinish').onclick = () => {
        document.getElementById('modalEarlyFinish').classList.replace('hidden', 'flex');
        const btnConfirm = document.getElementById('btnConfirmEarlyFinish');
        let count = 3;
        
        btnConfirm.disabled = true;
        btnConfirm.className = 'flex-1 py-3.5 bg-gray-200 text-gray-400 font-bold rounded-2xl cursor-not-allowed transition-all';
        btnConfirm.innerText = `Tunggu (${count})`;
        
        window.earlyFinishInterval = setInterval(() => {
            count--;
            if(count > 0) {
                btnConfirm.innerText = `Tunggu (${count})`;
            } else {
                clearInterval(window.earlyFinishInterval);
                btnConfirm.disabled = false;
                btnConfirm.innerText = 'Ya, Kunci';
                btnConfirm.className = 'flex-1 py-3.5 bg-amber-500 text-white font-bold rounded-2xl shadow-lg shadow-amber-500/30 active:scale-95 transition-all';
            }
        }, 1000);
    };

    window.closeEarlyFinishModal = () => {
        clearInterval(window.earlyFinishInterval);
        document.getElementById('modalEarlyFinish').classList.replace('flex', 'hidden');
    };

    window.confirmEarlyFinish = () => {
        finalTimeTaken = (parsedWeek === 1 ? 105 : 180) - timeLeft; 
        timeLeft = 0; 
        updateTimerUI(); 
        clearInterval(timerInterval); 
        disableAcademicSection(); 
        closeEarlyFinishModal();
    };

    const _saveDraftAnswers = () => {
        const answers = {};
        document.querySelectorAll('.question-block').forEach(block => {
            const qId = block.dataset.id; const type = block.dataset.type || 'pilgan'; let sel;
            if (type === 'drag') sel = document.getElementById(`ans-${qId}`).value;
            else if (type === 'urutan') sel = JSON.parse(document.getElementById(`ans-${qId}`).value || '[]');
            else sel = block.querySelector(`input[name="q-${qId}"]:checked`)?.value;
            if (sel) answers[qId] = sel;
        });
        const psych = {
            akhlak: document.querySelector('input[name="q_akhlak"]:checked')?.value,
            disiplin: document.querySelector('input[name="q_disiplin"]:checked')?.value,
            aktif: document.querySelector('input[name="q_aktif"]:checked')?.value,
        };
        localStorage.setItem(ansKey, JSON.stringify({ answers, psych }));
        validate();
    };
    const executeAutoSave = debounce(_saveDraftAnswers, 500);

    const restoreDraftAnswers = () => {
        const saved = JSON.parse(localStorage.getItem(ansKey));
        if (!saved) return;
        if (saved.answers) {
            Object.entries(saved.answers).forEach(([qId, val]) => {
                const block = document.querySelector(`.question-block[data-id="${qId}"]`); if (!block) return;
                const type = block.dataset.type || 'pilgan';
                if (type === 'drag') {
                    const keys = val.split(','); const slots = block.querySelectorAll('.blank-slot');
                    keys.forEach((k, i) => { if (k && slots[i]) { const btn = block.querySelector(`.word-btn[data-key="${k}"]`); if(btn) { slots[i].innerText = btn.innerText; slots[i].dataset.key = k; btn.classList.add('hidden'); } } });
                    document.getElementById(`ans-${qId}`).value = val;
                } else if (type === 'urutan') {
                    const list = document.getElementById(`sortable-${qId}`);
                    if (list && Array.isArray(val)) val.forEach(text => { const li = Array.from(list.children).find(el => el.dataset.val === text); if (li) list.appendChild(li); });
                    document.getElementById(`ans-${qId}`).value = JSON.stringify(val);
                } else {
                    const r = document.querySelector(`input[name="q-${qId}"][value="${val}"]`); if(r) r.checked = true;
                }
            });
        }
        if (saved.psych) {
            if (saved.psych.akhlak) { const r = document.querySelector(`input[name="q_akhlak"][value="${saved.psych.akhlak}"]`); if (r) r.checked = true; }
            if (saved.psych.disiplin) { const r = document.querySelector(`input[name="q_disiplin"][value="${saved.psych.disiplin}"]`); if (r) r.checked = true; }
            if (saved.psych.aktif) { const r = document.querySelector(`input[name="q_aktif"][value="${saved.psych.aktif}"]`); if (r) r.checked = true; }
            validate();
        }
    };

    document.getElementById('questionsList').addEventListener('change', () => { isDirty = true; executeAutoSave(); window.MiawMascot?.resetTimer(); });
    document.getElementById('kuesionerContainer').addEventListener('change', () => { isDirty = true; executeAutoSave(); window.MiawMascot?.resetTimer(); });

    // ==========================================
    // 6. TIMER & UJIAN
    // ==========================================
    const disableAcademicSection = () => {
        document.getElementById('academicSection').classList.add('opacity-40', 'pointer-events-none', 'grayscale');
        document.getElementById('btnEarlyFinish').classList.add('hidden');
