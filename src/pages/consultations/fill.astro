    let vigPulseInterval = null;
    const setVignette = (active) => {
        const ids = ['vigLeft','vigRight','vigTop','vigBottom'];
        const grads = [
            'linear-gradient(to right,rgba(239,68,68,{a}),rgba(239,68,68,0))',
            'linear-gradient(to left,rgba(239,68,68,{a}),rgba(239,68,68,0))',
            'linear-gradient(to bottom,rgba(239,68,68,{a}),rgba(239,68,68,0))',
            'linear-gradient(to top,rgba(239,68,68,{a}),rgba(239,68,68,0))',
        ];
        if (!active) {
            clearInterval(vigPulseInterval);
            vigPulseInterval = null;
            ids.forEach((id, i) => document.getElementById(id).style.background = grads[i].replace('{a}','0'));
            return;
        }
        let bright = true;
        const applyVig = () => {
            const alpha = bright ? '0.65' : '0.25';
            ids.forEach((id, i) => document.getElementById(id).style.background = grads[i].replace('{a}', alpha));
            bright = !bright;
        };
        applyVig();
        clearInterval(vigPulseInterval);
        vigPulseInterval = setInterval(applyVig, 500);
    };

    const updateTimerUI = () => {
        const headerText = document.getElementById('headerTimerText');
        const floatText = document.getElementById('timerTextFloat');

        if (!isPreview && isQuizStarted && window.MiawMascot) {
            if (timeLeft === 60) {
                window.MiawMascot.say('large', () => `Gawat <strong>${currentStudentName}</strong>! Waktu sisa <strong>1 Menit</strong> lagi! Ayo ngebut!`, null, 'warning', 6000);
            }
            if (timeLeft === 30) {
                window.MiawMascot.say('large', () => `Miaww!! <strong>${currentStudentName}</strong> cepetan! Waktu tinggal <strong>30 Detik</strong>!`, null, 'warning', 6000);
            }
        }
        
        const maxTime = parsedWeek === 1 ? 105 : 180;
        const m = Math.floor(Math.max(0, timeLeft) / 60).toString().padStart(2, '0');
        const s = (Math.max(0, timeLeft) % 60).toString().padStart(2, '0');
        
        if (headerText) headerText.innerText = `${m}:${s}`;
        if (floatText) floatText.innerText = `${m}:${s}`;
        
        // Progress Ring Lingkaran
        const percentage = Math.max(0, (timeLeft / maxTime) * 100);
        const timerRing = document.getElementById('timerRing');
        const icon = document.getElementById('floatTimerIcon');
        const headerIcon = document.getElementById('headerTimerIcon');
        const headerDisplay = document.getElementById('headerTimerDisplay');
        
        // [PERBAIKAN 2C]: Kurang dari 30 Detik berubah Merah!
        if (timeLeft <= 30 && timeLeft > 0) {
            timerRing.style.background = `conic-gradient(#ef4444 ${percentage}%, #fee2e2 ${percentage}%)`;
            icon.className = 'fa-solid fa-stopwatch text-red-600 animate-ping';
            if(headerDisplay) headerDisplay.className = 'absolute left-1/2 -translate-x-1/2 px-6 py-2 bg-red-600 text-white rounded-full font-mono font-black text-xl border-2 border-red-700 shadow-md animate-pulse';
            if(headerIcon) headerIcon.className = 'fa-solid fa-stopwatch text-white mr-1';
            if (timeLeft <= 10) setVignette(true); else setVignette(false);
        } else if (timeLeft <= 0) {
            timerRing.style.background = `conic-gradient(#9ca3af 0%, #f3f4f6 100%)`;
            icon.className = 'fa-solid fa-stopwatch text-gray-400';
            if(headerDisplay) headerDisplay.className = 'absolute left-1/2 -translate-x-1/2 px-6 py-2 bg-gray-200 text-gray-500 rounded-full font-mono font-black text-xl border-2 border-gray-300 shadow-md';
            if(headerIcon) headerIcon.className = 'fa-solid fa-stopwatch text-gray-400 mr-1';
            setVignette(false);
        } else {
            timerRing.style.background = `conic-gradient(#16a34a ${percentage}%, #f0fdf4 ${percentage}%)`;
            icon.className = 'fa-solid fa-stopwatch text-green-600';
            if(headerDisplay) headerDisplay.className = 'absolute left-1/2 -translate-x-1/2 px-6 py-2 bg-white text-gray-800 rounded-full font-mono font-black text-xl border-2 border-gray-200 shadow-md transition-all';
            if(headerIcon) headerIcon.className = 'fa-solid fa-stopwatch text-green-500 mr-1';
            setVignette(false);
        }
    };

