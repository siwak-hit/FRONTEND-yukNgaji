    const updateTimerUI = () => {
        if (timeLeft <= 0 && isQuizStarted && !isEvaluatingExtraLife) disableAcademicSection();
        
        const m = Math.floor(Math.max(0, timeLeft) / 60).toString().padStart(2, '0');
        const s = (Math.max(0, timeLeft) % 60).toString().padStart(2, '0');
        
        if (elHeaderTimerText) elHeaderTimerText.innerText = `${m}:${s}`;
        if (elFloatText) elFloatText.innerText = `${m}:${s}`;
        
        const percentage = Math.max(0, (timeLeft / (parsedWeek === 1 ? 105 : 180)) * 100);
        if (timeLeft <= 30 && timeLeft > 0) {
            if(elTimerRing) elTimerRing.style.background = `conic-gradient(#ef4444 ${percentage}%, #fee2e2 ${percentage}%)`;
            if(elFloatTimerIcon) elFloatTimerIcon.className = 'fa-solid fa-stopwatch text-red-600 animate-ping';
            if(elHeaderTimerDisplay) elHeaderTimerDisplay.className = 'absolute left-1/2 -translate-x-1/2 px-6 py-2 bg-red-600 text-white rounded-full font-mono font-black text-xl border-2 border-red-700 shadow-md animate-pulse';
            if(elHeaderTimerIcon) elHeaderTimerIcon.className = 'fa-solid fa-stopwatch text-white mr-1';
            setVignette(timeLeft <= 10);
        } else if (timeLeft <= 0) {
            if(elTimerRing) elTimerRing.style.background = `conic-gradient(#9ca3af 0%, #f3f4f6 100%)`;
            if(elFloatTimerIcon) elFloatTimerIcon.className = 'fa-solid fa-stopwatch text-gray-400';
            if(elHeaderTimerDisplay) elHeaderTimerDisplay.className = 'absolute left-1/2 -translate-x-1/2 px-6 py-2 bg-gray-200 text-gray-500 rounded-full font-mono font-black text-xl border-2 border-gray-300 shadow-md';
            if(elHeaderTimerIcon) elHeaderTimerIcon.className = 'fa-solid fa-stopwatch text-gray-400 mr-1';
            setVignette(false);
        } else {
            if(elTimerRing) elTimerRing.style.background = `conic-gradient(#16a34a ${percentage}%, #f0fdf4 ${percentage}%)`;
            if(elFloatTimerIcon) elFloatTimerIcon.className = 'fa-solid fa-stopwatch text-green-600';
            if(elHeaderTimerDisplay) elHeaderTimerDisplay.className = 'absolute left-1/2 -translate-x-1/2 px-6 py-2 bg-white text-gray-800 rounded-full font-mono font-black text-xl border-2 border-gray-200 shadow-md transition-all';
            if(elHeaderTimerIcon) elHeaderTimerIcon.className = 'fa-solid fa-stopwatch text-green-500 mr-1';
            setVignette(false);
        }
    };

    const checkExistingSession = () => {
        if (isPreview) return;
        const savedEndTime = localStorage.getItem(timeKey);
        if (savedEndTime) {
            document.getElementById('startOverlay').classList.add('hidden');
            timeLeft = Math.floor((savedEndTime - Date.now()) / 1000);
            if (timeLeft > 0) startTest(false);
            else { timeLeft = 0; startTest(false); disableAcademicSection(); }
        }
    };

    document.getElementById('btnStart').onclick = () => {
        document.getElementById('startOverlay').classList.add('opacity-0', 'pointer-events-none');
        document.getElementById('countdownOverlay').classList.remove('hidden');
