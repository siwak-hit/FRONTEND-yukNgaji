    window.handleShopClick = async (itemKey) => {
        const btn = document.getElementById(`btn-shop-${itemKey}`); if (btn.disabled) return;
        if (studentInventory[itemKey] > 0) {
            if (itemKey === 'item_serang') openAttackModal();
