                boughtItemsThisSession[selectedItemToBuy] = true; 
                
                if (selectedItemToBuy === 'item_extra_life') {
                    window.showToast?.('success', 'Extra Life Siaga!', `Setelah dibeli, item langsung terpakai & otomatis berjaga mengoreksi jawabanmu.`);
                } else {
                    window.showToast?.('success', 'Berhasil!', `Item masuk ke inventori. Silakan klik lagi untuk memakai!`);
                }
                updateShopUI(); closeBuyModal();
                return;
            }

            const res = await fetch(`${API_URL}/api/shop/buy`, {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify({ student_id: studentId, item_type: selectedItemToBuy, week: parsedWeek })
            });

            const data = await res.json();
            if (data.status === 'success') {
                studentWallet = data.data.poin;
                studentInventory[selectedItemToBuy] = data.data[selectedItemToBuy];
                boughtItemsThisSession[selectedItemToBuy] = true;
                
                if (selectedItemToBuy === 'item_extra_life') {
                    window.showToast?.('success', 'Extra Life Siaga!', `Setelah dibeli, item langsung terpakai & otomatis berjaga mengoreksi jawabanmu.`);
                } else {
                    window.showToast?.('success', 'Berhasil!', `Item berhasil dibeli. Klik ikonnya di toko untuk menggunakannya!`);
                }
                updateShopUI(); closeBuyModal();
            } else throw new Error(data.message);
        } catch (error) {
            window.showToast?.('danger', 'Gagal Beli', error.message);
        } finally {
            btn.innerText = 'Beli Sekarang'; btn.disabled = false; closeBuyModal();
        }
    };

    window.executeBuyItem = async () => {
        const btn = document.getElementById('btnConfirmBuy');
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>'; btn.disabled = true;

        try {
            if (isPreview) {
                await new Promise(r => setTimeout(r, 600));
                studentWallet -= ITEM_DB[selectedItemToBuy].price;
                studentInventory[selectedItemToBuy] += 1;
                boughtItemsThisSession[selectedItemToBuy] = true; 
                
                if (selectedItemToBuy === 'item_extra_life') {
                    window.showToast?.('success', 'Extra Life Siaga!', `Setelah dibeli, item langsung terpakai & otomatis berjaga mengoreksi jawabanmu.`);
                } else {
                    window.showToast?.('success', 'Berhasil!', `Item masuk ke inventori. Silakan klik lagi untuk memakai!`);
                }
                updateShopUI(); closeBuyModal();
                return;
            }

            const res = await fetch(`${API_URL}/api/shop/buy`, {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify({ student_id: studentId, item_type: selectedItemToBuy, week: parsedWeek })
            });

            const data = await res.json();
            if (data.status === 'success') {
                studentWallet = data.data.poin;
                studentInventory[selectedItemToBuy] = data.data[selectedItemToBuy];
                boughtItemsThisSession[selectedItemToBuy] = true;
                
                if (selectedItemToBuy === 'item_extra_life') {
                    window.showToast?.('success', 'Extra Life Siaga!', `Setelah dibeli, item langsung terpakai & otomatis berjaga mengoreksi jawabanmu.`);
                } else {
                    window.showToast?.('success', 'Berhasil!', `Item berhasil dibeli. Klik ikonnya di toko untuk menggunakannya!`);
                }
                updateShopUI(); closeBuyModal();
            } else throw new Error(data.message);
        } catch (error) {
            window.showToast?.('danger', 'Gagal Beli', error.message);
        } finally {
            btn.innerText = 'Beli Sekarang'; btn.disabled = false; closeBuyModal();
        }
    };

    // Fungsi Render UI Toko (DIPERBAIKI)
    const updateShopUI = () => {
        const displayPoin = document.getElementById('currentPoinDisplay');
        if (displayPoin) displayPoin.innerText = studentWallet;

        Object.keys(ITEM_DB).forEach(key => {
            const btn = document.getElementById(`btn-shop-${key}`);
            if (!btn) return;
            
            const price = ITEM_DB[key].price;
            const isOwned = studentInventory[key] > 0;
            const isBought = boughtItemsThisSession[key];

            const titleEl = btn.querySelector('.item-title');
            const priceEl = btn.querySelector('.item-price');
            
            const oldBadge = btn.querySelector('.qty-badge');
            if (oldBadge) oldBadge.remove();

            btn.className = "h-24 bg-white rounded-2xl border border-gray-100 flex flex-col items-center justify-center transition-all group relative";
            btn.disabled = false;
            
            if (isOwned) {
                if (key === 'item_extra_life') {
                    btn.classList.add('bg-pink-50', 'border-pink-300', 'cursor-default');
                    titleEl.innerText = "AKTIF OTOMATIS";
                    titleEl.className = "text-[8px] font-black text-pink-700 mt-1 uppercase tracking-wider item-title";
                    priceEl.innerText = "";
                    btn.disabled = true;
                } else {
                    btn.classList.add('bg-indigo-50', 'border-indigo-300', 'cursor-pointer');
                    titleEl.innerText = "PAKAI SEKARANG";
                    titleEl.className = "text-[8px] font-black text-indigo-700 mt-1 uppercase tracking-wider item-title";
                    priceEl.innerText = "";
                }
                const newBadge = document.createElement('span');
                newBadge.className = "qty-badge absolute -top-2 -right-2 bg-indigo-600 text-white text-[10px] font-black w-5 h-5 rounded-full flex items-center justify-center border-2 border-white shadow-md";
                newBadge.innerText = studentInventory[key];
                btn.appendChild(newBadge);
            } 
            else if (isBought && !isOwned) {
                btn.classList.add('bg-gray-100', 'border-gray-200', 'opacity-50', 'grayscale', 'cursor-not-allowed');
                titleEl.className = "text-[10px] font-bold text-gray-700 mt-1 item-title";
                priceEl.innerText = "HABIS";
                btn.disabled = true;
            } 
            // [PERBAIKAN]: Kunci tombol dan jadikan abu-abu JIKA POIN KURANG DARI HARGA INFLASI
            else if (studentWallet < price) {
                btn.classList.add('bg-gray-50', 'border-gray-200', 'opacity-50', 'grayscale', 'cursor-not-allowed');
                titleEl.className = "text-[10px] font-bold text-gray-700 mt-1 item-title";
                priceEl.innerText = `💰 ${price}`;
                btn.disabled = true;
            } 
            else {
                btn.classList.add('hover:bg-indigo-50', 'hover:border-indigo-200', 'active:scale-95', 'cursor-pointer', 'shadow-sm');
                titleEl.className = "text-[10px] font-bold text-gray-700 mt-1 item-title";
                priceEl.innerText = price + " Poin";
                btn.disabled = false;
            }
        });

        // Update Vignette & Floating Active Items
        const vignette = document.getElementById('shieldVignette');
        if (vignette) {
            if (window.isShieldActive && isQuizStarted) vignette.classList.replace('opacity-0', 'opacity-100');
            else vignette.classList.replace('opacity-100', 'opacity-0');
        }

        const floatingItems = document.getElementById('floatingItems');
        const itemsContainer = document.getElementById('itemsTextContainer');
        if (isQuizStarted) {
            let activeHtml = '';
            if (window.isShieldActive) activeHtml += `<span class="text-base drop-shadow-sm animate-pulse" title="Perisai Aktif">🛡️</span>`;
            if (window.isDoubleScoreActive) activeHtml += `<span class="text-base drop-shadow-sm animate-pulse" title="Double Poin Aktif">✨</span>`;
            if (studentInventory.item_extra_life > 0) activeHtml += `<span class="text-base drop-shadow-sm animate-pulse" title="Extra Life Siaga">💖</span>`;

            if (activeHtml !== '') {
                floatingItems.classList.remove('hidden');
                floatingItems.classList.add('flex');
                itemsContainer.innerHTML = activeHtml;
            } else {
                floatingItems.classList.add('hidden');
                floatingItems.classList.remove('flex');
            }
        }
    };

    init();
</script>

