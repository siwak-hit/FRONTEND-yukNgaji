---
import Layout from '../../layouts/Layout.astro';
import NavbarGuru from '../../components/NavbarGuru.astro';
import Toast from '../../components/Toast.astro';
---

<Layout title="Sesi Belajar - yukNgaji">
    <div class="px-6 py-8 pb-32 min-h-screen">
        
        <header class="mb-8">
            <h1 class="text-2xl font-bold text-gray-800 tracking-tight">Mulai Sesi</h1>
            <p class="text-xs text-gray-500 font-medium mt-1 uppercase tracking-widest">Input nilai onboarding Anak</p>
        </header>

        <div id="examPortalBanner" class="mb-8 bg-gray-50 border-2 border-dashed border-gray-200 rounded-3xl p-6 text-gray-400 relative flex items-center justify-between transition-all duration-300">
            <div class="relative z-10 flex items-center gap-4">
                <div class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center">
                    <i class="fa-solid fa-spinner fa-spin text-xl text-gray-300"></i>
                </div>
                <div>
                    <h2 class="text-xl font-black mb-1 text-gray-400">Portal Ujian Siswa</h2>
                    <p class="text-[10px] font-bold">Mengecek ketersediaan ujian...</p>
                </div>
            </div>
        </div>

        <section id="subjectSection" class="mb-8">
            <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-4 ml-1">1. Pilih Mata Pelajaran</h3>
            <div class="grid grid-cols-3 gap-3">
                {['tajwid', 'fiqih', 'tauhid'].map((subject) => (
                    <button class="subject-btn p-4 bg-white border border-gray-100 rounded-2xl flex flex-col items-center gap-2 transition-all active:scale-95 shadow-sm" data-value={subject}>
                        <div class={`w-10 h-10 rounded-xl flex items-center justify-center ${subject === 'tajwid' ? 'bg-green-50 text-green-600' : subject === 'fiqih' ? 'bg-blue-50 text-blue-600' : 'bg-purple-50 text-purple-600'}`}>
                            <i class={`fa-solid ${subject === 'tajwid' ? 'fa-book-quran' : subject === 'fiqih' ? 'fa-hand-holding-heart' : 'fa-star-and-crescent'}`}></i>
                        </div>
                        <span class="text-[10px] font-bold text-gray-700 capitalize">{subject}</span>
                    </button>
                ))}
            </div>
        </section>

        <section id="weekSection" class="mb-8 opacity-30 pointer-events-none transition-all duration-500">
            <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-4 ml-1">2. Pertemuan Ke-</h3>
            <div id="weekContainer" class="flex gap-3 overflow-x-auto no-scrollbar pb-2"></div>
        </section>

        <section id="studentSection" class="hidden animate-slide-up">
            <div class="flex flex-col gap-4 mb-6">
                <div class="flex justify-between items-center">
                    <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest ml-1">3. Pilih Anak</h3>
                    <span id="sessionBadge" class="text-[9px] bg-green-600 text-white px-3 py-1 rounded-full font-bold shadow-sm shadow-green-200"></span>
                </div>
                <div class="relative">
                    <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
                    <input type="text" id="studentSearch" class="w-full pl-10 pr-4 py-3 bg-white border border-gray-100 rounded-2xl text-xs focus:ring-2 focus:ring-green-500 transition-all shadow-sm" placeholder="Cari nama Anak...">
                </div>
            </div>
            <div id="studentGrid" class="grid grid-cols-2 gap-3"></div>
        </section>

    </div>

    <div id="modalExamPortal" class="fixed inset-0 bg-black/80 z-[100] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-md rounded-[2rem] p-6 shadow-2xl animate-slide-up relative">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-black text-gray-800 text-lg"><i class="fa-solid fa-rocket text-indigo-500 mr-2"></i> Setup Ujian</h3>
                <button onclick="closeExamPortal()" class="text-gray-400 hover:text-gray-600 w-8 h-8 flex items-center justify-center bg-gray-100 rounded-full active:scale-95"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="space-y-5">
                <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">1. Pilih Ujian (Siswa Belum Selesai)</label>
                    <select id="portalExamSelect" class="w-full mt-1 px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm font-bold text-gray-700 outline-none focus:ring-2 focus:ring-indigo-500">
                        <option value="">Memuat ujian aktif...</option>
                    </select>
                </div>
                
                <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">2. Pilih Siswa (Pengerja)</label>
                    <div class="relative mt-2 mb-3">
                        <i class="fa-solid fa-magnifying-glass absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
                        <input type="text" id="portalStudentSearch" class="w-full pl-9 pr-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl text-xs font-medium focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="Cari nama siswa...">
                    </div>

                    <div id="portalStudentList" class="grid grid-cols-2 gap-2 max-h-48 overflow-y-auto no-scrollbar border border-gray-100 p-2 rounded-xl bg-gray-50/50">
                        </div>
                    <input type="hidden" id="portalStudentSelectValue" value="">
                </div>
                
                <button onclick="startExam()" class="w-full py-4 mt-2 bg-indigo-600 text-white font-black rounded-2xl shadow-lg shadow-indigo-600/30 active:scale-95 transition-all text-sm uppercase tracking-wider">
                    Mulai Ujian!
                </button>
            </div>
        </div>
    </div>

    <div id="modalVerifyStudent" class="fixed inset-0 bg-gray-900/70 z-[100] hidden items-center justify-center p-4 backdrop-blur-sm transition-opacity duration-300 opacity-0">
        <div class="bg-white w-full max-w-sm rounded-[2rem] shadow-2xl text-center transform scale-95 transition-transform duration-300 relative overflow-hidden" id="modalVerifyStudentBox">
            
            <div class="w-full h-32 bg-indigo-500 relative">
                <img id="verifyCoverImage" src="https://images.unsplash.com/photo-1503676260728-1c00da094a0b?q=80&w=600&auto=format&fit=crop" class="w-full h-full object-cover mix-blend-overlay opacity-60" alt="Kids Cover">
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            </div>
            
            <div class="relative -mt-12 flex justify-center z-10">
                <div class="w-24 h-24 bg-white rounded-full border-[6px] border-white shadow-lg flex items-center justify-center text-4xl font-black text-indigo-600" id="verifyInitials">
                    NA
                </div>
            </div>
            
            <div class="px-6 pb-6 pt-3">
                <h3 class="text-indigo-400 font-black text-[10px] mb-1 uppercase tracking-widest">Tunggu Sebentar...</h3>
                <h2 class="text-2xl font-black text-gray-800 mb-2 uppercase line-clamp-2 leading-tight" id="verifyName">NAMA SISWA</h2>
                
                <div class="bg-amber-50 border-2 border-dashed border-amber-200 p-3.5 rounded-2xl mb-6 mt-3">
                    <p class="text-xs font-bold text-amber-700 leading-relaxed">
                        👀 Coba dibaca lagi namanya...<br>
                        Beneran ini kamu? Jangan sampai kamu ngerjain tugas punya temenmu lho ya! 🤭
                    </p>
                </div>

                <div class="space-y-3">
                    <button onclick="closeVerifyStudent()" class="w-full py-3.5 bg-gray-100 hover:bg-gray-200 text-gray-500 font-bold rounded-2xl transition-all shadow-sm active:scale-95 text-xs">
                        🙈 Eh Bukan, Salah Pencet!
                    </button>
                    <button id="btnProceedStudent" class="w-full py-4 bg-gray-200 text-gray-400 font-black rounded-2xl transition-all cursor-not-allowed flex items-center justify-center gap-2 text-sm" disabled>
                        <i class="fa-solid fa-hourglass-half" id="proceedLockIcon"></i>
                        <span id="proceedText">Tahan dulu (3)...</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- [BARU] MODAL PR TERLAMBAT (DEADLINE HABIS) -->
    <div id="modalPRLate" class="fixed inset-0 bg-black/80 z-[200] hidden items-center justify-center p-4 backdrop-blur-md transition-opacity duration-300 opacity-0">
        <div class="bg-white w-full max-w-sm rounded-[2rem] shadow-2xl text-center transform scale-95 transition-transform duration-300 relative overflow-hidden p-6 border-4 border-red-500" id="modalPRLateBox">
            
            <div class="w-20 h-20 bg-red-100 text-red-600 rounded-full flex items-center justify-center text-4xl mx-auto mb-4 border-4 border-white shadow-lg relative z-10">
                <i class="fa-solid fa-clock-rotate-left"></i>
            </div>
            
            <h2 class="text-2xl font-black text-gray-800 mb-1 uppercase tracking-tight">Yahh, Kamu Telat!</h2>
            <p class="text-xs text-gray-500 font-bold mb-4">Waktu pengerjaan tugas PR ini sudah habis.</p>
            
            <div class="bg-red-50 border border-red-100 rounded-2xl p-4 mb-6">
                <p class="text-[10px] font-black text-red-800 uppercase tracking-widest mb-1">Batas Waktu Sebelumnya:</p>
                <p id="lateDeadlineText" class="text-sm font-bold text-red-600">--</p>
            </div>

            <p class="text-[11px] text-gray-600 font-medium leading-relaxed mb-6 bg-gray-50 p-3 rounded-xl border border-gray-100">
                <i class="fa-solid fa-circle-info text-blue-500 mr-1"></i> Silakan hubungi <b>Kak Aziz (Ustadz)</b> untuk meminta perpanjangan waktu (dispensasi).
            </p>

            <button onclick="closePRLateModal()" class="w-full py-4 bg-red-600 hover:bg-red-700 text-white font-black rounded-2xl shadow-lg active:scale-95 transition-all text-sm uppercase tracking-widest">
                Saya Mengerti
            </button>
        </div>
    </div>

<!-- MODAL SATPAM PR (70% Video, 30% Text) -->
<div id="modalSatpamPR" class="fixed inset-0 bg-gray-950/95 z-[120] hidden items-center justify-center p-4 backdrop-blur-md transition-opacity duration-300 opacity-0">
    <div class="bg-white w-full max-w-sm rounded-[2rem] shadow-2xl overflow-hidden transform scale-95 transition-transform duration-300 flex flex-col h-[80vh] max-h-[600px] relative" id="modalSatpamBox">
        
        <!-- 70% Area Kamera -->
        <div class="relative h-[70%] bg-gray-900 overflow-hidden flex items-center justify-center z-10">
            <!-- Video Stream (di-mirror) -->
            <video id="satpamVideo" class="absolute inset-0 w-full h-full object-cover transform scale-x-[-1]" autoplay playsinline muted></video>
            
            <!-- Masking (Luar gelap, tengah terang) -->
            <div class="absolute inset-0 pointer-events-none flex items-center justify-center z-30">
                <div class="w-48 h-64 rounded-[4rem] shadow-[0_0_0_2000px_rgba(0,0,0,0.7)] pointer-events-none transition-all duration-300" id="satpamMask"></div>
            </div>
            
            <!-- Lingkaran Target (Z-INDEX 40: PALING ATAS DARI VIDEO) -->
            <div id="satpamTargetCircle" class="absolute w-48 h-64 border-4 border-dashed border-white/70 rounded-[4rem] transition-colors duration-300 pointer-events-none flex items-center justify-center z-40">
                <span id="satpamCountdown" class="text-white text-7xl font-black drop-shadow-xl hidden">3</span>
            </div>

            <canvas id="satpamCanvas" class="hidden"></canvas>
            
            <!-- Efek Pura-Pura Verifikasi (Z-INDEX 20: DI BAWAH LINGKARAN) -->
            <div id="satpamScanEffect" class="absolute inset-0 bg-indigo-600/40 hidden flex-col items-center justify-center backdrop-blur-sm z-20">
                <div class="absolute top-0 w-full h-2 bg-white animate-pulse shadow-[0_0_20px_white]" id="scannerLine" style="animation: scan 2s linear infinite;"></div>
                <i class="fa-solid fa-fingerprint text-6xl text-white mb-3"></i>
                <p class="text-white text-[10px] font-black uppercase tracking-widest text-center px-4" id="satpamProcessText">Memverifikasi Wajah...</p>
            </div>
        </div>
        
        <!-- 30% Area Teks & Instruksi (Z-INDEX 50: PALING DEPAN) -->
        <div class="h-[30%] bg-white p-5 flex flex-col justify-center text-center relative z-50">
            <div class="absolute -top-6 left-1/2 -translate-x-1/2 w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-lg border-4 border-gray-50 z-50">
                <i class="fa-solid fa-shield-halved text-indigo-500 text-xl"></i>
            </div>
            
            <h3 class="text-indigo-500 font-black text-[10px] mb-1 uppercase tracking-widest mt-2">TUGAS PR: <span id="satpamSubject"></span></h3>
            <h2 class="text-xl font-black text-gray-800 mb-2 uppercase line-clamp-1" id="satpamStudentName">NAMA SISWA</h2>
            
            <p id="satpamInstruction" class="text-xs font-bold text-gray-500 leading-relaxed bg-gray-50 p-2 rounded-xl border border-gray-100">
                Posisikan wajahmu di dalam garis untuk verifikasi.
            </p>

            <button onclick="closeSatpam()" id="btnCancelSatpam" class="mt-3 text-[10px] text-gray-400 font-bold uppercase tracking-widest hover:text-red-500 transition-colors">
                Batalkan
            </button>
        </div>
    </div>
</div>
    <NavbarGuru activeMenu="chat" />
    <Toast />
</Layout>

<script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js" is:inline></script>

<script>
    // =======================================================================
    // 1. GLOBAL STATE & INISIALISASI
    // =======================================================================
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const urlParams = new URLSearchParams(window.location.search);
    
    // [FIX] Tangkap raw token dan cegah string "null" merusak sistem
    const rawPrToken = urlParams.get('pr_token');
    const paramPrToken = (rawPrToken && rawPrToken !== 'null') ? rawPrToken : null;
    const isPRMode = urlParams.get('pr') === 'true' || !!paramPrToken;
    
    // Logika Token Cerdas (Gabungan Guru & Murid)
    let token = localStorage.getItem('token'); 
    if (paramPrToken) {
        token = paramPrToken;
        sessionStorage.setItem('temp_pr_token', paramPrToken);
    } else if (sessionStorage.getItem('temp_pr_token') && sessionStorage.getItem('temp_pr_token') !== 'null') {
        token = sessionStorage.getItem('temp_pr_token');
    }
    
    // Kalau bener-bener gak ada token, baru tendang
    if (!token) {
        window.location.replace('/');
        throw new Error("Akses ditolak: Token tidak ditemukan.");
    }

    // Cache Memory (Biar HP nggak capek fetch berulang kali)
    const STATE = {
        subject: isPRMode ? urlParams.get('subject') : null,
        week: isPRMode ? urlParams.get('week') : null,
        students: [],
        completedIds: [],
        cachedWeeks: {},
        cachedLocks: {},
        activeExams: [],
        examCompletion: {},
        currentSatpamId: null,
        currentSatpamName: null,
        satpamStream: null,
        satpamLoopId: null
    };

    // =======================================================================
    // 2. SETUP UI AWAL (MODE GURU VS MODE MURID)
    // =======================================================================
    const initUI = () => {
        if (isPRMode) {
            document.querySelector('header h1').innerText = "Pilih Nama Kamu";
            document.querySelector('header p').innerText = "Pastikan klik namamu sendiri ya!";
            
            const hideElements = ['examPortalBanner', 'subjectSection', 'weekSection'];
            hideElements.forEach(id => { const el = document.getElementById(id); if (el) el.style.display = 'none'; });
            
            const step3Title = document.querySelector('#studentSection h3');
            if (step3Title) step3Title.innerText = "DAFTAR SISWA KELAS";
            
            const bottomNav = document.querySelector('nav') || document.querySelector('.fixed.bottom-0.w-full');
            if (bottomNav) bottomNav.style.display = 'none';

            if (STATE.subject && STATE.week) fetchStudents();
        } else {
            checkActiveExams();
            bindSubjectButtons();
        }
    };

    // =======================================================================
    // 3. CORE FUNCTIONS (Sesi Belajar & Fetch Data)
    // =======================================================================
    const bindSubjectButtons = () => {
        document.querySelectorAll('.subject-btn').forEach(btn => {
            btn.addEventListener('click', async () => {
                // UI Highlight
                document.querySelectorAll('.subject-btn').forEach(b => b.classList.remove('border-green-600', 'ring-2', 'ring-green-100'));
                btn.classList.add('border-green-600', 'ring-2', 'ring-green-100');
                
                STATE.subject = btn.getAttribute('data-value');
                
                // Fetch Lock Status & Weeks Paralel (Biar Cepat)
                try {
                    const [resWeeks, resLocks] = await Promise.all([
                        STATE.cachedWeeks[STATE.subject] ? Promise.resolve({ data: STATE.cachedWeeks[STATE.subject] }) : fetch(`${API_URL}/api/onboarding/available-weeks/${STATE.subject}`, { headers: { 'Authorization': `Bearer ${token}` }}).then(r => r.json()),
                        STATE.cachedLocks[STATE.subject] ? Promise.resolve({ data: STATE.cachedLocks[STATE.subject] }) : fetch(`${API_URL}/api/onboarding/pr-locks/${STATE.subject}`, { headers: { 'Authorization': `Bearer ${token}` }}).then(r => r.json())
                    ]);

                    STATE.cachedWeeks[STATE.subject] = resWeeks.data;
                    STATE.cachedLocks[STATE.subject] = resLocks.data || [];
                    
                    renderWeekButtons(resWeeks.data, resLocks.data || []);
                    document.getElementById('weekSection').classList.remove('opacity-30', 'pointer-events-none');
                    document.getElementById('studentSection').classList.add('hidden');
                } catch (e) { console.error("Gagal memuat data minggu:", e); }
            });
        });
    };

    const renderWeekButtons = (weeksArray, lockedWeeks = []) => {
        const container = document.getElementById('weekContainer');
        container.innerHTML = '';
        if (!weeksArray || weeksArray.length === 0) {
            container.innerHTML = `<div class="p-4 text-xs text-orange-500 bg-orange-50 rounded-xl w-full">Belum ada materi...</div>`;
            return;
        }
        
        weeksArray.forEach(weekNum => {
            const isLocked = lockedWeeks.includes(weekNum);
            const btn = document.createElement('button');
            
            if (isLocked) {
                btn.className = "flex-shrink-0 w-12 h-12 bg-indigo-50 border border-indigo-100 rounded-xl text-indigo-400 opacity-90 flex flex-col items-center justify-center shadow-inner transition-all active:scale-95";
                btn.innerHTML = `<i class="fa-solid fa-house-laptop text-[10px] mb-0.5 text-indigo-500"></i><span class="text-[10px] font-black">${weekNum}</span>`;
                btn.onclick = () => window.showToast?.('info', 'Tugas PR 🏠', `Pertemuan ${weekNum} adalah PR. Silakan instruksikan siswa untuk mengerjakan dari HP masing-masing.`);
            } else {
                btn.className = "week-btn flex-shrink-0 w-12 h-12 bg-white border border-gray-100 rounded-xl font-bold text-gray-500 transition-all active:scale-90 shadow-sm flex items-center justify-center";
                btn.innerText = weekNum;
                btn.onclick = () => {
                    document.querySelectorAll('.week-btn').forEach(b => b.classList.remove('bg-green-600', 'text-white'));
                    btn.classList.add('bg-green-600', 'text-white');
                    STATE.week = weekNum;
                    fetchStudents();
                };
            }
            container.appendChild(btn);
        });
    };

    const fetchStudents = async () => {
        if (!STATE.subject || !STATE.week) return;
        try {
            document.getElementById('studentSection').classList.remove('hidden');
            document.getElementById('sessionBadge').innerText = `${STATE.subject.toUpperCase()} - MG ${STATE.week}`;

            // Fetch Paralel: Status Pengerjaan & Daftar Siswa
            const [resStatus, resStd] = await Promise.all([
                fetch(`${API_URL}/api/onboarding/status?subject=${STATE.subject}&week=${STATE.week}`, { headers: { 'Authorization': `Bearer ${token}` }}).then(r => r.json()),
                STATE.students.length > 0 ? Promise.resolve({ data: STATE.students }) : fetch(`${API_URL}/api/students/stats/enriched`, { headers: { 'Authorization': `Bearer ${token}` }}).then(r => r.json())
            ]);

            STATE.completedIds = resStatus.data || [];
            if (STATE.students.length === 0) STATE.students = resStd.data || [];
            
            renderStudentGrid(STATE.students, STATE.completedIds);
            if (!isPRMode) document.getElementById('studentSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
        } catch (e) { console.error("Gagal sinkronisasi data siswa:", e); }
    };

    const renderStudentGrid = (students, doneIds) => {
        const grid = document.getElementById('studentGrid');
        if (!students || students.length === 0) return grid.innerHTML = '<p class="col-span-2 text-center py-10 text-gray-400 text-xs italic">Siswa tidak ditemukan...</p>';
        
        grid.innerHTML = students.map(s => {
            const isFinished = doneIds.includes(s.id);
            const photoUrl = s.photo_url || '';
            const safeName = s.name.replace(/'/g, "\\'");
            return `
                <div class="student-card ${isFinished ? 'opacity-40 grayscale pointer-events-none' : 'active:scale-95 cursor-pointer'} bg-white p-4 rounded-3xl border border-gray-50 shadow-sm flex flex-col items-center text-center gap-3 transition-all"
                    ${!isFinished ? `onclick="openVerifyStudent('${s.id}', '${safeName}', '${photoUrl}')"` : ''}>
                    <div class="relative">
                        <div class="w-14 h-14 bg-green-50 text-green-600 rounded-2xl flex items-center justify-center text-lg font-bold">${s.name.substring(0, 2).toUpperCase()}</div>
                        ${isFinished ? '<div class="absolute -top-1 -right-1 w-5 h-5 bg-green-500 text-white rounded-full flex items-center justify-center text-[10px] shadow-sm"><i class="fa-solid fa-check"></i></div>' : ''}
                    </div>
                    <div>
                        <h4 class="font-bold text-gray-800 text-[11px] line-clamp-1 capitalize">${s.name}</h4>
                        <p class="text-[9px] text-gray-400 font-bold uppercase mt-1 tracking-tighter">${isFinished ? 'SELESAI' : s.grade}</p>
                    </div>
                </div>
            `;
        }).join('');
    };

    document.getElementById('studentSearch').addEventListener('input', (e) => {
        const term = e.target.value.toLowerCase();
        renderStudentGrid(STATE.students.filter(s => s.name.toLowerCase().includes(term)), STATE.completedIds);
    });

    // =======================================================================
    // 4. SATPAM PINTAR (AI FACE DETECTOR - OPTIMIZED)
    // =======================================================================
    window.openVerifyStudent = async (id, name, imageUrl) => {
        // [BARU] LOGIKA PENGECEKAN DEADLINE PR (FIXED FAIL-OPEN BUG)
        if (isPRMode) {
            try {
                // Fetch detail PR lock dari backend
                const res = await fetch(`${API_URL}/api/onboarding/pr-locks-detail?subject=${STATE.subject}&week=${STATE.week}`, { headers: { 'Authorization': `Bearer ${token}` }});
                const prDetail = await res.json();
                
                const prData = Array.isArray(prDetail.data) ? prDetail.data[0] : prDetail.data;

                if (prData) {
                    const now = new Date();
                    
                    // Parse JSONB dengan super aman (Looping kalau stringified berkali-kali)
                    let extendedList = prData.extended_students;
                    try {
                        while (typeof extendedList === 'string') {
                            extendedList = JSON.parse(extendedList);
                        }
                    } catch(e) {}

                    if (!Array.isArray(extendedList)) extendedList = [];

                    const extRecord = extendedList.find(ext => ext.student_id === id);

                    if (extRecord) {
                        // KASUS 1: PUNYA DISPENSASI
                        const extDeadline = new Date(extRecord.until);
                        
                        console.log("⏱️ Cek Waktu Dispensasi:");
                        console.log("Sekarang:", now.toLocaleString());
                        console.log("Batas Dispensasi:", extDeadline.toLocaleString());

                        if (now > extDeadline) {
                            openPRLateModal(extRecord.until);
                            return; // STOP MUTLAK! Jangan buka kamera!
                        }
                        window.showToast?.('info', 'Dispensasi Aktif', 'Akses perpanjangan berhasil. Ingat, nilaimu dipotong 10%!');
                        
                    } else if (prData.deadline_at) {
                        // KASUS 2: GAK PUNYA DISPENSASI
                        const originalDeadline = new Date(prData.deadline_at);

                        console.log("⏱️ Cek Waktu Normal:");
                        console.log("Sekarang:", now.toLocaleString());
                        console.log("Batas Normal:", originalDeadline.toLocaleString());

                        if (now > originalDeadline) {
                            openPRLateModal(prData.deadline_at);
                            return; // STOP MUTLAK! Jangan buka kamera!
                        }
                    }
                }
            } catch(e) {
                console.error("Gagal ngecek deadline:", e);
                window.showToast?.('danger', 'Error', 'Gagal memverifikasi waktu dengan server.');
                return; // STOP MUTLAK! Kalau server error, fail-closed biar aman.
            }

            // Kalau BENAR-BENAR lolos semua penjagaan di atas, baru buka Satpam!
            return openSatpamModal(id, name);
        }
        
        // ==========================================
        // Logika Modal Verifikasi Guru Biasa (Bukan PR)
        // ==========================================
        document.getElementById('verifyInitials').innerText = name.substring(0, 2).toUpperCase();
        document.getElementById('verifyName').innerText = name;
        const coverImg = document.getElementById('verifyCoverImage');
        coverImg.src = (imageUrl && imageUrl.trim() !== '' && imageUrl !== 'null') ? imageUrl : 'https://images.unsplash.com/photo-1503676260728-1c00da094a0b?q=80&w=600&auto=format&fit=crop';
        
        pendingStudentUrl = `/consultations/fill?id=${id}&subject=${STATE.subject}&week=${STATE.week}`;
        
        const modal = document.getElementById('modalVerifyStudent');
        modal.classList.replace('hidden', 'flex');
        setTimeout(() => { modal.classList.replace('opacity-0', 'opacity-100'); document.getElementById('modalVerifyStudentBox').classList.replace('scale-95', 'scale-100'); }, 10);
        
        const btn = document.getElementById('btnProceedStudent');
        btn.disabled = true; btn.className = 'w-full py-4 bg-gray-200 text-gray-400 font-black rounded-2xl cursor-not-allowed flex items-center justify-center gap-2 text-sm';
        let timeLeft = 3; document.getElementById('proceedText').innerText = `Tunggu ya (${timeLeft})...`;
        
        window.verifyTimer = setInterval(() => {
            timeLeft--;
            if (timeLeft > 0) document.getElementById('proceedText').innerText = `Tunggu ya (${timeLeft})...`;
            else {
                clearInterval(window.verifyTimer); btn.disabled = false;
                btn.className = 'w-full py-4 bg-green-500 hover:bg-green-600 text-white font-black rounded-2xl shadow-lg active:scale-95 flex items-center justify-center gap-2 text-sm';
                document.getElementById('proceedText').innerText = 'IYA BENAR, INI AKU! 🚀';
            }
        }, 1000);
    };

    let pendingStudentUrl = '';
    
    const openSatpamModal = async (id, name) => {
        STATE.currentSatpamId = id; STATE.currentSatpamName = name;
        document.getElementById('satpamStudentName').innerText = name;
        document.getElementById('satpamSubject').innerText = STATE.subject;
        
        pendingStudentUrl = `/consultations/fill?id=${id}&subject=${STATE.subject}&week=${STATE.week}&pr=true&pr_token=${paramPrToken}`;

        const modal = document.getElementById('modalSatpamPR');
        modal.classList.replace('hidden', 'flex');
        setTimeout(() => { modal.classList.replace('opacity-0', 'opacity-100'); document.getElementById('modalSatpamBox').classList.replace('scale-95', 'scale-100'); }, 10);

        await startSatpamCamera();
    };

    const startSatpamCamera = async () => {
        const video = document.getElementById('satpamVideo');
        const instruction = document.getElementById('satpamInstruction');
        
        try {
            // [TAHAP 1] Coba request kamera depan dengan resolusi ideal
            STATE.satpamStream = await navigator.mediaDevices.getUserMedia({ 
                video: { facingMode: 'user', width: { ideal: 480 }, height: { ideal: 640 } } 
            });
        } catch (err1) {
            try {
                // [TAHAP 2] Fallback: Minta SEMBARANG kamera pokoknya nyala!
                STATE.satpamStream = await navigator.mediaDevices.getUserMedia({ video: true });
            } catch (err2) {
                // [TAHAP 3] Penjelasan UX kalau beneran gagal/ditolak/dikunci aplikasi lain
                instruction.innerHTML = `
                    <span class='text-red-500 font-bold text-[10px]'>
                        <i class="fa-solid fa-triangle-exclamation"></i> Kamera gagal diakses.<br>
                        Pastikan tidak ada aplikasi lain (WA/Kamera) yang sedang terbuka di background. Tutup lalu <b>Refresh</b> halaman.
                    </span>`;
                const targetCircle = document.getElementById('satpamTargetCircle');
                if (targetCircle) targetCircle.classList.replace('border-white/70', 'border-red-500');
                
                return; // STOP DI SINI! Jangan lanjut baca metadata video
            }
        }

        // Kalau berhasil tembus (dari Tahap 1 atau 2), masukin stream-nya ke elemen video
        video.srcObject = STATE.satpamStream;
            
        video.onloadedmetadata = async () => {
            video.play();
            video.width = video.videoWidth; // Cegah error aspect ratio AI
            video.height = video.videoHeight;
            
            // UX: User bisa ngaca sambil nunggu AI download
            instruction.innerHTML = "<span class='text-blue-500 font-bold'><i class='fa-solid fa-spinner fa-spin mr-1'></i> Memuat sensor biometrik...<br><span class='text-[10px] text-gray-400'>Silakan posisikan wajah ke tengah layar.</span></span>";
            
            if (!window.isSatpamAILoaded) {
                try {
                    await faceapi.nets.tinyFaceDetector.loadFromUri('https://justadudewhohacks.github.io/face-api.js/models');
                    window.isSatpamAILoaded = true;
                } catch (err) {
                    instruction.innerHTML = "<span class='text-red-500 font-bold'>Gagal memuat AI. Pastikan internet stabil.</span>";
                    return;
                }
            }

            instruction.innerHTML = "<span class='text-gray-600 font-bold'>Kamera aktif. <br>Tahan wajah Anda di dalam lingkaran...</span>";
            runFaceDetectionLoop(); 
        };
    };

    const runFaceDetectionLoop = () => {
        const video = document.getElementById('satpamVideo');
        const instruction = document.getElementById('satpamInstruction');
        const targetCircle = document.getElementById('satpamTargetCircle');
        
        let scanProgress = 0;
        let noFaceTime = 0;
        let isVerifying = false;
        
        // [UPDATE 1] Threshold diturunkan ke 0.4. 
        // Biar AI lebih "peka" menangkap wajah walau cahaya agak kurang / remang-remang.
        const aiOptions = new faceapi.TinyFaceDetectorOptions({ inputSize: 224, scoreThreshold: 0.4 });

        const loop = async () => {
            if (!STATE.satpamStream || isVerifying) return; 

            try {
                const detection = await faceapi.detectSingleFace(video, aiOptions);

                if (detection) {
                    const box = detection.box; 
                    const vidW = video.videoWidth; 
                    const vidH = video.videoHeight;
                    
                    const faceCenterX = box.x + (box.width / 2); 
                    const faceCenterY = box.y + (box.height / 2);

                    // [UPDATE 2] Toleransi Posisi Diperlebar (dari 0.3 jadi 0.35)
                    // Karena layar HP sering nge-crop video, titik tengah AI sering geser. Kita kasih area tengah lebih luas!
                    const isCenteredX = Math.abs(faceCenterX - (vidW / 2)) < (vidW * 0.35); 
                    const isCenteredY = Math.abs(faceCenterY - (vidH / 2)) < (vidH * 0.35);
                    
                    // [UPDATE 3] Ukuran Minimal Wajah diturunkan dikit
                    const isBigEnough = box.width > (vidW * 0.15); 

                    // [UPDATE 4] Proporsi Wajah dilebarkan (0.5 sampai 1.2)
                    // AI kadang ngebentuk kotak yang sedikit melebar tergantung letak HP.
                    const faceRatio = box.width / box.height;
                    const isFullFace = faceRatio > 0.5 && faceRatio < 1.2;

                    if (isCenteredX && isCenteredY && isBigEnough && isFullFace) {
                        // --- WAJAH PAS DI TENGAH! ---
                        noFaceTime = 0;
                        scanProgress += 5; // Hitung mundur

                        targetCircle.className = 'absolute w-48 h-64 border-4 rounded-[4rem] flex items-center justify-center z-40 transition-colors duration-300 pointer-events-none border-solid';
                        targetCircle.style.borderColor = `rgba(34, 197, 94, ${scanProgress / 100})`; 
                        targetCircle.style.boxShadow = `0 0 ${scanProgress / 5}px rgba(34, 197, 94, 0.6)`;

                        if (scanProgress < 30) instruction.innerHTML = "<span class='text-green-500 font-bold'>Tahan sebentar...</span>";
                        else if (scanProgress < 70) instruction.innerHTML = "<span class='text-green-500 font-bold'>Jangan bergerak-gerak...</span>";
                        else if (scanProgress >= 100) {
                            isVerifying = true;
                            instruction.innerHTML = "<span class='text-green-600 font-black tracking-widest'>BERHASIL!</span>";
                            targetCircle.style.borderColor = 'rgb(34, 197, 94)'; 
                            targetCircle.style.boxShadow = '0 0 25px rgb(34, 197, 94)';
                            executeRealUpload(); 
                            return; 
                        }
                    } else {
                        // --- WAJAH KELUAR JALUR / KETUTUP ---
                        noFaceTime = 0; scanProgress = 0; 
                        targetCircle.style.boxShadow = 'none';
                        targetCircle.className = 'absolute w-48 h-64 border-4 rounded-[4rem] flex items-center justify-center z-40 transition-colors duration-300 pointer-events-none border-dashed border-orange-400';
                        
                        if (!isFullFace) {
                            instruction.innerHTML = "<span class='text-orange-500 font-bold'>Wajah harus terlihat penuh! Singkirkan tangan/penutup.</span>";
                        } else if (!isBigEnough) {
                            instruction.innerHTML = "<span class='text-orange-500 font-bold'>Wajah terlalu jauh. Maju sedikit!</span>";
                        } else {
                            instruction.innerHTML = "<span class='text-orange-500 font-bold'>Arahkan wajah pas ke tengah lingkaran!</span>";
                        }
                    }
                } else {
                    // --- TIDAK ADA WAJAH ---
                    noFaceTime += 150; scanProgress = 0; 
                    if (noFaceTime > 3000) { 
                        targetCircle.style.boxShadow = 'none';
                        targetCircle.className = 'absolute w-48 h-64 border-4 rounded-[4rem] flex items-center justify-center z-40 transition-colors duration-300 pointer-events-none border-dashed border-red-500';
                        instruction.innerHTML = "<span class='text-red-500 font-bold'>Wajah tidak terdeteksi!<br>Arahkan wajah ke kamera.</span>";
                    } else if (noFaceTime > 500) {
                        targetCircle.style.boxShadow = 'none';
                        targetCircle.className = 'absolute w-48 h-64 border-4 rounded-[4rem] flex items-center justify-center z-40 transition-colors duration-300 pointer-events-none border-dashed border-white/70';
                        instruction.innerHTML = "Posisikan wajahmu di dalam garis untuk verifikasi.";
                    }
                }
            } catch (e) { console.warn("AI Frame Dropped"); }

            STATE.satpamLoopId = setTimeout(loop, 150);
        };

        loop();
    };

    const executeRealUpload = async () => {
        const video = document.getElementById('satpamVideo');
        const canvas = document.getElementById('satpamCanvas');
        const scanEffect = document.getElementById('satpamScanEffect');
        const instruction = document.getElementById('satpamInstruction');

        // Jepret Foto (Kualitas 70% biar cepat upload)
        canvas.width = video.videoWidth; canvas.height = video.videoHeight;
        canvas.getContext('2d').drawImage(video, 0, 0, canvas.width, canvas.height);
        const base64Image = canvas.toDataURL('image/jpeg', 0.7);
        
        video.pause();
        scanEffect.classList.remove('hidden'); scanEffect.classList.add('flex');
        document.getElementById('btnCancelSatpam').style.display = 'none';
        instruction.innerHTML = "<span class='text-indigo-600 font-bold'>Mengunggah data biometrik...</span>";

        try {
            const uploadPromise = fetch(`${API_URL}/api/onboarding/upload-satpam`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({ student_id: STATE.currentSatpamId, student_name: STATE.currentSatpamName, subject: STATE.subject, week: STATE.week, image: base64Image })
            });

            setTimeout(() => { document.getElementById('satpamProcessText').innerText = "MENCOCOKKAN IDENTITAS..."; }, 1500);

            // Pastikan animasi minimal tayang 3 detik walaupun upload selesai duluan
            const [uploadRes] = await Promise.all([ uploadPromise, new Promise(resolve => setTimeout(resolve, 3000)) ]);

            if (!uploadRes.ok) throw new Error("Server menolak upload");

            document.getElementById('satpamProcessText').innerText = "AKSES DIBERIKAN!";
            document.getElementById('satpamProcessText').classList.replace('text-white', 'text-green-300');
            
            if (pendingStudentUrl) window.location.href = pendingStudentUrl;

        } catch (e) {
            document.getElementById('satpamProcessText').innerText = "GAGAL TERHUBUNG!";
            document.getElementById('satpamProcessText').classList.replace('text-white', 'text-red-400');
            instruction.innerHTML = "<span class='text-red-600 font-bold'>Gagal menyimpan foto. Silakan coba lagi.</span>";
            setTimeout(window.closeSatpam, 2500);
        }
    };

    window.closeSatpam = () => {
        const modal = document.getElementById('modalSatpamPR');
        modal.classList.replace('opacity-100', 'opacity-0');
        document.getElementById('modalSatpamBox').classList.replace('scale-100', 'scale-95');
        
        if (STATE.satpamLoopId) clearTimeout(STATE.satpamLoopId);
        if (STATE.satpamStream) { STATE.satpamStream.getTracks().forEach(track => track.stop()); STATE.satpamStream = null; }

        setTimeout(() => modal.classList.replace('flex', 'hidden'), 300);
    };

    // =======================================================================
    // 5. EXAM PORTAL (SISA FUNGSI GURU)
    // =======================================================================
    window.closeVerifyStudent = () => {
        const modal = document.getElementById('modalVerifyStudent');
        modal.classList.replace('opacity-100', 'opacity-0');
        document.getElementById('modalVerifyStudentBox').classList.replace('scale-100', 'scale-95');
        if(window.verifyTimer) clearInterval(window.verifyTimer);
        setTimeout(() => modal.classList.replace('flex', 'hidden'), 300);
    };
    
    // (Fungsi CheckActiveExams dan Exam Portal yang lama tetap aman dan berjalan)
    const checkActiveExams = async () => {
        const banner = document.getElementById('examPortalBanner');
        try {
            const res = await fetch(`${API_URL}/api/exams`, { headers: { 'Authorization': `Bearer ${token}` }});
            if (!res.ok) throw new Error("API Error"); 
            const activeExams = ((await res.json()).data || []).filter(e => e.is_active);

            if (activeExams.length === 0) {
                banner.className = "mb-8 bg-gray-50 border-2 border-dashed border-gray-200 rounded-3xl p-6 text-gray-400 relative overflow-hidden flex items-center justify-between opacity-80 cursor-not-allowed";
                banner.removeAttribute('onclick');
                banner.innerHTML = `<div class="relative z-10"><h2 class="text-xl font-black mb-1"><i class="fa-solid fa-lock mr-2 text-gray-300"></i> Portal Terkunci</h2><p class="text-[10px] font-bold">Belum ada ujian yang di-publish oleh Ustadz.</p></div><div class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center border border-gray-200"><i class="fa-solid fa-lock text-lg"></i></div>`;
                return;
            }

            if (STATE.students.length === 0) STATE.students = (await fetch(`${API_URL}/api/students/stats/enriched`, { headers: { 'Authorization': `Bearer ${token}` }}).then(r=>r.json())).data || [];
            
            let availableCount = 0;
            STATE.activeExams = await Promise.all(activeExams.map(async (exam) => {
                const rData = await fetch(`${API_URL}/api/exams/${exam.id}/results`, { headers: { 'Authorization': `Bearer ${token}` }}).then(r=>r.json());
                exam.results = rData.data || []; 
                exam.isFullyCompleted = exam.results.length >= STATE.students.length;
                if (!exam.isFullyCompleted) availableCount++;
                return exam;
            }));

            if (availableCount > 0) {
                banner.className = "mb-8 bg-gradient-to-r from-indigo-500 to-purple-600 rounded-3xl p-6 text-white shadow-xl shadow-indigo-500/30 relative overflow-hidden flex items-center justify-between cursor-pointer active:scale-95 transition-transform";
                banner.setAttribute('onclick', 'openExamPortal()');
                banner.innerHTML = `<div class="relative z-10"><h2 class="text-xl font-black mb-1"><i class="fa-solid fa-gamepad mr-2 animate-bounce"></i> Portal Ujian Siswa</h2><p class="text-[10px] font-medium text-indigo-100">Ada <b>${availableCount} Ujian</b> belum tuntas.</p></div><div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center border border-white/30"><i class="fa-solid fa-play text-xl ml-1"></i></div>`;
            } else {
                banner.className = "mb-8 bg-emerald-50 border border-emerald-200 rounded-3xl p-6 text-emerald-600 relative overflow-hidden flex items-center justify-between opacity-90 cursor-not-allowed";
                banner.removeAttribute('onclick');
                banner.innerHTML = `<div class="relative z-10"><h2 class="text-xl font-black mb-1"><i class="fa-solid fa-flag-checkered mr-2 text-emerald-500"></i> Ujian Tuntas</h2><p class="text-[10px] font-bold text-emerald-600/70">Seluruh siswa telah menyelesaikan ujian.</p></div><div class="w-12 h-12 bg-emerald-100 rounded-full flex items-center justify-center border border-emerald-200"><i class="fa-solid fa-check text-xl text-emerald-500"></i></div>`;
            }
        } catch (e) {
            if (banner) {
                banner.className = "mb-8 bg-gray-50 border-2 border-dashed border-gray-200 rounded-3xl p-6 text-gray-400 relative overflow-hidden flex items-center justify-between opacity-80 cursor-not-allowed";
                banner.removeAttribute('onclick');
                banner.innerHTML = `<div class="relative z-10"><h2 class="text-xl font-black mb-1"><i class="fa-solid fa-triangle-exclamation mr-2 text-gray-300"></i> Portal Belum Tersedia</h2><p class="text-[10px] font-bold">Fitur ujian sedang dalam tahap pengembangan.</p></div>`;
            }
        }
    };

    window.openPRLateModal = (deadlineString) => {
        const modal = document.getElementById('modalPRLate');
        const box = document.getElementById('modalPRLateBox');
        
        // Format tanggal biar enak dibaca anak-anak
        const d = new Date(deadlineString);
        const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' };
        document.getElementById('lateDeadlineText').innerText = d.toLocaleDateString('id-ID', options);

        modal.classList.replace('hidden', 'flex');
        setTimeout(() => { 
            modal.classList.replace('opacity-0', 'opacity-100'); 
            box.classList.replace('scale-95', 'scale-100'); 
        }, 10);
    };

    window.closePRLateModal = () => {
        const modal = document.getElementById('modalPRLate');
        const box = document.getElementById('modalPRLateBox');
        modal.classList.replace('opacity-100', 'opacity-0');
        box.classList.replace('scale-100', 'scale-95');
        setTimeout(() => modal.classList.replace('flex', 'hidden'), 300);
    };

    // Jalankan sistem!
    initUI();
</script>

