---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Leaderboard - yukNgaji">
    <div class="min-h-screen bg-gray-50 flex flex-col items-center pt-12 px-6 relative overflow-hidden font-sans pb-12">
        <!-- Background Ornamen Khas yukNgaji -->
        <div class="absolute top-[-10%] left-[-10%] w-64 h-64 bg-green-100 rounded-full mix-blend-multiply filter blur-[80px] opacity-70"></div>
        <div class="absolute top-[20%] right-[-10%] w-64 h-64 bg-blue-100 rounded-full mix-blend-multiply filter blur-[80px] opacity-70"></div>

        <div class="z-10 text-center mb-8 w-full max-w-md animate-slide-up">
            <div class="w-20 h-20 bg-white border border-gray-100 shadow-sm rounded-[2rem] flex items-center justify-center text-4xl mx-auto mb-4">
                🏆
            </div>
            <h1 class="text-3xl font-black text-gray-800 uppercase tracking-widest drop-shadow-sm mb-2">PERINGKAT</h1>
            <div class="inline-flex items-center gap-2 bg-indigo-50 px-4 py-1.5 rounded-full border border-indigo-100 shadow-sm">
                <i class="fa-solid fa-book-open text-indigo-500 text-[10px]"></i>
                <p class="text-indigo-700 font-bold uppercase tracking-widest text-[10px]" id="lbSubtitle">Memuat data...</p>
            </div>
        </div>

        <!-- Wadah List Leaderboard -->
        <div id="leaderboardContainer" class="w-full max-w-md space-y-3 z-10">
            <div class="text-center py-12 bg-white rounded-[2rem] border border-gray-100 shadow-sm"><i class="fa-solid fa-spinner fa-spin text-green-500 text-3xl"></i></div>
        </div>

        <!-- [BARU] Kartu Penjelasan Sistem Poin -->
        <div id="infoScoring" class="w-full max-w-md mt-6 bg-white p-6 rounded-[2rem] border border-gray-100 shadow-sm z-10 hidden opacity-0 transform translate-y-4 transition-all duration-700">
            <h3 class="text-xs font-black text-gray-800 uppercase tracking-widest mb-4 flex items-center gap-2">
                <i class="fa-solid fa-circle-info text-blue-500 text-lg"></i> Rahasia Poin Klasemen
            </h3>
            <div class="space-y-3">
                <div class="flex items-start gap-3 bg-gray-50 p-3 rounded-2xl border border-gray-100">
                    <div class="text-xl">🎯</div>
                    <div>
                        <p class="text-[10px] font-black text-gray-700 uppercase">Akurasi Jawaban (80%)</p>
                        <p class="text-[9px] text-gray-500 font-medium leading-relaxed mt-0.5">Nilai murni dari jawaban benarmu. Bobotnya paling besar!</p>
                    </div>
                </div>
                <div class="flex items-start gap-3 bg-gray-50 p-3 rounded-2xl border border-gray-100">
                    <div class="text-xl">⏱️</div>
                    <div>
                        <p class="text-[10px] font-black text-gray-700 uppercase">Kecepatan Waktu (10%)</p>
                        <p class="text-[9px] text-gray-500 font-medium leading-relaxed mt-0.5">Semakin banyak sisa waktu yang kamu miliki, semakin besar bonus poinnya.</p>
                    </div>
                </div>
                <div class="flex items-start gap-3 bg-gray-50 p-3 rounded-2xl border border-gray-100">
                    <div class="text-xl">🚀</div>
                    <div>
                        <p class="text-[10px] font-black text-gray-700 uppercase">Siapa Cepat (10%)</p>
                        <p class="text-[9px] text-gray-500 font-medium leading-relaxed mt-0.5">Urutan pengumpulan di kelas. Yang pertama kumpul otomatis dapat poin maksimal!</p>
                    </div>
                </div>
            </div>
            <div class="mt-6 pt-4 border-t border-dashed border-gray-200 text-center">
                <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Kamu boleh menutup browser ini.</p>
            </div>
        </div>

    </div>
</Layout>

<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js" is:inline></script>

<script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const urlParams = new URLSearchParams(window.location.search);
    const subject = urlParams.get('subject');
    const week = urlParams.get('week');
    const currentStudentId = urlParams.get('student_id');

    let token = localStorage.getItem('token');
    if (!token) token = sessionStorage.getItem('temp_pr_token');

    document.getElementById('lbSubtitle').innerText = `${subject} • PERTEMUAN ${week}`;

    const fetchLeaderboard = async () => {
        const container = document.getElementById('leaderboardContainer');
        const infoCard = document.getElementById('infoScoring');
        
        try {
            if (!token) throw new Error("Akses ditolak. Token tidak ditemukan.");

            const res = await fetch(`${API_URL}/api/onboarding/leaderboard-pr?subject=${subject}&week=${week}`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            
            if (!res.ok) throw new Error(`Gagal mengambil data dari server (${res.status})`);
            
            const data = await res.json();
            
            if (!data.data || data.data.length === 0) {
                container.innerHTML = '<div class="bg-white p-8 rounded-[2rem] border border-gray-100 shadow-sm text-center"><div class="text-4xl mb-3">👻</div><p class="text-xs text-gray-400 font-bold uppercase tracking-widest">Belum ada data pengerjaan.</p></div>';
                return;
            }

            if (typeof confetti === 'function') confetti({ particleCount: 150, spread: 80, origin: { y: 0.3 } });

            container.innerHTML = data.data.map((student, index) => {
                const rank = index + 1;
                const widthPercent = Math.min(100, student.composite_score);
                const isMe = student.student_id === currentStudentId;
                
                let bgClass = 'bg-white border-gray-100';
                let barColor = 'from-gray-100 to-gray-200';
                let rankBadge = `<div class="w-8 h-8 rounded-xl bg-gray-100 border border-gray-200 text-gray-400 font-black flex items-center justify-center shrink-0 shadow-sm">${rank}</div>`;
                let textClass = 'text-gray-700';
                
                if (rank === 1) {
                    bgClass = 'bg-amber-50 border-amber-200';
                    barColor = 'from-amber-200 to-orange-300';
                    rankBadge = `<div class="w-11 h-11 rounded-[14px] bg-gradient-to-br from-amber-300 to-orange-500 border-2 border-white text-white font-black flex items-center justify-center shrink-0 shadow-md shadow-orange-500/40"><i class="fa-solid fa-crown text-lg"></i></div>`;
                    textClass = 'text-amber-900';
                } else if (rank === 2) {
                    bgClass = 'bg-slate-50 border-slate-200';
                    barColor = 'from-slate-200 to-slate-300';
                    rankBadge = `<div class="w-10 h-10 rounded-[12px] bg-gradient-to-br from-slate-300 to-slate-400 border-2 border-white text-white font-black flex items-center justify-center shrink-0 shadow-sm shadow-slate-400/40">2</div>`;
                    textClass = 'text-slate-800';
                } else if (rank === 3) {
                    bgClass = 'bg-orange-50 border-orange-200';
                    barColor = 'from-orange-200 to-orange-300';
                    rankBadge = `<div class="w-9 h-9 rounded-[10px] bg-gradient-to-br from-orange-300 to-orange-400 border-2 border-white text-white font-black flex items-center justify-center shrink-0 shadow-sm shadow-orange-400/40">3</div>`;
                    textClass = 'text-orange-900';
                }

                if (isMe) {
                    bgClass += ' ring-2 ring-indigo-400 shadow-md transform scale-[1.02]';
                }

                const meBadge = isMe ? `<span class="text-[8px] bg-indigo-600 text-white px-2 py-0.5 rounded-full font-black uppercase tracking-widest shadow-sm">Ini Kamu!</span>` : '';
                const prBadge = student.is_pr ? `<span class="text-[8px] bg-purple-50 text-purple-600 px-2 py-0.5 rounded border border-purple-200 font-bold uppercase tracking-widest shadow-sm">PR</span>` : '';

                return `
                    <div class="relative w-full rounded-[2rem] border ${bgClass} p-4 overflow-hidden shadow-sm transition-all animate-slide-up" style="animation-delay: ${index * 100}ms; opacity: 0; animation-fill-mode: forwards;">
                        <div class="absolute top-0 left-0 h-full bg-gradient-to-r ${barColor} opacity-40 transition-all duration-1000 ease-out" style="width: 0%;" data-width="${widthPercent}%"></div>
                        
                        <div class="relative z-10 flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                ${rankBadge}
                                <div>
                                    <div class="flex items-center flex-wrap gap-1.5 mb-1">
                                        <p class="font-black uppercase tracking-wider text-sm ${textClass}">${student.name}</p>
                                        ${meBadge}
                                        ${prBadge}
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <span class="text-[9px] bg-white/60 px-2 py-0.5 rounded border border-white/40 text-gray-600 font-bold shadow-sm">🎯 ${student.raw_score}</span>
                                        <span class="text-[9px] bg-white/60 px-2 py-0.5 rounded border border-white/40 text-gray-600 font-bold shadow-sm">⏱️ ${student.time_taken}s</span>
                                    </div>
                                </div>
                            </div>
                            <div class="text-right bg-white/80 px-3 py-2 rounded-2xl border border-white shadow-sm flex flex-col items-center justify-center min-w-[60px]">
                                <p class="text-xl font-black ${textClass} leading-none drop-shadow-sm">${student.composite_score}</p>
                                <p class="text-[7px] text-gray-500 font-bold uppercase tracking-widest mt-1">Poin</p>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            setTimeout(() => {
                document.querySelectorAll('[data-width]').forEach(el => {
                    el.style.width = el.getAttribute('data-width');
                });
            }, 100);

            // Munculkan Kartu Info Scoring dengan animasi halus setelah list selesai di-render
            setTimeout(() => {
                infoCard.classList.remove('hidden');
                // Kasih jeda 50ms biar browser ngerender hidden->block dulu baru di-animate
                setTimeout(() => {
                    infoCard.classList.replace('opacity-0', 'opacity-100');
                    infoCard.classList.replace('translate-y-4', 'translate-y-0');
                }, 50);
            }, (data.data.length * 100) + 300); // Muncul berurutan setelah baris terakhir

        } catch (error) {
            console.error(error);
            container.innerHTML = `<div class="bg-white p-6 rounded-[2rem] border border-red-100 shadow-sm text-center"><i class="fa-solid fa-triangle-exclamation text-red-500 text-3xl mb-3"></i><p class="text-xs text-red-600 font-bold">${error.message || 'Gagal memuat klasemen.'}</p></div>`;
        }
    };

    fetchLeaderboard();
</script>

<style is:global>
    .animate-slide-up { animation: slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    @keyframes slideUp { 
        0% { transform: translateY(20px) scale(0.95); opacity: 0; } 
        100% { transform: translateY(0) scale(1); opacity: 1; } 
    }
</style>