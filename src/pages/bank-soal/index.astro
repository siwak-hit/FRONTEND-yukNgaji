        document.getElementById('editSoalId').value = q.id;
        
        document.getElementById('editSoalType').value = q.type || 'pilgan';
        document.getElementById('editSoalQ').value = q.question;
        document.getElementById('editSoalLevel').value = q.difficulty_level || 'sedang';
        
        const optWrapper = document.getElementById('editOptionsWrapper');
        optWrapper.innerHTML = '';
        const opts = q.options && Object.keys(q.options).length > 0 ? q.options : {A:"", B:"", C:"", D:""};
        Object.entries(opts).forEach(([k, v]) => { appendOptionRow(optWrapper, k, v); });

        toggleEditType(q.correct_answer);
        
        modal.classList.replace('hidden', 'flex');
