    document.getElementById('btnFinalSave').onclick = async () => {
        const cards   = document.querySelectorAll('#previewContent .soal-card');
        const subject = activeSubjectForUpload;
        const week    = parseInt(document.getElementById('targetWeek').value);

        if (!week || week < 1) return window.showToast('warning', 'Perhatian', 'Nomor pertemuan tidak valid.');

        const questionsData = [];
        cards.forEach(card => {
            const data = extractCardData(card);
            if (data.question && (data.type === 'tf' || (data.options.A && data.options.B))) {
                questionsData.push(data);
            }
        });

        if (questionsData.length === 0) return window.showToast('warning', 'Perhatian', 'Tidak ada soal yang valid untuk disimpan.');

        const btn = document.getElementById('btnFinalSave');
        btn.textContent = "Menyimpan..."; btn.disabled = true;

        try {
            const res = await fetch(`${API_URL}/api/onboarding/upload-template`, {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify({ subject, week, questions: questionsData })
            });
            const result = await res.json();
            if (res.ok) {
                window.showToast('success', 'Berhasil', `${questionsData.length} soal disimpan.`);
                isSummaryCached = false; 
                isDirty = false; // Reset Dirty Setelah Simpan
                setTimeout(() => { document.getElementById('modalPreview').classList.add('hidden'); fetchAccordion(); }, 1200); 
            } else window.showToast('danger', 'Error', result.message || 'Gagal menyimpan.');
        } catch (err) { console.error(err); window.showToast('danger', 'Error', 'Terjadi kesalahan jaringan.'); } 
        finally { btn.textContent = "Simpan"; btn.disabled = false; }
