---
import Layout from '../../layouts/Layout.astro';
import NavbarGuru from '../../components/NavbarGuru.astro';
import Toast from '../../components/Toast.astro';
import ModalAlert from '../../components/ModalAlert.astro';
---

<Layout title="Bank Soal - yukNgaji">
    <div class="px-6 py-8 pb-32 min-h-screen flex flex-col bg-gray-50">
        
        <header class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-2xl font-bold text-gray-800 tracking-tight">Bank Soal</h1>
                <p class="text-xs text-gray-400 mt-1 font-medium uppercase tracking-widest">Manajemen Kuesioner</p>
            </div>
            <button id="btnOpenUpload" class="w-12 h-12 bg-green-600 text-white rounded-2xl shadow-lg shadow-green-600/30 flex items-center justify-center active:scale-95 transition-all">
                <i class="fa-solid fa-plus text-lg"></i>
            </button>
        </header>

        <a href="/exams" class="mb-6 bg-gradient-to-br from-amber-400 to-orange-500 p-5 rounded-3xl shadow-lg shadow-orange-500/20 flex items-center justify-between active:scale-[0.98] transition-all block relative overflow-hidden">
            <div class="absolute -right-6 -top-6 w-24 h-24 bg-white/10 rounded-full blur-xl"></div>
            <div class="absolute right-10 -bottom-8 w-20 h-20 bg-white/10 rounded-full blur-xl"></div>

            <div class="flex items-center gap-4 relative z-10">
                <div class="w-12 h-12 bg-white/20 rounded-2xl flex items-center justify-center text-white text-xl backdrop-blur-sm border border-white/20 shadow-inner">
                    <i class="fa-solid fa-graduation-cap"></i>
                </div>
                <div>
                    <h2 class="text-white font-bold text-base leading-tight drop-shadow-sm">Ujian & Evaluasi <span class="bg-red-500 text-white text-[8px] px-1.5 py-0.5 rounded-full ml-1 align-top uppercase tracking-widest font-black animate-pulse">Baru</span></h2>
                    <p class="text-orange-50 text-[10px] mt-0.5 font-medium leading-relaxed">Buat ujian khusus dengan timer, gambar, & hint.</p>
                </div>
            </div>
            <div class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center text-white relative z-10 backdrop-blur-sm">
                <i class="fa-solid fa-chevron-right text-xs"></i>
            </div>
        </a>

        <section class="mb-6 bg-green-50 p-4 rounded-2xl border border-green-100">
            <div class="flex items-start gap-3">
                <i class="fa-solid fa-circle-info text-green-600 mt-1 flex-shrink-0"></i>
                <div class="flex-1">
                    <h4 class="text-xs font-bold text-green-800 uppercase">Petunjuk Upload</h4>
                    <p class="text-[10px] text-green-700 leading-relaxed mt-1">
                        Gunakan format <b>Q:</b> (Soal), <b>A-D:</b> (Pilihan), <b>KUNCI:</b> (Jawaban), dan <b>LEVEL:</b> (Tingkat).
                    </p>
                    <button id="btnDownloadTemplate" class="mt-3 flex items-center gap-2 text-[10px] font-bold bg-white text-green-600 px-3 py-1.5 rounded-lg border border-green-200 active:scale-95 transition-all">
                        <i class="fa-solid fa-download"></i>
                        Unduh Template .txt
                    </button>
                </div>
            </div>
        </section>

        <section class="mb-4 flex gap-2">
            <div class="relative flex-1">
                <i class="fa-solid fa-magnifying-glass absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
                <input type="number" id="searchWeek" placeholder="Cari pertemuan (cth: 1)" class="w-full pl-9 pr-4 py-3 bg-white border border-gray-200 rounded-xl text-sm font-bold focus:ring-2 focus:ring-green-500 outline-none shadow-sm placeholder-gray-300">
            </div>
            <button id="btnSortWeek" class="w-12 h-[46px] bg-white border border-gray-200 rounded-xl text-gray-600 text-sm shadow-sm active:scale-95 transition-all flex items-center justify-center" title="Urutkan (Asc/Desc)">
                <i class="fa-solid fa-arrow-down-1-9"></i>
            </button>
        </section>

        <section class="flex-1 space-y-4" id="accordionContainer">
            <div class="animate-pulse bg-white h-16 rounded-2xl border border-gray-100"></div>
            <div class="animate-pulse bg-white h-16 rounded-2xl border border-gray-100"></div>
            <div class="animate-pulse bg-white h-16 rounded-2xl border border-gray-100"></div>
        </section>
    </div>

    <div id="modalUpload" class="fixed inset-0 bg-black/40 z-[60] hidden flex items-end sm:items-center justify-center p-0 sm:p-4">
        <div class="bg-white w-full max-w-md rounded-t-3xl sm:rounded-3xl p-6 shadow-2xl animate-slide-up">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-bold text-gray-800">Tambah Soal Baru</h3>
                <button onclick="closeUpload()" class="text-gray-400"><i class="fa-solid fa-xmark"></i></button>
            </div>
            
            <form id="formUpload" class="space-y-4">
                <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase ml-1">Mata Pelajaran</label>
                    <select id="upSubject" class="w-full mt-1 px-4 py-3 bg-gray-50 border-none rounded-xl text-sm focus:ring-2 focus:ring-green-500">
                        <option value="tajwid">Tajwid</option>
                        <option value="fiqih">Fiqih</option>
                        <option value="tauhid">Tauhid</option>
                    </select>
                </div>

                <div class="p-3 bg-blue-50 rounded-xl border border-blue-100">
                    <p class="text-[10px] font-bold text-blue-700 uppercase mb-2">Target Pertemuan</p>
                    <div class="space-y-2">
                        <label class="flex items-center gap-3 cursor-pointer p-2 rounded-xl hover:bg-blue-100 transition-colors">
                            <input type="radio" name="weekMode" value="baru" checked class="accent-green-600">
                            <div>
                                <p class="text-xs font-bold text-gray-700">Pertemuan Baru</p>
                                <p class="text-[10px] text-gray-400" id="labelPertemuanBaru">Otomatis ke minggu berikutnya</p>
                            </div>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer p-2 rounded-xl hover:bg-blue-100 transition-colors">
                            <input type="radio" name="weekMode" value="sisipan" class="accent-green-600">
                            <div>
                                <p class="text-xs font-bold text-gray-700">Sisipan / Tambah ke Pertemuan Lama</p>
                                <p class="text-[10px] text-gray-400">Pilih minggu yang sudah ada atau kosong</p>
                            </div>
                        </label>
                    </div>

                    <div id="sisipanDropdownWrap" class="hidden mt-3">
                        <select id="sisipanWeek" class="w-full px-3 py-2 bg-white rounded-xl text-sm border border-blue-200 font-medium">
                            <option value="">Pilih minggu...</option>
                        </select>
                    </div>
                </div>

                <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase ml-1">File Template (.txt) <span class="text-gray-300 normal-case font-normal">(opsional jika manual)</span></label>
                    <input type="file" id="upFile" accept=".txt" class="w-full mt-1 text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-semibold file:bg-green-50 file:text-green-700 hover:file:bg-green-100 cursor-pointer">
                </div>

                <div class="grid grid-cols-2 gap-2">
                    <button type="submit" class="py-3 bg-green-600 text-white font-bold rounded-2xl shadow-lg active:scale-95 transition-all text-sm">
                        <i class="fa-solid fa-file-arrow-up mr-1"></i> Upload File
                    </button>
                    <button type="button" onclick="openManualFromModal()" class="py-3 bg-white border-2 border-dashed border-green-300 text-green-700 font-bold rounded-2xl active:scale-95 transition-all text-sm">
                        <i class="fa-solid fa-pen mr-1"></i> Input Manual
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div id="modalPreview" class="fixed inset-0 bg-white z-[60] hidden h-screen flex flex-col overflow-hidden">
        <header class="fixed top-0 left-0 w-full p-5 border-b flex justify-between items-center bg-white z-20 flex-shrink-0 shadow-sm">
            <button onclick="closePreview()" class="text-gray-400 text-xl active:scale-95 transition-all"><i class="fa-solid fa-chevron-left"></i></button>
            <h3 class="font-bold text-gray-800">Preview & Edit Soal</h3>
            <button id="btnFinalSave" class="text-green-600 font-bold text-sm active:opacity-70 transition-opacity">Simpan</button>
        </header>

        <div class="mt-[72px] bg-green-50 p-4 border-b flex items-center gap-2 flex-shrink-0">
            <label class="text-[10px] font-bold text-green-700 uppercase">Mapel:</label>
            <span id="previewSubjectLabel" class="text-xs font-black text-green-700 uppercase mr-4">-</span>
            <label class="text-[10px] font-bold text-green-700 uppercase">Target Pertemuan:</label>
            <span class="text-[10px] text-gray-500 font-bold">MG-</span>
            <input type="number" id="targetWeek" value="1" min="1" class="w-12 h-8 rounded-lg border-none text-center font-bold text-green-600 focus:ring-2 focus:ring-green-500">
        </div>

        <div class="bg-blue-50 border-b border-blue-100 p-4 flex gap-3 items-start flex-shrink-0">
            <i class="fa-solid fa-circle-info text-blue-500 mt-0.5"></i>
            <p class="text-[10px] text-blue-800 font-medium leading-relaxed">
                <b class="uppercase tracking-wider">Info Otak Adaptif AI:</b><br>
                Sistem otomatis memberikan soal <b>Mudah/Sedang/Sulit</b> secara dinamis berdasarkan riwayat nilai minggu sebelumnya.
            </p>
        </div>

        <div id="previewContent" class="flex-1 overflow-y-auto p-6 space-y-6 pb-[100px] no-scrollbar"></div>
    
        <div class="fixed bottom-0 sm:bottom-[72px] left-0 w-full p-4 bg-gradient-to-t from-white via-white to-transparent z-10 flex-shrink-0">
            <div class="max-w-md mx-auto">
                <button id="btnTambahManual" class="w-full py-4 bg-white border-2 border-dashed border-green-200 rounded-2xl text-green-600 font-bold text-xs shadow-lg active:scale-95 transition-all">
                    <i class="fa-solid fa-plus mr-1"></i> Tambah Soal Manual
                </button>
            </div>
        </div>
    </div>

    <div id="modalEditSoal" class="fixed inset-0 bg-black/60 z-[70] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-md rounded-3xl p-6 shadow-2xl max-h-[90vh] overflow-y-auto no-scrollbar">
            <div class="flex justify-between items-center mb-5">
                <h3 class="font-bold text-gray-800">Edit Soal</h3>
                <button onclick="closeEditSoal()" class="text-gray-400"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <input type="hidden" id="editSoalId">
            <div class="space-y-3">
                <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase">Pertanyaan</label>
                    <textarea id="editSoalQ" rows="3" class="w-full mt-1 p-3 bg-gray-50 rounded-xl text-sm border-none focus:ring-2 focus:ring-blue-400"></textarea>
                </div>
                <div class="grid grid-cols-2 gap-2">
                    <div><label class="text-[10px] text-gray-400 font-bold uppercase">Opsi A</label><input type="text" id="editSoalA" class="w-full mt-1 p-2 bg-gray-50 rounded-xl text-xs border-none"></div>
                    <div><label class="text-[10px] text-gray-400 font-bold uppercase">Opsi B</label><input type="text" id="editSoalB" class="w-full mt-1 p-2 bg-gray-50 rounded-xl text-xs border-none"></div>
                    <div><label class="text-[10px] text-gray-400 font-bold uppercase">Opsi C</label><input type="text" id="editSoalC" class="w-full mt-1 p-2 bg-gray-50 rounded-xl text-xs border-none"></div>
                    <div><label class="text-[10px] text-gray-400 font-bold uppercase">Opsi D</label><input type="text" id="editSoalD" class="w-full mt-1 p-2 bg-gray-50 rounded-xl text-xs border-none"></div>
                </div>
                <div class="flex items-center gap-4">
                    <div class="flex items-center gap-2">
                        <span class="text-[10px] font-bold text-gray-400">KUNCI:</span>
                        <select id="editSoalKey" class="text-xs font-bold border-none bg-green-50 text-green-700 rounded-lg px-2 py-1">
                            <option value="A">A</option><option value="B">B</option>
                            <option value="C">C</option><option value="D">D</option>
                        </select>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-[10px] font-bold text-gray-400">LEVEL:</span>
                        <select id="editSoalLevel" class="text-xs font-bold border-none bg-blue-50 text-blue-700 rounded-lg px-2 py-1">
                            <option value="mudah">Mudah</option>
                            <option value="sedang">Sedang</option>
                            <option value="sulit">Sulit</option>
                        </select>
                    </div>
                </div>
                <button onclick="submitEditSoal()" class="w-full py-3 bg-blue-600 text-white font-bold rounded-2xl shadow-lg active:scale-95 transition-all">
                    <i class="fa-solid fa-floppy-disk mr-2"></i>Simpan Perubahan
                </button>
            </div>
        </div>
    </div>

    <NavbarGuru activeMenu="exam" />
    <Toast />
    <ModalAlert />
</Layout>

<script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const token = localStorage.getItem('token');
    if (!token) window.location.replace('/');

    const SUBJECTS = ['tajwid', 'fiqih', 'tauhid'];
    const SUBJECT_COLORS = {
        tajwid:  { bg: 'bg-green-50',  border: 'border-green-200',  text: 'text-green-700',  badge: 'bg-green-100 text-green-700'  },
        fiqih:   { bg: 'bg-blue-50',   border: 'border-blue-200',   text: 'text-blue-700',   badge: 'bg-blue-100 text-blue-700'   },
        tauhid:  { bg: 'bg-purple-50', border: 'border-purple-200', text: 'text-purple-700', badge: 'bg-purple-100 text-purple-700'},
    };

    // State global
    let summaryData = {};
    let activeSubjectForUpload = 'tajwid';
    let resolvedWeekForUpload  = 1;
    let allWeeksData = {}; 
    let isSortAsc = true;
    
    // [BARU] Pelacak Cache untuk endpoint /summary
    let isSummaryCached = false; 

    // ================================================================
    // OPEN/CLOSE & SMART ADD (DENGAN OPTIMASI CACHE)
    // ================================================================
    document.getElementById('btnOpenUpload').onclick = async () => {
        await loadSummaryIntoModal();
        document.getElementById('modalUpload').classList.remove('hidden');
    };
    
    window.closeUpload  = () => document.getElementById('modalUpload').classList.add('hidden');
    window.closePreview = () => document.getElementById('modalPreview').classList.add('hidden');

    const loadSummaryIntoModal = async () => {
        // Cek apakah data summary sudah tersimpan di memori (Cache Hit)
        if (!isSummaryCached) {
            const btn = document.getElementById('btnOpenUpload');
            const oldContent = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin text-lg"></i>'; // Animasi loading
            
            try {
                const res = await fetch(`${API_URL}/api/onboarding/questions/summary`, { headers: { 'Authorization': `Bearer ${token}` }});
                const result = await res.json();
                summaryData = result.data || {};
                isSummaryCached = true; // Tandai bahwa data sudah dicache
            } catch (e) {
                console.error("Gagal mengambil summary", e);
            } finally {
                btn.innerHTML = oldContent; // Kembalikan icon Plus
            }
        }
        
        updateSmartAddUI();
    };

    const updateSmartAddUI = () => {
        const subject = document.getElementById('upSubject').value;
        const mode    = document.querySelector('input[name="weekMode"]:checked')?.value || 'baru';
        const info    = summaryData[subject] || { maxWeek: 0, gaps: [], allWeeks: [] };

        const nextWeek = info.maxWeek + 1;
        document.getElementById('labelPertemuanBaru').textContent = info.maxWeek === 0 ? 'Belum ada soal — akan jadi Pertemuan 1' : `Otomatis ke Pertemuan ${nextWeek} (setelah Mg-${info.maxWeek})`;

        const sisipanWeekEl = document.getElementById('sisipanWeek');
        const sisipanWrap   = document.getElementById('sisipanDropdownWrap');

        if (mode === 'sisipan') {
            sisipanWrap.classList.remove('hidden');
            const gapOptions  = info.gaps.map(w => `<option value="${w}">MG-${w} (Kosong / Bolong)</option>`).join('');
            const existOptions = info.allWeeks.map(w => `<option value="${w}">MG-${w} (Tambah soal di pertemuan ini)</option>`).join('');
            sisipanWeekEl.innerHTML = `<option value="">Pilih minggu...</option>${gapOptions}${existOptions}`;
        } else {
            sisipanWrap.classList.add('hidden');
        }

        if (mode === 'baru') resolvedWeekForUpload = nextWeek;
        else resolvedWeekForUpload = parseInt(sisipanWeekEl.value) || null;
        
        activeSubjectForUpload = subject;
    };

    document.getElementById('upSubject').onchange = updateSmartAddUI;
    document.querySelectorAll('input[name="weekMode"]').forEach(r => r.onchange = updateSmartAddUI);
    document.getElementById('sisipanWeek').onchange = () => resolvedWeekForUpload = parseInt(document.getElementById('sisipanWeek').value) || null;

    // ================================================================
    // DOWNLOAD TEMPLATE & UPLOAD
    // ================================================================
    document.getElementById('btnDownloadTemplate').onclick = () => {
        const templateText = `Q: Contoh perbuatan syirik adalah?\nA: Shalat tepat waktu\nB: Berdoa kepada Allah\nC: Meminta kepada kuburan\nD: Membaca Al-Qur'an\nKUNCI: C\nLEVEL: MUDAH\n\nQ: Apa arti dari kalimat "Laa ilaaha illallah"?\nA: Allah Maha Besar\nB: Tiada tuhan selain Allah\nC: Allah Maha Pengasih\nD: Segala puji bagi Allah\nKUNCI: B\nLEVEL: SEDANG`;
        const blob = new Blob([templateText], { type: 'text/plain' });
        const url  = URL.createObjectURL(blob);
        const a    = document.createElement('a');
        a.href = url; a.download = 'template_soal_yukNgaji.txt'; a.click();
        URL.revokeObjectURL(url);
    };

    document.getElementById('formUpload').onsubmit = (e) => {
        e.preventDefault();
        const file = document.getElementById('upFile').files[0];
        if (!file) { openManualFromModal(); return; }
        const reader = new FileReader();
        reader.onload = (ev) => {
            const questions = parseTextToJSON(ev.target.result);
            renderPreview(questions);
        };
        reader.readAsText(file);
    };

    window.openManualFromModal = () => { closeUpload(); renderPreview([]); };

    const parseTextToJSON = (text) => {
        const blocks = text.split(/\r?\n\r?\n/);
        return blocks.map(block => {
            const lines = block.split('\n').map(l => l.trim());
            return {
                q:     lines.find(l => l.startsWith('Q:'))?.replace('Q:', '').trim()      || '',
                a:     lines.find(l => l.startsWith('A:'))?.replace('A:', '').trim()      || '',
                b:     lines.find(l => l.startsWith('B:'))?.replace('B:', '').trim()      || '',
                c:     lines.find(l => l.startsWith('C:'))?.replace('C:', '').trim()      || '',
                d:     lines.find(l => l.startsWith('D:'))?.replace('D:', '').trim()      || '',
                key:   lines.find(l => l.startsWith('KUNCI:'))?.replace('KUNCI:', '').trim() || 'A',
                level: lines.find(l => l.startsWith('LEVEL:'))?.replace('LEVEL:', '').trim().toLowerCase() || 'sedang'
            };
        }).filter(item => item.q !== '');
    };

    // ================================================================
    // RENDER PREVIEW EDITOR
    // ================================================================
    window.renderPreview = (questions) => {
        const container = document.getElementById('previewContent');
        container.innerHTML = '';
        questions.forEach((item, idx) => container.appendChild(createSoalCard(item, idx + 1)));
        document.getElementById('targetWeek').value = resolvedWeekForUpload || 1;
        document.getElementById('previewSubjectLabel').textContent = activeSubjectForUpload;
        document.getElementById('modalUpload').classList.add('hidden');
        document.getElementById('modalPreview').classList.remove('hidden');
    };

    const createSoalCard = (item, displayIndex) => {
        const div = document.createElement('div');
        div.className = "soal-card bg-white p-5 rounded-2xl border border-gray-100 shadow-sm space-y-3";
        div.innerHTML = `
            <div class="flex justify-between items-center">
                <span class="text-[10px] font-bold text-green-600 bg-green-50 px-2 py-1 rounded">SOAL ${displayIndex || 'BARU'}</span>
                <button onclick="this.parentElement.parentElement.remove()" class="text-red-400 text-xs"><i class="fa-solid fa-trash"></i></button>
            </div>
            <textarea class="q-input w-full text-sm font-bold text-gray-800 border-none bg-gray-50 rounded-xl p-3 focus:ring-0" rows="2">${item.q || ''}</textarea>
            <div class="grid grid-cols-2 gap-2">
                <input type="text" class="opt-a text-xs p-2 bg-gray-50 border-none rounded-lg" placeholder="Opsi A" value="${item.a || ''}">
                <input type="text" class="opt-b text-xs p-2 bg-gray-50 border-none rounded-lg" placeholder="Opsi B" value="${item.b || ''}">
                <input type="text" class="opt-c text-xs p-2 bg-gray-50 border-none rounded-lg" placeholder="Opsi C" value="${item.c || ''}">
                <input type="text" class="opt-d text-xs p-2 bg-gray-50 border-none rounded-lg" placeholder="Opsi D" value="${item.d || ''}">
            </div>
            <div class="flex items-center gap-4">
                <div class="flex items-center gap-2">
                    <span class="text-[10px] font-bold text-gray-400">KUNCI:</span>
                    <select class="key-input text-xs font-bold border-none bg-green-50 text-green-700 rounded-lg px-2 py-1">
                        <option value="A" ${item.key === 'A' ? 'selected' : ''}>A</option>
                        <option value="B" ${item.key === 'B' ? 'selected' : ''}>B</option>
                        <option value="C" ${item.key === 'C' ? 'selected' : ''}>C</option>
                        <option value="D" ${item.key === 'D' ? 'selected' : ''}>D</option>
                    </select>
                </div>
                <div class="flex items-center gap-2">
                    <span class="text-[10px] font-bold text-gray-400">LEVEL:</span>
                    <select class="level-input text-xs font-bold border-none bg-blue-50 text-blue-700 rounded-lg px-2 py-1">
                        <option value="mudah"  ${item.level === 'mudah'  ? 'selected' : ''}>Mudah</option>
                        <option value="sedang" ${(!item.level || item.level === 'sedang') ? 'selected' : ''}>Sedang</option>
                        <option value="sulit"  ${item.level === 'sulit'  ? 'selected' : ''}>Sulit</option>
                    </select>
                </div>
            </div>
        `;
        return div;
    };

    window.addNewQuestionField = () => {
        const container = document.getElementById('previewContent');
        const card = createSoalCard({}, null);
        container.appendChild(card);
        setTimeout(() => card.scrollIntoView({ behavior: 'smooth', block: 'center' }), 150);
    };
    document.getElementById('btnTambahManual').onclick = window.addNewQuestionField;

    // SIMPAN SOAL BARU
    document.getElementById('btnFinalSave').onclick = async () => {
        const cards   = document.querySelectorAll('#previewContent .soal-card');
        const subject = activeSubjectForUpload;
        const week    = parseInt(document.getElementById('targetWeek').value);

        if (!week || week < 1) return window.showToast('warning', 'Perhatian', 'Nomor pertemuan tidak valid.');

        const questionsData = [];
        cards.forEach(card => {
            const question = card.querySelector('.q-input').value.trim();
            const optA = card.querySelector('.opt-a').value.trim();
            const optB = card.querySelector('.opt-b').value.trim();
            const optC = card.querySelector('.opt-c').value.trim();
            const optD = card.querySelector('.opt-d').value.trim();
            const key   = card.querySelector('.key-input').value;
            const level = card.querySelector('.level-input').value;
            if (question && optA && optB) {
                questionsData.push({ question, options: { A: optA, B: optB, C: optC, D: optD }, correct_answer: key, difficulty_level: level });
            }
        });

        if (questionsData.length === 0) return window.showToast('warning', 'Perhatian', 'Tidak ada soal yang valid untuk disimpan.');

        const btn = document.getElementById('btnFinalSave');
        btn.textContent = "Menyimpan..."; btn.disabled = true;

        try {
            const res = await fetch(`${API_URL}/api/onboarding/upload-template`, {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify({ subject, week, questions: questionsData })
            });
            const result = await res.json();
            if (res.ok) {
                window.showToast('success', 'Berhasil', `${questionsData.length} soal disimpan.`);
                
                // [PENTING] Hapus cache karena jumlah soal/minggu berubah!
                isSummaryCached = false; 

                setTimeout(() => { closePreview(); fetchAccordion(); }, 1200); 
            } else window.showToast('danger', 'Error', result.message || 'Gagal menyimpan.');
        } catch (err) { console.error(err); window.showToast('danger', 'Error', 'Terjadi kesalahan jaringan.'); } 
        finally { btn.textContent = "Simpan"; btn.disabled = false; }
    };

    // ================================================================
    // FETCH DATA AWAL (CUMA 1 KALI SAAT LOAD HALAMAN)
    // ================================================================
    const fetchAccordion = async () => {
        const container = document.getElementById('accordionContainer');
        container.innerHTML = `
            <div class="animate-pulse bg-white h-16 rounded-2xl border border-gray-100"></div>
            <div class="animate-pulse bg-white h-16 rounded-2xl border border-gray-100"></div>
            <div class="animate-pulse bg-white h-16 rounded-2xl border border-gray-100"></div>`;
        try {
            const responses = await Promise.all(SUBJECTS.map(s =>
                    fetch(`${API_URL}/api/onboarding/questions/${s}`, { headers: { 'Authorization': `Bearer ${token}` } })
                    .then(r => r.json()).then(result => ({ subject: s, grouped: result.data || {} }))
            ));

            allWeeksData = {};
            responses.forEach(({ subject, grouped }) => {
                Object.keys(grouped).forEach(weekStr => {
                    const weekNum = parseInt(weekStr);
                    if (!allWeeksData[weekNum]) allWeeksData[weekNum] = { tajwid: [], fiqih: [], tauhid: [] };
                    allWeeksData[weekNum][subject] = grouped[weekStr];
                });
            });
            renderAllWeeks();
        } catch (e) {
            console.error("Gagal load accordion:", e);
            container.innerHTML = '<p class="text-xs text-red-500 font-bold text-center">Gagal memuat data.</p>';
        }
    };

    // ================================================================
    // LOGIKA FILTER & SORTING & RENDER ACCORDION
    // ================================================================
    document.getElementById('searchWeek').addEventListener('input', () => renderAllWeeks());
    document.getElementById('btnSortWeek').addEventListener('click', () => {
        isSortAsc = !isSortAsc;
        document.getElementById('btnSortWeek').innerHTML = isSortAsc 
            ? '<i class="fa-solid fa-arrow-down-1-9"></i>' : '<i class="fa-solid fa-arrow-down-9-1"></i>';
        renderAllWeeks();
    });

    const renderAllWeeks = () => {
        const container = document.getElementById('accordionContainer');
        container.innerHTML = '';
        const searchTerm = document.getElementById('searchWeek').value.trim();
        let weeks = Object.keys(allWeeksData).map(Number);

        if (searchTerm) weeks = weeks.filter(w => w.toString() === searchTerm);
        weeks.sort((a, b) => isSortAsc ? a - b : b - a);

        if (weeks.length === 0) {
            container.innerHTML = `
                <div class="p-8 text-center bg-white rounded-2xl border border-dashed border-gray-200">
                    <i class="fa-solid fa-book-open text-3xl text-gray-200 mb-3 block"></i>
                    <p class="text-xs text-gray-400 font-bold uppercase tracking-widest">Data Tidak Ditemukan</p>
                </div>`;
            return;
        }
        weeks.forEach(week => container.appendChild(renderWeekAccordion(week, allWeeksData[week])));
    };

    const renderWeekAccordion = (week, subjectsData) => {
        const totalQ = (subjectsData.tajwid?.length || 0) + (subjectsData.fiqih?.length || 0) + (subjectsData.tauhid?.length || 0);
        const wrapper = document.createElement('div');
        wrapper.className = `rounded-2xl border border-gray-200 overflow-hidden shadow-sm bg-white mb-4`;
        
        const header = document.createElement('div');
        header.className = `bg-gray-50 px-5 py-4 flex items-center justify-between cursor-pointer hover:bg-gray-100 transition-colors`;
        header.innerHTML = `
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-white border border-gray-200 text-gray-800 rounded-xl flex items-center justify-center font-black text-xl shadow-sm">${week}</div>
                <div>
                    <h3 class="font-black text-gray-800 uppercase text-sm tracking-wide">Pertemuan ${week}</h3>
                    <p class="text-[10px] text-gray-400 font-bold mt-0.5">${totalQ} Total Soal</p>
                </div>
            </div>
            <i class="fa-solid fa-chevron-down text-gray-400 transition-transform duration-200 accordion-arrow"></i>`;
        
        const body = document.createElement('div');
        body.className = 'accordion-body hidden bg-white p-4 space-y-3'; 

        SUBJECTS.forEach(subject => {
            const qList = subjectsData[subject];
            if (qList && qList.length > 0) {
                const c = SUBJECT_COLORS[subject];
                const subjWrapper = document.createElement('div');
                subjWrapper.className = `rounded-xl border ${c.border} overflow-hidden bg-white`;

                const subjHeader = document.createElement('div');
                subjHeader.className = `${c.bg} px-4 py-3 flex items-center justify-between cursor-pointer hover:brightness-95 transition-all`;
                const icon = subject === 'tajwid' ? '📖' : subject === 'fiqih' ? '⚖️' : '🕌';
                subjHeader.innerHTML = `
                    <div class="flex items-center gap-3">
                        <span class="text-base">${icon}</span>
                        <span class="text-xs font-black ${c.text} uppercase tracking-wider">${subject}</span>
                        <span class="text-[9px] font-bold text-gray-500 bg-white px-2 py-0.5 rounded-md border ${c.border} shadow-sm">${qList.length} soal</span>
                    </div>
                    <i class="fa-solid fa-chevron-down ${c.text} transition-transform duration-200 subj-arrow text-xs"></i>
                `;

                const subjBody = document.createElement('div');
                subjBody.className = `hidden px-4 pb-4 pt-3 space-y-3 border-t border-dashed ${c.border}`;
                subjBody.innerHTML = qList.map((q, i) => renderSoalItem(q, i, subject)).join('');

                subjHeader.onclick = (e) => {
                    e.stopPropagation();
                    const isHidden = subjBody.classList.toggle('hidden');
                    subjHeader.querySelector('.subj-arrow').style.transform = isHidden ? '' : 'rotate(180deg)';
                };

                subjWrapper.appendChild(subjHeader);
                subjWrapper.appendChild(subjBody);
                body.appendChild(subjWrapper);
            }
        });

        header.onclick = () => {
            const isHidden = body.classList.toggle('hidden');
            header.querySelector('.accordion-arrow').style.transform = isHidden ? '' : 'rotate(180deg)';
        };

        wrapper.appendChild(header);
        wrapper.appendChild(body);
        return wrapper;
    };

    const renderSoalItem = (q, index, subject) => {
        const optHtml = Object.entries(q.options || {})
            .map(([k, v]) => `<span class="${k === q.correct_answer ? 'text-green-600 font-bold' : 'text-gray-400'}">${k}: ${v}</span>`)
            .join(' · ');
        const levelColor = { mudah: 'text-green-600 bg-green-50', sedang: 'text-blue-600 bg-blue-50', sulit: 'text-red-500 bg-red-50' };
        const lc = levelColor[q.difficulty_level] || 'text-gray-500 bg-gray-50';

        return `
            <div class="bg-gray-50 rounded-xl p-3 border border-gray-200 shadow-sm space-y-1.5" data-soal-id="${q.id}">
                <div class="flex items-start justify-between gap-2">
                    <p class="text-xs font-bold text-gray-800 flex-1 leading-relaxed">${index + 1}. ${q.question}</p>
                    <div class="flex items-center gap-1 flex-shrink-0">
                        <span class="text-[9px] font-bold px-1.5 py-0.5 rounded ${lc}">${q.difficulty_level}</span>
                        <button onclick="openEditSoal(${JSON.stringify(q).replace(/"/g, '&quot;')})" class="w-6 h-6 flex items-center justify-center bg-blue-100 text-blue-600 rounded-lg text-[10px] active:scale-95 transition-all" title="Edit"><i class="fa-solid fa-pen"></i></button>
                        <button onclick="hapusSoal('${q.id}', '${subject}')" class="w-6 h-6 flex items-center justify-center bg-red-100 text-red-500 rounded-lg text-[10px] active:scale-95 transition-all" title="Hapus"><i class="fa-solid fa-trash"></i></button>
                    </div>
                </div>
                <div class="text-[10px] leading-relaxed">${optHtml}</div>
            </div>`;
    };

    // ================================================================
    // EDIT SOAL (OPTIMASI UI, TANPA FETCH ULANG KE SERVER)
    // ================================================================
    window.openEditSoal = (q) => {
        document.getElementById('editSoalId').value    = q.id;
        document.getElementById('editSoalQ').value     = q.question;
        document.getElementById('editSoalA').value     = q.options?.A || '';
        document.getElementById('editSoalB').value     = q.options?.B || '';
        document.getElementById('editSoalC').value     = q.options?.C || '';
        document.getElementById('editSoalD').value     = q.options?.D || '';
        document.getElementById('editSoalKey').value   = q.correct_answer || 'A';
        document.getElementById('editSoalLevel').value = q.difficulty_level || 'sedang';
        document.getElementById('modalEditSoal').classList.replace('hidden', 'flex');
    };

    window.closeEditSoal = () => document.getElementById('modalEditSoal').classList.replace('flex', 'hidden');
    
    window.submitEditSoal = async () => {
        const id = document.getElementById('editSoalId').value;
        const payload = {
            question: document.getElementById('editSoalQ').value.trim(),
            options: {
                A: document.getElementById('editSoalA').value.trim(),
                B: document.getElementById('editSoalB').value.trim(),
                C: document.getElementById('editSoalC').value.trim(),
                D: document.getElementById('editSoalD').value.trim(),
            },
            correct_answer: document.getElementById('editSoalKey').value,
            difficulty_level: document.getElementById('editSoalLevel').value,
        };

        if (!payload.question || !payload.options.A || !payload.options.B) return window.showToast('warning', 'Perhatian', 'Pertanyaan dan minimal 2 opsi wajib diisi.');

        try {
            const res = await fetch(`${API_URL}/api/onboarding/questions/${id}`, {
                method: 'PUT',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            if (res.ok) {
                window.showToast('success', 'Berhasil', 'Soal berhasil diperbarui.');
                closeEditSoal();
                
                // [OPTIMASI UI] Update memory lokal, hemat 3 panggilan server
                for (const week in allWeeksData) {
                    for (const subj in allWeeksData[week]) {
                        const qIndex = allWeeksData[week][subj].findIndex(q => q.id === id);
                        if (qIndex !== -1) {
                            allWeeksData[week][subj][qIndex] = { ...allWeeksData[week][subj][qIndex], ...payload };
                            break;
                        }
                    }
                }
                renderAllWeeks(); // Refresh UI langsung dari memori

            } else window.showToast('danger', 'Error', (await res.json()).message || 'Gagal update.');
        } catch (e) { window.showToast('danger', 'Error', 'Terjadi kesalahan jaringan.'); }
    };

    // ================================================================
    // HAPUS SOAL (OPTIMASI UI, TANPA FETCH ULANG KE SERVER)
    // ================================================================
    window.hapusSoal = async (id, subject) => {
        if (!confirm(`Hapus soal ini dari bank soal ${subject}? Tindakan tidak bisa dibatalkan.`)) return;

        try {
            const res = await fetch(`${API_URL}/api/onboarding/questions/${id}`, {
                method: 'DELETE',
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (res.ok) {
                window.showToast('success', 'Terhapus', 'Soal berhasil dihapus.');
                
                // [PENTING] Hapus cache karena jumlah soal/minggu bisa berubah!
                isSummaryCached = false; 

                // [OPTIMASI UI] Hapus dari memory lokal, hemat 3 panggilan server
                for (const week in allWeeksData) {
                    if (allWeeksData[week][subject]) {
                        const qIndex = allWeeksData[week][subject].findIndex(q => q.id === id);
                        if (qIndex !== -1) {
                            allWeeksData[week][subject].splice(qIndex, 1);
                            break;
                        }
                    }
                }
                renderAllWeeks(); // Refresh UI langsung dari memori

            } else window.showToast('danger', 'Error', 'Gagal menghapus soal.');
        } catch { window.showToast('danger', 'Error', 'Terjadi kesalahan jaringan.'); }
    };

    fetchAccordion();
</script>

<style>
    .animate-slide-up { animation: slideUp 0.3s ease-out; }
    @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
    .accordion-body { display: block; }
    .accordion-body.hidden { display: none; }
    .week-body.hidden { display: none; }
</style>