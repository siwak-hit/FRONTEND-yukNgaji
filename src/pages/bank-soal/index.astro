    document.getElementById('formUpload').onsubmit = (e) => {
        e.preventDefault();
        const file = document.getElementById('upFile').files[0];
        if (!file) { openManualFromModal(); return; }
        const reader = new FileReader();
        reader.onload = (ev) => { renderPreview(parseTextToJSON(ev.target.result)); isDirty = true; };
