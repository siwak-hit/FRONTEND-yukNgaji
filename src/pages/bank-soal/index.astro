    window.closeEditSoal = () => {
        if (isDirty) {
            showConfirmBack(() => document.getElementById('modalEditSoal').classList.replace('flex', 'hidden'));
        } else {
            document.getElementById('modalEditSoal').classList.replace('flex', 'hidden');
        }
    };
    
    window.submitEditSoal = async () => {
        const modal = document.getElementById('modalEditSoal');
        const id = document.getElementById('editSoalId').value;
        const payload = extractCardData(modal);

        if (!payload.question || (payload.type !== 'tf' && (!payload.options.A || !payload.options.B))) {
            return window.showToast('warning', 'Perhatian', 'Pertanyaan dan minimal 2 opsi wajib diisi.');
        }

        try {
            const res = await fetch(`${API_URL}/api/onboarding/questions/${id}`, {
                method: 'PUT',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            if (res.ok) {
                window.showToast('success', 'Berhasil', 'Soal berhasil diperbarui.');
                
                isDirty = false; // Reset Dirty
                document.getElementById('modalEditSoal').classList.replace('flex', 'hidden');
                
                for (const week in allWeeksData) {
                    for (const subj in allWeeksData[week]) {
                        const qIndex = allWeeksData[week][subj].findIndex(q => q.id === id);
                        if (qIndex !== -1) {
                            allWeeksData[week][subj][qIndex] = { ...allWeeksData[week][subj][qIndex], ...payload };
                            break;
                        }
                    }
                }
                renderAllWeeks(); 
            } else window.showToast('danger', 'Error', (await res.json()).message || 'Gagal update.');
        } catch (e) { window.showToast('danger', 'Error', 'Terjadi kesalahan jaringan.'); }
    };


    // ================================================================
    // FETCH & RENDER ACCORDION SOAL
    // ================================================================
    const fetchAccordion = async () => {
        const container = document.getElementById('accordionContainer');
        container.innerHTML = `
            <div class="animate-pulse bg-white h-16 rounded-2xl border border-gray-100"></div>
            <div class="animate-pulse bg-white h-16 rounded-2xl border border-gray-100"></div>
            <div class="animate-pulse bg-white h-16 rounded-2xl border border-gray-100"></div>`;
        try {
            const responses = await Promise.all(SUBJECTS.map(s =>
                    fetch(`${API_URL}/api/onboarding/questions/${s}`, { headers: { 'Authorization': `Bearer ${token}` } })
                    .then(r => r.json()).then(result => ({ subject: s, grouped: result.data || {} }))
            ));

            allWeeksData = {};
            responses.forEach(({ subject, grouped }) => {
                Object.keys(grouped).forEach(weekStr => {
                    const weekNum = parseInt(weekStr);
                    if (!allWeeksData[weekNum]) allWeeksData[weekNum] = { tajwid: [], fiqih: [], tauhid: [] };
                    allWeeksData[weekNum][subject] = grouped[weekStr];
                });
            });
            renderAllWeeks();
        } catch (e) {
            console.error("Gagal load accordion:", e);
            container.innerHTML = '<p class="text-xs text-red-500 font-bold text-center">Gagal memuat data.</p>';
        }
    };

    document.getElementById('searchWeek').addEventListener('input', () => renderAllWeeks());
    document.getElementById('btnSortWeek').addEventListener('click', () => {
        isSortAsc = !isSortAsc;
        document.getElementById('btnSortWeek').innerHTML = isSortAsc 
            ? '<i class="fa-solid fa-arrow-down-1-9"></i>' : '<i class="fa-solid fa-arrow-down-9-1"></i>';
        renderAllWeeks();
    });

    const renderAllWeeks = () => {
        const container = document.getElementById('accordionContainer');
        container.innerHTML = '';
        const searchTerm = document.getElementById('searchWeek').value.trim();
        let weeks = Object.keys(allWeeksData).map(Number);

        if (searchTerm) weeks = weeks.filter(w => w.toString() === searchTerm);
        weeks.sort((a, b) => isSortAsc ? a - b : b - a);

        if (weeks.length === 0) {
            container.innerHTML = `
                <div class="p-8 text-center bg-white rounded-2xl border border-dashed border-gray-200">
                    <i class="fa-solid fa-book-open text-3xl text-gray-200 mb-3 block"></i>
                    <p class="text-xs text-gray-400 font-bold uppercase tracking-widest">Data Tidak Ditemukan</p>
                </div>`;
            return;
        }
        weeks.forEach(week => container.appendChild(renderWeekAccordion(week, allWeeksData[week])));
    };

    const renderWeekAccordion = (week, subjectsData) => {
        const totalQ = (subjectsData.tajwid?.length || 0) + (subjectsData.fiqih?.length || 0) + (subjectsData.tauhid?.length || 0);
        const wrapper = document.createElement('div');
        wrapper.className = `rounded-2xl border border-gray-200 overflow-hidden shadow-sm bg-white mb-4`;
        
        const header = document.createElement('div');
        header.className = `bg-gray-50 px-5 py-4 flex items-center justify-between cursor-pointer hover:bg-gray-100 transition-colors`;
        header.innerHTML = `
