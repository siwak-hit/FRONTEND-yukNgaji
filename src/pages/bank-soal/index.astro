                <div class="w-12 h-12 bg-white border border-gray-200 text-gray-800 rounded-xl flex items-center justify-center font-black text-xl shadow-sm">${week}</div>
                <div>
                    <h3 class="font-black text-gray-800 uppercase text-sm tracking-wide">Pertemuan ${week}</h3>
                    <p class="text-[10px] text-gray-400 font-bold mt-0.5">${totalQ} Total Soal</p>
                </div>
            </div>
            <i class="fa-solid fa-chevron-down text-gray-400 transition-transform duration-200 accordion-arrow"></i>`;
        
        const body = document.createElement('div');
        body.className = 'accordion-body hidden bg-white p-4 space-y-3'; 

        SUBJECTS.forEach(subject => {
            const qList = subjectsData[subject];
            if (qList && qList.length > 0) {
                const c = SUBJECT_COLORS[subject];
                const subjWrapper = document.createElement('div');
                subjWrapper.className = `rounded-xl border ${c.border} overflow-hidden bg-white`;

                const subjHeader = document.createElement('div');
                subjHeader.className = `${c.bg} px-4 py-3 flex items-center justify-between cursor-pointer hover:brightness-95 transition-all`;
                const icon = subject === 'tajwid' ? '📖' : subject === 'fiqih' ? '⚖️' : '🕌';
                
                // TOMBOL PREVIEW DITAMBAHKAN DI SINI
                subjHeader.innerHTML = `
                    <div class="flex items-center gap-3">
                        <span class="text-base">${icon}</span>
                        <span class="text-xs font-black ${c.text} uppercase tracking-wider">${subject}</span>
                        <span class="text-[9px] font-bold text-gray-500 bg-white px-2 py-0.5 rounded-md border ${c.border} shadow-sm">${qList.length} soal</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <button onclick="previewKuesioner(event, '${subject}', ${week})" class="w-7 h-7 bg-white border border-gray-200 rounded-lg flex items-center justify-center text-gray-400 hover:text-indigo-500 hover:border-indigo-200 transition-colors shadow-sm" title="Preview POV Siswa">
                            <i class="fa-solid fa-eye text-[10px]"></i>
                        </button>
                        <i class="fa-solid fa-chevron-down ${c.text} transition-transform duration-200 subj-arrow text-xs ml-1"></i>
                    </div>
                `;

                const subjBody = document.createElement('div');
                subjBody.className = `hidden px-4 pb-4 pt-3 space-y-3 border-t border-dashed ${c.border}`;
                subjBody.innerHTML = qList.map((q, i) => renderSoalItem(q, i, subject)).join('');

                subjHeader.onclick = (e) => {
                    e.stopPropagation();
                    const isHidden = subjBody.classList.toggle('hidden');
                    subjHeader.querySelector('.subj-arrow').style.transform = isHidden ? '' : 'rotate(180deg)';
                };

                subjWrapper.appendChild(subjHeader);
                subjWrapper.appendChild(subjBody);
                body.appendChild(subjWrapper);
            }
        });

        header.onclick = () => {
            const isHidden = body.classList.toggle('hidden');
            header.querySelector('.accordion-arrow').style.transform = isHidden ? '' : 'rotate(180deg)';
        };

        wrapper.appendChild(header);
        wrapper.appendChild(body);
        return wrapper;
    };

    // FUNGSI PREVIEW POV SISWA
    window.previewKuesioner = (e, subject, week) => {
        e.stopPropagation(); // Mencegah accordion terbuka tertutup
        window.location.href = `/consultations/fill?preview=true&subject=${subject}&week=${week}`;
    };

    const renderSoalItem = (q, index, subject) => {
        const typeBadge = q.type === 'tf' ? '<span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-purple-100 text-purple-600 border border-purple-200 uppercase tracking-widest shadow-sm">T/F</span>' :
                          q.type === 'drag' ? '<span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-orange-100 text-orange-600 border border-orange-200 uppercase tracking-widest shadow-sm">DRAG</span>' :
                          '<span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-gray-100 text-gray-500 border border-gray-200 uppercase tracking-widest shadow-sm">PG</span>';

        let optHtml = '';
        if (q.type === 'drag') {
            const allOpts = Object.entries(q.options || {})
                .map(([k, v]) => `<span class="inline-block px-1.5 py-0.5 rounded border border-orange-200 bg-orange-50 text-orange-700 font-bold">${k}: ${v}</span>`)
                .join(' ');
            const answerKeys = (q.correct_answer || '').split(',');
            let blankIndex = 0;
            const filledSentence = (q.question || '').replace(/\[BLANK\]/g, () => {
                const key = answerKeys[blankIndex] || '?';
                const val = (q.options || {})[key] || key;
                blankIndex++;
                return `<span class="inline-block bg-green-100 text-green-700 font-black px-1.5 py-0.5 rounded border border-green-300 text-[10px]">${val}</span>`;
            });
            optHtml = `
                <div class="space-y-2">
                    <p class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">Kalimat Lengkap:</p>
                    <p class="text-[11px] text-gray-700 leading-relaxed font-medium">${filledSentence}</p>
                    <p class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mt-1">Pilihan Jawaban:</p>
                    <div class="flex flex-wrap gap-1">${allOpts}</div>
                </div>`;
        } else {
            optHtml = Object.entries(q.options || {})
                .map(([k, v]) => `<span class="${k === q.correct_answer ? 'text-green-600 font-bold' : 'text-gray-400'}">${k}: ${v}</span>`)
                .join(' · ');
        }
        
        const levelColor = { mudah: 'text-green-600 bg-green-50', sedang: 'text-blue-600 bg-blue-50', sulit: 'text-red-500 bg-red-50' };
        const lc = levelColor[q.difficulty_level] || 'text-gray-500 bg-gray-50';

        return `
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 shadow-sm space-y-2" data-soal-id="${q.id}">
                <div class="flex items-start justify-between gap-2 border-b border-gray-100 pb-2">
                    <p class="text-xs font-bold text-gray-800 flex-1 leading-relaxed">${index + 1}. ${q.question}</p>
                    <div class="flex flex-col items-end gap-1.5 flex-shrink-0">
                        <div class="flex items-center gap-1">
                            ${typeBadge}
                            <span class="text-[9px] font-bold px-1.5 py-0.5 rounded border border-white shadow-sm ${lc}">${q.difficulty_level}</span>
                        </div>
                        <div class="flex gap-1 mt-1">
                            <button onclick="openEditSoal(${JSON.stringify(q).replace(/"/g, '&quot;')})" class="w-6 h-6 flex items-center justify-center bg-white text-blue-500 border border-blue-100 rounded-md text-[10px] shadow-sm active:scale-95 transition-all" title="Edit"><i class="fa-solid fa-pen"></i></button>
                            <button onclick="hapusSoal('${q.id}', '${subject}')" class="w-6 h-6 flex items-center justify-center bg-white text-red-500 border border-red-100 rounded-md text-[10px] shadow-sm active:scale-95 transition-all" title="Hapus"><i class="fa-solid fa-trash"></i></button>
                        </div>
                    </div>
                </div>
                <div class="text-[10px] leading-relaxed pt-1">${optHtml}</div>
            </div>`;
    };

    // HAPUS SOAL 
    window.hapusSoal = async (id, subject) => {
        if (!confirm(`Hapus soal ini dari bank soal ${subject}? Tindakan tidak bisa dibatalkan.`)) return;
        try {
            const res = await fetch(`${API_URL}/api/onboarding/questions/${id}`, {
                method: 'DELETE',
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (res.ok) {
                window.showToast('success', 'Terhapus', 'Soal berhasil dihapus.');
                isSummaryCached = false; 

                for (const week in allWeeksData) {
                    if (allWeeksData[week][subject]) {
                        const qIndex = allWeeksData[week][subject].findIndex(q => q.id === id);
                        if (qIndex !== -1) {
                            allWeeksData[week][subject].splice(qIndex, 1);
                            break;
                        }
                    }
                }
                renderAllWeeks(); 
            } else window.showToast('danger', 'Error', 'Gagal menghapus soal.');
        } catch { window.showToast('danger', 'Error', 'Terjadi kesalahan jaringan.'); }
    };

    fetchAccordion();
</script>

<style>
    .animate-slide-up { animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    @keyframes slideUp { from { transform: translateY(30px) scale(0.95); opacity: 0; } to { transform: translateY(0) scale(1); opacity: 1; } }
    .accordion-body { display: block; }
    .accordion-body.hidden { display: none !important; }
</style>