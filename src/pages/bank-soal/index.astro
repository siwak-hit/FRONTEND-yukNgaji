    // BUG 2 FIXED: FORM INPUT MANUAL TERBUKA KOSONG (Langsung tembak Soal 1)
    window.openManualFromModal = () => { 
        closeUpload(); 
        renderPreview([]); 
        addNewQuestionField(); 
        isDirty = false; // Reset dirty karena baru buka kosong
    };

    const parseTextToJSON = (text) => {
        const blocks = text.split(/\r?\n\r?\n/);
        return blocks.map(block => {
            const lines = block.split('\n').map(l => l.trim());
            const type = lines.find(l => l.startsWith('TIPE:'))?.replace('TIPE:', '').trim().toLowerCase() || 'pilgan';
            const q = lines.find(l => l.startsWith('Q:'))?.replace('Q:', '').trim() || '';
            const key = lines.find(l => l.startsWith('KUNCI:'))?.replace('KUNCI:', '').trim() || 'A';
            const level = lines.find(l => l.startsWith('LEVEL:'))?.replace('LEVEL:', '').trim().toLowerCase() || 'sedang';
            
            const options = {};
            ['A','B','C','D','E','F','G','H'].forEach(letter => {
                const line = lines.find(l => l.startsWith(`${letter}:`));
                if (line) options[letter] = line.replace(`${letter}:`, '').trim();
            });
            
            if ((type === 'pilgan' || type === 'drag') && Object.keys(options).length === 0) {
                options.A = ""; options.B = ""; options.C = ""; options.D = "";
            }
            return { type, q, options, key, level };
        }).filter(item => item.q !== '');
    };

    window.renderPreview = (questions) => {
        const container = document.getElementById('previewContent');
        container.innerHTML = '';
        questions.forEach((item, idx) => { container.appendChild(createSoalCard(item, idx + 1)); });
        document.getElementById('targetWeek').value = resolvedWeekForUpload || 1;
        document.getElementById('previewSubjectLabel').textContent = activeSubjectForUpload;
        document.getElementById('modalUpload').classList.add('hidden');
        document.getElementById('modalPreview').classList.remove('hidden');
    };

