---
import Layout from '../../layouts/Layout.astro';
import NavbarGuru from '../../components/NavbarGuru.astro';
import Toast from '../../components/Toast.astro';
import ModalAlert from '../../components/ModalAlert.astro';
---

<Layout title="Bank Soal - yukNgaji">
    <div class="px-6 py-8 pb-32 min-h-screen flex flex-col bg-gray-50">
        
        <header class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-2xl font-bold text-gray-800 tracking-tight">Bank Soal</h1>
                <p class="text-xs text-gray-400 mt-1 font-medium uppercase tracking-widest">Manajemen Kuesioner</p>
            </div>
            <button id="btnOpenUpload" class="w-12 h-12 bg-green-600 text-white rounded-2xl shadow-lg shadow-green-600/30 flex items-center justify-center active:scale-95 transition-all">
                <i class="fa-solid fa-plus text-lg"></i>
            </button>
        </header>

        <a href="/exams" class="mb-6 bg-gradient-to-br from-amber-400 to-orange-500 p-6 rounded-3xl shadow-lg shadow-orange-500/30 flex items-center justify-between active:scale-95 transition-transform relative overflow-hidden cursor-pointer">
            <div class="absolute -right-6 -top-6 w-24 h-24 bg-white/10 rounded-full blur-xl pointer-events-none"></div>
            <div class="absolute right-10 -bottom-8 w-20 h-20 bg-white/10 rounded-full blur-xl pointer-events-none"></div>

            <div class="relative z-10 flex items-center gap-4">
                <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center text-white backdrop-blur-sm border border-white/20 shadow-inner shrink-0">
                    <i class="fa-solid fa-graduation-cap text-xl"></i>
                </div>
                <div>
                    <h2 class="text-xl font-black mb-1 text-white drop-shadow-sm flex items-center flex-wrap gap-1.5">
                        Ujian & Evaluasi 
                        <span class="bg-red-500 text-white text-[8px] px-1.5 py-0.5 rounded-full uppercase tracking-widest font-black animate-pulse shadow-sm">Baru</span>
                    </h2>
                    <p class="text-[10px] font-bold text-orange-50/90 leading-tight">Buat ujian khusus dengan timer, gambar, & hint.</p>
                </div>
            </div>
            
            <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center text-white relative z-10 backdrop-blur-sm border border-white/20 shrink-0 hidden sm:flex">
                <i class="fa-solid fa-chevron-right text-lg"></i>
            </div>
        </a>

        <section class="mb-6 bg-green-50 p-4 rounded-2xl border border-green-100">
            <div class="flex items-start gap-3">
                <i class="fa-solid fa-circle-info text-green-600 mt-1 flex-shrink-0"></i>
                <div class="flex-1">
                    <h4 class="text-xs font-bold text-green-800 uppercase">Petunjuk Upload</h4>
                    <p class="text-[10px] text-green-700 leading-relaxed mt-1">
                        Gunakan format <b>TIPE:</b> (pilgan/tf/drag), <b>Q:</b> (Soal), <b>A-D:</b> (Pilihan), <b>KUNCI:</b> (A/B/C/D), dan <b>LEVEL:</b> (mudah/sedang/sulit).
                    </p>
                    <button id="btnDownloadTemplate" class="mt-3 flex items-center gap-2 text-[10px] font-bold bg-white text-green-600 px-3 py-1.5 rounded-lg border border-green-200 active:scale-95 transition-all">
                        <i class="fa-solid fa-download"></i>
                        Unduh Template .txt
                    </button>
                </div>
            </div>
        </section>

        <section class="mb-4 flex gap-2">
            <div class="relative flex-1">
                <i class="fa-solid fa-magnifying-glass absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
                <input type="number" id="searchWeek" placeholder="Cari pertemuan (cth: 1)" class="w-full pl-9 pr-4 py-3 bg-white border border-gray-200 rounded-xl text-sm font-bold focus:ring-2 focus:ring-green-500 outline-none shadow-sm placeholder-gray-300">
            </div>
            <button id="btnSortWeek" class="w-12 h-[46px] bg-white border border-gray-200 rounded-xl text-gray-600 text-sm shadow-sm active:scale-95 transition-all flex items-center justify-center" title="Urutkan (Asc/Desc)">
                <i class="fa-solid fa-arrow-down-1-9"></i>
            </button>
        </section>

        <section class="flex-1 space-y-4" id="accordionContainer">
            <div class="animate-pulse bg-white h-16 rounded-2xl border border-gray-100"></div>
            <div class="animate-pulse bg-white h-16 rounded-2xl border border-gray-100"></div>
            <div class="animate-pulse bg-white h-16 rounded-2xl border border-gray-100"></div>
        </section>
    </div>

    <div id="modalUpload" class="fixed inset-0 bg-black/40 z-[60] hidden flex items-end sm:items-center justify-center p-0 sm:p-4">
        <div class="bg-white w-full max-w-md rounded-t-3xl sm:rounded-3xl p-6 shadow-2xl animate-slide-up">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-bold text-gray-800">Tambah Soal Baru</h3>
                <button onclick="closeUpload()" class="text-gray-400"><i class="fa-solid fa-xmark"></i></button>
            </div>
            
            <form id="formUpload" class="space-y-4">
                <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase ml-1">Mata Pelajaran</label>
                    <select id="upSubject" class="w-full mt-1 px-4 py-3 bg-gray-50 border-none rounded-xl text-sm focus:ring-2 focus:ring-green-500">
                        <option value="tajwid">Tajwid</option>
                        <option value="fiqih">Fiqih</option>
                        <option value="tauhid">Tauhid</option>
                    </select>
                </div>

                <div class="p-3 bg-blue-50 rounded-xl border border-blue-100">
                    <p class="text-[10px] font-bold text-blue-700 uppercase mb-2">Target Pertemuan</p>
                    <div class="space-y-2">
                        <label class="flex items-center gap-3 cursor-pointer p-2 rounded-xl hover:bg-blue-100 transition-colors">
                            <input type="radio" name="weekMode" value="baru" checked class="accent-green-600">
                            <div>
                                <p class="text-xs font-bold text-gray-700">Pertemuan Baru</p>
                                <p class="text-[10px] text-gray-400" id="labelPertemuanBaru">Otomatis ke minggu berikutnya</p>
                            </div>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer p-2 rounded-xl hover:bg-blue-100 transition-colors">
                            <input type="radio" name="weekMode" value="sisipan" class="accent-green-600">
                            <div>
                                <p class="text-xs font-bold text-gray-700">Sisipan / Tambah ke Pertemuan Lama</p>
                                <p class="text-[10px] text-gray-400">Pilih minggu yang sudah ada atau kosong</p>
                            </div>
                        </label>
                    </div>

                    <div id="sisipanDropdownWrap" class="hidden mt-3">
                        <select id="sisipanWeek" class="w-full px-3 py-2 bg-white rounded-xl text-sm border border-blue-200 font-medium">
                            <option value="">Pilih minggu...</option>
                        </select>
                    </div>
                </div>

                <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase ml-1">File Template (.txt) <span class="text-gray-300 normal-case font-normal">(opsional jika manual)</span></label>
                    <input type="file" id="upFile" accept=".txt" class="w-full mt-1 text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-semibold file:bg-green-50 file:text-green-700 hover:file:bg-green-100 cursor-pointer">
                </div>

                <div class="grid grid-cols-2 gap-2">
                    <button type="submit" class="py-3 bg-green-600 text-white font-bold rounded-2xl shadow-lg active:scale-95 transition-all text-sm">
                        <i class="fa-solid fa-file-arrow-up mr-1"></i> Upload File
                    </button>
                    <button type="button" onclick="openManualFromModal()" class="py-3 bg-white border-2 border-dashed border-green-300 text-green-700 font-bold rounded-2xl active:scale-95 transition-all text-sm">
                        <i class="fa-solid fa-pen mr-1"></i> Input Manual
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div id="modalPreview" class="fixed inset-0 bg-white z-[60] hidden h-screen flex flex-col overflow-hidden">
        <header class="fixed top-0 left-0 w-full p-5 border-b flex justify-between items-center bg-white z-20 flex-shrink-0 shadow-sm">
            <button onclick="closePreview()" class="text-gray-400 text-xl active:scale-95 transition-all"><i class="fa-solid fa-chevron-left"></i></button>
            <h3 class="font-bold text-gray-800">Preview & Edit Soal</h3>
            <button id="btnFinalSave" class="text-green-600 font-bold text-sm active:opacity-70 transition-opacity">Simpan</button>
        </header>

        <div class="mt-[72px] bg-green-50 p-4 border-b flex items-center gap-2 flex-shrink-0">
            <label class="text-[10px] font-bold text-green-700 uppercase">Mapel:</label>
            <span id="previewSubjectLabel" class="text-xs font-black text-green-700 uppercase mr-4">-</span>
            <label class="text-[10px] font-bold text-green-700 uppercase">Target Pertemuan:</label>
            <span class="text-[10px] text-gray-500 font-bold">MG-</span>
            <input type="number" id="targetWeek" value="1" min="1" class="w-12 h-8 rounded-lg border-none text-center font-bold text-green-600 focus:ring-2 focus:ring-green-500">
        </div>

        <div class="bg-blue-50 border-b border-blue-100 p-4 flex gap-3 items-start flex-shrink-0">
            <i class="fa-solid fa-circle-info text-blue-500 mt-0.5"></i>
            <p class="text-[10px] text-blue-800 font-medium leading-relaxed">
                <b class="uppercase tracking-wider">Info Otak Adaptif AI:</b><br>
                Sistem otomatis memberikan soal <b>Mudah/Sedang/Sulit</b> secara dinamis berdasarkan riwayat nilai minggu sebelumnya.
            </p>
        </div>

        <div id="previewContent" class="flex-1 overflow-y-auto p-6 space-y-6 pb-[100px] no-scrollbar bg-gray-50"></div>
    
        <div class="fixed bottom-0 sm:bottom-[72px] left-0 w-full p-4 bg-gradient-to-t from-white via-white to-transparent z-10 flex-shrink-0">
            <div class="max-w-md mx-auto">
                <button id="btnTambahManual" class="w-full py-4 bg-white border-2 border-dashed border-green-200 rounded-2xl text-green-600 font-bold text-xs shadow-lg active:scale-95 transition-all">
                    <i class="fa-solid fa-plus mr-1"></i> Tambah Soal Manual
                </button>
            </div>
        </div>
    </div>

    <div id="modalEditSoal" class="fixed inset-0 bg-black/60 z-[70] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-md rounded-3xl p-6 shadow-2xl max-h-[90vh] overflow-y-auto no-scrollbar card-core-logic">
            <div class="flex justify-between items-center mb-4">
                <h3 class="font-bold text-gray-800">Edit Soal</h3>
                <button onclick="closeEditSoal()" class="text-gray-400"><i class="fa-solid fa-xmark"></i></button>
            </div>
            
            <input type="hidden" id="editSoalId">
            
            <div class="flex items-center gap-3 bg-gray-50 p-2 rounded-xl border border-gray-100 mb-4">
                <label class="text-[10px] font-bold text-gray-500 uppercase ml-2">Tipe Soal:</label>
                <select id="editSoalType" onchange="toggleEditType()" class="text-xs font-bold border-none bg-white rounded-lg px-2 py-1.5 outline-none shadow-sm flex-1 text-gray-700 focus:ring-2 focus:ring-blue-400">
                    <option value="pilgan">Pilihan Ganda</option>
                    <option value="tf">Benar / Salah</option>
                    <option value="drag">Drag & Drop (Menghubungkan)</option>
                </select>
            </div>

            <div id="editDragHint" class="drag-tools hidden mb-3 p-3 bg-indigo-50/50 border border-indigo-100 rounded-xl flex flex-col sm:flex-row sm:items-center justify-between gap-3">
                <div class="flex items-start gap-2.5">
                    <div class="w-6 h-6 rounded-full bg-indigo-100 text-indigo-500 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <i class="fa-solid fa-wand-magic-sparkles text-xs"></i>
                    </div>
                    <p class="text-[10px] text-indigo-900 leading-relaxed font-medium">
                        <b class="text-indigo-700">Mode Drag & Drop:</b><br>
                        Klik tombol di samping untuk menyisipkan kolom kosong pada soal.
                    </p>
                </div>
                <button type="button" onclick="insertBlank(this)" class="flex-shrink-0 w-full sm:w-auto text-[10px] font-bold bg-indigo-600 text-white px-4 py-2.5 rounded-lg hover:bg-indigo-700 transition-colors shadow-md shadow-indigo-600/20 active:scale-95 flex items-center justify-center gap-2">
                    <i class="fa-solid fa-plus"></i> Sisipkan [BLANK]
                </button>
            </div>

            <div>
                <label class="text-[10px] font-bold text-gray-400 uppercase">Pertanyaan</label>
                <textarea id="editSoalQ" rows="3" class="q-input w-full mt-1 p-3 bg-gray-50 rounded-xl text-sm font-bold border-none focus:ring-2 focus:ring-blue-400" oninput="updateDragKeys(this)"></textarea>
            </div>
            
            <div id="editOptionsWrapper" class="options-wrapper flex flex-col gap-2 mt-3"></div>
            <button type="button" id="editBtnAddOption" class="btn-add-option text-[10px] font-bold text-blue-500 mt-2 hover:bg-blue-50 px-2 py-1 rounded transition-colors active:scale-95" onclick="addOptionRow(this)">+ Tambah Pilihan Jawaban</button>

            <div id="editTfWrapper" class="hidden p-3 bg-blue-50 border border-blue-100 rounded-xl flex items-center gap-3 mt-3">
                <div class="w-8 h-8 rounded-full bg-blue-200 text-blue-600 flex items-center justify-center flex-shrink-0"><i class="fa-solid fa-toggle-on"></i></div>
                <p class="text-[10px] font-bold text-blue-700 leading-relaxed">Mode Benar/Salah aktif. Opsi jawaban otomatis menjadi A (Benar) dan B (Salah).</p>
            </div>

            <div class="flex flex-col gap-3 mt-4 bg-gray-50 p-3 rounded-xl border border-gray-100">
                <div class="key-standard flex items-center gap-2">
                    <span class="text-[10px] font-bold text-gray-400">KUNCI (PG/TF):</span>
                    <select id="editSoalKey" class="key-input text-xs font-bold border-none bg-green-100 text-green-700 rounded-lg px-3 py-1.5 shadow-sm outline-none"></select>
                </div>
                
                <div id="editKeyDrag" class="key-drag hidden w-full">
                    <span class="text-[10px] font-bold text-gray-400 mb-2 block">KUNCI JAWABAN DRAG & DROP:</span>
                    <div class="drag-keys-container grid grid-cols-2 gap-2"></div>
                </div>

                <div class="flex items-center gap-2 mt-2 pt-2 border-t border-gray-200">
                    <span class="text-[10px] font-bold text-gray-400">LEVEL KESULITAN:</span>
                    <select id="editSoalLevel" class="level-input text-xs font-bold border-none bg-indigo-100 text-indigo-700 rounded-lg px-2 py-1.5 shadow-sm">
                        <option value="mudah">Mudah</option>
                        <option value="sedang">Sedang</option>
                        <option value="sulit">Sulit</option>
                    </select>
                </div>
            </div>
            <button onclick="submitEditSoal()" class="w-full py-3 mt-2 bg-blue-600 text-white font-bold rounded-2xl shadow-lg shadow-blue-600/30 active:scale-95 transition-all">
                <i class="fa-solid fa-floppy-disk mr-2"></i>Simpan Perubahan
            </button>
        </div>
    </div>

    <div id="modalConfirmBack" class="fixed inset-0 bg-black/60 z-[100] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-sm rounded-2xl p-6 shadow-2xl relative animate-slide-up text-center border border-gray-100">
            <div class="w-16 h-16 bg-amber-50 text-amber-500 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4 border border-amber-100 shadow-inner">
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>
            <h3 class="font-black text-gray-800 text-lg mb-2">Perubahan Belum Disimpan!</h3>
            <p class="text-xs font-bold text-gray-500 leading-relaxed mb-6">
                Anda memiliki soal yang baru diketik/diedit dan belum disimpan. Yakin ingin menutup editor?
            </p>
            <div class="flex gap-3">
                <button onclick="closeConfirmBack()" class="flex-1 py-3 bg-gray-100 text-gray-500 font-bold rounded-xl active:scale-95 transition-all">Batal</button>
                <button onclick="forceCloseAction()" class="flex-1 py-3 bg-red-600 text-white font-bold rounded-xl shadow-md shadow-red-600/20 active:scale-95 transition-all">Ya, Tutup</button>
            </div>
        </div>
    </div>

    <NavbarGuru activeMenu="exam" />
    <Toast />
    <ModalAlert />
</Layout>

<script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const token = localStorage.getItem('token');
    if (!token) window.location.replace('/');

    const SUBJECTS = ['tajwid', 'fiqih', 'tauhid'];
    const SUBJECT_COLORS = {
        tajwid:  { bg: 'bg-green-50',  border: 'border-green-200',  text: 'text-green-700',  badge: 'bg-green-100 text-green-700'  },
        fiqih:   { bg: 'bg-blue-50',   border: 'border-blue-200',   text: 'text-blue-700',   badge: 'bg-blue-100 text-blue-700'   },
        tauhid:  { bg: 'bg-purple-50', border: 'border-purple-200', text: 'text-purple-700', badge: 'bg-purple-100 text-purple-700'},
    };

    let summaryData = {};
    let activeSubjectForUpload = 'tajwid';
    let resolvedWeekForUpload  = 1;
    let allWeeksData = {}; 
    let isSortAsc = true;
    let isSummaryCached = false; 

    // STATE UNSAVED CHANGES
    let isDirty = false;
    let pendingCloseAction = null;

    // Menandai perubahan saat ada input di dalam elemen .card-core-logic
    document.addEventListener('input', (e) => {
        if (e.target.closest('.card-core-logic')) isDirty = true;
    });

    window.markDirty = () => { isDirty = true; };

    // Logika Mencegah Keluar Browser
    window.addEventListener('beforeunload', (e) => {
        if (isDirty) { e.preventDefault(); e.returnValue = ''; }
    });

    // Pengendali Modal Unsaved
    window.showConfirmBack = (action) => {
        pendingCloseAction = action;
        document.getElementById('modalConfirmBack').classList.replace('hidden', 'flex');
    };

    window.closeConfirmBack = () => {
        pendingCloseAction = null;
        document.getElementById('modalConfirmBack').classList.replace('flex', 'hidden');
    };

    window.forceCloseAction = () => {
        isDirty = false; // Reset dirty
        document.getElementById('modalConfirmBack').classList.replace('flex', 'hidden');
        if (pendingCloseAction) pendingCloseAction();
    };

    // ================================================================
    // CORE LOGIC (HELPER UNTUK BUILDER SOAL & MODAL EDIT)
    // ================================================================
    
    window.appendOptionRow = (wrapper, key, val) => {
        const row = document.createElement('div');
        row.className = "opt-row flex items-center gap-2";
        row.dataset.key = key;
        row.innerHTML = `
            <label class="text-[10px] text-gray-400 font-bold uppercase w-[40px] flex-shrink-0">Opsi ${key}</label>
            <input type="text" class="opt-val flex-1 p-2 bg-white border border-gray-200 rounded-lg text-xs outline-none focus:ring-2 focus:ring-blue-200 shadow-sm font-medium text-gray-700" placeholder="Jawaban ${key}" value="${val}">
            <button type="button" onclick="removeOptionRow(this)" class="btn-remove-opt text-red-400 hover:bg-red-50 w-8 h-8 rounded-lg flex items-center justify-center transition-colors active:scale-95" title="Hapus Opsi"><i class="fa-solid fa-xmark"></i></button>
        `;
        
        // Refresh kunci Drag Drop saat ketikan opsi berubah
        row.querySelector('.opt-val').addEventListener('input', () => {
            const card = wrapper.closest('.card-core-logic');
            if (card?.querySelector('.type-input')?.value === 'drag') {
                const textarea = card.querySelector('.q-input');
                const selects = card.querySelectorAll('.drag-key-select');
                const currentKeys = Array.from(selects).map(s => s.value);
                
                updateDragKeys(textarea);
                
                // Kembalikan pilihan dropdown setelah refresh
                const newSelects = card.querySelectorAll('.drag-key-select');
                newSelects.forEach((sel, i) => { if (currentKeys[i]) sel.value = currentKeys[i]; });
            }
        });
        wrapper.appendChild(row);
    };

    window.syncStandardKeys = (cardElement, presetKey = null) => {
        const keyInput = cardElement.querySelector('.key-input');
        const rows = Array.from(cardElement.querySelectorAll('.opt-row'));
        keyInput.innerHTML = rows.map(r => `<option value="${r.dataset.key}">${r.dataset.key}</option>`).join('');
        if (presetKey && rows.find(r => r.dataset.key === presetKey)) {
            keyInput.value = presetKey;
        }
    };

    window.insertBlank = (btn) => {
        markDirty();
        const card = btn.closest('.card-core-logic');
        const textarea = card.querySelector('.q-input');
        const cursorPosition = textarea.selectionStart;
        const textBefore = textarea.value.substring(0, cursorPosition);
        const textAfter = textarea.value.substring(cursorPosition, textarea.value.length);
        
        textarea.value = textBefore + '[BLANK]' + textAfter;
        textarea.focus();
        textarea.selectionStart = cursorPosition + 7;
        textarea.selectionEnd = cursorPosition + 7;
        
        updateDragKeys(textarea);
    };

    window.updateDragKeys = (textarea, presetKeys = null) => {
        const card = textarea.closest('.card-core-logic');
        const type = card.querySelector('.type-input').value;
        if (type !== 'drag') return;

        const text = textarea.value;
        const blankCount = (text.match(/\[BLANK\]/g) || []).length;
        const keyContainer = card.querySelector('.drag-keys-container');
        const optRows = Array.from(card.querySelectorAll('.opt-row'));
        const visibleOptions = optRows.map(row => row.dataset.key);

        if (blankCount === 0) {
            keyContainer.innerHTML = '<span class="text-[10px] text-red-500 col-span-2 italic">Minimal masukkan 1 [BLANK] pada teks soal di atas.</span>';
            return;
        }

        let html = '';
        for(let i=0; i<blankCount; i++) {
            const optionsHtml = optRows.map(row => {
                const val = row.querySelector('.opt-val')?.value?.trim() || '';
                const key = row.dataset.key;
                return `<option value="${key}">${key}: ${val || '(kosong)'}</option>`;
            }).join('');
            
            html += `
                <div class="flex items-center gap-2 p-2 bg-white border border-gray-200 rounded-lg shadow-sm focus-within:ring-2 focus-within:ring-indigo-400">
                    <span class="text-[10px] font-black text-indigo-600 bg-indigo-50 px-1.5 py-0.5 rounded border border-indigo-100">B${i+1}</span>
                    <select class="drag-key-select text-[11px] font-bold border-none bg-transparent outline-none flex-1 text-gray-700 cursor-pointer">
                        ${optionsHtml}
                    </select>
                </div>
            `;
        }
        keyContainer.innerHTML = html;

        if (presetKeys) {
            const selects = keyContainer.querySelectorAll('.drag-key-select');
            const keysArray = presetKeys.split(',');
            selects.forEach((sel, i) => {
                if (keysArray[i] && visibleOptions.includes(keysArray[i])) sel.value = keysArray[i];
            });
        }
    };

    window.addOptionRow = (btn) => {
        markDirty();
        const card = btn.closest('.card-core-logic');
        const wrapper = card.querySelector('.options-wrapper');
        const currentRows = wrapper.querySelectorAll('.opt-row');
        const nextCharCode = 65 + currentRows.length; // 65 is 'A'
        
        if (nextCharCode > 72) { // Max H
            window.showToast?.('warning', 'Maksimal', 'Maksimal 8 opsi jawaban (A-H).');
            return;
        }
        
        const letter = String.fromCharCode(nextCharCode);
        appendOptionRow(wrapper, letter, "");
        
        const type = card.querySelector('.type-input').value;
        if (type === 'drag') updateDragKeys(card.querySelector('.q-input'));
        else if (type === 'pilgan') syncStandardKeys(card);
    };

    window.removeOptionRow = (btn) => {
        markDirty();
        const card = btn.closest('.card-core-logic');
        const wrapper = card.querySelector('.options-wrapper');
        
        if (wrapper.querySelectorAll('.opt-row').length <= 2) {
            window.showToast?.('warning', 'Minimal', 'Minimal harus ada 2 opsi jawaban.');
            return;
        }

        btn.closest('.opt-row').remove();
        
        // Re-index
        const rows = wrapper.querySelectorAll('.opt-row');
        rows.forEach((r, idx) => {
            const letter = String.fromCharCode(65 + idx);
            r.dataset.key = letter;
            r.querySelector('label').innerText = `Opsi ${letter}`;
            r.querySelector('input').placeholder = `Jawaban ${letter}`;
        });
        
        const type = card.querySelector('.type-input').value;
        if (type === 'drag') updateDragKeys(card.querySelector('.q-input'));
        else if (type === 'pilgan') syncStandardKeys(card);
    };

    // Master Switcher (Mengatur Tampilan saat Tipe Soal diubah)
    window.toggleCardType = (selectEl, presetKey = null) => {
        const card = selectEl.closest('.card-core-logic');
        const type = selectEl.value;
        
        const optWrapper = card.querySelector('.options-wrapper');
        const btnAddOpt = card.querySelector('.btn-add-option');
        const tfWrapper = card.querySelector('.tf-wrapper');
        const dragTools = card.querySelector('.drag-tools');
        const keyStandard = card.querySelector('.key-standard');
        const keyDrag = card.querySelector('.key-drag');
        const keyInput = card.querySelector('.key-input');
        const textarea = card.querySelector('.q-input');

        optWrapper.classList.add('hidden');
        if(btnAddOpt) btnAddOpt.classList.add('hidden');
        tfWrapper.classList.add('hidden');
        dragTools.classList.add('hidden');
        keyStandard.classList.add('hidden');
        keyDrag.classList.add('hidden');

        if (type === 'tf') {
            tfWrapper.classList.remove('hidden');
            keyStandard.classList.remove('hidden');
            
            Array.from(keyInput.options).forEach(o => {
                if(o.value === 'C' || o.value === 'D' || o.value > 'B') o.style.display = 'none';
                if(o.value === 'A') o.text = 'A (Benar)';
                if(o.value === 'B') o.text = 'B (Salah)';
            });
            if(keyInput.value !== 'A' && keyInput.value !== 'B') keyInput.value = 'A';
            if(presetKey === 'A' || presetKey === 'B') keyInput.value = presetKey;
            
        } else if (type === 'drag') {
            optWrapper.classList.remove('hidden');
            if(btnAddOpt) btnAddOpt.classList.remove('hidden');
            dragTools.classList.remove('hidden');
            keyDrag.classList.remove('hidden');
            
            card.querySelectorAll('.btn-remove-opt').forEach(btn => btn.style.display = 'flex');
            updateDragKeys(textarea, presetKey);

        } else { // pilgan
            optWrapper.classList.remove('hidden');
            if(btnAddOpt) btnAddOpt.classList.remove('hidden');
            keyStandard.classList.remove('hidden');
            
            card.querySelectorAll('.btn-remove-opt').forEach(btn => btn.style.display = 'flex');
            syncStandardKeys(card, presetKey);
        }
    };

    const extractCardData = (card) => {
        const type = card.querySelector('.type-input').value;
        const question = card.querySelector('.q-input').value.trim();
        const level = card.querySelector('.level-input').value;
        
        let finalOptions = {};
        let finalKey = "A";

        if (type === 'tf') {
            finalOptions = { A: "Benar", B: "Salah" };
            finalKey = card.querySelector('.key-input').value;
        } else {
            const rows = card.querySelectorAll('.opt-row');
            rows.forEach(r => { finalOptions[r.dataset.key] = r.querySelector('.opt-val').value.trim(); });
            
            if (type === 'drag') {
                const selects = card.querySelectorAll('.drag-key-select');
                finalKey = Array.from(selects).map(s => s.value).join(',');
            } else {
                finalKey = card.querySelector('.key-input').value;
            }
        }

        return { type, question, options: finalOptions, correct_answer: finalKey, difficulty_level: level };
    };


    // ================================================================
    // PREVIEW EDITOR & TIPE
    // ================================================================

    document.getElementById('btnOpenUpload').onclick = async () => {
        await loadSummaryIntoModal();
        document.getElementById('modalUpload').classList.remove('hidden');
