---
import Layout from '../../layouts/Layout.astro';
import NavbarGuru from '../../components/NavbarGuru.astro';
import Toast from '../../components/Toast.astro';
import ModalAlert from '../../components/ModalAlert.astro';
---

<Layout title="Bank Soal - yukNgaji">
    <div class="px-6 py-8 pb-32 min-h-screen flex flex-col bg-gray-50">
        
        <header class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-2xl font-bold text-gray-800 tracking-tight">Bank Soal</h1>
                <p class="text-xs text-gray-400 mt-1 font-medium uppercase tracking-widest">Manajemen Kuesioner</p>
            </div>
            <button id="btnOpenUpload" class="w-12 h-12 bg-green-600 text-white rounded-2xl shadow-lg shadow-green-600/30 flex items-center justify-center active:scale-95 transition-all">
                <i class="fa-solid fa-plus text-lg"></i>
            </button>
        </header>

        <a href="/exams" class="mb-6 bg-gradient-to-br from-amber-400 to-orange-500 p-6 rounded-3xl shadow-lg shadow-orange-500/30 flex items-center justify-between active:scale-95 transition-transform relative overflow-hidden cursor-pointer">
            <div class="absolute -right-6 -top-6 w-24 h-24 bg-white/10 rounded-full blur-xl pointer-events-none"></div>
            <div class="absolute right-10 -bottom-8 w-20 h-20 bg-white/10 rounded-full blur-xl pointer-events-none"></div>

            <div class="relative z-10 flex items-center gap-4">
                <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center text-white backdrop-blur-sm border border-white/20 shadow-inner shrink-0">
                    <i class="fa-solid fa-graduation-cap text-xl"></i>
                </div>
                <div>
                    <h2 class="text-xl font-black mb-1 text-white drop-shadow-sm flex items-center flex-wrap gap-1.5">
                        Ujian & Evaluasi 
                        <span class="bg-red-500 text-white text-[8px] px-1.5 py-0.5 rounded-full uppercase tracking-widest font-black animate-pulse shadow-sm">Baru</span>
                    </h2>
                    <p class="text-[10px] font-bold text-orange-50/90 leading-tight">Buat ujian khusus dengan timer, gambar, & hint.</p>
                </div>
            </div>
            
            <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center text-white relative z-10 backdrop-blur-sm border border-white/20 shrink-0 hidden sm:flex">
                <i class="fa-solid fa-chevron-right text-lg"></i>
            </div>
        </a>

        <section class="mb-6 bg-green-50 p-4 rounded-2xl border border-green-100">
            <div class="flex items-start gap-3">
                <i class="fa-solid fa-circle-info text-green-600 mt-1 flex-shrink-0"></i>
                <div class="flex-1">
                    <h4 class="text-xs font-bold text-green-800 uppercase">Petunjuk Upload</h4>
                    <p class="text-[10px] text-green-700 leading-relaxed mt-1">
                        Gunakan format <b>TIPE:</b> (pilgan/tf/drag), <b>Q:</b> (Soal), <b>A-D:</b> (Pilihan), <b>KUNCI:</b> (A/B/C/D), dan <b>LEVEL:</b> (mudah/sedang/sulit).
                    </p>
                    <button id="btnDownloadTemplate" class="mt-3 flex items-center gap-2 text-[10px] font-bold bg-white text-green-600 px-3 py-1.5 rounded-lg border border-green-200 active:scale-95 transition-all">
                        <i class="fa-solid fa-download"></i>
                        Unduh Template .txt
                    </button>
                </div>
            </div>
        </section>

        <section class="mb-4 flex gap-2">
            <div class="relative flex-1">
                <i class="fa-solid fa-magnifying-glass absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
                <input type="number" id="searchWeek" placeholder="Cari pertemuan (cth: 1)" class="w-full pl-9 pr-4 py-3 bg-white border border-gray-200 rounded-xl text-sm font-bold focus:ring-2 focus:ring-green-500 outline-none shadow-sm placeholder-gray-300">
            </div>
            <button id="btnSortWeek" class="w-12 h-[46px] bg-white border border-gray-200 rounded-xl text-gray-600 text-sm shadow-sm active:scale-95 transition-all flex items-center justify-center" title="Urutkan (Asc/Desc)">
                <i class="fa-solid fa-arrow-down-1-9"></i>
            </button>
        </section>

        <section class="flex-1 space-y-4" id="accordionContainer">
            <div class="animate-pulse bg-white h-16 rounded-2xl border border-gray-100"></div>
            <div class="animate-pulse bg-white h-16 rounded-2xl border border-gray-100"></div>
            <div class="animate-pulse bg-white h-16 rounded-2xl border border-gray-100"></div>
        </section>
    </div>

    <div id="modalUpload" class="fixed inset-0 bg-black/40 z-[60] hidden flex items-end sm:items-center justify-center p-0 sm:p-4">
        <div class="bg-white w-full max-w-md rounded-t-3xl sm:rounded-3xl p-6 shadow-2xl animate-slide-up">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-bold text-gray-800">Tambah Soal Baru</h3>
                <button onclick="closeUpload()" class="text-gray-400"><i class="fa-solid fa-xmark"></i></button>
            </div>
            
            <form id="formUpload" class="space-y-4">
                <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase ml-1">Mata Pelajaran</label>
                    <select id="upSubject" class="w-full mt-1 px-4 py-3 bg-gray-50 border-none rounded-xl text-sm focus:ring-2 focus:ring-green-500">
                        <option value="tajwid">Tajwid</option>
                        <option value="fiqih">Fiqih</option>
                        <option value="tauhid">Tauhid</option>
                    </select>
                </div>

                <div class="p-3 bg-blue-50 rounded-xl border border-blue-100">
                    <p class="text-[10px] font-bold text-blue-700 uppercase mb-2">Target Pertemuan</p>
                    <div class="space-y-2">
                        <label class="flex items-center gap-3 cursor-pointer p-2 rounded-xl hover:bg-blue-100 transition-colors">
                            <input type="radio" name="weekMode" value="baru" checked class="accent-green-600">
                            <div>
                                <p class="text-xs font-bold text-gray-700">Pertemuan Baru</p>
                                <p class="text-[10px] text-gray-400" id="labelPertemuanBaru">Otomatis ke minggu berikutnya</p>
                            </div>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer p-2 rounded-xl hover:bg-blue-100 transition-colors">
                            <input type="radio" name="weekMode" value="sisipan" class="accent-green-600">
                            <div>
                                <p class="text-xs font-bold text-gray-700">Sisipan / Tambah ke Pertemuan Lama</p>
                                <p class="text-[10px] text-gray-400">Pilih minggu yang sudah ada atau kosong</p>
                            </div>
                        </label>
                    </div>

                    <div id="sisipanDropdownWrap" class="hidden mt-3">
                        <select id="sisipanWeek" class="w-full px-3 py-2 bg-white rounded-xl text-sm border border-blue-200 font-medium">
                            <option value="">Pilih minggu...</option>
                        </select>
                    </div>
                </div>

                <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase ml-1">File Template (.txt) <span class="text-gray-300 normal-case font-normal">(opsional)</span></label>
                    <input type="file" id="upFile" accept=".txt" class="w-full mt-1 text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-semibold file:bg-green-50 file:text-green-700 hover:file:bg-green-100 cursor-pointer">
                </div>

                <div class="grid grid-cols-2 gap-2">
                    <button type="submit" class="py-3 bg-green-600 text-white font-bold rounded-2xl shadow-lg active:scale-95 transition-all text-sm">
                        <i class="fa-solid fa-file-arrow-up mr-1"></i> Upload File
                    </button>
                    <button type="button" onclick="openManualFromModal()" class="py-3 bg-white border-2 border-dashed border-green-300 text-green-700 font-bold rounded-2xl active:scale-95 transition-all text-sm">
                        <i class="fa-solid fa-pen mr-1"></i> Input Manual
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div id="modalPreview" class="fixed inset-0 bg-white z-[60] hidden h-screen flex flex-col overflow-hidden">
        <header class="fixed top-0 left-0 w-full p-5 border-b flex justify-between items-center bg-white z-20 flex-shrink-0 shadow-sm">
            <button onclick="closePreview()" class="text-gray-400 text-xl active:scale-95 transition-all"><i class="fa-solid fa-chevron-left"></i></button>
            <h3 class="font-bold text-gray-800">Preview & Edit Soal</h3>
            <button id="btnFinalSave" class="text-green-600 font-bold text-sm active:opacity-70 transition-opacity">Simpan</button>
        </header>

        <div class="mt-[72px] bg-green-50 p-4 border-b flex items-center gap-2 flex-shrink-0">
            <label class="text-[10px] font-bold text-green-700 uppercase shrink-0">Mapel:</label>
            <span id="previewSubjectLabel" class="text-xs font-black text-green-700 uppercase mr-2 sm:mr-4">-</span>
            <label class="text-[10px] font-bold text-green-700 uppercase shrink-0">Target:</label>
            <span class="text-[10px] text-gray-500 font-bold">MG-</span>
            <input type="number" id="targetWeek" value="1" min="1" class="w-12 h-8 rounded-lg border-none text-center font-bold text-green-600 focus:ring-2 focus:ring-green-500">
        </div>

        <div id="previewContent" class="flex-1 overflow-y-auto p-4 sm:p-6 space-y-6 pb-[100px] no-scrollbar bg-gray-50"></div>
    
        <div class="fixed bottom-0 sm:bottom-[72px] left-0 w-full p-4 bg-gradient-to-t from-white via-white to-transparent z-10 flex-shrink-0">
            <div class="max-w-md mx-auto">
                <button id="btnTambahManual" onclick="addNewQuestionField()" class="w-full py-4 bg-white border-2 border-dashed border-green-200 rounded-2xl text-green-600 font-bold text-xs shadow-lg active:scale-95 transition-all">
                    <i class="fa-solid fa-plus mr-1"></i> Tambah Soal Baru
                </button>
            </div>
        </div>
    </div>

    <div id="modalEditSoal" class="fixed inset-0 bg-black/60 z-[70] hidden items-end sm:items-center justify-center p-0 sm:p-4 backdrop-blur-sm">
        <div class="bg-white w-full h-[90vh] sm:h-auto sm:max-h-[90vh] sm:max-w-md rounded-t-3xl sm:rounded-3xl p-5 sm:p-6 shadow-2xl overflow-y-auto no-scrollbar card-core-logic flex flex-col animate-slide-up">
            <div class="flex justify-between items-center mb-4 shrink-0">
                <h3 class="font-bold text-gray-800">Edit Soal</h3>
                <button onclick="closeEditSoal()" class="w-8 h-8 flex items-center justify-center bg-gray-100 rounded-full text-gray-500 active:scale-95"><i class="fa-solid fa-xmark"></i></button>
            </div>
            
            <div class="flex-1 space-y-4">
                <input type="hidden" id="editSoalId">
                
                <div class="flex flex-col sm:flex-row sm:items-center gap-2 bg-gray-50 p-3 rounded-xl border border-gray-100">
                    <label class="text-[10px] font-bold text-gray-500 uppercase ml-1 shrink-0">Tipe Soal:</label>
                    <select id="editSoalType" onchange="toggleEditType()" class="type-input text-xs font-bold border border-gray-200 bg-white rounded-lg px-3 py-2.5 outline-none shadow-sm w-full sm:flex-1 text-gray-700 focus:ring-2 focus:ring-blue-400">
                        <option value="pilgan">Pilihan Ganda</option>
                        <option value="tf">Benar / Salah</option>
                        <option value="drag">Drag & Drop (Menghubungkan)</option>
                        <option value="urutan">Mengurutkan (Puzzle)</option>
                    </select>
                </div>

                <div id="editDragHint" class="drag-tools hidden p-3 bg-indigo-50/50 border border-indigo-100 rounded-xl flex flex-col gap-3">
                    <div class="flex items-start gap-2.5">
                        <div class="w-6 h-6 rounded-full bg-indigo-100 text-indigo-500 flex items-center justify-center shrink-0 mt-0.5">
                            <i class="fa-solid fa-wand-magic-sparkles text-xs"></i>
                        </div>
                        <p class="text-[10px] text-indigo-900 leading-relaxed font-medium">
                            <b class="text-indigo-700">Mode Drag & Drop:</b><br>
                            Klik tombol di bawah untuk menyisipkan kolom kosong pada soal.
                        </p>
                    </div>
                    <button type="button" onclick="insertBlank(this)" class="w-full text-[10px] font-bold bg-indigo-600 text-white px-4 py-3 rounded-lg hover:bg-indigo-700 transition-colors shadow-md shadow-indigo-600/20 active:scale-95 flex items-center justify-center gap-2">
                        <i class="fa-solid fa-plus"></i> Sisipkan [BLANK]
                    </button>
                </div>

                <div class="urutan-tools hidden p-3 bg-teal-50 border border-teal-100 rounded-xl flex items-center gap-3 mt-3 w-full">
                    <div class="w-8 h-8 rounded-full bg-teal-200 text-teal-700 flex items-center justify-center shrink-0"><i class="fa-solid fa-list-ol"></i></div>
                    <p class="text-[10px] font-bold text-teal-800 leading-relaxed">Mode Mengurutkan aktif.<br>Masukkan opsi secara acak. Tentukan <b>URUTAN BENARNYA</b> di bagian Kunci Jawaban bawah.</p>
                </div>

                <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase">Pertanyaan</label>
                    <textarea id="editSoalQ" rows="3" class="q-input w-full mt-1 p-3 bg-gray-50 rounded-xl text-sm font-bold border border-gray-200 focus:ring-2 focus:ring-blue-400 outline-none" oninput="updateDragKeys(this)"></textarea>
                    <div class="mt-3">
                        <label class="text-[10px] font-bold text-gray-400 uppercase">Gambar / GIF (Opsional)</label>
                        <div class="flex items-center gap-2 mt-1">
                            <input type="text" id="editSoalImg" placeholder="https://... atau upload file" class="img-input flex-1 p-3 bg-gray-50 rounded-xl text-xs font-bold border border-gray-200 outline-none focus:ring-2 focus:ring-blue-400" oninput="previewEditImg(this.value)">
                            <label class="shrink-0 w-10 h-10 bg-green-50 border border-green-200 rounded-xl flex items-center justify-center cursor-pointer hover:bg-green-100 transition-colors" title="Upload gambar dari perangkat">
                                <i class="fa-solid fa-upload text-green-600 text-sm"></i>
                                <input type="file" id="editSoalImgFile" accept="image/*,image/gif" class="hidden" onchange="handleEditImgUpload(this)">
                            </label>
                        </div>
                        <div id="editImgPreview" class="hidden mt-2">
                            <img id="editImgPreviewEl" src="" class="max-h-28 rounded-xl border border-gray-200 object-contain" onerror="document.getElementById('editImgPreview').classList.add('hidden')">
                        </div>
                    </div>
                </div>
                
                <div id="editOptionsWrapper" class="options-wrapper flex flex-col gap-2 w-full"></div>
                <button type="button" id="editBtnAddOption" class="btn-add-option text-[10px] font-bold text-blue-500 w-full p-3 border-2 border-dashed border-blue-200 bg-blue-50 hover:bg-blue-100 rounded-xl transition-colors active:scale-95 text-center mt-2" onclick="addOptionRow(this)">+ Tambah Pilihan Jawaban</button>

                <div id="editTfWrapper" class="tf-wrapper hidden p-3 bg-blue-50 border border-blue-100 rounded-xl flex items-center gap-3 mt-3">
                    <div class="w-8 h-8 rounded-full bg-blue-200 text-blue-600 flex items-center justify-center shrink-0"><i class="fa-solid fa-toggle-on"></i></div>
                    <p class="text-[10px] font-bold text-blue-700 leading-relaxed">Mode Benar/Salah aktif. Opsi jawaban otomatis menjadi A (Benar) dan B (Salah).</p>
                </div>

                <div class="flex flex-col gap-4 mt-4 bg-gray-50 p-4 rounded-xl border border-gray-100">
                    
                    <div class="key-standard flex flex-col sm:flex-row sm:items-center gap-2">
                        <span class="text-[10px] font-bold text-gray-400 shrink-0">KUNCI JAWABAN:</span>
                        <select id="editSoalKey" class="key-input text-xs font-bold border border-gray-200 bg-white text-green-700 rounded-lg px-3 py-2.5 shadow-sm outline-none w-full sm:flex-1"></select>
                    </div>
                    
                    <div id="editKeyDrag" class="key-drag hidden w-full">
                        <span class="text-[10px] font-bold text-gray-400 mb-2 block">KUNCI JAWABAN DRAG & DROP:</span>
                        <div class="drag-keys-container grid grid-cols-1 sm:grid-cols-2 gap-2"></div>
                    </div>

                    <div class="key-urutan hidden w-full">
                        <span class="text-[10px] font-bold text-gray-400 mb-2 block">KUNCI JAWABAN URUTAN:</span>
                        <div class="urutan-keys-container flex flex-col gap-2"></div>
                    </div>

                    <div class="flex flex-col sm:flex-row sm:items-center gap-2 pt-4 border-t border-gray-200">
                        <span class="text-[10px] font-bold text-gray-400 shrink-0">LEVEL KESULITAN:</span>
                        <select id="editSoalLevel" class="level-input text-xs font-bold border border-gray-200 bg-white text-indigo-700 rounded-lg px-3 py-2.5 shadow-sm outline-none w-full sm:flex-1">
                            <option value="mudah">Mudah</option>
                            <option value="sedang">Sedang</option>
                            <option value="sulit">Sulit</option>
                        </select>
                    </div>
                </div>
            </div>
            
            <button onclick="submitEditSoal()" class="shrink-0 w-full py-4 mt-5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl shadow-lg shadow-blue-600/30 active:scale-95 transition-all">
                <i class="fa-solid fa-floppy-disk mr-2"></i>Simpan Perubahan
            </button>
        </div>
    </div>

    <div id="modalConfirmBack" class="fixed inset-0 bg-black/60 z-[100] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-sm rounded-2xl p-6 shadow-2xl relative animate-slide-up text-center border border-gray-100">
            <div class="w-16 h-16 bg-amber-50 text-amber-500 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4 border border-amber-100 shadow-inner">
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>
            <h3 class="font-black text-gray-800 text-lg mb-2">Perubahan Belum Disimpan!</h3>
            <p class="text-xs font-bold text-gray-500 leading-relaxed mb-6">
                Anda memiliki soal yang baru diketik/diedit dan belum disimpan. Yakin ingin menutup editor?
            </p>
            <div class="flex gap-3">
                <button onclick="closeConfirmBack()" class="flex-1 py-3 bg-gray-100 text-gray-500 font-bold rounded-xl active:scale-95 transition-all">Batal</button>
                <button onclick="forceCloseAction()" class="flex-1 py-3 bg-red-600 text-white font-bold rounded-xl shadow-md shadow-red-600/20 active:scale-95 transition-all">Ya, Tutup</button>
            </div>
        </div>
    </div>

    <NavbarGuru activeMenu="exam" />
    <Toast />
    <ModalAlert />
</Layout>

<script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const token = localStorage.getItem('token');
    if (!token) window.location.replace('/');

    const SUBJECTS = ['tajwid', 'fiqih', 'tauhid'];
    const SUBJECT_COLORS = {
        tajwid:  { bg: 'bg-green-50',  border: 'border-green-200',  text: 'text-green-700',  badge: 'bg-green-100 text-green-700'  },
        fiqih:   { bg: 'bg-blue-50',   border: 'border-blue-200',   text: 'text-blue-700',   badge: 'bg-blue-100 text-blue-700'   },
        tauhid:  { bg: 'bg-purple-50', border: 'border-purple-200', text: 'text-purple-700', badge: 'bg-purple-100 text-purple-700'},
    };

    // =================================================================
    // 1. GLOBAL STATE & CACHE BARU (LAZY LOADING)
    // =================================================================
    let accordionSummary = {}; // Menyimpan kerangka (minggu & mapel)
    let soalCache = {};        // Menyimpan data soal yang sudah di-fetch: Format { "1-tajwid": [...] }
    let activeWeek = null;     // Melacak Pertemuan mana yang sedang terbuka
    
    let summaryData = {};
    let activeSubjectForUpload = 'tajwid';
    let resolvedWeekForUpload  = 1;
    let isSortAsc = true;
    let isSummaryCached = false; 
    let isDirty = false;
    let pendingCloseAction = null;

    document.addEventListener('input', (e) => {
        if (e.target.closest('.card-core-logic')) isDirty = true;
    });

    window.markDirty = () => { isDirty = true; };

    window.addEventListener('beforeunload', (e) => {
        if (isDirty) { e.preventDefault(); e.returnValue = ''; }
    });

    window.showConfirmBack = (action) => {
        pendingCloseAction = action;
        document.getElementById('modalConfirmBack').classList.replace('hidden', 'flex');
    };

    window.closeConfirmBack = () => {
        pendingCloseAction = null;
        document.getElementById('modalConfirmBack').classList.replace('flex', 'hidden');
    };

    window.forceCloseAction = () => {
        isDirty = false; 
        document.getElementById('modalConfirmBack').classList.replace('flex', 'hidden');
        if (pendingCloseAction) pendingCloseAction();
    };

    // =================================================================
    // 2. LOGIC EDITOR SOAL (TOOLS, DRAG & DROP, URUTAN)
    // =================================================================
    window.relabelOptions = (card) => {
        const rows = card.querySelectorAll('.opt-row');
        rows.forEach((r, idx) => {
            const letter = String.fromCharCode(65 + idx);
            r.dataset.key = letter;
            r.querySelector('label').innerText = `Opsi ${letter}`;
            r.querySelector('input').placeholder = `Jawaban ${letter}`;
        });
    };

    window.updateUrutanKeys = (card, presetKeys = null) => {
        const keyContainer = card.querySelector('.urutan-keys-container');
        if (!keyContainer) return;
        const rows = Array.from(card.querySelectorAll('.opt-row'));

        let html = '';
        rows.forEach((_, i) => {
            const optionsHtml = rows.map(r => {
                const val = r.querySelector('.opt-val')?.value?.trim() || '';
                const key = r.dataset.key;
                return `<option value="${key}">Opsi ${key} ${val ? `(${val})` : ''}</option>`;
            }).join('');

            html += `
                <div class="flex items-center gap-2 p-2 bg-white border border-gray-200 rounded-lg shadow-sm w-full mt-1">
                    <span class="text-[10px] font-black text-teal-600 bg-teal-50 px-2 py-1 rounded border border-teal-100 shrink-0">Ke-${i+1}</span>
                    <select class="urutan-key-select text-xs font-bold border-none bg-transparent outline-none flex-1 text-gray-700 cursor-pointer min-w-0 truncate">
                        <option value="">Pilih Opsi...</option>
                        ${optionsHtml}
                    </select>
                </div>
            `;
        });
        keyContainer.innerHTML = html;

        if (presetKeys && Array.isArray(presetKeys)) {
            const selects = keyContainer.querySelectorAll('.urutan-key-select');
            selects.forEach((sel, i) => {
                if (presetKeys[i]) {
                    const matchedRow = rows.find(r => r.querySelector('.opt-val').value.trim() === presetKeys[i]);
                    if (matchedRow) sel.value = matchedRow.dataset.key;
                }
            });
        }
    };

    window.appendOptionRow = (wrapper, key, val) => {
        const row = document.createElement('div');
        row.className = "opt-row flex items-center gap-2 w-full";
        row.dataset.key = key;
        row.innerHTML = `
            <label class="text-[10px] text-gray-400 font-bold uppercase w-[40px] shrink-0">Opsi ${key}</label>
            <input type="text" class="opt-val flex-1 min-w-0 p-3 bg-white border border-gray-200 rounded-lg text-xs outline-none focus:ring-2 focus:ring-blue-200 shadow-sm font-medium text-gray-700" placeholder="Jawaban ${key}" value="${val}">
            <button type="button" onclick="removeOptionRow(this)" class="btn-remove-opt shrink-0 text-red-400 bg-red-50 hover:bg-red-100 w-10 h-10 rounded-lg flex items-center justify-center transition-colors active:scale-95" title="Hapus"><i class="fa-solid fa-xmark"></i></button>
        `;
        row.querySelector('.opt-val').addEventListener('input', () => {
            const card = wrapper.closest('.card-core-logic');
            const type = card?.querySelector('.type-input')?.value;
            if (type === 'drag') {
                const textarea = card.querySelector('.q-input');
                const selects = card.querySelectorAll('.drag-key-select');
                const currentKeys = Array.from(selects).map(s => s.value);
                updateDragKeys(textarea);
                const newSelects = card.querySelectorAll('.drag-key-select');
                newSelects.forEach((sel, i) => { if (currentKeys[i]) sel.value = currentKeys[i]; });
            } else if (type === 'urutan') {
                const selects = card.querySelectorAll('.urutan-key-select');
                const currentKeys = Array.from(selects).map(s => s.value);
                updateUrutanKeys(card);
                const newSelects = card.querySelectorAll('.urutan-key-select');
                newSelects.forEach((sel, i) => { if (currentKeys[i]) sel.value = currentKeys[i]; });
            }
        });
        wrapper.appendChild(row);
    };

    window.syncStandardKeys = (cardElement, presetKey = null) => {
        const keyInput = cardElement.querySelector('.key-input');
        if (!keyInput) return;
        const rows = Array.from(cardElement.querySelectorAll('.opt-row'));
        keyInput.innerHTML = rows.map(r => `<option value="${r.dataset.key}">${r.dataset.key}</option>`).join('');
        if (presetKey && rows.find(r => r.dataset.key === presetKey)) {
            keyInput.value = presetKey;
        }
    };

    window.insertBlank = (btn) => {
        markDirty();
        const card = btn.closest('.card-core-logic');
        const textarea = card.querySelector('.q-input');
        const cursorPosition = textarea.selectionStart;
        const textBefore = textarea.value.substring(0, cursorPosition);
        const textAfter = textarea.value.substring(cursorPosition, textarea.value.length);
        
        textarea.value = textBefore + '[BLANK]' + textAfter;
        textarea.focus();
        textarea.selectionStart = cursorPosition + 7;
        textarea.selectionEnd = cursorPosition + 7;
        
        updateDragKeys(textarea);
    };

    window.updateDragKeys = (textarea, presetKeys = null) => {
        const card = textarea.closest('.card-core-logic');
        if (!card) return;
        const typeEl = card.querySelector('.type-input');
        if (!typeEl || typeEl.value !== 'drag') return;

        const text = textarea.value;
        const blankCount = (text.match(/\[BLANK\]/g) || []).length;
        const keyContainer = card.querySelector('.drag-keys-container');
        if (!keyContainer) return;

        const optRows = Array.from(card.querySelectorAll('.opt-row'));
        const visibleOptions = optRows.map(row => row.dataset.key);

        if (blankCount === 0) {
            keyContainer.innerHTML = '<span class="text-[10px] text-red-500 col-span-2 italic">Minimal masukkan 1 [BLANK] pada teks soal di atas.</span>';
            return;
        }

        let html = '';
        for(let i=0; i<blankCount; i++) {
            const optionsHtml = optRows.map(row => {
                const val = row.querySelector('.opt-val')?.value?.trim() || '';
                const key = row.dataset.key;
                return `<option value="${key}">${key}: ${val || '(kosong)'}</option>`;
            }).join('');
            html += `
                <div class="flex items-center gap-2 p-2 bg-white border border-gray-200 rounded-lg shadow-sm focus-within:ring-2 focus-within:ring-indigo-400 w-full overflow-hidden mt-1">
                    <span class="text-[10px] font-black text-indigo-600 bg-indigo-50 px-2 py-1 rounded border border-indigo-100 shrink-0">B${i+1}</span>
                    <select class="drag-key-select text-xs font-bold border-none bg-transparent outline-none flex-1 text-gray-700 cursor-pointer min-w-0 truncate">
                        ${optionsHtml}
                    </select>
                </div>
            `;
        }
        keyContainer.innerHTML = html;
        if (presetKeys) {
            const selects = keyContainer.querySelectorAll('.drag-key-select');
            const keysArray = presetKeys.split(',');
            selects.forEach((sel, i) => {
                if (keysArray[i] && visibleOptions.includes(keysArray[i])) sel.value = keysArray[i];
            });
        }
    };

    window.addOptionRow = (btn) => {
        markDirty();
        const card = btn.closest('.card-core-logic');
        const wrapper = card.querySelector('.options-wrapper');
        const currentRows = wrapper.querySelectorAll('.opt-row');
        const nextCharCode = 65 + currentRows.length;
        if (nextCharCode > 72) { return window.showToast?.('warning', 'Maksimal', 'Maksimal 8 opsi jawaban (A-H).'); }
        
        const letter = String.fromCharCode(nextCharCode);
        appendOptionRow(wrapper, letter, "");
        
        const type = card.querySelector('.type-input').value;
        relabelOptions(card);

        if (type === 'drag') updateDragKeys(card.querySelector('.q-input'));
        else if (type === 'urutan') {
            const selects = card.querySelectorAll('.urutan-key-select');
            const currentKeys = Array.from(selects).map(s => s.value);
            updateUrutanKeys(card);
            const newSelects = card.querySelectorAll('.urutan-key-select');
            newSelects.forEach((sel, i) => { if (currentKeys[i]) sel.value = currentKeys[i]; });
        }
        else if (type === 'pilgan') syncStandardKeys(card);
    };

    window.removeOptionRow = (btn) => {
        markDirty();
        const card = btn.closest('.card-core-logic');
        const wrapper = card.querySelector('.options-wrapper');
        
        if (wrapper.querySelectorAll('.opt-row').length <= 2) {
            return window.showToast?.('warning', 'Minimal', 'Minimal harus ada 2 opsi jawaban.');
        }

        btn.closest('.opt-row').remove();
        
        const type = card.querySelector('.type-input').value;
        relabelOptions(card);

        if (type === 'drag') updateDragKeys(card.querySelector('.q-input'));
        else if (type === 'urutan') {
            const selects = card.querySelectorAll('.urutan-key-select');
            const currentKeys = Array.from(selects).map(s => s.value);
            updateUrutanKeys(card);
            const newSelects = card.querySelectorAll('.urutan-key-select');
            newSelects.forEach((sel, i) => { if (currentKeys[i]) sel.value = currentKeys[i]; });
        }
        else if (type === 'pilgan') syncStandardKeys(card);
    };

    window.toggleCardType = (selectEl, presetKey = null) => {
        const card = selectEl.closest('.card-core-logic');
        if (!card) return;

        const type = selectEl.value;
        const optWrapper = card.querySelector('.options-wrapper');
        const btnAddOpt = card.querySelector('.btn-add-option');
        const tfWrapper = card.querySelector('.tf-wrapper');
        const dragTools = card.querySelector('.drag-tools');
        const urutanTools = card.querySelector('.urutan-tools'); 
        const keyStandard = card.querySelector('.key-standard');
        const keyDrag = card.querySelector('.key-drag');
        const keyInput = card.querySelector('.key-input');
        const textarea = card.querySelector('.q-input');
        const keyUrutan = card.querySelector('.key-urutan'); 
        
        if(optWrapper) optWrapper.classList.add('hidden');
        if(btnAddOpt) btnAddOpt.classList.add('hidden');
        if(tfWrapper) tfWrapper.classList.add('hidden');
        if(dragTools) dragTools.classList.add('hidden');
        if(urutanTools) urutanTools.classList.add('hidden');
        if(keyStandard) keyStandard.classList.add('hidden');
        if(keyDrag) keyDrag.classList.add('hidden');
        if(keyUrutan) keyUrutan.classList.add('hidden');

        relabelOptions(card);

        if (type === 'tf') {
            if(tfWrapper) tfWrapper.classList.remove('hidden');
            if(keyStandard) keyStandard.classList.remove('hidden');
            if(keyInput) {
                keyInput.innerHTML = `
                    <option value="A">A (Benar)</option>
                    <option value="B">B (Salah)</option>
                `;
                if(keyInput.value !== 'A' && keyInput.value !== 'B') keyInput.value = 'A';
                if(presetKey === 'A' || presetKey === 'B') keyInput.value = presetKey;
            }
        } else if (type === 'urutan') {
            if(optWrapper) optWrapper.classList.remove('hidden');
            if(btnAddOpt) btnAddOpt.classList.remove('hidden');
            if(urutanTools) urutanTools.classList.remove('hidden');
            if(keyUrutan) keyUrutan.classList.remove('hidden');
            
            card.querySelectorAll('.btn-remove-opt').forEach(btn => btn.style.display = 'flex');
            if(keyUrutan) updateUrutanKeys(card, presetKey);
        } else if (type === 'drag') {
            if(optWrapper) optWrapper.classList.remove('hidden');
            if(btnAddOpt) btnAddOpt.classList.remove('hidden');
            if(dragTools) dragTools.classList.remove('hidden');
            if(keyDrag) keyDrag.classList.remove('hidden');
            
            card.querySelectorAll('.btn-remove-opt').forEach(btn => btn.style.display = 'flex');
            if(textarea) updateDragKeys(textarea, presetKey);
        } else { // pilgan
            if(optWrapper) optWrapper.classList.remove('hidden');
            if(btnAddOpt) btnAddOpt.classList.remove('hidden');
            if(keyStandard) keyStandard.classList.remove('hidden');
            
            card.querySelectorAll('.btn-remove-opt').forEach(btn => btn.style.display = 'flex');
            if(keyInput) syncStandardKeys(card, presetKey);
        }
    };

    const extractCardData = (card) => {
        const type = card.querySelector('.type-input')?.value || 'pilgan';
        const question = card.querySelector('.q-input')?.value.trim() || '';
        const level = card.querySelector('.level-input')?.value || 'sedang';
        const image_url = card.querySelector('.img-input')?.value.trim() || null;
        let finalOptions = {};
        let finalKey = "A";

        if (type === 'tf') {
            finalOptions = { A: "Benar", B: "Salah" };
            finalKey = card.querySelector('.key-input')?.value || 'A';
        } else if (type === 'urutan') {
            const rows = card.querySelectorAll('.opt-row');
            finalOptions = Array.from(rows).map(r => r.querySelector('.opt-val').value.trim()).filter(v => v !== '');
            const selects = card.querySelectorAll('.urutan-key-select');
            finalKey = Array.from(selects).map(sel => {
                const row = Array.from(rows).find(r => r.dataset.key === sel.value);
                return row ? row.querySelector('.opt-val').value.trim() : "";
            }).filter(v => v !== '');
        } else {
            const rows = card.querySelectorAll('.opt-row');
            rows.forEach(r => { finalOptions[r.dataset.key] = r.querySelector('.opt-val').value.trim(); });
            if (type === 'drag') {
                const selects = card.querySelectorAll('.drag-key-select');
                finalKey = Array.from(selects).map(s => s.value).join(',');
            } else {
                finalKey = card.querySelector('.key-input')?.value || 'A';
            }
        }

        return { type, question, options: finalOptions, correct_answer: finalKey, difficulty_level: level, image_url };
    };

    // =================================================================
    // 3. LAZY LOADING ACCORDION (MAPEL & PERTEMUAN)
    // =================================================================
    
    // FETCH DATA
    const fetchAccordion = async () => {
        const container = document.getElementById('accordionContainer');
        // [FIX BUG 2] Spinner Loading Keren saat Load Data
        container.innerHTML = `
            <div class="py-12 flex flex-col items-center justify-center">
                <i class="fa-solid fa-spinner fa-spin text-4xl mb-4 text-green-500"></i>
                <p class="text-xs font-bold uppercase tracking-widest text-gray-400">Memuat Bank Soal...</p>
            </div>
        `;
        
        try {
            const res = await fetch(`${API_URL}/api/onboarding/questions/summary-all`, { headers: { 'Authorization': `Bearer ${token}` } });
            const result = await res.json();
            accordionSummary = result.data; 
            renderAllWeeksShell();
        } catch (e) {
            container.innerHTML = '<p class="text-xs text-red-500 font-bold text-center">Gagal memuat struktur data.</p>';
        }
    };

    // =================================================================
    // FUNGSI TOGGLE GEMBOK PR KE DATABASE
    // =================================================================
    window.toggleLockPR = async (subject, week, isChecked) => {
        try {
            const res = await fetch(`${API_URL}/api/onboarding/pr-lock`, {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify({ subject, week, is_locked: isChecked })
            });
            if(res.ok) {
                window.showToast?.('success', 'Status Diperbarui', isChecked ? `Pertemuan ${week} dikunci KHUSUS PR.` : `Pertemuan ${week} dibuka kembali untuk kelas.`);
            } else {
                throw new Error("Gagal menyimpan ke server");
            }
        } catch(e) {
            window.showToast?.('danger', 'Error', 'Gagal mengubah status gembok PR.');
        }
    };

    // RENDER KERANGKA ACCORDION
    const renderAllWeeksShell = () => {
        const container = document.getElementById('accordionContainer');
        container.innerHTML = '';
        
        const searchTerm = document.getElementById('searchWeek').value.trim();
        let weeks = Object.keys(accordionSummary).map(Number);
        
        if (searchTerm) weeks = weeks.filter(w => w.toString() === searchTerm);
        weeks.sort((a, b) => isSortAsc ? a - b : b - a);

        if (weeks.length === 0) {
            container.innerHTML = `<div class="p-8 text-center bg-white rounded-2xl border border-dashed border-gray-200"><i class="fa-solid fa-book-open text-3xl text-gray-200 mb-3 block"></i><p class="text-xs text-gray-400 font-bold uppercase tracking-widest">Data Tidak Ditemukan</p></div>`;
            return;
        }

        weeks.forEach(week => {
            const counts = accordionSummary[week];
            const totalQ = (counts.tajwid || 0) + (counts.fiqih || 0) + (counts.tauhid || 0);
            
            const wrapper = document.createElement('div');
            wrapper.className = `pertemuan-wrapper rounded-2xl border border-gray-200 overflow-hidden shadow-sm bg-white mb-4`;
            wrapper.dataset.week = week;

            wrapper.innerHTML = `
                <div class="pertemuan-header bg-gray-50 px-5 py-4 flex items-center justify-between cursor-pointer hover:bg-gray-100 transition-colors" onclick="togglePertemuan(${week})">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-white border border-gray-200 text-gray-800 rounded-xl flex items-center justify-center font-black text-xl shadow-sm">${week}</div>
                        <div>
                            <h3 class="font-black text-gray-800 uppercase text-sm tracking-wide">Pertemuan ${week}</h3>
                            <p class="text-[10px] text-gray-400 font-bold mt-0.5">${totalQ} Total Soal</p>
                        </div>
                    </div>
                    <i class="fa-solid fa-chevron-down text-gray-400 transition-transform duration-200 arrow-pertemuan"></i>
                </div>
                <div class="pertemuan-body hidden bg-white p-4 space-y-3" id="body-week-${week}"></div>
            `;
            container.appendChild(wrapper);
        });
    };

    // SEARCH & SORT BINDINGS
    document.getElementById('searchWeek').addEventListener('input', () => renderAllWeeksShell());
    document.getElementById('btnSortWeek').addEventListener('click', () => {
        isSortAsc = !isSortAsc;
        document.getElementById('btnSortWeek').innerHTML = isSortAsc ? '<i class="fa-solid fa-arrow-down-1-9"></i>' : '<i class="fa-solid fa-arrow-down-9-1"></i>';
        renderAllWeeksShell();
    });

    window.togglePertemuan = (week) => {
        const targetBody = document.getElementById(`body-week-${week}`);
        const wrapper = targetBody.closest('.pertemuan-wrapper');
        const arrow = wrapper.querySelector('.arrow-pertemuan');
        const isCurrentlyHidden = targetBody.classList.contains('hidden');

        document.querySelectorAll('.pertemuan-body').forEach(el => {
            el.classList.add('hidden');
            el.closest('.pertemuan-wrapper').querySelector('.arrow-pertemuan').style.transform = '';
        });

        if (isCurrentlyHidden) {
            targetBody.classList.remove('hidden');
            arrow.style.transform = 'rotate(180deg)';
            activeWeek = week;
            
            if (targetBody.innerHTML.trim() === '') {
                renderMapelShells(week, targetBody);
            }
        } else {
            activeWeek = null;
        }
    };

    const renderMapelShells = (week, containerEl) => {
        const counts = accordionSummary[week];
        
        containerEl.innerHTML = `
            <div class="flex justify-end mb-1" id="btnBulkModeWrap-${week}">
                <button onclick="enterBulkMode(${week})" class="text-[10px] font-bold text-gray-500 bg-gray-50 hover:bg-gray-100 px-3 py-1.5 rounded-lg transition-colors border border-gray-200 flex items-center gap-1.5"><i class="fa-solid fa-list-check"></i> Bulk Action</button>
            </div>
            <div class="flex flex-wrap justify-between items-center bg-red-50 p-3 rounded-xl border border-red-100 mb-3 hidden gap-2" id="bulkToolbar-${week}">
                <div class="flex items-center gap-2">
                    <input type="checkbox" id="selectAll-${week}" class="w-4 h-4 accent-red-500 rounded cursor-pointer" onchange="toggleSelectAll(${week}, this.checked)">
                    <label for="selectAll-${week}" class="text-[10px] font-bold text-red-700 cursor-pointer uppercase tracking-wider mt-0.5">Pilih Semua</label>
                </div>
                <div class="flex gap-2">
                    <button onclick="cancelBulkMode(${week})" class="text-[10px] font-bold text-red-400 hover:text-red-600 px-3 py-1.5 transition-colors">Batal</button>
                    <button onclick="executeBulkDelete(${week})" class="text-[10px] font-bold bg-red-500 text-white px-3 py-1.5 rounded-lg hover:bg-red-600 transition-colors shadow-sm flex items-center gap-1.5"><i class="fa-solid fa-trash"></i> Hapus (<span id="bulkCount-${week}">0</span>)</button>
                </div>
            </div>
        `;

        SUBJECTS.forEach(subject => {
            const count = counts[subject] || 0;
            if (count === 0) return; 

            const c = SUBJECT_COLORS[subject];
            const icon = subject === 'tajwid' ? '📖' : subject === 'fiqih' ? '⚖️' : '🕌';

            const mapelWrapper = document.createElement('div');
            mapelWrapper.className = `rounded-xl border ${c.border} overflow-hidden bg-white mapel-wrapper`;
            mapelWrapper.dataset.subject = subject;

            mapelWrapper.innerHTML = `
                <div class="mapel-header ${c.bg} px-4 py-3 flex items-center justify-between cursor-pointer hover:brightness-95 transition-all" onclick="toggleMapel(${week}, '${subject}', this)">
                    <div class="flex items-center gap-3">
                        <span class="text-base">${icon}</span>
                        <span class="text-xs font-black ${c.text} uppercase tracking-wider">${subject}</span>
                        <span class="text-[9px] font-bold text-gray-500 bg-white px-2 py-0.5 rounded-md border ${c.border} shadow-sm">${count} soal</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <button onclick="previewKuesioner(event, '${subject}', ${week})" class="w-7 h-7 bg-white border border-gray-200 rounded-lg flex items-center justify-center text-gray-400 hover:text-indigo-500 hover:border-indigo-200 transition-colors shadow-sm" title="Preview POV Siswa"><i class="fa-solid fa-eye text-[10px]"></i></button>
                        <i class="fa-solid fa-chevron-down ${c.text} transition-transform duration-200 arrow-mapel text-xs ml-1"></i>
                    </div>
                </div>
                <div class="mapel-body hidden px-4 pb-4 pt-3 space-y-3 border-t border-dashed ${c.border}" id="body-mapel-${week}-${subject}"></div>
            `;
            containerEl.appendChild(mapelWrapper);
        });
    };

    window.toggleMapel = async (week, subject, headerEl) => {
        const targetBody = document.getElementById(`body-mapel-${week}-${subject}`);
        const wrapper = targetBody.closest('.mapel-wrapper');
        const arrow = wrapper.querySelector('.arrow-mapel');
        const isCurrentlyHidden = targetBody.classList.contains('hidden');

        const weekBody = document.getElementById(`body-week-${week}`);
        weekBody.querySelectorAll('.mapel-body').forEach(el => {
            el.classList.add('hidden');
            el.closest('.mapel-wrapper').querySelector('.arrow-mapel').style.transform = '';
        });

        if (isCurrentlyHidden) {
            targetBody.classList.remove('hidden');
            arrow.style.transform = 'rotate(180deg)';
            
            const cacheKey = `${week}-${subject}`;
            
            if (!soalCache[cacheKey]) {
                targetBody.innerHTML = `<div class="py-6 text-center text-gray-400"><i class="fa-solid fa-spinner fa-spin text-2xl mb-2 block text-green-500"></i><p class="text-[10px] font-bold uppercase tracking-widest">Mengambil Soal...</p></div>`;
                try {
                    const res = await fetch(`${API_URL}/api/onboarding/questions/${subject}?week=${week}`, { headers: { 'Authorization': `Bearer ${token}` } });
                    const result = await res.json();
                    soalCache[cacheKey] = result.data || []; 
                } catch(e) {
                    targetBody.innerHTML = `<p class="text-xs text-red-500 text-center py-4">Gagal memuat soal.</p>`;
                    return;
                }
            }
            // [BARU] Ambil status gembok dari Database biar switch-nya nyesuaiin
            let isLocked = false;
            try {
                const resLock = await fetch(`${API_URL}/api/onboarding/pr-locks/${subject}`, { headers: { 'Authorization': `Bearer ${token}` }});
                const lockData = await resLock.json();
                isLocked = (lockData.data || []).includes(week);
            } catch(e) {}

            // [PANEL PR] Desain UI Keren dengan tambahan Switch Gembok
            const prPanelHtml = `
                <div class="bg-indigo-50 border border-indigo-100 rounded-2xl p-4 mb-4 flex flex-col gap-4 shadow-sm relative overflow-hidden">
                    <div class="absolute -right-4 -top-4 w-16 h-16 bg-indigo-200/50 rounded-full blur-xl pointer-events-none"></div>
                    
                    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 relative z-10 w-full">
                        <div class="flex items-start gap-3">
                            <div class="w-10 h-10 bg-indigo-100 text-indigo-600 rounded-xl flex items-center justify-center shrink-0 shadow-inner">
                                <i class="fa-solid fa-house-laptop text-lg"></i>
                            </div>
                            <div>
                                <h4 class="text-xs font-black text-indigo-800 uppercase tracking-widest mb-0.5">Jadikan Tugas PR</h4>
                                <p class="text-[10px] text-indigo-600 font-medium">Bagikan link ke grup WA agar murid bisa ngerjain dari rumah.</p>
                            </div>
                        </div>
                        <button onclick="copyPRLink('${subject}', ${week})" class="w-full sm:w-auto bg-indigo-600 hover:bg-indigo-700 text-white text-[11px] font-bold px-4 py-2.5 rounded-xl shadow-md shadow-indigo-600/20 active:scale-95 transition-all flex items-center justify-center gap-2 shrink-0">
                            <i class="fa-solid fa-copy"></i> Salin Link PR
                        </button>
                    </div>

                    <!-- [BARU] TOGGLE LOCK PR (Mencegah ngerjain di kelas) -->
                    <div class="flex items-center justify-between w-full pt-3 border-t border-indigo-100/50 relative z-10">
                        <div>
                            <span class="text-[10px] font-black text-indigo-800 uppercase tracking-widest block">Kunci di Kelas Biasa?</span>
                            <span class="text-[9px] text-indigo-500">Mencegah Sesi Belajar tatap muka tak sengaja membuka minggu ini.</span>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" class="sr-only peer" onchange="toggleLockPR('${subject}', ${week}, this.checked)" ${isLocked ? 'checked' : ''}>
                            <div class="w-11 h-6 bg-gray-300 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"></div>
                        </label>
                    </div>
                </div>
            `;

            targetBody.innerHTML = prPanelHtml + soalCache[cacheKey].map((q, i) => renderSoalItem(q, i, subject, week)).join('');
        }
    };

    window.previewKuesioner = (e, subject, week) => {
        e.stopPropagation();
        window.location.href = `/consultations/fill?preview=true&subject=${subject}&week=${week}`;
    };

    const renderSoalItem = (q, index, subject, week) => {
        const thumbHtml = q.image_url ? `<div class="mt-2 mb-2 w-full max-w-[120px] rounded-lg overflow-hidden border border-gray-200 shadow-inner bg-white"><img src="${q.image_url}" class="w-full h-auto object-contain max-h-24" onerror="this.parentElement.remove()"></div>` : '';
        const typeBadge = q.type === 'tf' ? '<span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-purple-100 text-purple-600 border border-purple-200 uppercase tracking-widest shadow-sm">T/F</span>' : q.type === 'drag' ? '<span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-orange-100 text-orange-600 border border-orange-200 uppercase tracking-widest shadow-sm">DRAG</span>' : q.type === 'urutan' ? '<span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-teal-100 text-teal-600 border border-teal-200 uppercase tracking-widest shadow-sm">URUTAN</span>' : '<span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-gray-100 text-gray-500 border border-gray-200 uppercase tracking-widest shadow-sm">PG</span>';
        let optHtml = '';
        
        if (q.type === 'drag') {
            const allOpts = Object.entries(q.options || {}).map(([k, v]) => `<span class="inline-block px-1.5 py-0.5 rounded border border-orange-200 bg-orange-50 text-orange-700 font-bold">${k}: ${v}</span>`).join(' ');
            const answerKeys = (q.correct_answer || '').split(',');
            let blankIndex = 0;
            const filledSentence = (q.question || '').replace(/\[BLANK\]/g, () => {
                const key = answerKeys[blankIndex] || '?';
                const val = (q.options || {})[key] || key;
                blankIndex++;
                return `<span class="inline-block bg-green-100 text-green-700 font-black px-1.5 py-0.5 rounded border border-green-300 text-[10px]">${val}</span>`;
            });
            optHtml = `<div class="space-y-2"><p class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">Kalimat Lengkap:</p><p class="text-[11px] text-gray-700 leading-relaxed font-medium">${filledSentence}</p><p class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mt-1">Pilihan Jawaban:</p><div class="flex flex-wrap gap-1">${allOpts}</div></div>`;
        } else if (q.type === 'urutan') {
            const arrUrutan = Array.isArray(q.options) ? q.options : [];
            const keyArr = Array.isArray(q.correct_answer) ? q.correct_answer : []; 
            const finalRenderArr = keyArr.length > 0 ? keyArr : arrUrutan;
            optHtml = `<div class="space-y-1"><p class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">Urutan Benar:</p><div class="flex flex-wrap items-center gap-1.5 mt-1">${finalRenderArr.map((item) => `<span class="inline-block px-2 py-1 rounded bg-teal-50 border border-teal-200 text-teal-700 font-bold text-[10px]">${item}</span>`).join('<i class="fa-solid fa-arrow-right text-[10px] text-gray-300"></i>')}</div></div>`;
        } else {
            optHtml = Object.entries(q.options || {}).map(([k, v]) => `<span class="${k === q.correct_answer ? 'text-green-600 font-bold' : 'text-gray-400'}">${k}: ${v}</span>`).join(' · ');
        }
        
        const levelColor = { mudah: 'text-green-600 bg-green-50', sedang: 'text-blue-600 bg-blue-50', sulit: 'text-red-500 bg-red-50' };
        const lc = levelColor[q.difficulty_level] || 'text-gray-500 bg-gray-50';

        return `<div class="bg-gray-50 rounded-xl p-4 border border-gray-200 shadow-sm space-y-2 relative" data-soal-id="${q.id}">
            <div class="flex items-start justify-between gap-2 border-b border-gray-100 pb-2">
                <div class="flex items-start gap-2 flex-1">
                    <div class="hidden bulk-checkbox-wrap week-${week} mt-0.5 shrink-0">
                        <input type="checkbox" class="w-4 h-4 accent-red-500 rounded cursor-pointer bulk-checkbox" value="${q.id}" onchange="updateBulkCount(${week})">
                    </div>
                    <div class="flex-1">
                        <p class="text-xs font-bold text-gray-800 leading-relaxed">${index + 1}. ${q.question}</p>
                        ${thumbHtml}
                    </div>
                </div>
                <div class="flex flex-col items-end gap-1.5 flex-shrink-0">
                    <div class="flex items-center gap-1">${typeBadge}<span class="text-[9px] font-bold px-1.5 py-0.5 rounded border border-white shadow-sm ${lc}">${q.difficulty_level}</span></div>
                    <div class="flex gap-1 mt-1">
                        <button onclick="openEditSoal(${JSON.stringify(q).replace(/"/g, '&quot;')})" class="w-6 h-6 flex items-center justify-center bg-white text-blue-500 border border-blue-100 rounded-md text-[10px] shadow-sm active:scale-95 transition-all" title="Edit"><i class="fa-solid fa-pen"></i></button>
                        <button onclick="hapusSoal('${q.id}', '${subject}')" class="w-6 h-6 flex items-center justify-center bg-white text-red-500 border border-red-100 rounded-md text-[10px] shadow-sm active:scale-95 transition-all" title="Hapus"><i class="fa-solid fa-trash"></i></button>
                    </div>
                </div>
            </div>
            <div class="text-[10px] leading-relaxed pt-1">${optHtml}</div>
        </div>`;
    };

    // =================================================================
    // 4. CRUD ACTIONS (DELETE, EDIT, UPLOAD, BULK)
    // =================================================================
    window.hapusSoal = async (id, subject) => {
        if (!confirm(`Hapus soal ini dari bank soal ${subject}? Tindakan tidak bisa dibatalkan.`)) return;
        try {
            const res = await fetch(`${API_URL}/api/onboarding/questions/${id}`, { method: 'DELETE', headers: { 'Authorization': `Bearer ${token}` } });
            if (res.ok) {
                window.showToast('success', 'Terhapus', 'Soal berhasil dihapus.');
                isSummaryCached = false; 
                
                // Cari dan Hapus dari soalCache
                for (const cacheKey in soalCache) {
                    if (cacheKey.includes(`-${subject}`)) {
                        const qIndex = soalCache[cacheKey].findIndex(q => q.id === id);
                        if (qIndex !== -1) { 
                            soalCache[cacheKey].splice(qIndex, 1); 
                            const [w, subj] = cacheKey.split('-');
                            const bodyMapel = document.getElementById(`body-mapel-${w}-${subj}`);
                            if (bodyMapel && !bodyMapel.classList.contains('hidden')) {
                                bodyMapel.innerHTML = soalCache[cacheKey].map((q, i) => renderSoalItem(q, i, subj, w)).join('');
                            }
                            break; 
                        }
                    }
                }
                fetchAccordion(); // Update ulang angka
            } else window.showToast('danger', 'Error', 'Gagal menghapus soal.');
        } catch { window.showToast('danger', 'Error', 'Terjadi kesalahan jaringan.'); }
    };

    window.submitEditSoal = async () => {
        const modal = document.getElementById('modalEditSoal');
        const id = document.getElementById('editSoalId').value;
        const payload = extractCardData(modal);

        if (!payload.question || (payload.type !== 'tf' && payload.type !== 'urutan' && (!payload.options.A || !payload.options.B))) {
            return window.showToast('warning', 'Perhatian', 'Pertanyaan dan minimal opsi wajib diisi.');
        }

        try {
            const res = await fetch(`${API_URL}/api/onboarding/questions/${id}`, {
                method: 'PUT',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            if (res.ok) {
                window.showToast('success', 'Berhasil', 'Soal berhasil diperbarui.');
                isDirty = false; 
                document.getElementById('modalEditSoal').classList.replace('flex', 'hidden');
                
                // [FIX BUG 1] Update Live di Cache dan UI
                for (const cacheKey in soalCache) {
                    const qIndex = soalCache[cacheKey].findIndex(q => q.id === id);
                    if (qIndex !== -1) {
                        soalCache[cacheKey][qIndex] = { ...soalCache[cacheKey][qIndex], ...payload };
                        const [w, subj] = cacheKey.split('-');
                        const bodyMapel = document.getElementById(`body-mapel-${w}-${subj}`);
                        if (bodyMapel && !bodyMapel.classList.contains('hidden')) {
                            bodyMapel.innerHTML = soalCache[cacheKey].map((q, i) => renderSoalItem(q, i, subj, w)).join('');
                        }
                        break;
                    }
                }
            } else window.showToast('danger', 'Error', (await res.json()).message || 'Gagal update.');
        } catch (e) { window.showToast('danger', 'Error', 'Terjadi kesalahan jaringan.'); }
    };

    document.getElementById('btnFinalSave').onclick = async () => {
        const cards   = document.querySelectorAll('#previewContent .soal-card');
        const subject = activeSubjectForUpload;
        const week    = parseInt(document.getElementById('targetWeek').value);
        if (!week || week < 1) return window.showToast('warning', 'Perhatian', 'Nomor pertemuan tidak valid.');

        const questionsData = [];
        cards.forEach(card => {
            const data = extractCardData(card);
            if (data.question && (data.type === 'tf' || data.type === 'urutan' || (data.options.A && data.options.B))) {
                questionsData.push(data);
            }
        });
        if (questionsData.length === 0) return window.showToast('warning', 'Perhatian', 'Tidak ada soal yang valid untuk disimpan.');

        const btn = document.getElementById('btnFinalSave');
        btn.textContent = "Menyimpan..."; btn.disabled = true;

        try {
            const res = await fetch(`${API_URL}/api/onboarding/upload-template`, {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify({ subject, week, questions: questionsData })
            });
            const result = await res.json();
            if (res.ok) {
                window.showToast('success', 'Berhasil', `${questionsData.length} soal disimpan.`);
                isSummaryCached = false; 
                isDirty = false; 
                // Kosongkan cache untuk pertemuan ini agar fetch ulang data terbaru
                Object.keys(soalCache).forEach(key => { if(key.startsWith(`${week}-`)) delete soalCache[key]; });
                setTimeout(() => { document.getElementById('modalPreview').classList.add('hidden'); fetchAccordion(); }, 1200);
            } else window.showToast('danger', 'Error', result.message || 'Gagal menyimpan.');
        } catch (err) { window.showToast('danger', 'Error', 'Terjadi kesalahan jaringan.'); } 
        finally { btn.textContent = "Simpan"; btn.disabled = false; }
    };

    // FITUR BULK ACTION
    window.enterBulkMode = (week) => {
        document.getElementById(`btnBulkModeWrap-${week}`).classList.add('hidden');
        document.getElementById(`bulkToolbar-${week}`).classList.remove('hidden');
        document.querySelectorAll(`.bulk-checkbox-wrap.week-${week}`).forEach(el => el.classList.remove('hidden'));
        updateBulkCount(week);
    };

    window.cancelBulkMode = (week) => {
        document.getElementById(`btnBulkModeWrap-${week}`).classList.remove('hidden');
        document.getElementById(`bulkToolbar-${week}`).classList.add('hidden');
        document.querySelectorAll(`.bulk-checkbox-wrap.week-${week}`).forEach(el => {
            el.classList.add('hidden');
            el.querySelector('input').checked = false;
        });
        document.getElementById(`selectAll-${week}`).checked = false;
    };

    window.toggleSelectAll = (week, isChecked) => {
        document.querySelectorAll(`.bulk-checkbox-wrap.week-${week} input[type="checkbox"]`).forEach(cb => { cb.checked = isChecked; });
        updateBulkCount(week);
    };

    window.updateBulkCount = (week) => {
        const count = document.querySelectorAll(`.bulk-checkbox-wrap.week-${week} input[type="checkbox"]:checked`).length;
        document.getElementById(`bulkCount-${week}`).innerText = count;
        const total = document.querySelectorAll(`.bulk-checkbox-wrap.week-${week} input[type="checkbox"]`).length;
        document.getElementById(`selectAll-${week}`).checked = (count === total && total > 0);
    };

    window.executeBulkDelete = async (week) => {
        const checked = document.querySelectorAll(`.bulk-checkbox-wrap.week-${week} input[type="checkbox"]:checked`);
        if (checked.length === 0) return window.showToast('warning', 'Perhatian', 'Pilih minimal 1 soal untuk dihapus.');
        if (!confirm(`Yakin ingin menghapus ${checked.length} soal terpilih? Tindakan ini tidak bisa dibatalkan.`)) return;

        const idsToDelete = Array.from(checked).map(cb => cb.value);
        const btn = document.querySelector(`#bulkToolbar-${week} button.bg-red-500`);
        const oldText = btn.innerHTML;
        
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Menghapus...';
        btn.disabled = true;
        try {
            const deletePromises = idsToDelete.map(id => fetch(`${API_URL}/api/onboarding/questions/${id}`, { method: 'DELETE', headers: { 'Authorization': `Bearer ${token}` } }));
            await Promise.all(deletePromises);

            window.showToast('success', 'Berhasil', `${idsToDelete.length} soal berhasil dihapus.`);
            isSummaryCached = false;
            
            idsToDelete.forEach(id => {
                for (const cacheKey in soalCache) {
                    if (cacheKey.startsWith(`${week}-`)) {
                        const qIndex = soalCache[cacheKey].findIndex(q => q.id === id);
                        if (qIndex !== -1) { 
                            soalCache[cacheKey].splice(qIndex, 1);
                            const [w, subj] = cacheKey.split('-');
                            const bodyMapel = document.getElementById(`body-mapel-${w}-${subj}`);
                            if (bodyMapel && !bodyMapel.classList.contains('hidden')) {
                                bodyMapel.innerHTML = soalCache[cacheKey].map((q, i) => renderSoalItem(q, i, subj, w)).join('');
                            }
                        }
                    }
                }
            });
            fetchAccordion(); // Refresh angka
        } catch (err) {
            window.showToast('danger', 'Error', 'Terjadi kesalahan saat menghapus massal.');
            btn.innerHTML = oldText; btn.disabled = false;
        }
    };

    // =================================================================
    // 5. HELPER UPLOAD FILE & GAMBAR
    // =================================================================
    document.getElementById('btnOpenUpload').onclick = async () => {
        await loadSummaryIntoModal();
        document.getElementById('modalUpload').classList.remove('hidden');
    };
    
    window.closeUpload  = () => document.getElementById('modalUpload').classList.add('hidden');
    window.closePreview = () => {
        if (isDirty) showConfirmBack(() => document.getElementById('modalPreview').classList.add('hidden'));
        else document.getElementById('modalPreview').classList.add('hidden');
    };

    const loadSummaryIntoModal = async () => {
        if (!isSummaryCached) {
            const btn = document.getElementById('btnOpenUpload');
            const oldContent = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin text-lg"></i>';
            try {
                const res = await fetch(`${API_URL}/api/onboarding/questions/summary`, { headers: { 'Authorization': `Bearer ${token}` }});
                const result = await res.json();
                summaryData = result.data || {};
                isSummaryCached = true;
            } catch (e) { console.error("Gagal mengambil summary", e); } 
            finally { btn.innerHTML = oldContent; }
        }
        updateSmartAddUI();
    };

    const updateSmartAddUI = () => {
        const subject = document.getElementById('upSubject').value;
        const mode    = document.querySelector('input[name="weekMode"]:checked')?.value || 'baru';
        const info    = summaryData[subject] || { maxWeek: 0, gaps: [], allWeeks: [] };

        const nextWeek = info.maxWeek + 1;
        document.getElementById('labelPertemuanBaru').textContent = info.maxWeek === 0 ? 'Belum ada soal — akan jadi Pertemuan 1' : `Otomatis ke Pertemuan ${nextWeek} (setelah Mg-${info.maxWeek})`;

        const sisipanWeekEl = document.getElementById('sisipanWeek');
        const sisipanWrap   = document.getElementById('sisipanDropdownWrap');

        if (mode === 'sisipan') {
            sisipanWrap.classList.remove('hidden');
            const gapOptions  = info.gaps.map(w => `<option value="${w}">MG-${w} (Kosong / Bolong)</option>`).join('');
            const existOptions = info.allWeeks.map(w => `<option value="${w}">MG-${w} (Tambah soal di pertemuan ini)</option>`).join('');
            sisipanWeekEl.innerHTML = `<option value="">Pilih minggu...</option>${gapOptions}${existOptions}`;
        } else {
            sisipanWrap.classList.add('hidden');
        }

        if (mode === 'baru') resolvedWeekForUpload = nextWeek;
        else resolvedWeekForUpload = parseInt(sisipanWeekEl.value) || null;
        
        activeSubjectForUpload = subject;
    };

    document.getElementById('upSubject').onchange = updateSmartAddUI;
    document.querySelectorAll('input[name="weekMode"]').forEach(r => r.onchange = updateSmartAddUI);
    document.getElementById('sisipanWeek').onchange = () => resolvedWeekForUpload = parseInt(document.getElementById('sisipanWeek').value) || null;

    document.getElementById('btnDownloadTemplate').onclick = () => {
        const templateText = `TIPE: pilgan\nQ: Contoh perbuatan syirik adalah?\nA: Shalat tepat waktu\nB: Berdoa kepada Allah\nC: Meminta kepada kuburan\nD: Membaca Al-Qur'an\nKUNCI: C\nLEVEL: MUDAH\n\nTIPE: tf\nQ: Berbakti kepada orang tua adalah kewajiban yang utama.\nA: Benar\nB: Salah\nKUNCI: A\nLEVEL: SEDANG\n\nTIPE: drag\nQ: Ya Allah ampunilah dosaku dan dosa [BLANK] yang menyayangiku.\nA: Kucingku\nB: Guruku\nC: Kedua orang tuaku\nD: Tetanggaku\nKUNCI: C\nLEVEL: MUDAH\n\nTIPE: urutan\nQ: Urutkan rukun wudhu yang benar.\nA: Basuh Tangan\nB: Niat\nC: Cuci Kaki\nD: Basuh Muka\nKUNCI: B, D, A, C\nLEVEL: SEDANG`;
        const blob = new Blob([templateText], { type: 'text/plain' });
        const url  = URL.createObjectURL(blob);
        const a    = document.createElement('a');
        a.href = url; a.download = 'template_soal_yukNgaji.txt'; a.click();
        URL.revokeObjectURL(url);
    };

    document.getElementById('formUpload').onsubmit = (e) => {
        e.preventDefault();
        const file = document.getElementById('upFile').files[0];
        if (!file) { openManualFromModal(); return; }
        const reader = new FileReader();
        reader.onload = (ev) => { renderPreview(parseTextToJSON(ev.target.result)); isDirty = true; };
        reader.readAsText(file);
    };

    window.openManualFromModal = () => { closeUpload(); renderPreview([]); addNewQuestionField(); isDirty = false; };

    const parseTextToJSON = (text) => {
        const blocks = text.split(/\r?\n\r?\n/);
        return blocks.map(block => {
            const lines = block.split('\n').map(l => l.trim());
            const type = lines.find(l => l.startsWith('TIPE:'))?.replace('TIPE:', '').trim().toLowerCase() || 'pilgan';
            const q = lines.find(l => l.startsWith('Q:'))?.replace('Q:', '').trim() || '';
            let key = lines.find(l => l.startsWith('KUNCI:'))?.replace('KUNCI:', '').trim() || 'A'; 
            const level = lines.find(l => l.startsWith('LEVEL:'))?.replace('LEVEL:', '').trim().toLowerCase() || 'sedang';
            const img = lines.find(l => l.startsWith('IMG:'))?.replace('IMG:', '').trim() || null;
            let options = {}; 
            
            ['A','B','C','D','E','F','G','H'].forEach(letter => {
                const line = lines.find(l => l.startsWith(`${letter}:`));
                if (line) options[letter] = line.replace(`${letter}:`, '').trim();
            });

            if ((type === 'pilgan' || type === 'drag') && Object.keys(options).length === 0) {
                options.A = ""; options.B = ""; options.C = ""; options.D = "";
            }

            if (type === 'urutan') {
                const arr = Object.values(options).filter(v => v !== '');
                const keyLetters = key.split(',').map(s => s.trim());
                const correctArr = keyLetters.map(k => options[k]).filter(Boolean);
                options = arr; key = correctArr;
            }
            return { type, q, options, key, level, image_url: img };
        }).filter(item => item.q !== '');
    };

    window.renderPreview = (questions) => {
        const container = document.getElementById('previewContent');
        container.innerHTML = '';
        questions.forEach((item, idx) => { container.appendChild(createSoalCard(item, idx + 1)); });
        document.getElementById('targetWeek').value = resolvedWeekForUpload || 1;
        document.getElementById('previewSubjectLabel').textContent = activeSubjectForUpload;
        document.getElementById('modalUpload').classList.add('hidden');
        document.getElementById('modalPreview').classList.remove('hidden');
    };

    const createSoalCard = (item, displayIndex) => {
        const type = item.type || 'pilgan';
        const div = document.createElement('div');
        div.className = "soal-card card-core-logic bg-white p-4 sm:p-5 rounded-3xl border border-gray-200 shadow-sm";
        div.innerHTML = `
            <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-3 mb-4 pb-3 border-b border-gray-100">
                <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-3 w-full sm:w-auto">
                    <span class="text-[10px] font-black text-white bg-gray-800 px-2 py-1 rounded shadow-sm self-start sm:self-auto shrink-0">SOAL ${displayIndex || 'BARU'}</span>
                    <select class="type-input text-[10px] font-bold border border-gray-200 bg-gray-50 text-gray-600 rounded-lg px-3 py-2 outline-none cursor-pointer w-full sm:w-auto appearance-none" onchange="toggleCardType(this)">
                        <option value="pilgan" ${type==='pilgan'?'selected':''}>Pilihan Ganda</option>
                        <option value="tf" ${type==='tf'?'selected':''}>Benar / Salah</option>
                        <option value="drag" ${type==='drag'?'selected':''}>Drag & Drop</option>
                        <option value="urutan" ${type==='urutan'?'selected':''}>Mengurutkan (Puzzle)</option>
                    </select>
                </div>
                <button type="button" onclick="this.closest('.soal-card').remove(); markDirty();" class="text-red-500 font-bold text-[10px] self-end sm:self-auto hover:bg-red-50 p-2 rounded-lg transition-colors border border-red-100 sm:border-none flex items-center gap-1.5"><i class="fa-solid fa-trash"></i> Hapus</button>
            </div>
            
            <div class="drag-tools hidden mb-3 p-3 bg-indigo-50/50 border border-indigo-100 rounded-xl flex flex-col sm:flex-row sm:items-center justify-between gap-3">
                <div class="flex items-start gap-2.5">
                    <div class="w-6 h-6 rounded-full bg-indigo-100 text-indigo-500 flex items-center justify-center shrink-0 mt-0.5"><i class="fa-solid fa-wand-magic-sparkles text-xs"></i></div>
                    <p class="text-[10px] text-indigo-900 leading-relaxed font-medium"><b class="text-indigo-700">Mode Drag & Drop:</b><br>Klik tombol di bawah untuk menyisipkan kolom kosong pada soal.</p>
                </div>
                <button type="button" onclick="insertBlank(this)" class="w-full sm:w-auto text-[10px] font-bold bg-indigo-600 text-white px-4 py-3 rounded-lg hover:bg-indigo-700 transition-colors shadow-md shadow-indigo-600/20 active:scale-95 flex items-center justify-center gap-2 shrink-0"><i class="fa-solid fa-plus"></i> Sisipkan [BLANK]</button>
            </div>

            <div class="space-y-3">
                <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase">Pertanyaan</label>
                    <textarea class="q-input w-full mt-1 p-3 bg-gray-50 rounded-xl text-sm font-bold border border-gray-200 focus:ring-2 focus:ring-blue-400 outline-none" rows="2" placeholder="Tulis pertanyaan di sini..." oninput="updateDragKeys(this)">${item.q || ''}</textarea>
                </div>

                <div class="img-container">
                    <label class="text-[10px] font-bold text-gray-400 uppercase">Gambar / GIF (Opsional)</label>
                    <div class="flex items-center gap-2 mt-1">
                        <input type="text" class="img-input flex-1 p-2.5 bg-gray-50 border border-gray-200 rounded-xl text-[10px] font-bold outline-none focus:ring-2 focus:ring-green-400" placeholder="https://domain.com/gambar.gif atau upload file" value="${item.image_url || ''}">
                        <label class="shrink-0 w-9 h-9 bg-green-50 border border-green-200 rounded-xl flex items-center justify-center cursor-pointer hover:bg-green-100 transition-colors" title="Upload gambar dari perangkat">
                            <i class="fa-solid fa-upload text-green-600 text-xs"></i>
                            <input type="file" accept="image/*,image/gif" class="img-file-input hidden" onchange="handleCardImgUpload(this)">
                        </label>
                    </div>
                    <div class="img-preview mt-2 ${item.image_url ? '' : 'hidden'}">
                        ${item.image_url ? `<img src="${item.image_url}" class="max-h-28 rounded-xl border border-gray-200 object-contain" onerror="this.closest('.img-preview').classList.add('hidden')">` : ''}
                    </div>
                </div>
            </div>

            <div class="urutan-tools hidden mb-3 p-3 bg-teal-50 border border-teal-100 rounded-xl flex items-center gap-3 w-full mt-3">
                <div class="w-8 h-8 rounded-full bg-teal-200 text-teal-700 flex items-center justify-center shrink-0"><i class="fa-solid fa-list-ol"></i></div>
                <p class="text-[10px] font-bold text-teal-800 leading-relaxed">Mode Mengurutkan aktif.<br>Masukkan elemen di bawah secara acak. Sistem akan mengacaknya saat ujian.</p>
            </div>

            <div class="options-wrapper flex flex-col gap-2 mt-3 w-full"></div>
            <button type="button" class="btn-add-option hidden text-[10px] font-bold text-blue-500 mt-2 w-full p-3 bg-blue-50 border-2 border-dashed border-blue-200 hover:bg-blue-100 rounded-xl transition-colors active:scale-95 text-center" onclick="addOptionRow(this)">+ Tambah Pilihan Jawaban</button>

            <div class="tf-wrapper hidden mt-3 p-3 bg-blue-50 border border-blue-100 rounded-xl flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-blue-200 text-blue-600 flex items-center justify-center shrink-0"><i class="fa-solid fa-toggle-on"></i></div>
                <p class="text-[10px] font-bold text-blue-700 leading-relaxed">Mode Benar/Salah aktif. Opsi otomatis menjadi A (Benar) dan B (Salah).</p>
            </div>

            <div class="flex flex-col gap-4 mt-4 bg-gray-50 p-4 rounded-xl border border-gray-100">
                <div class="key-standard flex flex-col sm:flex-row sm:items-center gap-2">
                    <span class="text-[10px] font-bold text-gray-400 shrink-0">KUNCI (PG/TF):</span>
                    <select class="key-input text-xs font-bold border border-gray-200 bg-white text-green-700 rounded-lg px-3 py-2.5 shadow-sm outline-none w-full sm:flex-1 appearance-none"></select>
                </div>
                
                <div class="key-drag hidden w-full">
                    <span class="text-[10px] font-bold text-gray-400 mb-2 block">KUNCI JAWABAN DRAG & DROP:</span>
                    <div class="drag-keys-container grid grid-cols-1 sm:grid-cols-2 gap-2"></div>
                </div>

                <div class="key-urutan hidden w-full">
                    <span class="text-[10px] font-bold text-gray-400 mb-2 block">KUNCI JAWABAN URUTAN:</span>
                    <div class="urutan-keys-container flex flex-col gap-2"></div>
                </div>

                <div class="flex flex-col sm:flex-row sm:items-center gap-2 pt-4 border-t border-gray-200">
                    <span class="text-[10px] font-bold text-gray-400 shrink-0">LEVEL KESULITAN:</span>
                    <select class="level-input text-xs font-bold border border-gray-200 bg-white text-indigo-700 rounded-lg px-3 py-2.5 shadow-sm outline-none w-full sm:flex-1 appearance-none">
                        <option value="mudah" ${item.level === 'mudah' ? 'selected' : ''}>Mudah</option>
                        <option value="sedang" ${(!item.level || item.level === 'sedang') ? 'selected' : ''}>Sedang</option>
                        <option value="sulit" ${item.level === 'sulit' ? 'selected' : ''}>Sulit</option>
                    </select>
                </div>
            </div>
        `;
        const optWrapper = div.querySelector('.options-wrapper');
        const defaultOpts = item.options && Object.keys(item.options).length > 0 ? item.options : { A: "", B: "", C: "", D: "" };
        if (Array.isArray(defaultOpts)) { defaultOpts.forEach((v, i) => { appendOptionRow(optWrapper, i + 1, v); }); } 
        else { Object.entries(defaultOpts).forEach(([k, v]) => { appendOptionRow(optWrapper, k, v); }); }

        setTimeout(() => toggleCardType(div.querySelector('.type-input'), item.key), 10);
        return div;
    };

    window.addNewQuestionField = () => {
        markDirty();
        const container = document.getElementById('previewContent');
        const card = createSoalCard({}, null);
        container.appendChild(card);
        setTimeout(() => card.scrollIntoView({ behavior: 'smooth', block: 'center' }), 150);
    };

    window.openEditSoal = (q) => {
        const modal = document.getElementById('modalEditSoal');
        document.getElementById('editSoalId').value = q.id;
        document.getElementById('editSoalType').value = q.type || 'pilgan';
        document.getElementById('editSoalQ').value = q.question;
        document.getElementById('editSoalLevel').value = q.difficulty_level || 'sedang';
        document.getElementById('editSoalImg').value = q.image_url || '';
        previewEditImg(q.image_url || '');
        
        const optWrapper = document.getElementById('editOptionsWrapper');
        optWrapper.innerHTML = '';
        const opts = q.options && Object.keys(q.options).length > 0 ? q.options : {A:"", B:"", C:"", D:""};
        
        if (Array.isArray(opts)) { opts.forEach((v, i) => { appendOptionRow(optWrapper, i + 1, v); }); } 
        else { Object.entries(opts).forEach(([k, v]) => { appendOptionRow(optWrapper, k, v); }); }

        let presetAnswer = q.correct_answer;
        if (q.type === 'urutan' && typeof presetAnswer === 'string') {
            try { presetAnswer = JSON.parse(presetAnswer); } catch(e) {}
        }
        
        toggleEditType(presetAnswer);
        modal.classList.replace('hidden', 'flex');
        isDirty = false;
    };

    window.toggleEditType = (presetKey = null) => { toggleCardType(document.getElementById('editSoalType'), presetKey); };

    window.closeEditSoal = () => {
        const doClose = () => {
            document.getElementById('modalEditSoal').classList.replace('flex', 'hidden');
            document.getElementById('editSoalImgFile').value = '';
            document.getElementById('editImgPreview').classList.add('hidden');
        };
        if (isDirty) showConfirmBack(doClose);
        else doClose();
    };

    window.handleCardImgUpload = async (fileInput) => {
        const file = fileInput.files[0];
        if (!file) return;
        const card = fileInput.closest('.card-core-logic');
        const imgInput = card.querySelector('.img-input');
        const previewWrap = card.querySelector('.img-preview');
        imgInput.value = "Sedang mengupload...";
        const formData = new FormData();
        formData.append('file', file);
        try {
            const res = await fetch(`${API_URL}/api/upload-image`, { method: 'POST', headers: { 'Authorization': `Bearer ${token}` }, body: formData });
            const result = await res.json();
            if (res.ok) {
                const finalImageUrl = result.data.url;
                imgInput.value = finalImageUrl;
                if (previewWrap) {
                    previewWrap.classList.remove('hidden');
                    const existingImg = previewWrap.querySelector('img');
                    if (existingImg) existingImg.src = finalImageUrl;
                    else previewWrap.innerHTML = `<img src="${finalImageUrl}" class="max-h-28 rounded-xl border border-gray-200 object-contain" onerror="this.closest('.img-preview').classList.add('hidden')">`;
                }
                markDirty();
            } else { window.showToast?.('danger', 'Error', 'Gagal upload gambar.'); imgInput.value = ""; }
        } catch (err) { window.showToast?.('danger', 'Error', 'Terjadi kesalahan jaringan.'); imgInput.value = ""; }
    };

    document.addEventListener('input', (e) => {
        if (e.target.classList.contains('img-input') && e.target.closest('.card-core-logic')) {
            const card = e.target.closest('.card-core-logic');
            const previewWrap = card.querySelector('.img-preview');
            const url = e.target.value.trim();
            if (previewWrap) {
                if (url) {
                    previewWrap.classList.remove('hidden');
                    const existingImg = previewWrap.querySelector('img');
                    if (existingImg) existingImg.src = url;
                    else previewWrap.innerHTML = `<img src="${url}" class="max-h-28 rounded-xl border border-gray-200 object-contain" onerror="this.closest('.img-preview').classList.add('hidden')">`;
                } else { previewWrap.classList.add('hidden'); }
            }
        }
    });

    window.handleEditImgUpload = async (fileInput) => {
        const file = fileInput.files[0];
        if (!file) return;
        const imgInput = document.getElementById('editSoalImg');
        imgInput.value = "Sedang mengupload...";
        
        const formData = new FormData();
        formData.append('file', file);
        try {
            const res = await fetch(`${API_URL}/api/upload-image`, { method: 'POST', headers: { 'Authorization': `Bearer ${token}` }, body: formData });
            const result = await res.json();
            if (res.ok) {
                const finalImageUrl = result.data.url;
                imgInput.value = finalImageUrl;
                previewEditImg(finalImageUrl);
                isDirty = true;
            } else { window.showToast?.('danger', 'Error', 'Gagal upload gambar.'); imgInput.value = ""; }
        } catch (err) { window.showToast?.('danger', 'Error', 'Terjadi kesalahan jaringan.'); imgInput.value = ""; }
    };

    window.previewEditImg = (url) => {
        const previewWrap = document.getElementById('editImgPreview');
        const previewEl = document.getElementById('editImgPreviewEl');
        if (url && url.trim()) { previewEl.src = url.trim(); previewWrap.classList.remove('hidden'); } 
        else { previewWrap.classList.add('hidden'); }
    };

    // =================================================================
    // FUNGSI SHARE LINK PR KE WHATSAPP
    // =================================================================
    window.copyPRLink = (subject, week) => {
        const frontendUrl = window.location.origin; // Otomatis ngambil http://localhost:1234 atau domain asli
        
        // [FIX BUG] Sisipkan variabel "token" ustadz ke dalam parameter pr_token
        const link = `${frontendUrl}/consultations?subject=${subject}&week=${week}&pr=true&pr_token=${token}`;
        
        // Coba salin ke Clipboard bawaan device
        navigator.clipboard.writeText(link).then(() => {
            window.showToast?.('success', 'Link Disalin!', `Link PR ${subject.toUpperCase()} Pert. ${week} berhasil disalin. Silakan paste di Grup WA.`);
        }).catch(err => {
            // Fallback kalau browser gak support auto-copy
            prompt('Copy link ini manual:', link);
        });
    };

    // INIT
    fetchAccordion();
</script>

<style>
    .animate-slide-up { animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    @keyframes slideUp { from { transform: translateY(30px) scale(0.95); opacity: 0; } to { transform: translateY(0) scale(1); opacity: 1; } }
    .accordion-body { display: block; }
    .accordion-body.hidden { display: none !important; }
</style>