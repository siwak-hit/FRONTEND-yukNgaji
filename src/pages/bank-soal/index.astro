                <button type="button" onclick="insertBlank(this)" class="flex-shrink-0 w-full sm:w-auto text-[10px] font-bold bg-indigo-600 text-white px-4 py-2.5 rounded-lg hover:bg-indigo-700 transition-colors shadow-md shadow-indigo-600/20 active:scale-95 flex items-center justify-center gap-2">
                    <i class="fa-solid fa-plus"></i> Sisipkan [BLANK]
                </button>
            </div>

            <textarea class="q-input w-full text-sm font-bold text-gray-800 border border-gray-100 bg-gray-50 rounded-xl p-3 focus:ring-2 focus:ring-blue-400 outline-none" rows="2" placeholder="Tulis pertanyaan di sini..." oninput="updateDragKeys(this)">${item.q || ''}</textarea>
            
            <div class="options-wrapper flex flex-col gap-2 mt-3"></div>
            <button type="button" class="btn-add-option hidden text-[10px] font-bold text-blue-500 mt-2 hover:bg-blue-50 px-2 py-1 rounded transition-colors active:scale-95" onclick="addOptionRow(this)">+ Tambah Pilihan Jawaban</button>

