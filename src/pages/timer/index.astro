---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Atur Timer - yukNgaji">
    <div class="px-6 py-8 pb-32 min-h-screen flex flex-col">

        <header class="flex items-center gap-4 mb-8">
            <a href="/dashboard" class="w-10 h-10 bg-white rounded-xl flex items-center justify-center border border-gray-100 shadow-sm text-gray-600 active:scale-95 transition-all">
                <i class="fa-solid fa-chevron-left"></i>
            </a>
            <h1 class="text-xl font-bold text-gray-800">Atur Timer</h1>
        </header>

        <section class="mb-6 bg-white p-5 rounded-3xl border border-gray-100 shadow-sm">
            <h2 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Pilih Durasi (Menit)</h2>
            <div class="grid grid-cols-4 gap-2 mb-4">
                <button class="btn-quick-time py-3 bg-green-50 text-green-600 font-bold rounded-xl active:scale-95 border border-green-200" data-min="10">10</button>
                <button class="btn-quick-time py-3 bg-green-50 text-green-600 font-bold rounded-xl active:scale-95 border border-green-200" data-min="15">15</button>
                <button class="btn-quick-time py-3 bg-green-50 text-green-600 font-bold rounded-xl active:scale-95 border border-green-200" data-min="20">20</button>
                <button class="btn-quick-time py-3 bg-green-50 text-green-600 font-bold rounded-xl active:scale-95 border border-green-200" data-min="30">30</button>
            </div>
            
            <div class="flex items-center gap-3">
                <input type="number" id="customMin" placeholder="Manual..." class="flex-1 px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm font-bold text-gray-700 focus:outline-none focus:ring-2 focus:ring-green-500">
                <button id="btnStartManual" class="px-6 py-3 bg-green-600 text-white font-bold rounded-xl active:scale-95 shadow-lg shadow-green-600/30">Mulai</button>
            </div>
        </section>

        <div class="flex items-center gap-4 mb-6">
            <div class="h-px bg-gray-200 flex-1"></div>
            <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Atau</span>
            <div class="h-px bg-gray-200 flex-1"></div>
        </div>

        <section class="mb-6 bg-white p-5 rounded-3xl border border-gray-100 shadow-sm">
            <h2 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Selesai Pada Pukul</h2>
            <div class="flex items-center gap-3">
                <div class="flex-1 relative">
                    <i class="fa-regular fa-clock absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                    <input type="time" id="targetTimeInput" class="w-full pl-10 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-lg font-black text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <button id="btnStartTarget" class="px-6 py-3 h-full bg-blue-600 text-white font-bold rounded-xl active:scale-95 shadow-lg shadow-blue-600/30">Set</button>
            </div>
        </section>

    </div>
</Layout>

<script>
    const saveAndRedirect = (endTimeMs) => {
        localStorage.setItem('ngaji_timer_end', endTimeMs.toString());
        // Paksa refresh ke dashboard agar timer global memuat ulang dan langsung muncul
        window.location.href = "/dashboard";
    };

    // 1. Durasi Cepat
    document.querySelectorAll('.btn-quick-time').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const mins = parseInt(e.target.dataset.min);
            saveAndRedirect(Date.now() + (mins * 60000));
        });
    });

    // 2. Durasi Manual
    document.getElementById('btnStartManual').addEventListener('click', () => {
        const customMin = document.getElementById('customMin').value;
        if (!customMin || parseInt(customMin) <= 0) return alert('Masukkan menit yang valid!');
        saveAndRedirect(Date.now() + (parseInt(customMin) * 60000));
    });

    // 3. Target Jam Selesai
    document.getElementById('btnStartTarget').addEventListener('click', () => {
        const timeVal = document.getElementById('targetTimeInput').value;
        if (!timeVal) return alert('Pilih jam selesai!');

        const [hours, minutes] = timeVal.split(':').map(Number);
        const targetDate = new Date();
        targetDate.setHours(hours, minutes, 0, 0);

        // Jika jam yang dipilih sudah lewat hari ini, asumsikan untuk besok
        if (targetDate.getTime() <= Date.now()) {
            targetDate.setDate(targetDate.getDate() + 1);
        }

        saveAndRedirect(targetDate.getTime());
    });
</script>