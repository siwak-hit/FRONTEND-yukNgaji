---
import Layout from '../layouts/Layout.astro';
import Toast from '../components/Toast.astro';
import ModalAlert from '../components/ModalAlert.astro';
import NavbarGuru from '../components/NavbarGuru.astro';
---

<Layout title="Dashboard Guru - yukNgaji">
    <div class="px-6 py-8 pb-16 min-h-screen flex flex-col">

        <header class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-2xl font-bold text-green-600 tracking-tight" id="greetingName">yukNgaji</h1>
                <p class="text-xs text-gray-500 font-medium" id="welcomeMsg">Assalamu'alaikum, Ustadz!</p>
            </div>
        
            <div class="flex items-center gap-3">
                <!-- [BARU] Tombol Notifikasi -->
                <button onclick="openNotifModal()" class="relative text-indigo-500 bg-indigo-50 w-10 h-10 rounded-xl flex items-center justify-center active:scale-95 transition-transform shadow-sm">
                    <i class="fa-solid fa-bell"></i>
                    <span id="notifBadge" class="hidden absolute -top-1.5 -right-1.5 bg-red-500 text-white text-[9px] font-black px-1.5 py-0.5 rounded-full shadow-sm border border-white">0</span>
                </button>
                <button id="btnLogout" class="text-red-500 bg-red-50 w-10 h-10 rounded-xl flex items-center justify-center active:scale-95 transition-transform shadow-sm">
                    <i class="fa-solid fa-power-off"></i>
                </button>
            </div>
        </header>

        <section class="mb-16">
            <h2 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Ringkasan Kelas</h2>
            <div class="grid grid-cols-2 gap-3">
                
                <div class="bg-green-50 p-4 rounded-2xl flex flex-col justify-center text-center border border-green-100 shadow-sm">
                    <div class="w-8 h-8 bg-green-100 text-green-500 rounded-full flex items-center justify-center mx-auto mb-2">
                        <i class="fa-solid fa-users"></i>
                    </div>
                    <h3 class="text-xl font-black text-green-700 mb-0.5" id="statStudents">-</h3>
                    <p class="text-[9px] text-green-600 font-bold uppercase tracking-widest">Total Anak</p>
                </div>

                <div class="bg-indigo-50 p-4 rounded-2xl flex flex-col justify-center text-center border border-indigo-100 shadow-sm">
                    <div class="w-8 h-8 bg-indigo-100 text-indigo-500 rounded-full flex items-center justify-center mx-auto mb-2">
                        <i class="fa-solid fa-file-contract"></i>
                    </div>
                    <h3 class="text-xl font-black text-indigo-600 mb-0.5" id="statExams">0</h3>
                    <p class="text-[9px] text-indigo-700 font-bold uppercase tracking-widest">Total Ujian</p>
                </div>

                <div onclick="openNotDoneModal()" class="col-span-2 bg-red-50 rounded-2xl p-4 border border-red-100 flex flex-col justify-between cursor-pointer hover:bg-red-100 transition-all active:scale-[0.98] group shadow-sm">
                    <div class="flex justify-between items-center mb-1">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 bg-red-100 text-red-600 rounded-lg flex items-center justify-center text-xs group-hover:scale-110 transition-transform">
                                <i class="fa-solid fa-user-clock"></i>
                            </div>
                            <span class="text-[11px] font-bold text-red-600 uppercase tracking-wider">Belum Mengerjakan Tugas</span>
                        </div>
                        <i class="fa-solid fa-chevron-right text-xs text-red-300 group-hover:text-red-500 group-hover:translate-x-1 transition-all"></i>
                    </div>
                    <div class="flex items-end justify-between mt-2 pl-1">
                        <h3 class="text-3xl font-black text-red-700 leading-none" id="notDoneCount">0</h3>
                        <p class="text-[10px] text-red-400 font-bold">Siswa Perlu Diingatkan</p>
                    </div>
                </div>

            </div>
        </section>

        <div class="mb-6">
            <h2 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Aksi Cepat</h2>

            <a href="/absensi" id="btnAbsensi" class="relative block w-full bg-blue-50 p-4 rounded-2xl overflow-hidden mb-3 active:scale-[0.98] transition-all">
                <div class="flex items-center justify-between z-10 relative">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-blue-100 text-blue-500 rounded-xl flex items-center justify-center">
                            <i class="fa-solid fa-calendar-check text-lg"></i>
                        </div>
                        <div>
                            <h3 class="font-bold text-blue-800 text-sm">Absensi Hari Ini</h3>
                            <p id="absensiStatusText" class="text-[10px] text-blue-400 font-bold uppercase tracking-wider">Mengecek status...</p>
                        </div>
                    </div>
                    <i class="fa-solid fa-chevron-right text-blue-300 text-xs"></i>
                </div>
                <div id="absensiPulse" class="absolute inset-0 border-2 border-transparent rounded-2xl pointer-events-none"></div>
            </a>

            <div class="grid grid-cols-4 gap-2 sm:gap-3">
                <a href="/timer" class="relative bg-yellow-50 p-2 sm:p-4 rounded-2xl overflow-hidden active:scale-95 transition-transform flex flex-col items-center justify-center gap-1 sm:gap-2 text-center border border-yellow-100">
                    <div class="w-8 h-8 sm:w-10 sm:h-10 bg-yellow-100 text-yellow-600 rounded-xl flex items-center justify-center shrink-0">
                        <i class="fa-solid fa-stopwatch text-base sm:text-lg"></i>
                    </div>
                    <div>
                        <h3 class="font-bold text-yellow-800 text-[10px] sm:text-sm leading-tight">Timer</h3>
                        <p class="text-[7px] sm:text-[9px] text-yellow-500 font-bold uppercase tracking-wider truncate">Durasi</p>
                    </div>
                </a>

                <a href="/seats" class="relative bg-green-50 p-2 sm:p-4 rounded-2xl overflow-hidden active:scale-95 transition-transform flex flex-col items-center justify-center gap-1 sm:gap-2 text-center border border-green-100">
                    <div class="w-8 h-8 sm:w-10 sm:h-10 bg-green-100 text-green-600 rounded-xl flex items-center justify-center shrink-0">
                        <i class="fa-solid fa-chair text-base sm:text-lg"></i>
                    </div>
                    <div>
                        <h3 class="font-bold text-green-800 text-[10px] sm:text-sm leading-tight">Denah</h3>
                        <p class="text-[7px] sm:text-[9px] text-green-500 font-bold uppercase tracking-wider truncate">Posisi</p>
                    </div>
                </a>

                <a href="/hafalan" class="relative bg-emerald-50 p-2 sm:p-4 rounded-2xl overflow-hidden active:scale-95 transition-transform flex flex-col items-center justify-center gap-1 sm:gap-2 text-center border border-emerald-100">
                    <div class="w-8 h-8 sm:w-10 sm:h-10 bg-emerald-100 text-emerald-600 rounded-xl flex items-center justify-center shrink-0">
                        <i class="fa-solid fa-book-quran text-base sm:text-lg"></i>
                    </div>
                    <div>
                        <h3 class="font-bold text-emerald-800 text-[10px] sm:text-sm leading-tight">Hafalan</h3>
                        <p class="text-[7px] sm:text-[9px] text-emerald-500 font-bold uppercase tracking-wider truncate">Juz Amma</p>
                    </div>
                </a>

                <a href="/galeri" class="relative bg-purple-50 p-2 sm:p-4 rounded-2xl overflow-hidden active:scale-95 transition-transform flex flex-col items-center justify-center gap-1 sm:gap-2 text-center border border-purple-100 shadow-sm">
                    <div class="w-8 h-8 sm:w-10 sm:h-10 bg-purple-100 text-purple-600 rounded-xl flex items-center justify-center shrink-0">
                        <i class="fa-solid fa-images text-base sm:text-lg"></i>
                    </div>
                    <div>
                        <h3 class="font-bold text-purple-800 text-[10px] sm:text-sm leading-tight">Galeri</h3>
                        <p class="text-[7px] sm:text-[9px] text-purple-500 font-bold uppercase tracking-wider truncate">Foto Raport</p>
                    </div>
                </a>
            </div>
        </div>

        <section class="flex-1">
            <div class="flex p-1 bg-gray-100 rounded-2xl mb-5 shadow-inner">
                <button id="tabList" class="flex-1 py-3 text-[10px] font-bold bg-white text-green-600 rounded-xl shadow-sm transition-all uppercase tracking-widest">
                    <i class="fa-solid fa-users mr-1"></i> Daftar Anak
                </button>
                <button id="tabLeaderboard" class="flex-1 py-3 text-[10px] font-bold text-gray-400 hover:text-gray-600 transition-all uppercase tracking-widest">
                    <i class="fa-solid fa-trophy mr-1"></i> Leaderboard
                </button>
            </div>

            <div id="contentList" class="block animate-slide-up">
                <div class="flex justify-between items-center mb-4 px-1">
                    <select id="filterList" class="bg-white border border-gray-200 text-gray-600 text-xs font-bold rounded-lg px-2 py-1.5 focus:ring-2 focus:ring-green-500 outline-none shadow-sm cursor-pointer">
                        <option value="abjad">Abjad (A - Z)</option>
                        <option value="nilai">Nilai Rata-rata Tertinggi</option>
                        <option value="rajin">Kehadiran Terbanyak</option>
                    </select>
                    <button class="text-xs font-bold text-green-600 hover:text-green-700 bg-green-50 px-3 py-1.5 rounded-lg transition-colors" onclick="window.location.href='/students'">Lihat Semua</button>
                </div>

                <div id="studentList" class="space-y-3">
                    <div class="text-center py-8"><i class="fa-solid fa-spinner fa-spin text-green-500 text-3xl"></i><p class="text-xs text-gray-400 mt-3 font-bold">Menghitung data...</p></div>
                </div>
                
                <div id="remainingStudentsContainer" class="mt-4 text-center hidden">
                    <span id="remainingStudentsText" class="inline-block bg-gray-100 text-gray-500 text-[10px] font-bold px-4 py-1.5 rounded-full border border-gray-200 shadow-sm">
                        + 5 anak lainnya
                    </span>
                </div>
            </div>

            <div id="contentLeaderboard" class="hidden animate-slide-up">
                <div class="flex items-end justify-center gap-2 mb-6 h-52 mt-6" id="podiumContainer">
                    <div class="text-center w-full"><i class="fa-solid fa-spinner fa-spin text-amber-500 text-2xl"></i></div>
                </div>

                <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden mb-4">
                    <div class="bg-gray-50 px-4 py-3 border-b border-gray-100 flex items-center justify-between">
                        <h4 class="text-xs font-bold text-gray-700 uppercase tracking-widest"><i class="fa-solid fa-ranking-star text-amber-500 mr-1"></i> Top 5 Rata-rata</h4>
                    </div>
                    <div class="overflow-x-auto no-scrollbar">
                        <table class="w-full text-left border-collapse min-w-[300px]">
                            <thead>
                                <tr class="bg-white border-b border-gray-50 text-[9px] uppercase tracking-wider text-gray-400">
                                    <th class="p-3 font-bold">Nama</th>
                                    <th class="p-3 font-bold text-center">Tjw</th>
                                    <th class="p-3 font-bold text-center">Fqh</th>
                                    <th class="p-3 font-bold text-center">Thd</th>
                                    <th class="p-3 font-bold text-center">Hadir</th>
                                </tr>
                            </thead>
                            <tbody id="leaderboardTable" class="text-xs divide-y divide-gray-50">
                            </tbody>
                        </table>
                    </div>
                </div>
                <p class="text-center text-[9px] text-gray-400 italic mb-8">* Peringkat dihitung otomatis dari nilai kuesioner dan absensi.</p>
            </div>
        </section>
        
        <section class="mb-6">
            <div class="mt-8 mb-4 bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden relative z-20">
                <button onclick="toggleDangerZone()" class="w-full px-5 py-4 flex items-center justify-between bg-gray-50 hover:bg-gray-100 transition-colors active:scale-95">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 bg-gray-200 text-gray-500 rounded-xl flex items-center justify-center">
                            <i class="fa-solid fa-gear"></i>
                        </div>
                        <span class="text-xs font-bold text-gray-700 uppercase tracking-widest">Pengaturan Lanjutan</span>
                    </div>
                    <i id="dangerIcon" class="fa-solid fa-chevron-down text-gray-400 transition-transform duration-300"></i>
                </button>
                
                <div id="dangerContent" class="hidden px-5 py-4 border-t border-gray-100 bg-white">
                    <div class="bg-red-50 border border-red-100 rounded-2xl p-4">
                        <h4 class="text-sm font-bold text-red-600 mb-1"><i class="fa-solid fa-triangle-exclamation mr-1"></i> Zona Bahaya</h4>
                        <p class="text-[10px] text-red-500 leading-relaxed mb-4">Menghapus permanen seluruh data nilai, absen, tugas, dan kuesioner. Hanya nama siswa yang dipertahankan.</p>
                        <button onclick="openResetModal()" class="w-full py-3 bg-red-600 text-white text-xs font-bold rounded-xl shadow-lg shadow-red-600/20 active:scale-95 transition-all">
                            <i class="fa-solid fa-bomb mr-1"></i> Reset Tahun Ajaran
                        </button>
                    </div>
                </div>
            </div>
        </section> 
        
        <div id="modalReset" class="fixed inset-0 bg-black/80 z-[100] hidden items-center justify-center p-4 backdrop-blur-sm">
            <div class="bg-white w-full max-w-sm rounded-[2rem] p-6 shadow-2xl animate-slide-up relative overflow-hidden">
                <div class="w-16 h-16 bg-red-50 text-red-600 rounded-full flex items-center justify-center text-3xl mx-auto mb-4 border border-red-100">
                    <i class="fa-solid fa-shield-halved"></i>
                </div>
                <h3 class="font-black text-gray-800 text-lg mb-1 text-center">Verifikasi Keamanan</h3>
                <p class="text-[10px] text-gray-500 mb-5 leading-relaxed text-center">
                    Masukkan <b>Password Akun</b> Anda untuk mengonfirmasi reset data. Sistem akan otomatis mengunduh file backup JSON.
                </p>
                <div class="bg-gray-50 p-1.5 rounded-xl border border-gray-200 mb-6">
                    <input type="password" id="resetPasswordInput" placeholder="Password Anda..." class="w-full px-3 py-2.5 bg-transparent text-sm font-bold text-gray-800 focus:outline-none text-center tracking-widest">
                </div>
                
                <div class="flex gap-2">
                    <button onclick="closeResetModal()" class="flex-1 py-3.5 bg-gray-100 text-gray-500 text-xs font-bold rounded-xl active:scale-95 transition-all">Batal</button>
                    <button id="btnExecuteReset" class="flex-1 py-3.5 bg-red-600 text-white text-xs font-bold rounded-xl shadow-lg active:scale-95 transition-all disabled:opacity-50 disabled:cursor-not-allowed" disabled>Hapus Data</button>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL TUNGGAKAN -->
    <div id="modalNotDone" class="fixed inset-0 bg-black/60 z-[100] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-sm rounded-[2rem] p-6 shadow-2xl flex flex-col max-h-[85vh] animate-slide-up">
            <div class="text-center mb-3">
                <div class="w-14 h-14 bg-red-50 text-red-500 rounded-full flex items-center justify-center text-2xl mx-auto mb-2 border border-red-100 shadow-inner">
                    <i class="fa-solid fa-user-clock"></i>
                </div>
                <h3 class="font-black text-gray-800 text-lg">Daftar Tunggakan</h3>
            </div>
            
            <div class="flex gap-2 mb-4">
                <select id="modalFilterSubject" class="w-full text-xs bg-gray-50 border border-gray-200 text-gray-600 rounded-xl px-2 py-2 outline-none focus:ring-2 focus:ring-red-500 transition-all font-bold cursor-pointer">
                    <option value="">Semua Pelajaran</option>
                </select>
                <select id="modalFilterWeek" class="w-full text-xs bg-gray-50 border border-gray-200 text-gray-600 rounded-xl px-2 py-2 outline-none focus:ring-2 focus:ring-red-500 transition-all font-bold cursor-pointer">
                    <option value="">Semua Pertemuan</option>
                </select>
            </div>
            
            <div id="notDoneListContainer" class="flex-1 overflow-y-auto space-y-2 pr-1 mb-4 custom-scrollbar">
                <div class="text-center py-6"><i class="fa-solid fa-spinner fa-spin text-red-500"></i></div>
            </div>
    
            <button onclick="closeNotDoneModal()" class="w-full py-3.5 bg-red-500 hover:bg-red-600 text-white font-bold rounded-2xl active:scale-95 transition-all text-sm">
                Tutup
            </button>
        </div>
    </div>

    <!-- [BARU] MODAL NOTIFIKASI PR -->
    <div id="modalNotif" class="fixed inset-0 bg-black/60 z-[200] hidden items-end sm:items-center justify-center p-0 sm:p-4 backdrop-blur-sm transition-opacity opacity-0">
        <div class="bg-white w-full sm:max-w-sm rounded-t-[2rem] sm:rounded-[2rem] p-6 shadow-2xl flex flex-col h-[75vh] sm:h-[80vh] transform translate-y-full sm:translate-y-0 transition-transform duration-300" id="notifBox">
            <div class="flex justify-between items-center mb-4">
                <div class="flex items-center gap-2">
                    <div class="w-10 h-10 bg-indigo-100 text-indigo-600 rounded-full flex items-center justify-center">
                        <i class="fa-solid fa-bell"></i>
                    </div>
                    <h3 class="font-black text-gray-800 text-lg">Notifikasi PR</h3>
                </div>
                <button onclick="closeNotifModal()" class="w-8 h-8 bg-gray-100 text-gray-400 rounded-full flex items-center justify-center active:scale-95"><i class="fa-solid fa-xmark"></i></button>
            </div>
            
            <div class="flex justify-between items-center mb-4 pb-3 border-b border-gray-100">
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest"><span id="notifCountText">0</span> Pesan Baru</p>
                <button onclick="clearAllNotifs()" class="text-[10px] font-bold text-red-500 hover:text-red-600 bg-red-50 px-3 py-1.5 rounded-lg active:scale-95 transition-colors">
                    <i class="fa-solid fa-trash-can mr-1"></i> Hapus Semua
                </button>
            </div>

            <div id="notifListContainer" class="flex-1 overflow-y-auto space-y-3 no-scrollbar pb-6">
                <!-- List notif masuk kesini -->
                <div class="text-center py-10"><i class="fa-solid fa-spinner fa-spin text-indigo-500"></i></div>
            </div>
        </div>
    </div>

    <!-- [BARU] MODAL KONFIRMASI CUSTOM NOTIFIKASI -->
    <div id="modalConfirmNotif" class="fixed inset-0 bg-black/60 z-[9999] hidden items-center justify-center p-4 backdrop-blur-sm transition-opacity duration-300 opacity-0">
        <div class="bg-white w-full max-w-sm rounded-[2rem] p-6 shadow-2xl text-center transform scale-100 animate-bounce-short border-4 border-indigo-400" id="modalConfirmNotifBox">
            <div id="confirmNotifIconBox" class="w-20 h-20 bg-indigo-50 text-indigo-500 rounded-full flex items-center justify-center text-4xl mx-auto mb-4 border border-indigo-100 shadow-inner">
                <i class="fa-solid fa-bell-slash"></i>
            </div>
            <h3 id="confirmNotifTitle" class="font-black text-gray-800 text-xl mb-2">Hapus Notifikasi?</h3>
            <p id="confirmNotifMessage" class="text-sm text-gray-600 mb-6 leading-relaxed font-medium">Apakah Anda yakin?</p>
            <div class="flex gap-3">
                <button id="btnConfirmNotifCancel" class="flex-1 py-3.5 bg-gray-100 hover:bg-gray-200 text-gray-500 font-bold rounded-2xl active:scale-95 transition-all text-sm">Batal</button>
                <button id="btnConfirmNotifYes" class="flex-1 py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-2xl shadow-lg shadow-indigo-600/30 active:scale-95 transition-all text-sm">Ya, Hapus</button>
            </div>
        </div>
    </div>

    <Toast />
    <ModalAlert />
    <NavbarGuru activeMenu="home" />
</Layout>

<script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const token = localStorage.getItem('token');
    const userData = JSON.parse(localStorage.getItem('user') || '{}');
    
    let enrichedStudents = [];    
    let availableTasks = []; 

    if (!token) window.location.replace('/');

    const greetingEl = document.getElementById('greetingName');
    if (greetingEl) greetingEl.innerText = `Ahlan, Ustadz ${userData.username || ''}!`;

    // --- TAB SWITCHER LOGIC ---
    const tabList = document.getElementById('tabList');
    const tabLeader = document.getElementById('tabLeaderboard');
    const contentList = document.getElementById('contentList');
    const contentLeader = document.getElementById('contentLeaderboard');

    const activeTabClass = "flex-1 py-3 text-[10px] font-bold bg-white text-green-600 rounded-xl shadow-sm transition-all uppercase tracking-widest";
    const inactiveTabClass = "flex-1 py-3 text-[10px] font-bold text-gray-400 hover:text-gray-600 transition-all uppercase tracking-widest";
    
    tabList.onclick = () => {
        tabList.className = activeTabClass; tabLeader.className = inactiveTabClass;
        contentList.classList.replace('hidden', 'block');
        contentLeader.classList.replace('block', 'hidden');
    };
    tabLeader.onclick = () => {
        tabLeader.className = activeTabClass; tabList.className = inactiveTabClass;
        contentLeader.classList.replace('hidden', 'block'); contentList.classList.replace('block', 'hidden');
    };

    // ==============================================================
    // [UPDATE] LOGIKA NOTIFIKASI PR (GROUPING & AUTO-DELETE)
    // ==============================================================
    let notifications = [];

    // Fungsi Helper untuk Grouping Waktu
    const getTimeCategory = (dateString) => {
        const notifDate = new Date(dateString);
        const now = new Date();
        const diffMs = now - notifDate;
        const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
        const diffHours = Math.floor(diffMs / (1000 * 60 * 60));

        if (diffDays === 0 && now.getDate() === notifDate.getDate()) {
            if (diffHours < 12 && notifDate.getHours() < 12) return "Pagi Ini";
            if (diffHours < 12 && notifDate.getHours() >= 12 && notifDate.getHours() < 15) return "Siang Ini";
            if (diffHours < 12 && notifDate.getHours() >= 15 && notifDate.getHours() < 18) return "Sore Ini";
            if (diffHours < 12 && notifDate.getHours() >= 18) return "Malam Ini";
            return "Hari Ini";
        }
        if (diffDays === 1) return "Kemarin";
        if (diffDays > 1 && diffDays <= 7) return "Minggu Ini";
        return "Beberapa Minggu Lalu";
    };

    const loadNotifications = async (isFirstLoad = false) => {
        try {
            const res = await fetch(`${API_URL}/api/notifications`, { headers: { 'Authorization': `Bearer ${token}` }});
            const result = await res.json();
            notifications = result.data || [];
            
            // Logika Auto-Delete (Hanya jalan pas baru buka laci)
            if (!isFirstLoad) {
                const oldNotifs = notifications.filter(n => {
                    const diffDays = Math.floor((new Date() - new Date(n.created_at)) / (1000 * 60 * 60 * 24));
                    return diffDays > 7;
                });

                if (oldNotifs.length > 0) {
                    showConfirmNotif(
                        "Bersih-bersih Laci",
                        `Terdapat ${oldNotifs.length} notif yang sudah lewat dari seminggu. Mau dihapus biar laci rapi?`,
                        async () => {
                            // Hapus dari UI dulu
                            const oldIds = oldNotifs.map(n => n.id);
                            notifications = notifications.filter(n => !oldIds.includes(n.id));
                            updateNotifBadge();
                            renderNotifications();
                            // Hapus dari DB (asumsi lu bikin API bulk delete)
                            try {
                                await Promise.all(oldIds.map(id => fetch(`${API_URL}/api/notifications/${id}`, { method: 'DELETE', headers: { 'Authorization': `Bearer ${token}` }})));
                            } catch(e) {}
                        },
                        true // true = Kasih tau jangan dihapus kalau dia pencet Batal
                    );
                }
            }

            updateNotifBadge();
            renderNotifications();
        } catch (e) { console.error("Gagal load notif", e); }
    };

    const updateNotifBadge = () => {
        const badge = document.getElementById('notifBadge');
        const countText = document.getElementById('notifCountText');
        if (notifications.length > 0) {
            badge.innerText = notifications.length;
            badge.classList.remove('hidden');
            if (countText) countText.innerText = notifications.length;
        } else {
            badge.classList.add('hidden');
            if (countText) countText.innerText = '0';
        }
    }

    const renderNotifications = () => {
        const container = document.getElementById('notifListContainer');
        if (!container) return;

        if (notifications.length === 0) {
            container.innerHTML = `<div class="text-center py-10 flex flex-col items-center justify-center opacity-50"><i class="fa-regular fa-bell-slash text-5xl text-gray-300 mb-3"></i><p class="text-xs text-gray-500 font-bold">Belum ada notifikasi baru.</p></div>`;
            return;
        }

        // Grouping
        const grouped = {};
        notifications.forEach(notif => {
            const cat = getTimeCategory(notif.created_at);
            if (!grouped[cat]) grouped[cat] = [];
            grouped[cat].push(notif);
        });

        // Urutan render kategori
        const catOrder = ["Pagi Ini", "Siang Ini", "Sore Ini", "Malam Ini", "Hari Ini", "Kemarin", "Minggu Ini", "Beberapa Minggu Lalu"];

        container.innerHTML = catOrder.map(cat => {
            if (!grouped[cat] || grouped[cat].length === 0) return '';
            
            const listHtml = grouped[cat].map(notif => {
                const timeStr = new Date(notif.created_at).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
                return `
                <div class="bg-indigo-50/50 border border-indigo-100 p-3.5 rounded-2xl flex gap-3 relative group">
                    <div class="w-8 h-8 rounded-full bg-white shadow-sm flex items-center justify-center text-indigo-500 shrink-0 font-black text-xs border border-indigo-50">
                        <i class="fa-solid fa-check"></i>
                    </div>
                    <div class="flex-1 min-w-0 pr-6">
                        <p class="text-xs text-gray-700 leading-relaxed"><b class="text-indigo-700">${notif.student_name}</b> telah mengerjakan PR <b class="text-indigo-600 uppercase">${notif.subject}</b>.</p>
                        <p class="text-[9px] font-bold text-gray-400 mt-1.5 uppercase tracking-wider"><i class="fa-regular fa-clock"></i> ${timeStr}</p>
                    </div>
                    <button onclick="deleteNotif('${notif.id}')" class="absolute right-3 top-1/2 -translate-y-1/2 w-8 h-8 bg-white border border-red-100 text-red-400 hover:text-red-600 hover:bg-red-50 rounded-xl flex items-center justify-center transition-all opacity-100 sm:opacity-0 sm:group-hover:opacity-100 active:scale-95 shadow-sm">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
                `;
            }).join('');

            return `
                <div class="mb-4">
                    <h4 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 pl-1 border-b border-gray-100 pb-1">${cat}</h4>
                    <div class="space-y-2">
                        ${listHtml}
                    </div>
                </div>
            `;
        }).join('');
    };

    window.openNotifModal = () => {
        const modal = document.getElementById('modalNotif');
        const box = document.getElementById('notifBox');
        modal.classList.replace('hidden', 'flex');
        setTimeout(() => { 
            modal.classList.replace('opacity-0', 'opacity-100'); 
            box.classList.replace('translate-y-full', 'translate-y-0'); 
        }, 10);
        loadNotifications(false); // isFirstLoad = false (Cek auto-delete)
    };

    window.closeNotifModal = () => {
        const modal = document.getElementById('modalNotif');
        const box = document.getElementById('notifBox');
        modal.classList.replace('opacity-100', 'opacity-0');
        if (window.innerWidth < 640) box.classList.replace('translate-y-0', 'translate-y-full');
        setTimeout(() => modal.classList.replace('flex', 'hidden'), 300);
    };

    // --- MODAL KONFIRMASI CUSTOM NOTIF ---
    let notifConfirmCallback = null;
    let keepIfCancel = false;

    const showConfirmNotif = (title, message, onConfirm, warnIfCancel = false) => {
        document.getElementById('confirmNotifTitle').innerText = title;
        document.getElementById('confirmNotifMessage').innerText = message;
        notifConfirmCallback = onConfirm;
        keepIfCancel = warnIfCancel;
        
        const modal = document.getElementById('modalConfirmNotif');
        modal.classList.replace('hidden', 'flex');
        setTimeout(() => modal.classList.replace('opacity-0', 'opacity-100'), 10);
    };

    document.getElementById('btnConfirmNotifCancel').onclick = () => {
        const modal = document.getElementById('modalConfirmNotif');
        modal.classList.replace('opacity-100', 'opacity-0');
        setTimeout(() => modal.classList.replace('flex', 'hidden'), 300);
        notifConfirmCallback = null;
        if (keepIfCancel) {
            window.showToast?.('info', 'Notif Disimpan', 'Notif lama dipindahkan ke "Beberapa Minggu Lalu".');
        }
    };

    document.getElementById('btnConfirmNotifYes').onclick = () => {
        const modal = document.getElementById('modalConfirmNotif');
        modal.classList.replace('opacity-100', 'opacity-0');
        setTimeout(() => modal.classList.replace('flex', 'hidden'), 300);
        if (notifConfirmCallback) notifConfirmCallback();
    };

    window.deleteNotif = (id) => {
        showConfirmNotif('Hapus Notifikasi?', 'Notif ini akan dihapus permanen dari laci.', async () => {
            notifications = notifications.filter(n => n.id !== id);
            updateNotifBadge();
            renderNotifications();
            try { await fetch(`${API_URL}/api/notifications/${id}`, { method: 'DELETE', headers: { 'Authorization': `Bearer ${token}` }}); } catch (e) {}
        });
    };

    window.clearAllNotifs = () => {
        if (notifications.length === 0) return;
        showConfirmNotif('Hapus Semua?', 'Yakin mau hapus semua notifikasi? Laci akan kembali kosong.', async () => {
            notifications = [];
            updateNotifBadge();
            renderNotifications();
            try { await fetch(`${API_URL}/api/notifications/clear`, { method: 'DELETE', headers: { 'Authorization': `Bearer ${token}` }}); } catch (e) {}
        });
    };


    // ==============================================================
    // LOGIKA TUNGGAKAN TUGAS (GLOBAL & MODAL)
    // ==============================================================
    window.prLocksCache = {};
    const initFiltersAndTasks = async () => {
        try {
            const headers = { 'Authorization': `Bearer ${token}` };
            const res = await fetch(`${API_URL}/api/insights/filters`, { headers });
            
            if(res.ok) {
                const filterData = await res.json();
                availableTasks = filterData.data.available_tasks || [];
                const subjectsList = filterData.data.subjects || [];

                const locksPromises = subjectsList.map(s => 
                    fetch(`${API_URL}/api/onboarding/pr-locks/${s.toLowerCase()}`, { headers })
                    .then(r => r.json())
                    .catch(() => ({data: []}))
                );
                const locksResults = await Promise.all(locksPromises);
                
                subjectsList.forEach((s, i) => {
                    window.prLocksCache[s.toLowerCase()] = locksResults[i].data || [];
                });
                
                const subjSelect = document.getElementById('modalFilterSubject');
                const weekSelect = document.getElementById('modalFilterWeek');

                if (subjSelect) {
                    subjSelect.innerHTML = `<option value="">Semua Pelajaran</option>` + 
                        subjectsList.map(s => `<option value="${s.toLowerCase()}">${s}</option>`).join('');
                }
                if (weekSelect) {
                    weekSelect.innerHTML = `<option value="">Semua Pertemuan</option>` + 
                        (filterData.data.weeks || []).map(w => `<option value="${w}">Pert. ${w}</option>`).join('');
                }

                subjSelect?.addEventListener('change', renderNotDoneModalList);
                weekSelect?.addEventListener('change', renderNotDoneModalList);
            }
            
            calculateGlobalMissingTasks();
        } catch (e) { console.error("Gagal memuat filter dan task", e); }
    };

    const calculateGlobalMissingTasks = () => {
        enrichedStudents.forEach(student => {
            const completed = student.completed_tasks || [];
            student.missing_tasks = availableTasks.filter(available => 
                !completed.some(done => done.subject === available.subject && done.week === available.week)
            );
        });

        const laggingStudents = enrichedStudents.filter(s => s.missing_tasks.length > 0);
        const notDoneCountEl = document.getElementById('notDoneCount');
        if (notDoneCountEl) notDoneCountEl.innerText = laggingStudents.length;
    };

    const renderNotDoneModalList = () => {
        const subjFilter = document.getElementById('modalFilterSubject')?.value;
        const weekFilter = parseInt(document.getElementById('modalFilterWeek')?.value);
        const container = document.getElementById('notDoneListContainer');

        if (!container) return;

        const filteredStudents = enrichedStudents.filter(student => {
            if (!student.missing_tasks || student.missing_tasks.length === 0) return false;
            return student.missing_tasks.some(mt => {
                const matchSubj = subjFilter ? mt.subject.toLowerCase() === subjFilter : true;
                const matchWeek = weekFilter ? mt.week === weekFilter : true;
                return matchSubj && matchWeek;
            });
        });

        if (filteredStudents.length === 0) {
            container.innerHTML = `<p class="text-center py-10 text-xs text-gray-400 italic">Alhamdulillah, tidak ada tunggakan sesuai kriteria ini! 🎉</p>`;
            return;
        }

        container.innerHTML = filteredStudents.map(student => {
            const relevantMissing = student.missing_tasks.filter(mt => {
                const matchSubj = subjFilter ? mt.subject.toLowerCase() === subjFilter : true;
                const matchWeek = weekFilter ? mt.week === weekFilter : true;
                return matchSubj && matchWeek;
            });

            let badgesHtml = '';
            let wrapperClass = 'items-center';

            if (!subjFilter || !weekFilter) {
                const badges = relevantMissing.slice(0, 2).map(mt => {
                    const isPR = window.prLocksCache[mt.subject.toLowerCase()]?.includes(mt.week);
                    const prLabel = isPR 
                        ? `<span class="bg-indigo-500 text-white px-1 py-0.5 rounded-[4px] ml-1 flex items-center gap-0.5 shadow-sm"><i class="fa-solid fa-house-laptop text-[6px]"></i> PR</span>` 
                        : '';

                    return `<span class="flex items-center text-[8px] bg-red-100 text-red-600 px-1.5 py-0.5 rounded font-black uppercase tracking-widest border border-red-200">
                        ${mt.subject} (Pert ${mt.week})${prLabel}
                    </span>`;
                }).join('');
                
                const moreCount = relevantMissing.length > 2 ? `<span class="flex items-center text-[8px] bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded font-bold border border-gray-200">+${relevantMissing.length - 2}</span>` : '';
                
                badgesHtml = `<div class="flex flex-wrap gap-1 mt-1.5">${badges}${moreCount}</div>`;
                wrapperClass = 'items-start pt-0.5';
            }

            return `
                <div class="flex items-center justify-between p-3 rounded-2xl bg-gray-50 border border-gray-100 hover:border-red-200 hover:bg-red-50 transition-all cursor-pointer group" onclick="window.location.href='/student/${student.id}'">
                    <div class="flex ${wrapperClass} gap-3">
                        <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center font-bold text-xs text-gray-400 border border-gray-200 group-hover:border-red-200 overflow-hidden shadow-sm shrink-0">
                            ${student.photo_url ? `<img src="${student.photo_url}" class="w-full h-full object-cover">` : student.name.substring(0,2).toUpperCase()}
                        </div>
                        <div>
                            <span class="text-xs font-bold text-gray-700 group-hover:text-red-600 block leading-tight">${student.name}</span>
                            ${badgesHtml}
                        </div>
                    </div>
                    <i class="fa-solid fa-arrow-right text-[10px] text-gray-300 group-hover:text-red-400"></i>
                </div>
            `;
        }).join('');
    };

    window.openNotDoneModal = () => {
        const modal = document.getElementById('modalNotDone');
        if (modal) modal.classList.replace('hidden', 'flex');
        renderNotDoneModalList();
    };

    window.closeNotDoneModal = () => {
        const modal = document.getElementById('modalNotDone');
        if (modal) modal.classList.replace('flex', 'hidden');
    };

    // ==============================================================
    // FETCH DATA UTAMA
    // ==============================================================
    const fetchDashboardData = async () => {
        try {
            const headers = { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' };
            
            const [dashRes, enrichedRes] = await Promise.all([
                fetch(`${API_URL}/api/insights/dashboard`, { headers }),
                fetch(`${API_URL}/api/students/stats/enriched`, { headers }) 
            ]);

            if (dashRes.status === 401 || enrichedRes.status === 401) throw new Error('Sesi habis');

            const dashData = await dashRes.json();
            const enrichedData = await enrichedRes.json();

            enrichedStudents = enrichedData.data || [];

            const statStudentsEl = document.getElementById('statStudents');
            if (statStudentsEl) statStudentsEl.innerText = dashData.data.total_students || enrichedStudents.length || 0;
            
            const statExamsEl = document.getElementById('statExams');
            if (statExamsEl) statExamsEl.innerText = dashData.data.total_exams || 0;

            renderStudentList();
            renderLeaderboard();
            await initFiltersAndTasks();
            
            // [BARU] Panggil loadNotifications pas dashboard dimuat
            loadNotifications(true);

        } catch (error) {
            if (window.showToast) window.showToast('danger', 'Error', 'Gagal memuat data dashboard.');
            document.getElementById('studentList').innerHTML = '<div class="text-center py-6 text-red-500 text-xs font-bold">Gagal memuat.</div>';
            document.getElementById('podiumContainer').innerHTML = '<div class="text-center w-full text-red-500 text-xs font-bold">Gagal memuat.</div>';
        }
    };

    const renderStudentList = () => {
        const filterEl = document.getElementById('filterList');
        if (!filterEl) return;
        
        const filter = filterEl.value;
        const container = document.getElementById('studentList');
        const remContainer = document.getElementById('remainingStudentsContainer');
        const remText = document.getElementById('remainingStudentsText');
        
        if (enrichedStudents.length === 0) {
            container.innerHTML = `<div class="text-center py-10 bg-white rounded-3xl border border-gray-100 border-dashed"><i class="fa-solid fa-folder-open text-gray-200 text-5xl mb-3 block"></i><p class="text-gray-400 text-xs font-bold">Belum ada data Anak.</p></div>`;
            if (remContainer) remContainer.classList.add('hidden');
            return;
        }

        let sorted = [...enrichedStudents];
        if (filter === 'abjad') sorted.sort((a,b) => a.name.localeCompare(b.name));
        else if (filter === 'nilai') sorted.sort((a,b) => b.finalScore - a.finalScore);
        else if (filter === 'rajin') sorted.sort((a,b) => b.hadir - a.hadir);

        const top5 = sorted.slice(0, 5);
        container.innerHTML = top5.map((student, idx) => {
            const initials = student.name.substring(0, 2).toUpperCase();
            const avatarHtml = student.photo_url ? `<img src="${student.photo_url}" class="w-full h-full object-cover" alt="${student.name}" />` : initials;
            
            let detailBadge = '';
            if (filter === 'nilai') detailBadge = `<span class="bg-amber-100 text-amber-600 px-2 py-0.5 rounded text-[9px] font-bold ml-2"><i class="fa-solid fa-star text-[8px]"></i> Rata: ${student.finalScore}</span>`;
            else if (filter === 'rajin') detailBadge = `<span class="bg-blue-100 text-blue-600 px-2 py-0.5 rounded text-[9px] font-bold ml-2"><i class="fa-solid fa-calendar-check text-[8px]"></i> Hadir: ${student.hadir}x</span>`;

            return `
                <div class="bg-white p-4 rounded-2xl border border-gray-50 shadow-sm flex items-center justify-between active:scale-[0.98] transition-all cursor-pointer hover:border-green-200" onclick="window.location.href='/student/${student.id}'">
                    <div class="flex items-center gap-3">
                        <div class="relative">
                            <div class="w-12 h-12 bg-green-50 text-green-600 font-bold rounded-2xl flex items-center justify-center text-lg shadow-inner overflow-hidden">
                                ${avatarHtml}
                            </div>
                            ${filter !== 'abjad' ? `<div class="absolute -top-1 -left-1 w-5 h-5 bg-gray-800 text-white rounded-full flex items-center justify-center text-[9px] font-black border-2 border-white shadow-sm z-10">${idx + 1}</div>` : ''}
                        </div>
                        <div>
                            <h4 class="font-bold text-gray-800 text-sm truncate max-w-[150px]">${student.name}</h4>
                            <div class="flex items-center mt-0.5">
                                <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">${student.grade}</p>
                                ${detailBadge}
                            </div>
                        </div>
                    </div>
                    <div class="w-8 h-8 bg-gray-50 rounded-full flex items-center justify-center text-gray-300">
                        <i class="fa-solid fa-chevron-right text-[10px]"></i>
                    </div>
                </div>
            `;
        }).join('');

        if (remContainer && remText) {
            if (sorted.length > 5) {
                remText.innerText = `+ ${sorted.length - 5} anak lainnya`;
                remContainer.classList.remove('hidden');
            } else {
                remContainer.classList.add('hidden');
            }
        }
    };

    const filterListEl = document.getElementById('filterList');
    if (filterListEl) filterListEl.addEventListener('change', renderStudentList);

    const renderLeaderboard = () => {
        const podiumContainer = document.getElementById('podiumContainer');
        const tableBody = document.getElementById('leaderboardTable');

        if (!podiumContainer || !tableBody) return;

        if (enrichedStudents.length === 0) {
            podiumContainer.innerHTML = `<div class="text-center w-full"><p class="text-gray-400 text-xs font-bold">Belum ada data untuk Leaderboard.</p></div>`;
            return;
        }

        const ranked = [...enrichedStudents].sort((a,b) => b.finalScore - a.finalScore);
        const top5 = ranked.slice(0, 5);

        const generateAvatar = (student, colorClass) => {
            if(!student) return `<div class="w-12 h-12 rounded-full border-2 border-dashed border-gray-300 bg-gray-50"></div>`;
            
            const avatarHtml = student.photo_url 
                ? `<img src="${student.photo_url}" class="w-full h-full object-cover rounded-full" alt="Foto ${student.name}" />`
                : student.name.substring(0,2).toUpperCase();
                
            return `
                <div class="relative w-14 h-14 ${colorClass} rounded-full flex items-center justify-center font-black text-lg z-10 shadow-lg border-2 border-white cursor-pointer hover:-translate-y-1 transition-transform overflow-hidden" onclick="window.location.href='/student/${student.id}'">
                    ${avatarHtml}
                </div>
                <p class="text-[9px] font-bold mt-1 text-gray-700 truncate w-16 text-center capitalize">${student.name.split(' ')[0]}</p>
                <p class="text-[8px] font-black text-amber-500"><i class="fa-solid fa-star"></i> ${student.finalScore}</p>
            `;
        }

        podiumContainer.innerHTML = `
            <div class="flex flex-col items-center">
                ${generateAvatar(top5[1], 'bg-slate-200 text-slate-600')}
                <div class="w-20 h-20 bg-gradient-to-t from-slate-300 to-slate-100 rounded-t-xl shadow-inner flex items-start justify-center pt-2 mt-2 border border-slate-200">
                    <span class="text-slate-400 font-black text-2xl drop-shadow-sm">2</span>
                </div>
            </div>
            
            <div class="flex flex-col items-center">
                <i class="fa-solid fa-crown text-amber-400 text-3xl mb-1 animate-bounce drop-shadow-md"></i>
                ${generateAvatar(top5[0], 'bg-amber-100 text-amber-600 border-4 border-amber-300 w-16 h-16 text-2xl')}
                <div class="w-24 h-28 bg-gradient-to-t from-amber-400 to-amber-200 rounded-t-xl shadow-inner flex items-start justify-center pt-2 mt-2 border border-amber-300">
                    <span class="text-amber-600 font-black text-4xl drop-shadow-sm">1</span>
                </div>
            </div>

            <div class="flex flex-col items-center">
                ${generateAvatar(top5[2], 'bg-orange-100 text-orange-600')}
                <div class="w-20 h-16 bg-gradient-to-t from-orange-300 to-orange-100 rounded-t-xl shadow-inner flex items-start justify-center pt-2 mt-2 border border-orange-200">
                    <span class="text-orange-400 font-black text-xl drop-shadow-sm">3</span>
                </div>
            </div>
        `;
        
        tableBody.innerHTML = top5.map((s, i) => {
            const miniAvatar = s.photo_url 
                ? `<img src="${s.photo_url}" class="w-full h-full object-cover" />`
                : `<span class="text-[10px]">${s.name.substring(0,2).toUpperCase()}</span>`;

            return `
            <tr class="hover:bg-gray-50 transition-colors cursor-pointer" onclick="window.location.href='/student/${s.id}'">
                <td class="p-3">
                    <div class="flex items-center gap-2">
                        <div class="w-6 h-6 rounded-md bg-gray-100 flex items-center justify-center font-black text-gray-500 overflow-hidden shadow-inner flex-shrink-0">
                            ${miniAvatar}
                        </div>
                        <div>
                            <p class="font-bold text-gray-800 truncate max-w-[90px]">${s.name.split(' ')[0]}</p>
                            <p class="text-[8px] font-bold text-gray-400 uppercase">${s.grade}</p>
                        </div>
                    </div>
                </td>
                <td class="p-3 text-center font-bold text-green-600">${s.t_avg > 0 ? s.t_avg : '-'}</td>
                <td class="p-3 text-center font-bold text-blue-600">${s.f_avg > 0 ? s.f_avg : '-'}</td>
                <td class="p-3 text-center font-bold text-purple-600">${s.th_avg > 0 ? s.th_avg : '-'}</td>
                <td class="p-3 text-center font-black text-gray-700 bg-gray-50/50">${s.hadir}x</td>
            </tr>
            `;
        }).join('');
    };

    fetchDashboardData();

    document.getElementById('btnLogout')?.addEventListener('click', () => {
        localStorage.clear();
        window.location.replace('/');
    });
    
    // --- CEK ABSENSI ---
    const checkAbsensiStatus = async () => {
        try {
            const res = await fetch(`${API_URL}/api/attendances/today-status`, { headers: { 'Authorization': `Bearer ${token}` }});
            const result = await res.json();
            
            const statusText = document.getElementById('absensiStatusText');
            const pulseBox = document.getElementById('absensiPulse');

            if (!statusText || !pulseBox) return;
            
            if (result.isDone) {
                statusText.innerText = "Selesai (Sudah Absen)";
                statusText.classList.replace('text-gray-400', 'text-green-500');
            } else {
                statusText.innerText = result.isMandatory ? "Wajib Absen Sekarang!" : "Absensi Sunnah";
                if (result.isMandatory) {
                    statusText.classList.replace('text-gray-400', 'text-red-500');
                    pulseBox.classList.replace('border-transparent', 'border-red-500/50');
                    pulseBox.classList.add('animate-pulse');
                }
            }
        } catch (e) {}
    };
    checkAbsensiStatus();


    // ================================================================
    // LOGIKA PENGATURAN LANJUTAN & RESET TAHUN AJARAN
    // ================================================================
    window.toggleDangerZone = () => {
        const content = document.getElementById('dangerContent');
        const icon = document.getElementById('dangerIcon');
        if(content) content.classList.toggle('hidden');
        if(icon) icon.classList.toggle('rotate-180');
    };

    const resetPassInput = document.getElementById('resetPasswordInput');
    const btnExecuteReset = document.getElementById('btnExecuteReset');
    
    window.openResetModal = () => {
        if (resetPassInput) resetPassInput.value = '';
        if (btnExecuteReset) { btnExecuteReset.disabled = true; btnExecuteReset.innerHTML = 'Hapus Data'; }
        document.getElementById('modalReset')?.classList.replace('hidden', 'flex');
        setTimeout(() => { if (resetPassInput) resetPassInput.focus() }, 100);
    };
    
    window.closeResetModal = () => { document.getElementById('modalReset')?.classList.replace('flex', 'hidden'); };

    if (resetPassInput && btnExecuteReset) {
        resetPassInput.addEventListener('input', (e) => { btnExecuteReset.disabled = e.target.value.trim().length < 3; });
        
        btnExecuteReset.onclick = async () => {
            const password = resetPassInput.value.trim();
            if (!password) return;
            if (!confirm('Peringatan Terakhir: Anda yakin ingin menghapus SELURUH data transaksi?')) return;

            btnExecuteReset.disabled = true;
            btnExecuteReset.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Memproses...';

            try {
                const res = await fetch(`${API_URL}/api/admin/factory-reset`, {
                    method: 'POST',
                    headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                    body: JSON.stringify({ password: password }) 
                });
                const result = await res.json();

                if (res.ok) {
                    const blob = new Blob([JSON.stringify(result.backup, null, 2)], { type: "application/json" });
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url; a.download = `Backup_YukNgaji_${new Date().toISOString().split('T')[0]}.json`;
                    document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);

                    window.showToast?.('success', 'Reset Selesai', 'Data dihapus dan dibackup.');
                    closeResetModal(); setTimeout(() => window.location.reload(), 2000);
                } else throw new Error(result.message);
            } catch (err) {
                window.showToast?.('danger', 'Akses Ditolak', err.message || 'Terjadi kesalahan.');
                btnExecuteReset.innerHTML = 'Hapus Data'; btnExecuteReset.disabled = true; resetPassInput.value = ''; resetPassInput.focus();
            }
        };
    }
</script>

