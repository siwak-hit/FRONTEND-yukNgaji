---
// src/pages/wrapped/[id].astro
import Layout from '../../layouts/Layout.astro';
import Toast from '../../components/Toast.astro';
---

<Layout title="Catatan Ngajiku - yukNgaji">
  <!-- Container Utama (Target Download Keseluruhan) -->
  <div class="fixed inset-0 bg-slate-50 overflow-hidden flex flex-col font-sans select-none pattern-grid" id="wrappedContainer">
    
    <!-- Elemen Dekoratif Mengambang -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden z-0">
        <div class="absolute top-10 left-10 w-24 h-24 bg-yellow-300 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-float"></div>
        <div class="absolute top-40 right-10 w-32 h-32 bg-pink-300 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-float" style="animation-delay: 2s;"></div>
        <div class="absolute -bottom-10 left-20 w-40 h-40 bg-blue-300 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-float" style="animation-delay: 4s;"></div>
    </div>

    <!-- Header UI (Progress Bar & Action Buttons) -->
    <div class="absolute top-4 inset-x-4 z-50 flex flex-col gap-3" id="headerUI">
        <!-- Progress Bar -->
        <div class="flex gap-1.5 w-full transition-opacity duration-300" id="progressContainer"></div>
        
        <!-- Tombol Aksi -->
        <div class="flex justify-between items-center px-1" id="actionContainer">
            <button onclick="closeWrapped()" class="w-8 h-8 bg-white/90 backdrop-blur border border-slate-200 rounded-full flex items-center justify-center text-slate-600 hover:bg-slate-100 transition-colors shadow-sm">
                <i class="fa-solid fa-xmark"></i>
            </button>
            <button onclick="downloadCurrentSlide()" class="hidden bg-white/90 backdrop-blur border border-indigo-200 text-indigo-600 px-3 py-1.5 rounded-full text-[10px] font-black uppercase tracking-wider hover:bg-indigo-50 transition-colors shadow-sm items-center gap-1.5" id="btnDownload">
                <i class="fa-solid fa-download"></i> Simpan
            </button>
        </div>
    </div>

    <!-- Area Klik Tersembunyi (Prev/Next) -->
    <div class="absolute inset-y-0 left-0 w-1/3 z-30 cursor-pointer" onclick="prevSlide()" id="clickPrev"></div>
    <div class="absolute inset-y-0 right-0 w-2/3 z-30 cursor-pointer" onclick="nextSlide()" id="clickNext"></div>

    <!-- WRAPPED SLIDES -->
    <div id="slidesWrapper" class="relative w-full h-full flex items-center justify-center p-6 z-20 pt-20 pb-20">
        
        <!-- SLIDE 0: INTRO -->
        <div class="wrapped-slide hidden flex-col items-center justify-center text-center w-full max-w-sm h-full relative" data-index="0">
            <div class="bg-white/70 backdrop-blur-md border-2 border-indigo-100 p-8 rounded-[2rem] w-full shadow-xl relative animate-fade-in-up">
                <div class="absolute -top-6 -right-6 text-5xl animate-bounce" style="animation-duration: 2s;">🎒</div>
                <div class="absolute -bottom-4 -left-4 text-4xl animate-bounce" style="animation-duration: 2.5s; animation-delay: 0.5s;">✏️</div>
                <h2 id="s0_greeting" class="text-sm font-black text-indigo-400 mb-2 tracking-widest uppercase">Halo...</h2>
                <h1 id="s0_name" class="text-4xl font-black text-slate-800 mb-6 capitalize leading-tight">Nama Siswa</h1>
                <div class="bg-indigo-50 border border-indigo-100 rounded-xl p-4 inline-block">
                    <p id="s0_title" class="text-lg font-black text-indigo-600">Ini Perjalanan Ngajimu!</p>
                </div>
            </div>
            <p class="mt-8 text-[10px] font-bold text-slate-400 uppercase tracking-widest animate-pulse">Ketuk untuk mulai <i class="fa-solid fa-hand-pointer ml-1"></i></p>
        </div>

        <!-- SLIDE 1: NARASI 1 (Waktu Cepat Berlalu) -->
        <div class="wrapped-slide hidden flex-col items-center justify-center text-center w-full max-w-sm h-full relative" data-index="1">
            <div class="text-6xl mb-6 animate-pop-in">⏳</div>
            <h2 id="s1_title" class="text-3xl font-black text-slate-800 mb-4 animate-fade-in-up">Gak Kerasa Ya...</h2>
            <p id="s1_desc1" class="text-lg text-slate-600 font-bold leading-relaxed animate-fade-in-up" style="animation-delay: 0.3s">Waktu cepet banget berlalunya.</p>
            <p id="s1_desc2" class="text-lg text-slate-600 font-bold leading-relaxed mt-2 animate-fade-in-up" style="animation-delay: 0.6s">Kemarin rasanya baru mulai belajar iqro...</p>
        </div>

        <!-- SLIDE 2: NARASI 2 (Perjuangan) -->
        <div class="wrapped-slide hidden flex-col items-center justify-center text-center w-full max-w-sm h-full relative" data-index="2">
            <div class="text-6xl mb-6 animate-pop-in">💪</div>
            <h2 id="s2_title" class="text-3xl font-black text-slate-800 mb-4 animate-fade-in-up">Ujian Udah Beres!</h2>
            <p id="s2_desc1" class="text-base text-slate-600 font-bold leading-relaxed bg-white/60 p-6 rounded-3xl border border-slate-200 animate-fade-in-up shadow-sm" style="animation-delay: 0.3s">
                Pasti capek ya ngerjain tugas, ngapalin ayat, nahan ngantuk pas subuh. Tapi kamu hebat banget bisa lewatin semuanya!
            </p>
        </div>

        <!-- SLIDE 3: NARASI 3 (Pesan Guru) -->
        <div class="wrapped-slide hidden flex-col items-center justify-center text-center w-full max-w-sm h-full relative" data-index="3">
            <div class="text-6xl mb-6 animate-pop-in">💌</div>
            <h2 id="s3_title" class="text-3xl font-black text-slate-800 mb-4 animate-fade-in-up">Pesan Ustadz/ah</h2>
            <p id="s3_desc1" class="text-base text-indigo-700 font-black leading-relaxed bg-indigo-100 p-6 rounded-3xl border border-indigo-200 animate-fade-in-up shadow-sm" style="animation-delay: 0.3s">
                "Terima kasih sudah berjuang keras! Ilmu yang kamu pelajari ini bakal jadi penerang jalanmu nanti."
            </p>
            <p class="mt-6 text-[10px] font-bold text-slate-400 uppercase tracking-widest animate-fade-in-up" style="animation-delay: 0.9s">Mari kita lihat rapormu! <i class="fa-solid fa-arrow-right ml-1"></i></p>
        </div>

        <!-- SLIDE 4: ABSENSI -->
        <div class="wrapped-slide hidden flex-col items-center justify-center text-center w-full max-w-sm h-full relative" data-index="4">
            <div class="w-20 h-20 bg-amber-100 text-amber-500 rounded-full flex items-center justify-center text-4xl mb-6 shadow-inner animate-pop-in border-4 border-white">
                <i class="fa-solid fa-calendar-check"></i>
            </div>
            <h2 id="s4_title" class="text-2xl font-black text-slate-800 mb-2 animate-fade-in-up" style="animation-delay: 0.2s">Si Paling Rajin!</h2>
            <p id="s4_desc1" class="text-xs text-slate-500 font-bold mb-6 animate-fade-in-up" style="animation-delay: 0.3s">Kamu sudah hadir sebanyak</p>
            <div class="bg-white border-4 border-amber-200 p-8 rounded-[2rem] w-full shadow-lg transform rotate-2 animate-fade-in-up relative" style="animation-delay: 0.4s">
                <div class="absolute -top-3 -left-3 w-6 h-6 bg-amber-400 rounded-full shadow-sm"></div>
                <p class="text-7xl font-black text-amber-500 mb-2 leading-none"><span id="s4_hadir">0</span><span class="text-3xl text-amber-300 ml-1">x</span></p>
                <p id="s4_desc2" class="text-[11px] text-amber-700 font-bold">Luar biasa! Pertahankan terus ya!</p>
            </div>
        </div>

        <!-- SLIDE 5: HAFALAN -->
        <div class="wrapped-slide hidden flex-col items-center justify-center text-center w-full max-w-sm h-full relative" data-index="5">
            <div class="w-20 h-20 bg-emerald-100 text-emerald-500 rounded-full flex items-center justify-center text-4xl mb-6 shadow-inner animate-pop-in border-4 border-white">
                <i class="fa-solid fa-book-open"></i>
            </div>
            <h2 id="s5_title" class="text-2xl font-black text-slate-800 mb-2 animate-fade-in-up" style="animation-delay: 0.2s">Penghafal Quran!</h2>
            <p id="s5_desc1" class="text-xs text-slate-500 font-bold mb-6 animate-fade-in-up" style="animation-delay: 0.3s">Setoran hafalanmu sudah sampai di:</p>
            <div class="bg-emerald-500 text-white p-8 rounded-[2rem] w-full shadow-xl transform -rotate-1 animate-fade-in-up relative" style="animation-delay: 0.4s">
                <div class="absolute -bottom-3 -right-3 w-8 h-8 bg-emerald-300 rounded-full shadow-sm opacity-50"></div>
                <p id="s5_surah" class="text-3xl font-black mb-1">Juz 30</p>
                <div class="inline-block bg-white/20 px-3 py-1 rounded-lg mt-2">
                    <p id="s5_ayah" class="text-sm font-bold uppercase tracking-widest text-emerald-50">Ayat 0</p>
                </div>
            </div>
        </div>

        <!-- SLIDE 6: GAMIFIKASI -->
        <div class="wrapped-slide hidden flex-col items-center justify-center text-center w-full max-w-sm h-full relative" data-index="6">
            <div class="w-full bg-white border-2 border-indigo-100 p-6 rounded-[2rem] shadow-xl animate-fade-in-up" id="gamificationContainer">
                <h2 id="s6_title" class="text-2xl font-black text-slate-800 mb-1">Si Sultan Koin!</h2>
                <p id="s6_desc1" class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-4">Total Kekayaanmu:</p>
                
                <div class="flex items-center justify-center gap-3 mb-6 animate-pop-in" style="animation-delay: 0.2s">
                    <i class="fa-solid fa-coins text-4xl text-yellow-500"></i>
                    <span id="s6_poin" class="text-6xl font-black text-indigo-600">0</span>
                </div>
                
                <div class="grid grid-cols-2 gap-3 animate-fade-in-up" style="animation-delay: 0.4s">
                    <div class="bg-indigo-50 border border-indigo-100 p-3 rounded-2xl flex flex-col items-center">
                        <i class="fa-solid fa-cart-shopping text-indigo-400 text-xl mb-1"></i>
                        <p class="text-[8px] text-slate-400 font-black uppercase tracking-widest">Item Favorit</p>
                        <p id="s6_fav_item" class="text-xs font-black text-indigo-700 leading-tight mt-1">Perisai 🛡️</p>
                    </div>
                    <div class="bg-red-50 border border-red-100 p-3 rounded-2xl flex flex-col items-center">
                        <i class="fa-solid fa-crosshairs text-red-400 text-xl mb-1"></i>
                        <p class="text-[8px] text-slate-400 font-black uppercase tracking-widest">Korban Serangan</p>
                        <p id="s6_fav_target" class="text-xs font-black text-red-700 leading-tight mt-1 capitalize line-clamp-1">Teman</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- SLIDE 7: GALERI BENTO -->
        <div class="wrapped-slide hidden flex-col items-center justify-center w-full max-w-sm h-full relative" data-index="7">
            <div class="text-center w-full mb-4">
                <h2 id="s7_title" class="text-2xl font-black text-slate-800 mb-1 animate-fade-in-up">Wajah Bersejarah</h2>
                <p id="s7_desc1" class="text-xs text-slate-500 font-bold animate-fade-in-up" style="animation-delay: 0.2s">Rekaman diam-diam ustadz! 📸</p>
            </div>
            
            <div id="bentoGallery" class="w-full bg-white p-3 rounded-3xl shadow-lg border border-slate-200 animate-fade-in-up" style="animation-delay: 0.4s">
                <div class="grid grid-cols-3 grid-rows-3 gap-2 w-full aspect-[4/5]" id="bentoGrid">
                    <div class="col-span-3 row-span-3 flex items-center justify-center bg-slate-100 rounded-xl"><i class="fa-solid fa-spinner fa-spin text-slate-400 text-2xl"></i></div>
                </div>
            </div>

            <!-- Tombol Lanjut (Muncul cuma di slide galeri) -->
            <button onclick="nextSlide()" id="btnNextGallery" class="mt-6 bg-indigo-600 text-white font-black px-6 py-3 rounded-full shadow-[0_4px_0_#4f46e5] active:translate-y-[4px] active:shadow-none transition-all animate-pop-in hidden" style="animation-delay: 0.6s">
                Lanjut <i class="fa-solid fa-arrow-right ml-1"></i>
            </button>
        </div>

        <!-- SLIDE 8: AUDIO (Grand Finale) -->
        <div class="wrapped-slide hidden flex-col items-center justify-center text-center w-full max-w-sm h-full relative" data-index="8">
            <div class="w-24 h-24 bg-gradient-to-tr from-indigo-400 to-purple-500 rounded-full flex items-center justify-center text-4xl mb-6 shadow-xl shadow-indigo-200 animate-bounce relative z-10 border-4 border-white">
                <i class="fa-solid fa-microphone-lines text-white"></i>
            </div>
            
            <div class="bg-white border-2 border-indigo-100 p-6 rounded-[2rem] shadow-xl relative z-10 w-full animate-fade-in-up">
                <h2 id="s8_title" class="text-2xl font-black text-slate-800 mb-2">Suara Emasmu!</h2>
                <p id="s8_desc1" class="text-[10px] text-slate-500 font-bold mb-6 leading-relaxed">Dan hari ini, kamu menutup ujian dengan indah. Dengerin lagi rekaman tartilmu...</p>
                
                <div class="bg-indigo-50 border border-indigo-100 p-3 rounded-2xl mb-2">
                    <audio id="finalAudio" controls class="w-full rounded-lg"></audio>
                </div>
            </div>
            
            <button onclick="closeWrapped()" class="mt-8 relative z-10 bg-indigo-600 text-white font-black px-8 py-4 rounded-2xl shadow-[0_6px_0_#4f46e5] active:translate-y-[6px] active:shadow-none transition-all animate-pop-in" style="animation-delay: 0.5s">
                Tutup Catatan <i class="fa-solid fa-check ml-1"></i>
            </button>
        </div>

    </div>
  </div>

  <!-- MODAL PHOTO VIEWER -->
  <div id="photoViewerModal" class="fixed inset-0 z-[600] hidden items-center justify-center p-4 bg-slate-900/95 backdrop-blur-sm transition-opacity">
      <button onclick="closePhotoViewer()" class="absolute top-6 right-6 w-10 h-10 bg-white/20 rounded-full text-white flex items-center justify-center hover:bg-white/30"><i class="fa-solid fa-xmark"></i></button>
      <div class="w-full max-w-md bg-white rounded-2xl p-2 shadow-2xl relative">
          <img id="viewerImage" src="" class="w-full h-auto max-h-[70vh] object-contain rounded-xl bg-slate-100" crossorigin="anonymous">
          <button onclick="downloadSinglePhoto()" class="absolute bottom-6 left-1/2 -translate-x-1/2 bg-indigo-600 text-white px-6 py-3 rounded-full font-black text-sm shadow-lg flex items-center gap-2 hover:bg-indigo-700 active:scale-95">
              <i class="fa-solid fa-download"></i> Simpan Foto
          </button>
      </div>
  </div>

  <Toast />
</Layout>

<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js" is:inline></script>
<!-- Library html-to-image (Support Tailwind & JPG) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html-to-image/1.11.11/html-to-image.min.js" is:inline></script>

<script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const token = localStorage.getItem('token');
    const studentId = window.location.pathname.split('/').pop();
    const urlParams = new URLSearchParams(window.location.search);
    const isPreview = urlParams.get('preview') === 'true';

    const WRAPPED_COPY = {
        s0: { greeting: "Halo...", title: "Ini Perjalanan Ngajimu!" },
        s1: { title: "Gak Kerasa Ya...", desc1: "Waktu cepet banget berlalunya.", desc2: "Kemarin rasanya baru mulai belajar iqro..." },
        s2: { title: "Ujian Udah Beres!", desc1: "Pasti capek ngerjain tugas, ngapalin ayat. Tapi kamu hebat bisa lewatin semuanya!" },
        s3: { title: "Pesan Ustadz/ah", desc1: "\"Terima kasih sudah berjuang keras! Ilmu yang kamu pelajari ini bakal jadi penerang jalanmu nanti.\"" },
        s4: { title: "Si Paling Rajin!", desc1: "Kamu sudah hadir sebanyak", desc2: "Luar biasa! Pertahankan terus ya!" },
        s5: { title: "Penghafal Quran!", desc1: "Setoran hafalanmu sudah sampai di:" },
        s6: { title: "Si Sultan Koin!", desc1: "Total Kekayaanmu:", favItem: "Item Favorit", favTarget: "Korban Serangan" },
        s7: { title: "Wajah Bersejarah", desc1: "Rekaman diam-diam ustadz! 📸" },
        s8: { title: "Suara Emasmu!", desc1: "Dan hari ini, kamu menutup ujian dengan indah. Dengerin lagi rekaman tartilmu..." }
    };

    let currentSlide = 0;
    const totalSlides = 9; 
    let slideTimers = []; 
    const SLIDE_DURATION = 6000; 

    const base64Audio = sessionStorage.getItem('easterEggAudio');
    
    const initData = async () => {
        try {
            // Setup Text
            for(let i=0; i<=8; i++) {
                if(WRAPPED_COPY[`s${i}`]) {
                    Object.keys(WRAPPED_COPY[`s${i}`]).forEach(key => {
                        const el = document.getElementById(`s${i}_${key}`);
                        if(el) el.innerText = WRAPPED_COPY[`s${i}`][key];
                    });
                }
            }

            if (isPreview) {
                document.getElementById('s0_name').innerText = "Siswa Teladan";
                document.getElementById('s4_hadir').innerText = "45";
                document.getElementById('s5_surah').innerText = "Juz 30";
                document.getElementById('s5_ayah').innerText = "Ayat 15";
                document.getElementById('s6_poin').innerText = "5200";
                document.getElementById('s6_fav_item').innerText = "Pedang Serang ⚔️";
                document.getElementById('s6_fav_target').innerText = "John Doe";
                
                // Pake Dummy Image yang AMAN DARI CORS
                const dummyImages = [
                    "https://dummyimage.com/400x400/e2e8f0/64748b&text=Muka+Tegang",
                    "https://dummyimage.com/400x400/cbd5e1/475569&text=Fokus+Ujian",
                    "https://dummyimage.com/400x400/94a3b8/334155&text=Ngantuk",
                    "https://dummyimage.com/400x400/64748b/1e293b&text=Santuy"
                ];
                renderBentoGrid(dummyImages);
                setupAudioPreview(base64Audio); 
            } else {
                const stdRes = await fetch(`${API_URL}/api/students/${studentId}`, { headers: { 'Authorization': `Bearer ${token}` }});
                const stdData = (await stdRes.json()).data;
                document.getElementById('s0_name').innerText = stdData.name;
                document.getElementById('s6_poin').innerText = stdData.poin || 0;
                document.getElementById('s5_surah').innerText = "Juz 30"; 
                document.getElementById('s5_ayah').innerText = `Ayat ${stdData.current_ayah || 0}`;

                try {
                    const logsRes = await fetch(`${API_URL}/api/students/${studentId}/point-history?days=all&limit=100`, { headers: { 'Authorization': `Bearer ${token}` }});
                    const logsData = (await logsRes.json()).data || [];
                    
                    let itemsCount = { 'Perisai 🛡️': 0, 'Pedang Serang ⚔️': 0, 'Double Score ✨': 0, 'Extra Life 💖': 0 };
                    let targetsCount = {};

                    logsData.forEach(log => {
                        if(log.icon === '🛍️') {
                            if(log.title.includes('Perisai')) itemsCount['Perisai 🛡️']++;
                            else if(log.title.includes('Serang')) itemsCount['Pedang Serang ⚔️']++;
                            else if(log.title.includes('Double')) itemsCount['Double Score ✨']++;
                            else itemsCount['Extra Life 💖']++;
                        }
                        if(log.icon === '🔥' && log.title.includes('mencuri poin dari')) {
                            const match = log.title.match(/<strong>(.*?)<\/strong>/);
                            if(match && match[1]) {
                                const tName = match[1];
                                targetsCount[tName] = (targetsCount[tName] || 0) + 1;
                            }
                        }
                    });

                    let favItem = Object.keys(itemsCount).reduce((a, b) => itemsCount[a] > itemsCount[b] ? a : b);
                    if(itemsCount[favItem] === 0) favItem = "Belum Ada";
                    let favTarget = Object.keys(targetsCount).length > 0 ? Object.keys(targetsCount).reduce((a, b) => targetsCount[a] > targetsCount[b] ? a : b) : "Cinta Damai 🕊️";

                    document.getElementById('s6_fav_item').innerText = favItem;
                    document.getElementById('s6_fav_target').innerText = favTarget;
                } catch(e) { console.error("Gagal load gamifikasi"); }

                try {
                    const attRes = await fetch(`${API_URL}/api/students/${studentId}/attendance`, { headers: { 'Authorization': `Bearer ${token}` }});
                    const attData = (await attRes.json()).data;
                    document.getElementById('s4_hadir').innerText = attData.stats.hadir || 0;
                } catch(e) { console.error("Gagal load absen"); }

                try {
                    const [galReq, satpamReq] = await Promise.all([
                        fetch(`${API_URL}/api/students/${studentId}/gallery`, { headers: { 'Authorization': `Bearer ${token}` }}).then(r=>r.json()).catch(()=>({data:[]})),
                        fetch(`${API_URL}/api/students/${studentId}/satpam-logs`, { headers: { 'Authorization': `Bearer ${token}` }}).then(r=>r.json()).catch(()=>({data:[]}))
                    ]);
                    
                    const galPhotos = (galReq.data||[]).map(i => i.image_url);
                    const satpamPhotos = (satpamReq.data||[]).map(i => i.photo_url);
                    
                    let allPhotos = [...galPhotos, ...satpamPhotos];
                    if(allPhotos.length === 0) allPhotos = ["https://dummyimage.com/400x400/f1f5f9/94a3b8&text=Belum+Ada+Foto"];
                    renderBentoGrid(allPhotos);
                } catch(e) { console.error("Gagal load gallery"); renderBentoGrid(["https://dummyimage.com/400x400/fee2e2/ef4444&text=Error"]);}

                setupAudioPreview(base64Audio);
            }

            initBars();
            showSlide(0);

        } catch (error) {
            console.error(error);
            window.showToast?.('danger', 'Error', 'Gagal memuat catatan Ngaji.');
        }
    };

    const setupAudioPreview = (base64String) => {
        const audioEl = document.getElementById('finalAudio');
        if (base64String) {
            audioEl.src = base64String;
        } else {
            document.getElementById('s8_desc1').innerText = "Ups, rekamannya belum ada atau tidak tersimpan.";
            audioEl.parentElement.classList.add('hidden');
        }
    };

    const renderBentoGrid = (images) => {
        const grid = document.getElementById('bentoGrid');
        grid.innerHTML = ''; 
        const pool = images.slice(0, 5);
        
        pool.forEach((url, i) => {
            let gridClass = "col-span-1 row-span-1";
            if(pool.length >= 3) {
                if(i === 0) gridClass = "col-span-2 row-span-2";
                else if(i === 1 || i === 2) gridClass = "col-span-1 row-span-1";
                else if(i === 3) gridClass = "col-span-2 row-span-1";
            } else if (pool.length === 1) {
                gridClass = "col-span-3 row-span-3";
            }

            grid.innerHTML += `
                <div class="${gridClass} relative bg-slate-100 rounded-2xl overflow-hidden shadow-sm border border-slate-200 cursor-pointer group" onclick="openPhotoViewer('${url}')">
                    <img src="${url}" crossorigin="anonymous" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110" />
                    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors flex items-center justify-center">
                        <i class="fa-solid fa-expand text-white opacity-0 group-hover:opacity-100 text-xl transition-opacity"></i>
                    </div>
                </div>
            `;
        });
    };

    const initBars = () => {
        const pCont = document.getElementById('progressContainer');
        pCont.innerHTML = '';
        for(let i=0; i<totalSlides; i++) {
            pCont.innerHTML += `
                <div class="flex-1 h-1.5 bg-slate-200/50 rounded-full overflow-hidden cursor-pointer" onclick="jumpToSlide(${i})">
                    <div id="bar-${i}" class="h-full bg-indigo-500 w-0 transition-none"></div>
                </div>
            `;
        }
    };

    const resetBars = () => {
        for(let i=0; i<totalSlides; i++) {
            const bar = document.getElementById(`bar-${i}`);
            bar.style.transition = 'none';
            if (i < currentSlide) bar.style.width = '100%';
            else bar.style.width = '0%';
        }
    };

    const animateBar = (index) => {
        const bar = document.getElementById(`bar-${index}`);
        setTimeout(() => {
            bar.style.transition = `width ${SLIDE_DURATION}ms linear`;
            bar.style.width = '100%';
        }, 50); 
    };

    const clearAllTimers = () => {
        slideTimers.forEach(t => clearTimeout(t));
        slideTimers = [];
        const audioEl = document.getElementById('finalAudio');
        if(audioEl && !audioEl.paused) audioEl.pause();
    };

    const shootConfetti = () => {
        if(typeof confetti !== 'undefined') {
            confetti({ particleCount: 50, spread: 60, origin: { y: 0.8 }, colors: ['#6366f1', '#f59e0b', '#10b981', '#f43f5e'] });
        }
    };

    window.jumpToSlide = (index) => {
        if(event) event.stopPropagation(); 
        showSlide(index);
    };

    const showSlide = (index) => {
        if (index < 0 || index >= totalSlides) {
            if(index >= totalSlides) closeWrapped();
            return;
        }

        clearAllTimers();
        currentSlide = index;
        
        const slides = document.querySelectorAll('.wrapped-slide');
        slides.forEach(s => {
            s.classList.replace('flex', 'hidden');
            const animatedElems = s.querySelectorAll('.animate-fade-in-up, .animate-pop-in');
            animatedElems.forEach(el => { el.style.animation = 'none'; el.offsetHeight; el.style.animation = null; });
        });

        slides[index].classList.replace('hidden', 'flex');
        shootConfetti(); 
        resetBars();
        
        const btnDownload = document.getElementById('btnDownload');
        const progressContainer = document.getElementById('progressContainer');
        const clickAreaNext = document.getElementById('clickNext');
        const clickAreaPrev = document.getElementById('clickPrev');

        // Mengatur Visibilitas Tombol Download (Hanya di Slide 1-7)
        if (index === 0 || index === 8) {
            btnDownload.classList.replace('flex', 'hidden');
        } else {
            btnDownload.classList.replace('hidden', 'flex');
        }

        // Logika Slide 7 (Galeri Bento)
        if (index === 7) {
            progressContainer.classList.add('opacity-0', 'pointer-events-none'); 
            document.getElementById('btnNextGallery').classList.remove('hidden'); 
            clickAreaNext.classList.add('hidden'); 
            clickAreaPrev.classList.add('hidden'); 
            return; // Matikan Auto-Next
        } else {
            progressContainer.classList.remove('opacity-0', 'pointer-events-none');
            document.getElementById('btnNextGallery').classList.add('hidden');
            clickAreaNext.classList.remove('hidden');
            clickAreaPrev.classList.remove('hidden');
        }

        // Logika Slide 8 (Audio Final)
        if (index === 8) {
            const audioEl = document.getElementById('finalAudio');
            if (audioEl && !audioEl.parentElement.classList.contains('hidden') && audioEl.src) {
                audioEl.play().catch(e => console.log("Auto-play diblok browser."));
                audioEl.onloadedmetadata = () => {
                    const durationMs = audioEl.duration * 1000;
                    document.getElementById(`bar-${index}`).style.transition = `width ${durationMs}ms linear`;
                    document.getElementById(`bar-${index}`).style.width = '100%';
                };
                audioEl.onended = () => { slideTimers.push(setTimeout(() => nextSlide(), 1000)); };
                return; 
            }
        }

        animateBar(index);
        slideTimers.push(setTimeout(() => nextSlide(), SLIDE_DURATION));
    };

    window.nextSlide = () => { showSlide(currentSlide + 1); };
    window.prevSlide = () => { showSlide(currentSlide - 1); };

    window.closeWrapped = () => {
        if (isPreview) window.location.href = `/exams`; 
        else window.location.replace('/students'); 
    };

    // ========================================================
    // PHOTO VIEWER & DOWNLOAD LOGIC (JPG Format & CORS Fix)
    // ========================================================
    window.openPhotoViewer = (url) => {
        if(event) event.stopPropagation(); 
        document.getElementById('viewerImage').src = url;
        document.getElementById('photoViewerModal').classList.replace('hidden', 'flex');
    };

    window.closePhotoViewer = () => {
        document.getElementById('photoViewerModal').classList.replace('flex', 'hidden');
    };

    window.downloadSinglePhoto = async () => {
        const url = document.getElementById('viewerImage').src;
        try {
            const response = await fetch(url);
            const blob = await response.blob();
            const blobUrl = window.URL.createObjectURL(blob);
            
            const link = document.createElement('a');
            link.download = `Ngaji_Memori_${Date.now()}.jpg`;
            link.href = blobUrl;
            link.click();
            window.URL.revokeObjectURL(blobUrl);
            window.showToast?.('success', 'Tersimpan!', 'Foto berhasil diunduh.');
        } catch(e) {
            const link = document.createElement('a');
            link.href = url;
            link.target = '_blank';
            link.download = `Ngaji_Memori_${Date.now()}.jpg`;
            link.click();
        }
    };

    // FUNGSI SAKTI DOWNLOAD KESELURUHAN BODY (JPG)
    window.downloadCurrentSlide = async () => {
        if(event) event.stopPropagation();
        
        const btn = document.getElementById('btnDownload');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Tunggu...';
        btn.disabled = true;

        // 1. Sembunyikan elemen UI Header dan Area Klik biar gak ikut kefoto
        const headerUI = document.getElementById('headerUI');
        const clickNext = document.getElementById('clickNext');
        const clickPrev = document.getElementById('clickPrev');
        const btnNextGallery = document.getElementById('btnNextGallery');

        headerUI.style.display = 'none';
        clickNext.style.display = 'none';
        clickPrev.style.display = 'none';
        if(btnNextGallery) btnNextGallery.style.display = 'none';

        try {
            // Target seluruh layar/body biar background dan pernak-perniknya dapet
            const elementToCapture = document.getElementById('wrappedContainer');
            
            // Konversi jadi JPG (Kualitas 90%, skip pembacaan font eksternal biar gak error CSSRules)
            const dataUrl = await htmlToImage.toJpeg(elementToCapture, {
                quality: 0.9,
                pixelRatio: 2,
                skipFonts: true, 
                backgroundColor: '#f8fafc' // Warna slate-50
            });

            const link = document.createElement('a');
            link.download = `Ngaji_Catatan_${currentSlide}_${Date.now()}.jpg`;
            link.href = dataUrl;
            link.click();
            
            window.showToast?.('success', 'Tersimpan!', 'Catatan (JPG) berhasil diunduh.');
        } catch (error) {
            console.error("Gagal render gambar:", error);
            window.showToast?.('danger', 'Ups!', 'Gagal menyimpan gambar.');
        } finally {
            // 2. Kembalikan lagi elemen UI
            headerUI.style.display = 'flex';
            clickNext.style.display = 'block';
            clickPrev.style.display = 'block';
            if(btnNextGallery && currentSlide === 7) btnNextGallery.style.display = 'block';
            
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    };

    initData();
</script>

