                // Jika "Iya", cek apakah bantuan sudah pernah dipakai
                const isHelpUsed = localStorage.getItem('cat_help_used') === 'true';
                
                if (!isHelpUsed) {
                    // Miaw menawarkan berhenti waktu
                    setCatChat('large', "Miaw miaw... Mau aku bantu berhentiin waktunya sebentar?", 'FREEZE');
                } else {
                    // Kalau bantuan sudah habis tapi dia ngeluh susah
                    setCatChat('large', "Yah, bantuan aku udah abis hari ini. Semangat ya, kamu pasti bisa!", null);
                    setTimeout(() => { 
                        bubble.style.opacity = "0";
                        retreatCat(); 
                    }, 2500);
                }
            } else {
                // Jika "Tidak" mengalami kesusahan (Langsung Balik)
                setCatChat('small', "Wih sombong... Yaudah kerjain sendiri sana!", null);
                setTimeout(() => { 
                    bubble.style.opacity = "0";
                    retreatCat(); 
                }, 1500);
            }
            return; // Keluar dari fungsi agar tidak menjalankan logika di bawahnya
        }

        // --- LOGIKA FREEZE WAKTU (Lanjutan dari pilihan "Iya") ---
        bubble.style.opacity = "0"; // Sembunyikan bubble segera setelah pilihan diklik

        if (actionType === 'FREEZE' && isYes) {
            localStorage.setItem('cat_help_used', 'true');
            triggerTimeFreeze();
            setCatChat('large', "Ok, aku tahan waktunya... Cepetan kerjain!");
        } else if (actionType === 'FREEZE' && !isYes) {
            setCatChat('small', "Cih, ditawarin bantuan malah nolak. Bye!", null);
        }

        // Apapun pilihannya di tahap kedua, kucing akan mundur
        setTimeout(() => {
            retreatCat();
        }, 1500);
    };

    
    const retreatCat = () => {
        catState = "RETREATING";
        applyCatState("RETREATING");
        
        const mascotContainer = document.getElementById('mascot-container');
        mascotContainer.style.transition = 'right 2s ease-in-out, transform 2s ease-in-out';
        
        // Reset posisi kembali ke pojok, ukuran normal, dan tidak melayang
        mascotContainer.style.right = '20px';
        mascotContainer.style.transform = 'translateX(0) translateY(0) scale(1)';

        setTimeout(() => {
            catState = "IDLE_EDGE";
            applyCatState("IDLE_EDGE");
            startRandomChats(); 
        }, CAT_CONFIG.RETREATING.lottieDuration);
    };

    // -----------------------------------------------------------------------
    // 🧊 EFEK WAKTU BEKU
    // -----------------------------------------------------------------------
    const triggerTimeFreeze = () => {
        window.isTimeStoppedByCat = true;
        const timerCont = document.getElementById('timerContainer');
        
        if (timerCont) {
            timerCont.style.background = "#3b82f6"; // Warna biru es
            timerCont.style.color = "white";
            timerCont.style.borderColor = "#2563eb";
            document.getElementById('timerText').innerText = "BEKU!";
        }

        // Waktu beku selama 7 detik
        setTimeout(() => {
            window.isTimeStoppedByCat = false;
            
            if (timerCont) {
                timerCont.style.background = "";
                timerCont.style.color = "";
                timerCont.style.borderColor = "";
                updateTimerUI(); // Paksa render ulang timer yang asli
            }

            // Setelah waktu beku selesai, kucing minta maaf dari posisinya di pojok
            if (catState === "IDLE_EDGE") {
                setCatChat('small', "Maaf ya, aku hanya bisa membantu itu saja... Lanjutkan!");
            }
        }, 7000);
    };

// 🧪 LOGIKA RADAR TABRAKAN (Efek Kesenggol)
    const checkCollision = () => {
        if (catState !== "TOWARD") return; 
        const catEl = document.getElementById('mascot-lottie');
        const catRect = catEl.getBoundingClientRect();
        
        // Target elemen yang bisa kena senggol (tombol jawaban & card soal)
        const targets = document.querySelectorAll('.opt-btn, .question-card'); 
        
        targets.forEach(el => {
            const rect = el.getBoundingClientRect();
            if (!(catRect.right < rect.left || catRect.left > rect.right || catRect.bottom < rect.top || catRect.top > rect.bottom)) {
                if (!el.classList.contains('bumped-element')) {
                    el.classList.add('bumped-element');
                    // Reset animasi agar bisa kena senggol lagi nanti
                    setTimeout(() => el.classList.remove('bumped-element'), 500); 
                }
            }
        });
    };

    // 🕒 LOGIKA KONFIRMASI WAKTU BEKU
    window.confirmTimeStop = (choice) => {
        const bubble = document.getElementById('mascot-chat');
        bubble.style.opacity = "0";

        if (choice) {
            window.isTimeStoppedByCat = true;
            timeStopUsed = true; // Kunci agar tidak muncul lagi
            
            const timerCont = document.getElementById('timerContainer');
            if (timerCont) {
                timerCont.style.background = "#6366f1";
                timerCont.style.color = "white";
                document.getElementById('timerText').innerText = "BEKU!";
            }

            setCatChat('large', "Ok, aku tahan waktunya... Cepetan kerjain!");

            setTimeout(() => {
                window.isTimeStoppedByCat = false;
                if (timerCont) {
                    timerCont.style.background = "";
                    timerCont.style.color = "";
                }
                setCatChat('large', "Dah ya, aku balik dulu!");
                // Langsung mundur setelah waktu habis
                setTimeout(() => { handleCatClick(); }, 1500);
            }, 5000);
        } else {
            // Jika pilih "Gak", langsung mundur
            handleCatClick();
        }
    };

    // TRIGGER MUNCUL AWAL
    const checkCatTrigger = () => {
        // Cegah kucing nongol sendiri kalau statusnya lagi diusir
        if (isCatDismissed) return; 

        if (catState === "HIDDEN" && currentIndex === 1) {
            catState = "ENTERING";
            applyCatState("ENTERING");
            
            const mascotContainer = document.getElementById('mascot-container');
            
            // Kucing ngomong di awal saat jalan
            setCatChat('small', "Miaw... miaw... miaw...");
            
            // Langsung geser masuk (tidak ada delay)
            mascotContainer.style.transition = 'right 2s ease-out, transform 2s ease-out';
            mascotContainer.style.right = '20px';
            mascotContainer.style.transform = 'translateX(0) scale(1)';
            
            // Tunggu sampai Lottie beres
            setTimeout(() => {
                catState = "IDLE_EDGE";
                applyCatState("IDLE_EDGE");
                
                setCatChat('small', "Miaw miaw... (kelihatannya ada yang lagi serius nih)");

                setTimeout(() => {
                    startRandomChats();
                    resetMiawTimer();
                }, 5000);

            }, CAT_CONFIG.ENTERING.lottieDuration); 
        }
    };

// -----------------------------------------------------------------------
    // ⏱️ LOGIKA CHAT RANDOM (IDLE) - 10 s/d 15 DETIK
    // -----------------------------------------------------------------------
    const startRandomChats = () => {
        clearInterval(chatTimer);
        const randomInterval = Math.floor(Math.random() * 5000) + 10000; // 10.000ms - 15.000ms

        chatTimer = setInterval(() => {
            if (catState === "IDLE_EDGE") {
                // Kalimat diobrolin kucing secara acak, dibuat lebih natural dan ngawasin
                const idlePhrases = [
                    "Jangan tegang, pelan-pelan aja bacanya... miaw",
                    "Miaw... Kalau ragu, coba ditandai dulu aja soalnya.",
                    "Semangat! Aku perhatiin dari sini ya 👀",
                    "Hoaaam... Aku agak ngantuk nungguin kamu kelar.",
                    "Tarik napas perlahan... Jangan lupa berkedip! miaw",
                    "Soalnya lumayan menjebak ya? Hihi... miaw.",
                    "Fokus, fokus... Waktu terus berjalan lho."
                ];
                
                setCatChat('small', idlePhrases[Math.floor(Math.random() * idlePhrases.length)]);
            }
        }, randomInterval);
    };

// -----------------------------------------------------------------------
    // 🐾 INTERAKSI KLIK KUCING
    // -----------------------------------------------------------------------
    window.handleCatClick = () => {
        resetMiawTimer();
        if (catState !== "IDLE_EDGE") return;
        catState = "TOWARD";
        clearInterval(chatTimer);
        applyCatState("TOWARD");

        const mascotContainer = document.getElementById('mascot-container');
        mascotContainer.style.transition = 'right 1.8s ease-in-out, transform 1.8s ease-in-out';
        mascotContainer.style.right = '50%';
        mascotContainer.style.transform = 'translateX(50%) translateY(-40px) scale(2)';

        setTimeout(() => {
            catState = "CLOSEUP";
            applyCatState("CLOSEUP");
            
            // Pertanyaan pembuka
            setCatChat('large', "Miaw... Apakah kamu mengalami kesusahan?", 'ASK_DIFFICULTY');
        }, CAT_CONFIG.TOWARD.lottieDuration);
    };
    if (typeof window.navigate === 'function') {
        const originalNavigate = window.navigate;
        window.navigate = (dir) => {
            originalNavigate(dir);
            checkCatTrigger();
        };
    }

    init();
</script>

<style is:global>
