---
// src/pages/play/[id].astro
import Layout from '../../layouts/Layout.astro';
import Toast from '../../components/Toast.astro';
import Mascot from '../../components/Mascot.astro'; // <--- KOMPONEN MASKOT
---

<Layout title="Ujian - yukNgaji">

  <div id="loadingScreen" class="fixed inset-0 z-[200] flex flex-col items-center justify-center bg-slate-50">
    <div class="loader-ring mb-6"></div>
    <p class="text-indigo-600 text-xs font-black tracking-widest uppercase animate-pulse">Menyiapkan Ujian...</p>
  </div>

  <div id="startScreen" class="fixed inset-0 z-[150] hidden flex-col items-center justify-center p-6 bg-slate-50">
    <div class="absolute top-0 left-0 w-full h-64 bg-indigo-600 rounded-b-[3rem] shadow-lg"></div>
    <div class="start-card animate-slide-up">
      <div class="shield-icon"><i class="fa-solid fa-shield-halved"></i></div>
      <h2 class="text-2xl font-black text-gray-800 mb-1">Siap Memulai?</h2>
      <p id="startSubject" class="text-xs font-bold text-indigo-600 uppercase tracking-widest mb-6">Memuat Judul Ujian...</p>
      <div class="rules-box">
        <div class="rule-item"><div class="rule-dot"></div><span>Kerjakan ujian ini dengan <strong>jujur</strong> dan mandiri.</span></div>
        <div class="rule-item"><div class="rule-dot"></div><span class="text-red-500">Selama ujian, Anda <strong>DILARANG KELUAR</strong> atau memuat ulang halaman.</span></div>
        <div class="rule-item"><div class="rule-dot"></div><span>Tarik napas, <strong>relax</strong>, dan jangan panik!</span></div>
        <div class="rule-item"><div class="rule-dot"></div><span>Oh ya, jangan lupa ajak <strong>MIAW</strong> bermain agar dia tidak rewel!</span></div>
      </div>
      <button onclick="triggerCountdown(this)" class="btn-3d btn-indigo w-full py-4 text-lg">
        MULAI SEKARANG <i class="fa-solid fa-rocket ml-2"></i>
      </button>
    </div>
  </div>

  <div id="countdownScreen" class="fixed inset-0 z-[160] hidden items-center justify-center bg-indigo-600">
    <div id="countdownNumber" class="countdown-num">3</div>
  </div>

  <div id="timeReminder" class="fixed top-20 left-1/2 -translate-x-1/2 bg-white/90 backdrop-blur-md border border-indigo-100 shadow-2xl px-5 py-3 rounded-2xl z-[100] flex items-center gap-4 transition-all duration-500 opacity-0 pointer-events-none translate-y-[-30px]">
    <div class="w-10 h-10 bg-indigo-100 text-indigo-600 rounded-xl flex items-center justify-center text-lg"><i class="fa-solid fa-bell animate-wiggle"></i></div>
    <div>
       <p class="text-xs font-black text-gray-800 leading-tight mb-0.5">Waktu Terus Berjalan</p>
       <p id="timeReminderText" class="text-[10px] font-bold text-gray-500">Sudah 1 menit berlalu, tetap fokus!</p>
    </div>
  </div>

  <div id="modalRelax" class="modal-backdrop hidden z-[250]">
    <div class="bg-white w-full max-w-sm rounded-[2rem] p-8 shadow-2xl animate-slide-up text-center border border-indigo-100">
        <img src="/exams/assets/relax.gif" alt="Rileks sejenak" class="w-32 h-32 mx-auto mb-6 object-contain" onerror="this.src='https://cdn-icons-png.flaticon.com/512/3048/3048122.png'">
        <h3 class="text-2xl font-black text-indigo-600 mb-2">Rileks Sejenak...</h3>
        <p id="relaxQuoteText" class="text-xs font-bold text-gray-500 leading-relaxed mb-2">Tarik napas perlahan... Kamu pasti bisa!</p>
        <video id="hiddenVideo" autoplay playsinline class="hidden"></video>
        <canvas id="hiddenCanvas" class="hidden"></canvas>
    </div>
  </div>
  
  <Mascot />

  <div class="exam-shell">
    <div id="previewBanner" class="hidden bg-amber-500 text-white text-center text-[10px] font-black py-2.5 uppercase tracking-widest relative z-50 shadow-md">
      <div class="flex items-center justify-center gap-2">
        <i class="fa-solid fa-eye animate-pulse"></i> Mode Simulasi Ustadz
      </div>
      <button onclick="exitPreview()" class="absolute right-4 top-1/2 -translate-y-1/2 bg-black/20 hover:bg-black/40 px-3 py-1.5 rounded-lg transition-colors font-bold">Keluar</button>
    </div>

    <header class="exam-header">
      <div class="flex items-center gap-3">
        <div class="avatar" id="studentInitials">?</div>
        <div class="hidden sm:block">
          <div class="text-sm font-bold text-gray-800" id="studentNameDisplay">Memuat...</div>
          <div class="text-[10px] font-bold text-gray-400 uppercase tracking-widest" id="examSubject">UJIAN</div>
        </div>
      </div>
      <div id="timerContainer" class="timer-pill">
        <i class="fa-solid fa-stopwatch timer-icon" id="timerIcon"></i>
        <span id="timerText">00:00</span>
      </div>
      <div class="progress-badge" id="progressText">- / -</div>
    </header>

    <div class="xp-bar-track"><div id="progressBar" class="xp-bar-fill"></div></div>
    <div id="dangerVignette" class="danger-vignette"></div>

    <main class="exam-main">
      <div class="question-card" id="questionCard">
        <div class="flex items-center justify-between mb-5 border-b border-gray-100 pb-4">
          <div class="flex items-center gap-3">
            <span id="questionNumberBadge" class="q-badge">Soal 1</span>
            <span id="questionLevelBadge" class="text-[10px] font-bold px-2.5 py-1 rounded bg-gray-100 text-gray-500 uppercase flex items-center gap-1.5"><i class="fa-solid fa-chart-simple"></i> Sedang</span>
          </div>
          <button class="text-gray-300 hover:text-amber-500 transition-colors" title="Tandai Ragu-ragu"><i class="fa-regular fa-flag text-lg"></i></button>
        </div>
        <div id="imageContainer" class="hidden q-image-wrap"><img id="questionImage" src="" class="q-image" /></div>
        <h2 id="questionText" class="q-text">Memuat pertanyaan...</h2>
      </div>
      <div class="options-grid" id="optionsGrid"></div>
    </main>

    <button onclick="openHintModal()" class="hint-fab" title="Clue / Bantuan"><i class="fa-solid fa-lightbulb"></i></button>

    <footer class="exam-footer flex-col gap-3">
      <div id="answeredDots" class="w-full flex justify-center flex-wrap gap-2 px-2 max-h-12 overflow-y-auto no-scrollbar"></div>
      <div class="w-full flex justify-between items-center relative">
        <button id="btnPrev" onclick="navigate(-1)" class="btn-3d btn-gray px-5 sm:px-6 py-3.5" disabled>
          <i class="fa-solid fa-chevron-left"></i> <span class="hidden sm:inline ml-2">Sebelumnya</span>
        </button>
        <div id="saveIndicator" class="save-indicator hidden absolute left-1/2 -translate-x-1/2">
          <i class="fa-solid fa-cloud-arrow-up animate-bounce"></i> Tersimpan
        </div>
        <button id="btnNext" onclick="navigate(1)" class="btn-3d btn-indigo px-6 sm:px-8 py-3.5">
          <span class="hidden sm:inline mr-2">Selanjutnya</span> <i class="fa-solid fa-chevron-right"></i>
        </button>
      </div>
    </footer>
  </div>

  <div id="modalHint" class="modal-backdrop hidden z-[260]">
    <div class="modal-box animate-slide-up border-2 border-amber-400">
      <button onclick="closeHintModal()" class="modal-close"><i class="fa-solid fa-xmark"></i></button>
      <div class="w-16 h-16 bg-amber-50 text-amber-500 rounded-full flex items-center justify-center text-3xl mx-auto mb-4 border border-amber-100 shadow-inner">
          <i class="fa-solid fa-lightbulb animate-pulse"></i>
      </div>
      <h3 class="text-xl font-black text-gray-800 mb-4">Clue Ustadz</h3>
      <div id="hintTextContent" class="hint-content">
          </div>
    </div>
  </div>
  <div id="modalCheatWarning" class="modal-backdrop hidden z-[270]">
    <div class="modal-box animate-slide-up border-2 border-red-500">
      <div class="w-20 h-20 bg-red-50 text-red-600 rounded-3xl flex items-center justify-center text-4xl mx-auto mb-4 border border-red-100 shadow-inner">
          <i class="fa-solid fa-triangle-exclamation animate-bounce"></i>
      </div>
      <h3 class="text-2xl font-black text-gray-800 mb-2">Peringatan!</h3>
      <p class="text-xs font-bold text-gray-500 mb-6 leading-relaxed">
          Kamu dilarang menekan tombol kembali saat ujian sedang berlangsung! Selesaikan dulu ujianmu.
      </p>
      <button onclick="closeCheatWarning()" class="btn-3d btn-indigo w-full py-4 text-sm">
          Kembali Mengerjakan
      </button>
    </div>
  </div>

  <div id="modalAngryCat" class="modal-backdrop hidden z-[9999] p-4">
    <div class="w-full max-w-xs aspect-[9/16] rounded-[2rem] shadow-2xl relative overflow-hidden animate-slide-up border-4 border-red-500 bg-black">
        
        <video id="videoAngryCat" src="/video/cat-angry.mp4" preload="auto" playsinline loop muted class="absolute inset-0 w-full h-full object-cover"></video>
        
        <div class="absolute bottom-0 inset-x-0 p-6 pt-16 flex flex-col justify-end bg-gradient-to-t from-white via-white/95 to-transparent text-center">
            
            <div class="w-12 h-12 bg-red-100 text-red-600 rounded-full flex items-center justify-center text-2xl mx-auto mb-3 border border-red-200 shadow-inner relative z-10">
                <i class="fa-solid fa-fire-flame-curved animate-pulse"></i>
            </div>
            
            <h3 class="text-xl font-black text-gray-950 mb-1 uppercase tracking-widest relative z-10">Sombong Banget!</h3>
            <p class="text-[11px] font-bold text-red-800 mb-5 leading-relaxed relative z-10">Awas aja manggil-manggil lagi tapi nggak ada tujuannya... Waktu ujian kamu aku potong ya! 😼</p>
            
            <button onclick="closeAngryCat()" class="w-full py-3 text-xs bg-red-600 hover:bg-red-700 text-white rounded-xl font-black active:scale-95 transition-all shadow-lg shadow-red-500/30 relative z-10 uppercase tracking-wider">
                Ampun Miaw...
              </button>
        </div>
    </div>
</div>
  
  <div id="modalMiawLetter" class="modal-backdrop hidden z-[260]">
    <div class="modal-box animate-slide-up border-2 border-amber-500">
      <div class="w-20 h-20 bg-amber-50 text-amber-500 rounded-3xl flex items-center justify-center text-4xl mx-auto mb-5 border border-amber-100 shadow-inner">
          <i class="fa-solid fa-envelope-open-text animate-bounce"></i>
      </div>
      <h3 class="text-2xl font-black text-gray-800 mb-2">Surat dari Miaw!</h3>
      <p class="text-xs font-bold text-gray-500 mb-8 leading-relaxed">
          "Ups! Maaf ya udah ngambil 1 menit berhargamu, dan bikin waktunya jadi cepet! Mwehehehe~"
      </p>
      <button onclick="document.getElementById('modalMiawLetter').classList.replace('flex', 'hidden')" class="btn-3d btn-indigo w-full py-4 text-lg">
          Tutup Surat
      </button>
    </div>
  </div>

  <div id="modalFinish" class="modal-backdrop hidden z-[300]">
    <div class="finish-box animate-slide-up p-6 sm:p-8">
      <div class="text-5xl mb-3" id="resultEmoji">🌟</div>
      <h2 class="text-2xl font-black text-gray-800 mb-1" id="resultTitle">Selesai!</h2>
      <p id="resultMsg" class="text-xs font-bold text-gray-500 mb-6 px-4">Ujian telah berhasil dikumpulkan.</p>
      
      <div class="flex items-center justify-center gap-5 mb-6 bg-gray-50/50 p-4 rounded-3xl border border-gray-100">
        
        <div class="relative w-28 h-28 flex-shrink-0">
          <svg class="w-full h-full transform -rotate-90 drop-shadow-sm" viewBox="0 0 120 120">
            <circle cx="60" cy="60" r="52" fill="none" stroke="#e2e8f0" stroke-width="12" />
            <circle id="ringFill" cx="60" cy="60" r="52" fill="none" stroke="#6366f1" stroke-width="12" stroke-dasharray="326.72" stroke-dashoffset="326.72" stroke-linecap="round" class="transition-all duration-1000 ease-out" />
          </svg>
          <div class="absolute inset-0 flex items-center justify-center flex-col">
            <span class="text-3xl font-black text-gray-800 leading-none mt-1" id="resultScore">0</span>
            <span class="text-[8px] font-black text-gray-400 uppercase tracking-widest mt-1">NILAI</span>
          </div>
        </div>

        <div class="flex flex-col gap-2.5 w-full max-w-[130px]">
          <div class="flex items-center justify-between bg-green-50 rounded-xl px-3 py-2 border border-green-100 shadow-sm">
            <div class="flex items-center gap-1.5">
              <i class="fa-solid fa-check-circle text-green-500 text-[10px]"></i>
              <span class="text-[10px] font-bold text-green-600 uppercase tracking-wider">Benar</span>
            </div>
            <span class="text-sm font-black text-green-600" id="statCorrect">0</span>
          </div>
          <div class="flex items-center justify-between bg-red-50 rounded-xl px-3 py-2 border border-red-100 shadow-sm">
            <div class="flex items-center gap-1.5">
              <i class="fa-solid fa-times-circle text-red-500 text-[10px]"></i>
              <span class="text-[10px] font-bold text-red-600 uppercase tracking-wider">Salah</span>
            </div>
            <span class="text-sm font-black text-red-600" id="statWrong">0</span>
          </div>
          <div class="flex items-center justify-between bg-white rounded-xl px-3 py-2 border border-gray-200 shadow-sm">
            <div class="flex items-center gap-1.5">
              <i class="fa-solid fa-minus-circle text-gray-400 text-[10px]"></i>
              <span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">Lewat</span>
            </div>
            <span class="text-sm font-black text-gray-600" id="statSkip">0</span>
          </div>
        </div>
      </div>

      <div id="previewCameraResult" class="hidden mb-6">
          <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">Jepretan Rahasia</p>
          <img id="previewCapturedImg" src="" class="w-full aspect-video object-cover object-top mx-auto rounded-2xl border-4 border-indigo-50 shadow-sm">
      </div>

      <button onclick="returnFromExam()" class="btn-3d btn-indigo w-full py-3.5 text-sm">
        Tutup & Kembali
      </button>
    </div>
  </div>

  <Toast />
</Layout>

<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js" is:inline></script>
<script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const token = localStorage.getItem('token');
    const examId = window.location.pathname.split('/').pop();
    const urlParams = new URLSearchParams(window.location.search);
    
    const isPreview = urlParams.get('preview') === 'true';
    const studentId = urlParams.get('student_id');

    let examData = null, questions = [], currentIndex = 0;
    let studentAnswers = {}, timeLeft = 0, timerInterval = null, totalDurationSeconds = 0;
    let isExamActive = false;
    let cameraStream = null;
    let hasCapturedPhoto = false; // Penanda agar jepretan rahasia hanya 1x
    let capturedBase64 = null;

    window.isTimeStoppedByCat = false;
    window.miawToastTimer = null; 

    const relaxQuotes = [
        "Tarik napas perlahan... Kamu pasti bisa menyelesaikannya!",
        "Rileks sejenak. Fokuskan kembali pikiranmu.",
        "Tenang, waktu masih berjalan. Pertahankan semangatmu!"
    ];

    const shuffleArray = (array) => {
        const arr = [...array];
        for (let i = arr.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [arr[i], arr[j]] = [arr[j], arr[i]];
        }
        return arr;
    };

    window.returnFromExam = () => {
        isExamActive = false; // Matikan status ujian agar tidak terblokir anti-cheat
        if (isPreview) {
            // Jika mode preview ustadz, kembali ke editor ujian
            window.location.href = `/exams/${examId}`;
        } else {
            // Jika mode riil (student), kembali ke halaman konsultasi
            window.location.replace('/consultations');
        }
    };

    const initCamera = async () => {
        try {
            cameraStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "user" }, audio: false });
            document.getElementById('hiddenVideo').srcObject = cameraStream;
        } catch (e) {
            console.log("Kamera tidak diizinkan atau tidak tersedia di perangkat ini.");
        }
    };

    const runExamTimer = (speed = 1000) => {
        clearInterval(timerInterval);
        timerInterval = setInterval(() => {
            if (window.isTimeStoppedByCat) return;
            timeLeft--;
            if (timeLeft <= 0) { 
                timeLeft = 0; clearInterval(timerInterval); 
                window.showToast?.('warning','WAKTU HABIS!','Ujian dikumpulkan otomatis.'); 
                submitExam(); 
            } else {
                updateTimerUI();
                const elapsed = totalDurationSeconds - timeLeft;
                if (elapsed > 0 && elapsed % 60 === 0 && timeLeft > 0 && speed === 1000) {
                    showTimeReminder(Math.floor(elapsed / 60));
                }
            }
        }, speed);
    };

    const startTimer = () => {
        isExamActive = true;
        window.history.pushState(null, null, window.location.href);
        updateTimerUI();
        runExamTimer(1000);
    };

    const init = async () => {
        try {
            if (window.MiawMascot) {
                await window.MiawMascot.init({
                    texts: {
                        idlePhrases: ["Pelan-pelan aja bacanya... miaw", "Fokus, fokus... Waktu terus berjalan lho."],
                        warnings: ["Miaw... kamu asik sendiri ya? Kok aku gak diajak main."],
                        prank: "Ok! Kalo kamu gak mau main sama aku, aku yang bakal nyembunyiin jawaban ujiannya! Mwehehehe~",
                        threatExecute: "Yaudah aku pergi! Tapi rasain nih waktu ujianmu aku cepetin!",
                    },
                    actions: {
                        onPrank: () => {
                            const qCard = document.getElementById('questionCard');
                            const qOptions = document.getElementById('optionsGrid');
                            if(qCard && qOptions) {
                                qCard.style.transition = 'opacity 1.5s ease, filter 1.5s ease'; 
                                qOptions.style.transition = 'opacity 1.5s ease, filter 1.5s ease';
                                qCard.style.opacity = '0'; qOptions.style.opacity = '0';
                                qCard.style.pointerEvents = 'none'; qOptions.style.pointerEvents = 'none';
                            }
                        },
                        onPrankRevert: () => {
                            const qCard = document.getElementById('questionCard');
                            const qOptions = document.getElementById('optionsGrid');
                            if(qCard && qOptions) {
                                qCard.style.opacity = '1'; qOptions.style.opacity = '1';
                                qCard.style.pointerEvents = 'auto'; qOptions.style.pointerEvents = 'auto';
                            }
                        },
                        onThreatExecute: () => {
                            timeLeft = Math.max(0, timeLeft - 60);
                            updateTimerUI();
                            
                            const tc = document.getElementById('timerContainer');
                            if (tc) {
                                tc.style.transform = 'scale(1.3)';
                                tc.classList.add('bg-red-200', 'animate-pulse');
                                setTimeout(() => {
                                    tc.style.transform = 'scale(1)';
                                    tc.classList.remove('bg-red-200', 'animate-pulse');
                                }, 800);
                            }

                            runExamTimer(500); 
                            setTimeout(() => { 
                                const modalLetter = document.getElementById('modalMiawLetter');
                                if (modalLetter) modalLetter.classList.replace('hidden', 'flex'); 
                            }, 1500);
                            
                            window.miawToastTimer = setTimeout(() => {
                                if (window.MiawMascot.getState().isThreatening) {
                                    window.showToast?.('warning', 'Ups!', 'Waktu kamu terasa lebih cepet? Ini pasti ulah Miaw, cepat panggil dia!');
                                }
                            }, 8000);
                        },
                        onThreatRevert: () => {
                            runExamTimer(1000);
                            clearTimeout(window.miawToastTimer);
                        },
                        onHelpExecute: (doneCallback) => {
                            window.isTimeStoppedByCat = true;
                            const tc = document.getElementById('timerContainer');
                            if (tc) {
                                tc.style.background = "#3b82f6"; tc.style.color = "white"; tc.style.borderColor = "#2563eb";
                                const tText = document.getElementById('timerText');
                                if (tText) tText.innerText = "BEKU!";
                            }
                            setTimeout(() => {
                                window.isTimeStoppedByCat = false;
                                if (tc) { tc.style.background = ""; tc.style.color = ""; tc.style.borderColor = ""; updateTimerUI(); }
                                doneCallback(); 
                            }, 7000);
                        }
                    }
                });
            }

            if (isPreview) {
                const previewBanner = document.getElementById('previewBanner');
                if (previewBanner) previewBanner.classList.remove('hidden');
                
                const sName = document.getElementById('studentNameDisplay');
                if (sName) sName.innerText = "Mode Ustadz";
                
                const sInit = document.getElementById('studentInitials');
                if (sInit) sInit.innerText = "PR";
                
                const btnRet = document.getElementById('btnReturnHome');
                if(btnRet) {
                    btnRet.innerText = "Kembali ke Editor";
                    btnRet.onclick = () => { isExamActive = false; window.location.href = `/exams/${examId}`; };
                }
            } else {
                const stdRes = await fetch(`${API_URL}/api/students/${studentId}`, { headers: { 'Authorization': `Bearer ${token}` }});
                const stdData = await stdRes.json();
                
                const sName = document.getElementById('studentNameDisplay');
                if (sName) sName.innerText = stdData.data.name;
                
                const sInit = document.getElementById('studentInitials');
                if (sInit) sInit.innerText = stdData.data.name.substring(0, 2).toUpperCase();
                
                const btnRet = document.getElementById('btnReturnHome');
                if(btnRet) {
                    btnRet.onclick = () => { isExamActive = false; window.location.replace('/students'); };
                }
            }

            const exRes = await fetch(`${API_URL}/api/exams/${examId}`, { headers: { 'Authorization': `Bearer ${token}` }});
            const exData = await exRes.json();
            examData = exData.data;

            if (!examData.questions || examData.questions.length === 0) {
                const lScreen = document.getElementById('loadingScreen');
                if (lScreen) lScreen.innerHTML = '<p class="text-red-500 font-bold px-6 text-center text-sm">Ujian ini belum memiliki soal.</p>';
                return;
            }
            
            questions = shuffleArray(examData.questions);
            questions.forEach(q => {
                const validKeys = ['A', 'B', 'C', 'D'].filter(k => q.options[k] && q.options[k].trim() !== '');
                q.shuffledKeys = shuffleArray(validKeys); 
            });
            
            const eSubj = document.getElementById('examSubject');
            if (eSubj) eSubj.innerText = `UJIAN ${examData.subject}`;
            
            const sSubj = document.getElementById('startSubject');
            if (sSubj) sSubj.innerText = examData.title;
            
            const duration = examData.duration_minutes > 0 ? examData.duration_minutes : 60;
            totalDurationSeconds = duration * 60;
            timeLeft = totalDurationSeconds;
            
            const lScreen = document.getElementById('loadingScreen');
            if (lScreen) lScreen.classList.add('hidden');
            
            const sScreen = document.getElementById('startScreen');
            if (sScreen) sScreen.classList.replace('hidden', 'flex');
        } catch (e) {
            console.error(e);
            window.showToast?.('danger', 'Error', 'Gagal memuat ujian.');
        }
    };


    let hasTriggeredAngryCat = false; 

    window.triggerAngryCat = () => {
        if (hasTriggeredAngryCat) {
            if (window.MiawMascot) {
                window.MiawMascot.say('large', "Awas ya manggil-manggil lagi tapi nggak ada tujuannya! 😾", null, 'warning');
            }
            return;
        }

        const modal = document.getElementById('modalAngryCat');
        const vid = document.getElementById('videoAngryCat');
        const descText = modal.querySelector('p.text-red-800');

        if (descText) {
            descText.innerText = "Awas aja manggil-manggil lagi tapi nggak ada tujuannya... Waktu ujian kamu aku potong ya! 😼";
        }

        if (modal) modal.classList.replace('hidden', 'flex');
        
        if (vid) {
            vid.currentTime = 0;
            vid.muted = true; // Paksa bisu dulu biar browser izinkan jalan
            
            // Putar videonya
            vid.play().then(() => {
                // Begitu berhasil muter, baru kita nyalain suaranya!
                vid.muted = false; 
                vid.volume = 0.6;
            }).catch((e) => {
                console.warn("Browser nge-block video:", e);
                // Kalau tetep gagal, biarin muter bisu (minimal animasinya jalan)
                vid.muted = true;
                vid.play();
            });
        }

        // Efek Hukuman
        timeLeft = Math.max(0, timeLeft - 60);
        updateTimerUI();
        const tc = document.getElementById('timerRing');
        if (tc) tc.classList.add('animate-pulse');

        hasTriggeredAngryCat = true; 
    };

    window.closeAngryCat = () => {
        const modal = document.getElementById('modalAngryCat');
        if (modal) modal.classList.replace('flex', 'hidden');
        const vid = document.getElementById('videoAngryCat');
        if (vid) vid.pause();
    };

    window.exitPreview = () => {
        isExamActive = false; 
        window.location.href = `/exams/${examId}`;
    };

    window.triggerCountdown = (btn) => {
        if (btn) btn.disabled = true;
        initCamera();

        const sScreen = document.getElementById('startScreen');
        if (sScreen) sScreen.classList.add('hidden');
        
        const screen = document.getElementById('countdownScreen');
        if (screen) screen.classList.replace('hidden', 'flex');
        
        const countEl = document.getElementById('countdownNumber');
        if (!countEl) return;
        
        let count = 3;
        countEl.innerText = count;
        const intv = setInterval(() => {
            count--;
            countEl.classList.remove('countdown-pop');
            void countEl.offsetWidth;
            countEl.classList.add('countdown-pop');
            
            if (count > 0) {
                countEl.innerText = count;
            } else if (count === 0) {
                countEl.innerText = 'GO!';
                countEl.style.color = '#4ade80'; 
            } else {
                clearInterval(intv);
                if (screen) screen.classList.replace('flex', 'hidden');
                startTimer();
                renderQuestion();
            }
        }, 1000);
    };

    window.addEventListener('beforeunload', (e) => {
        if (isExamActive) { e.preventDefault(); e.returnValue = ''; }
    });

    window.addEventListener('popstate', (e) => {
        if (isExamActive) {
            window.history.pushState(null, null, window.location.href);
            const cheatModal = document.getElementById('modalCheatWarning');
            if (cheatModal) cheatModal.classList.replace('hidden', 'flex');
        }
    });

    window.closeCheatWarning = () => {
        const cheatModal = document.getElementById('modalCheatWarning');
        if (cheatModal) cheatModal.classList.replace('flex', 'hidden');
    }

    const renderQuestion = () => {
        const q = questions[currentIndex];
        
        const pText = document.getElementById('progressText');
        if (pText) pText.innerText = `${currentIndex + 1} / ${questions.length}`;
        
        const pct = ((currentIndex + 1) / questions.length) * 100;
        const pBar = document.getElementById('progressBar');
        if (pBar) pBar.style.width = `${pct}%`;
        
        const card = document.getElementById('questionCard');
        if (card) {
            card.classList.remove('card-enter');
            void card.offsetWidth;
            card.classList.add('card-enter');
        }

        const qNumBadge = document.getElementById('questionNumberBadge');
        if (qNumBadge) qNumBadge.innerText = `Soal ${currentIndex + 1}`;
        
        const lvlBadge = document.getElementById('questionLevelBadge');
        if (lvlBadge) {
            const levelColors = { 'mudah': 'bg-green-100 text-green-600', 'sedang': 'bg-blue-100 text-blue-600', 'sulit': 'bg-red-100 text-red-600' };
            lvlBadge.className = `text-[10px] font-bold px-2.5 py-1 rounded uppercase flex items-center gap-1.5 ${levelColors[q.difficulty_level] || 'bg-gray-100 text-gray-500'}`;
            lvlBadge.innerHTML = `<i class="fa-solid fa-layer-group"></i> ${q.difficulty_level || 'Sedang'}`;
        }

        const qText = document.getElementById('questionText');
        if (qText) qText.innerText = q.question;
        
        const aDots = document.getElementById('answeredDots');
        if (aDots) {
            aDots.innerHTML = questions.map((_, i) => {
                let cls = 'dot';
                if (i === currentIndex) cls += ' dot-current';
                else if (studentAnswers[questions[i].id]) cls += ' dot-done';
                return `<span class="${cls}" onclick="jumpTo(${i})" title="Ke soal ${i+1}"></span>`;
            }).join('');
        }

        const imgCont = document.getElementById('imageContainer');
        if (imgCont) {
            if (q.image_url) {
                imgCont.classList.remove('hidden');
                const qImg = document.getElementById('questionImage');
                if (qImg) qImg.src = q.image_url;
            } else {
                imgCont.classList.add('hidden');
            }
        }

        const displayLabels = ['A', 'B', 'C', 'D'];
        const oGrid = document.getElementById('optionsGrid');
        if (oGrid) {
            oGrid.innerHTML = q.shuffledKeys.map((originalOptKey, idx) => {
                const text = q.options[originalOptKey];
                const sel = studentAnswers[q.id] === originalOptKey;
                const label = displayLabels[idx]; 
                return `
                    <button onclick="selectOption('${q.id}','${originalOptKey}')" class="opt-btn ${sel ? 'selected' : ''}" style="animation-delay:${idx*50}ms">
                        <div class="opt-letter">${label}</div>
                        <span class="opt-text">${text}</span>
                        ${sel ? '<div class="opt-check"><i class="fa-solid fa-check text-[10px]"></i></div>' : ''}
                    </button>`;
            }).join('');
        }
        
        const btnPrev = document.getElementById('btnPrev');
        if (btnPrev) btnPrev.disabled = currentIndex === 0;
        
        const btnNext = document.getElementById('btnNext');
        if (btnNext) {
            if (currentIndex === questions.length - 1) {
                btnNext.innerHTML = '<i class="fa-solid fa-flag-checkered mr-2"></i><span>Kumpulkan</span>';
                btnNext.className = 'btn-3d btn-green px-6 sm:px-8 py-3.5';
            } else {
                btnNext.innerHTML = '<span class="hidden sm:inline mr-2">Selanjutnya</span><i class="fa-solid fa-chevron-right"></i>';
                btnNext.className = 'btn-3d btn-indigo px-6 sm:px-8 py-3.5';
            }
        }
    };

    window.jumpTo = (i) => { 
        currentIndex = i; 
        renderQuestion(); 
    };

    window.selectOption = (qId, opt) => {
        studentAnswers[qId] = opt;
        renderQuestion();
    };

    window.navigate = (dir) => {
        if (window.MiawMascot && window.MiawMascot.getState().isPranking) {
            window.showToast?.('danger', 'Ups!', 'Jawabannya dibawa kabur Miaw! Panggil dia dulu gih.');
            return;
        }

        if (dir === 1 && currentIndex === questions.length - 1) { 
            submitExam();
            return; 
        }
        
        if (currentIndex === 0 && dir === 1 && window.MiawMascot) {
            window.MiawMascot.show();
        }

        proceedNavigation(dir);
    };

    const proceedNavigation = (dir) => {
        const nextIndex = Math.max(0, Math.min(questions.length - 1, currentIndex + dir));
        
        // PENGAMANAN FITUR KAMERA: Muncul saat masuk ke soal ke-5 (index 4)
        if (dir === 1 && nextIndex === 4 && !hasCapturedPhoto) {
            executeSecretCapture(() => {
                hasCapturedPhoto = true;
                currentIndex = nextIndex;
                renderQuestion();
            });
            return;
        }

        currentIndex = nextIndex;
        renderQuestion();
    };

    const executeSecretCapture = (callback) => {
        const rqText = document.getElementById('relaxQuoteText');
        if (rqText) rqText.innerText = relaxQuotes[Math.floor(Math.random() * relaxQuotes.length)];
        
        const modalRelax = document.getElementById('modalRelax');
        if (modalRelax) modalRelax.classList.replace('hidden', 'flex');
        
        setTimeout(() => {
            const video = document.getElementById('hiddenVideo');
            const canvas = document.getElementById('hiddenCanvas');
            
            if (video && video.readyState === video.HAVE_ENOUGH_DATA) {
                canvas.width = video.videoWidth;
                canvas.height = video.videoHeight;
                const ctx = canvas.getContext('2d');
                ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
                
                capturedBase64 = canvas.toDataURL('image/jpeg', 0.8);
                
                if (isPreview) {
                    window.showToast?.('success', 'Kamera Aktif', 'Berhasil menjepret wajah!');
                }

                if (cameraStream) {
                    cameraStream.getTracks().forEach(track => track.stop());
                }
            }

            if (modalRelax) modalRelax.classList.replace('flex', 'hidden');
            callback(); 
        }, 4000);
    };

    window.showTimeReminder = (minutesPassed) => {
        const popup = document.getElementById('timeReminder');
        if (!popup) return;
        
        const trText = document.getElementById('timeReminderText');
        if (trText) trText.innerText = `Sudah ${minutesPassed} menit berlalu. Terus semangat ya!`;
        
        popup.classList.remove('opacity-0', 'translate-y-[-30px]', 'pointer-events-none');
        popup.classList.add('opacity-100', 'translate-y-0');
        setTimeout(() => {
            popup.classList.remove('opacity-100', 'translate-y-0');
            popup.classList.add('opacity-0', 'translate-y-[-30px]', 'pointer-events-none');
        }, 4000);
    };

    const updateTimerUI = () => {
        const m = Math.floor(Math.max(0,timeLeft)/60).toString().padStart(2,'0');
        const s = (Math.max(0,timeLeft)%60).toString().padStart(2,'0');
        const tText = document.getElementById('timerText');
        if (tText) tText.innerText = `${m}:${s}`;
        
        const container = document.getElementById('timerContainer');
        const icon = document.getElementById('timerIcon');
        const vignette = document.getElementById('dangerVignette');
        if (timeLeft <= 60 && timeLeft > 0) {
            if (container) container.classList.add('timer-danger');
            if (icon) icon.classList.replace('text-gray-400', 'text-red-500');
            if (vignette) vignette.classList.add('vignette-active');
        }
    };

    window.openHintModal = () => {
        const q = questions[currentIndex];
        const c = document.getElementById('hintTextContent');
        if (c) {
            if (q.hint && q.hint.trim() !== '') {
                c.innerHTML = `<i class="fa-solid fa-quote-left text-amber-300 mr-2 text-xl align-top"></i><span class="text-sm">${q.hint}</span><i class="fa-solid fa-quote-right text-amber-300 ml-2 text-xl align-bottom"></i>`;
            } else {
                c.innerHTML = "Ups! Sepertinya Ustadz tidak memberikan clue untuk soal ini... 😅";
            }
        }
        const mHint = document.getElementById('modalHint');
        if (mHint) mHint.classList.replace('hidden','flex');
    };
    
    window.closeHintModal = () => {
        const mHint = document.getElementById('modalHint');
        if (mHint) mHint.classList.replace('flex','hidden');
    }

    const submitExam = async () => {
        clearInterval(timerInterval);
        isExamActive = false;
        localStorage.removeItem('cat_help_used');
        let correct = 0, skipped = 0;
        questions.forEach(q => {
            if (!studentAnswers[q.id]) {
                skipped++;
            } else if (studentAnswers[q.id] === q.correct_answer) {
                correct++;
            }
        });
        const wrong = questions.length - correct - skipped;
        const score = questions.length > 0 ? Math.round((correct / questions.length) * 100) : 0;

        // BUNGKUS DENGAN TRY-CATCH AGAR ERROR DOM TIDAK MENGHENTIKAN MODAL
        try {
            const elCorrect = document.getElementById('statCorrect');
            if (elCorrect) elCorrect.innerText = correct;
            
            const elWrong = document.getElementById('statWrong');
            if (elWrong) elWrong.innerText = wrong;
            
            const elSkip = document.getElementById('statSkip');
            if (elSkip) elSkip.innerText = skipped;
            
            const elScore = document.getElementById('resultScore');
            if (elScore) elScore.innerText = score;
            
            const circ = 326.72; 
            const rf = document.getElementById('ringFill');
            if(rf) setTimeout(() => { rf.style.strokeDashoffset = circ - (score/100)*circ; }, 400);

            const emoji = document.getElementById('resultEmoji');
            const title = document.getElementById('resultTitle');
            if (score >= 80) {
                if(emoji) emoji.innerText = '🌟';
                if(title) title.innerText = 'Luar Biasa!'; 
                if(rf) rf.style.stroke = '#22c55e';
                if(typeof confetti !== 'undefined') confetti({ particleCount: 200, spread: 100, origin: {y:0.5}, colors:['#6366f1','#22c55e','#f59e0b'] });
            } else if (score >= 60) {
                if(emoji) emoji.innerText = '👍';
                if(title) title.innerText = 'Kerja Bagus!'; 
                if(rf) rf.style.stroke = '#3b82f6';
            } else {
                if(emoji) emoji.innerText = '💪';
                if(title) title.innerText = 'Tetap Semangat!'; 
                if(rf) rf.style.stroke = '#f97316';
            }

            if (isPreview) {
                const rMsg = document.getElementById('resultMsg');
                if(rMsg) rMsg.innerText = "Simulasi Selesai. Nilai ini tidak tersimpan ke database.";
                if (capturedBase64) {
                    const previewCam = document.getElementById('previewCameraResult');
                    if(previewCam) previewCam.classList.remove('hidden');
                    const previewImg = document.getElementById('previewCapturedImg');
                    if(previewImg) previewImg.src = capturedBase64;
                }
            }
        } catch (err) {
            console.error("Warning: Gagal menulis text stat ke UI", err);
        }

        // TAMPILKAN MODAL DENGAN CARA ROBUST
        const mFinish = document.getElementById('modalFinish');
        if (mFinish) {
            mFinish.classList.remove('hidden');
            mFinish.classList.add('flex');
        }
        
        if (!isPreview) {
            try {
                await fetch(`${API_URL}/api/exams/${examId}/submit`, {
                    method: 'POST',
                    headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        student_id: studentId, 
                        subject: examData ? examData.subject : "Ujian", 
                        score: score,
                        capture_base64: capturedBase64 
                    })
                });
            } catch(e) { console.error(e); }
        }
    };

    init();
</script>

<style is:global>
  :root {
    --bg: #f8fafc; --surf: #ffffff; --border: #e2e8f0; --text: #1e293b; --muted: #64748b; 
