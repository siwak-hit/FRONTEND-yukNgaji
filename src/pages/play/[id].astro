  }

  /* TRIK MENGHILANGKAN BG HITAM & HIJAU (CHROMAKEY) */
  #mascot-lottie {
    pointer-events: auto;
    width: 180px;
    height: 180px;
  }

  /* BUBBLE CHAT INTERAKTIF */
  .mascot-bubble {
    position: absolute;
    background: white;
    border: 2px solid #6366f1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8px;
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    z-index: 110;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    opacity: 0;
    transform: scale(0);
    pointer-events: auto;
  }

  /* Bubble Kecil saat Iddle (Dibuat Persegi Panjang) */
  .bubble-small {
    top: -50px;
    left: -20px;
    width: max-content; /* Lebar menyesuaikan teks */
    max-width: 160px;   /* Maksimal lebar agar teks turun ke bawah (wrap) */
