---
import Layout from '../../layouts/Layout.astro';
import NavbarGuru from '../../components/NavbarGuru.astro';
import Toast from '../../components/Toast.astro';
---

<Layout title="Detail Anak - yukNgaji">
    <div class="px-6 py-8 pb-32 min-h-screen bg-gray-50">
        
        <header class="mb-6">
            <!-- Row 1: Back + Title + Actions -->
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <a href="/students" class="w-10 h-10 bg-white rounded-xl flex items-center justify-center border border-gray-100 shadow-sm text-gray-600">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                    <h1 class="text-xl font-bold text-gray-800">Detail Perkembangan</h1>
                </div>
                <button id="btnToggleNav" onclick="toggleStudentNav()"
                    class="w-10 h-10 bg-white border border-gray-100 rounded-xl shadow-sm flex items-center justify-center active:scale-95 transition-all text-gray-400"
                    title="Ganti siswa">
                    <i class="fa-solid fa-users-between-lines text-sm"></i>
                </button>
            </div>
        
            <!-- Row 2: Student Navigator (collapsible) -->
            <div id="studentNavPanel"
                class="overflow-hidden transition-all duration-300 ease-in-out"
                style="max-height: 0; opacity: 0; margin-top: 0;">
                <div class="pt-4 pb-1">
        
                    <div class="flex items-center justify-between mb-2.5 px-0.5">
                        <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">
                            <i class="fa-solid fa-users text-gray-300 mr-1"></i> Pindah Siswa
                        </span>
                        <span id="studentNavCounter"
                            class="text-[10px] font-bold text-gray-400 tabular-nums bg-white px-2 py-0.5 rounded-md border border-gray-100">
                            - / -
                        </span>
                    </div>
        
                    <div class="flex items-center gap-2 bg-white border border-gray-200 rounded-xl px-3 py-2.5 focus-within:ring-2 focus-within:ring-green-500 focus-within:border-green-500 transition-all mb-2.5 relative">
                        <i class="fa-solid fa-magnifying-glass text-gray-300 text-xs flex-shrink-0"></i>
                        <input
                            type="text"
                            id="studentSearchInput"
                            placeholder="Cari nama siswa..."
                            class="w-full text-sm font-bold text-gray-700 bg-transparent outline-none placeholder-gray-300"
                            autocomplete="off"
                        />
                        <div id="studentSearchDropdown"
                            class="hidden absolute top-[110%] left-0 right-0 bg-white border border-gray-100 rounded-2xl shadow-2xl z-50 overflow-hidden max-h-52 overflow-y-auto no-scrollbar">
                        </div>
                    </div>
        
                    <div class="grid grid-cols-2 gap-2.5">
                        <button id="btnPrevStudent" onclick="navigateStudent(-1)"
                            class="w-full py-2.5 bg-white border border-gray-200 rounded-xl flex items-center justify-center gap-2 text-gray-500 font-bold text-xs active:scale-95 transition-all disabled:opacity-40 disabled:bg-gray-50">
                            <i class="fa-solid fa-chevron-left text-[10px]"></i> Sebelumnya
                        </button>
                        <button id="btnNextStudent" onclick="navigateStudent(1)"
                            class="w-full py-2.5 bg-white border border-gray-200 rounded-xl flex items-center justify-center gap-2 text-gray-500 font-bold text-xs active:scale-95 transition-all disabled:opacity-40 disabled:bg-gray-50">
                            Selanjutnya <i class="fa-solid fa-chevron-right text-[10px]"></i>
                        </button>
                    </div>
                </div>
            </div>
        </header>

        <div id="modalKaleng" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
            <div class="bg-white p-6 rounded-lg shadow-xl max-w-sm w-full relative">
                <h3 class="text-lg font-bold mb-4 border-b pb-2">Status Kaleng Infaq</h3>
                <p id="kalengMessage" class="text-gray-700"></p>
                <button id="closeModalKaleng" class="mt-6 w-full bg-gray-200 text-gray-800 py-2 rounded font-semibold hover:bg-gray-300 transition-colors">Tutup</button>
            </div>
        </div>

        <section class="bg-white rounded-3xl p-6 shadow-sm border border-gray-50 mb-6">
            
            <div class="flex items-center gap-3 mb-5">
                <div id="studentInitial" class="w-14 h-14 bg-green-100 text-green-600 font-bold rounded-2xl flex items-center justify-center text-xl flex-shrink-0">--</div>
                <div class="flex-1 min-w-0">
                    <h2 id="studentName" class="text-lg font-bold text-gray-800 truncate">Memuat...</h2>
                    <p id="studentGrade" class="text-xs text-gray-400 font-medium uppercase tracking-wider">--</p>
                </div>
                <div class="flex items-center gap-2 flex-shrink-0">
                    <button onclick="openRaportModal()"
                        class="w-9 h-9 bg-green-600 text-white rounded-xl shadow-md shadow-green-600/30 flex items-center justify-center active:scale-95 transition-all"
                        title="Buat & Download Raport">
                        <i class="fa-solid fa-file-pdf text-sm"></i>
                    </button>
                    <button id="infoKalengBtn"
                        class="w-9 h-9 bg-gray-100 text-gray-400 border border-gray-200 rounded-xl shadow-sm flex items-center justify-center active:scale-95 transition-all"
                        title="Memuat status kaleng...">
                        <i class="fa-solid fa-jar text-sm"></i>
                    </button>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-3 mb-5">
                <a href="/absensi" id="badgeTodayStatus"
                    class="flex flex-col items-center justify-center bg-gray-50 border border-gray-100 p-3 rounded-2xl active:scale-95 transition-all">
                    <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1.5">Hari Ini</span>
                    <div id="todayStatusUI" class="flex items-center gap-1.5 text-xs font-black text-gray-500 text-center">
                        <i class="fa-solid fa-spinner fa-spin"></i> Cek...
                    </div>
                </a>
                
                <button onclick="openHafalanModal()" id="badgeHafalan"
                    class="flex flex-col items-center justify-center bg-green-50 border border-green-200 p-3 rounded-2xl active:scale-95 transition-all">
                    <span class="text-[10px] font-bold text-green-500 uppercase tracking-widest mb-1.5">Hafalan</span>
                    <div id="hafalanBadgeUI" class="text-xs font-black text-green-700 text-center">
                        <i class="fa-solid fa-spinner fa-spin"></i>
                    </div>
                </button>
            </div>

            <div class="border-t border-gray-100 pt-4 grid grid-cols-2 gap-3">
                <button onclick="openEditCheckpointModal()"
                    class="flex items-center justify-center gap-2 py-2.5 bg-blue-50 border border-blue-200 text-blue-600 rounded-xl text-xs font-bold active:scale-95 transition-all">
                    <i class="fa-solid fa-pen"></i> Edit Hafalan
                </button>
                
                <div class="relative w-full">
                    <button onclick="toggleHafalanMenu()"
                        class="w-full flex items-center justify-center gap-2 py-2.5 bg-gray-50 border border-gray-200 text-gray-600 rounded-xl text-xs font-bold active:scale-95 transition-all">
                        <i class="fa-solid fa-ellipsis-vertical"></i> Lainnya
                    </button>
                    
                    <div id="hafalanMenu" class="hidden absolute right-0 bottom-12 bg-white border border-gray-100 rounded-2xl shadow-xl w-48 z-50">
                        <button onclick="confirmResetHafalan()"
                            class="w-full flex items-center gap-2 px-4 py-3 text-xs text-red-500 font-bold hover:bg-red-50 transition-colors rounded-2xl">
                            <i class="fa-solid fa-rotate-left"></i> Reset Hafalan
                        </button>
                    </div>
                </div>
            </div>

        </section>

        <section class="bg-white rounded-3xl p-2 shadow-sm border border-gray-100 mb-6">
            <div class="flex p-1 bg-gray-50 rounded-2xl mb-2">
                <button id="tabDashAkademik" class="flex-1 py-2.5 text-[10px] font-bold bg-white text-blue-600 rounded-xl shadow-sm transition-all uppercase tracking-widest">Akademik</button>
                <button id="tabDashAbsensi" class="flex-1 py-2.5 text-[10px] font-bold text-gray-400 hover:text-gray-600 transition-all uppercase tracking-widest">Kehadiran</button>
            </div>

            <div id="contentDashAkademik" class="p-4 block">
                <div class="h-48 w-full mb-6">
                    <canvas id="progressChart"></canvas>
                </div>
                <div class="grid grid-cols-3 gap-2">
                    <div class="text-center p-2 bg-green-50 rounded-xl">
                        <p class="text-[10px] text-green-600 font-bold uppercase">Tajwid</p>
                        <p id="avgTajwid" class="font-bold text-gray-800">-</p>
                    </div>
                    <div class="text-center p-2 bg-blue-50 rounded-xl">
                        <p class="text-[10px] text-blue-600 font-bold uppercase">Fiqih</p>
                        <p id="avgFiqih" class="font-bold text-gray-800">-</p>
                    </div>
                    <div class="text-center p-2 bg-purple-50 rounded-xl">
                        <p class="text-[10px] text-purple-600 font-bold uppercase">Tauhid</p>
                        <p id="avgTauhid" class="font-bold text-gray-800">-</p>
                    </div>
                </div>
            </div>

            <div id="contentDashAbsensi" class="p-4 hidden">
                <div class="flex items-center gap-4 mb-6">
                    <div class="h-32 w-32 relative flex-shrink-0">
                        <canvas id="attendanceChart"></canvas>
                    </div>
                    <div class="flex-1 space-y-2">
                        <div class="flex justify-between items-center bg-gray-50 p-2 rounded-lg"><span class="text-[10px] font-bold text-gray-500 uppercase">Hadir</span><span id="statHadir" class="text-xs font-black text-green-600">0</span></div>
                        <div class="flex justify-between items-center bg-gray-50 p-2 rounded-lg"><span class="text-[10px] font-bold text-gray-500 uppercase">Izin/Sakit</span><span id="statIzin" class="text-xs font-black text-amber-500">0</span></div>
                        <div class="flex justify-between items-center bg-gray-50 p-2 rounded-lg"><span class="text-[10px] font-bold text-gray-500 uppercase">Alpa</span><span id="statAlpa" class="text-xs font-black text-red-500">0</span></div>
                    </div>
                </div>
                <div class="bg-blue-50 border border-blue-100 p-3 rounded-xl text-center">
                    <p class="text-[9px] font-bold text-blue-400 uppercase tracking-widest mb-1">Performa Kedisiplinan</p>
                    <p id="statPerformance" class="text-sm font-black text-blue-700">Memuat...</p>
                </div>
            </div>
        </section>

        <section class="mb-8">
            <div class="flex p-1 bg-gray-100 rounded-2xl mb-6">
                <button id="tabTodo" class="flex-1 py-3 text-[10px] font-bold bg-white text-green-700 rounded-xl shadow-sm transition-all uppercase tracking-widest"><i class="fa-solid fa-list-check mr-1"></i> Tugas AI</button>
                <button id="tabCons" class="flex-1 py-3 text-[10px] font-bold text-gray-400 hover:text-gray-600 transition-all uppercase tracking-widest"><i class="fa-regular fa-comments mr-1"></i> Konsultasi</button>
            </div>
            <div id="contentTodo" class="block"><div id="todoContainer" class="space-y-3"><p class="text-center text-gray-400 text-sm py-4">Memuat tugas...</p></div></div>
            <div id="contentCons" class="hidden"><div id="consContainer" class="space-y-4"><p class="text-center text-gray-400 text-sm py-4">Memuat riwayat...</p></div></div>
        </section>

    </div>

    <!-- ============================================================ -->
    <!-- MODAL RAPORT -->
    <!-- ============================================================ -->
    <div id="modalRaport" class="fixed inset-0 bg-black/60 z-[70] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-lg rounded-3xl p-6 shadow-2xl max-h-[90vh] overflow-y-auto no-scrollbar">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-bold text-gray-800">Buat & Download Raport</h3>
                <button onclick="closeRaportModal()" class="text-gray-400"><i class="fa-solid fa-xmark"></i></button>
            </div>
            
            <form id="formRaport" class="space-y-4">
                <input type="text" id="rapName" readonly class="w-full px-4 py-2 bg-gray-50 rounded-xl text-sm font-bold text-gray-500">

                <!-- [BARU] SECTION FOTO ANAK -->
                <div class="p-3 bg-gray-50 rounded-xl border border-gray-100">
                    <div class="flex items-center justify-between mb-2">
                        <h4 class="text-xs font-bold text-gray-700">
                            Foto Raport
                            <span class="text-[9px] font-normal text-gray-400 ml-1">(Opsional)</span>
                        </h4>
                        <div class="flex items-center gap-2">
                            <button type="button" id="btnAcakFoto" onclick="acakFotoRaport()"
                                class="text-[9px] bg-blue-100 text-blue-600 px-2 py-1 rounded-md font-bold transition-all active:scale-95"
                                title="Ambil foto acak dari kuesioner">
                                <i class="fa-solid fa-shuffle"></i> Acak Foto
                            </button>
                            <button type="button" id="btnHapusFoto" onclick="hapusFotoRaport()"
                                class="hidden text-[9px] bg-red-100 text-red-500 px-2 py-1 rounded-md font-bold transition-all active:scale-95">
                                <i class="fa-solid fa-xmark"></i> Tanpa Foto
                            </button>
                        </div>
                    </div>
                    <!-- Preview area -->
                    <div id="fotoPreviewArea" class="relative flex items-center justify-center h-28 bg-white rounded-xl border border-dashed border-gray-200 overflow-hidden">
                        <div id="fotoPlaceholder" class="text-center text-gray-400">
                            <i class="fa-regular fa-image text-3xl mb-1 block text-gray-300"></i>
                            <span id="fotoStatusText" class="text-[10px]">Tekan "Acak Foto" untuk memilih foto dari kuesioner</span>
                        </div>
                        <img id="fotoPreviewImg" src="" alt="Preview foto raport"
                            class="hidden absolute inset-0 w-full h-full object-cover rounded-xl">
                    </div>
                </div>

                <div class="p-3 bg-blue-50 rounded-xl border border-blue-100">
                    <h4 class="text-xs font-bold text-blue-800 mb-2">A. Akademik (Otomatis)</h4>
                    <div class="space-y-2">
                        <div class="flex justify-between items-center bg-white p-2 rounded-lg border border-blue-100/50 shadow-sm">
                            <span class="text-xs font-bold text-gray-700">Tajwid</span>
                            <div class="flex items-center gap-3">
                                <p class="text-[9px] text-gray-400 font-bold text-right leading-tight">Tg: <span id="rapNumTajwidWeekly" class="text-blue-500">0</span> (30%)<br>Uj: <span id="rapNumTajwidExam" class="text-amber-500">0</span> (70%)</p>
                                <input type="text" id="rapTajwid" disabled class="w-8 bg-blue-100 text-blue-700 text-center rounded font-black text-xs border-none py-1.5">
                            </div>
                        </div>
                        <div class="flex justify-between items-center bg-white p-2 rounded-lg border border-blue-100/50 shadow-sm">
                            <span class="text-xs font-bold text-gray-700">Fiqih</span>
                            <div class="flex items-center gap-3">
                                <p class="text-[9px] text-gray-400 font-bold text-right leading-tight">Tg: <span id="rapNumFiqihWeekly" class="text-blue-500">0</span> (30%)<br>Uj: <span id="rapNumFiqihExam" class="text-amber-500">0</span> (70%)</p>
                                <input type="text" id="rapFiqih" disabled class="w-8 bg-blue-100 text-blue-700 text-center rounded font-black text-xs border-none py-1.5">
                            </div>
                        </div>
                        <div class="flex justify-between items-center bg-white p-2 rounded-lg border border-blue-100/50 shadow-sm">
                            <span class="text-xs font-bold text-gray-700">Tauhid</span>
                            <div class="flex items-center gap-3">
                                <p class="text-[9px] text-gray-400 font-bold text-right leading-tight">Tg: <span id="rapNumTauhidWeekly" class="text-blue-500">0</span> (30%)<br>Uj: <span id="rapNumTauhidExam" class="text-amber-500">0</span> (70%)</p>
                                <input type="text" id="rapTauhid" disabled class="w-8 bg-blue-100 text-blue-700 text-center rounded font-black text-xs border-none py-1.5">
                            </div>
                        </div>
                    </div>
                    <div class="mt-2">
                        <label class="text-[10px] font-bold text-blue-800">Al-Quran / Iqro (Manual)</label>
                        <select id="rapQuran" class="w-full mt-1 px-2 py-1 bg-white rounded text-xs border-none"><option value="A">A (Sangat Baik)</option><option value="B">B (Baik)</option><option value="C">C (Cukup)</option><option value="D">D (Kurang)</option></select>
                    </div>
                </div>

                <div class="p-3 bg-green-50 rounded-xl border border-green-100">
                    <div class="flex items-center gap-2 mb-2">
                        <h4 class="text-xs font-bold text-green-800">B. Kepribadian</h4>
                        <span class="text-[8px] font-bold text-green-600 bg-green-200/50 px-1.5 py-0.5 rounded border border-green-200 uppercase tracking-widest">Bisa Diubah</span>
                    </div>
                    <div class="space-y-2">
                        <div class="flex justify-between items-center"><span class="text-xs">Kedisiplinan</span><select id="rapSikap1" class="text-xs p-1 rounded border-none"><option value="A">A</option><option value="B">B</option><option value="C">C</option><option value="D">D</option></select></div>
                        <div class="flex justify-between items-center"><span class="text-xs">Akhlak & Adab</span><select id="rapSikap2" class="text-xs p-1 rounded border-none"><option value="A">A</option><option value="B">B</option><option value="C">C</option><option value="D">D</option></select></div>
                        <div class="flex justify-between items-center"><span class="text-xs">Keaktifan</span><select id="rapSikap3" class="text-xs p-1 rounded border-none"><option value="A">A</option><option value="B">B</option><option value="C">C</option><option value="D">D</option></select></div>
                    </div>
                </div>

                <div class="p-3 bg-amber-50 rounded-xl border border-amber-100">
                    <h4 class="text-xs font-bold text-amber-800 mb-2">C. Kehadiran (Otomatis dari Absensi)</h4>
                    <div class="flex justify-between items-center text-xs font-medium"><span class="text-green-600">Hadir: <span id="rapHadir" class="font-bold">0</span></span><span class="text-amber-600">Izin/Sakit: <span id="rapIzin" class="font-bold">0</span></span><span class="text-red-600">Alpa: <span id="rapAlpa" class="font-bold">0</span></span></div>
                </div>

                <div>
                    <div class="flex justify-between items-end mb-1">
                        <label class="text-[10px] font-bold text-gray-400 uppercase">D. Catatan <span class="text-red-500">*</span></label>
                        <button type="button" onclick="generateSystemNote()" class="text-[9px] bg-purple-100 text-purple-600 px-2 py-1 rounded-md font-bold"><i class="fa-solid fa-wand-magic-sparkles"></i> Generate AI</button>
                    </div>
                    <textarea id="rapNote" required rows="4" class="w-full p-3 bg-gray-50 border border-gray-100 rounded-xl text-xs"></textarea>
                </div>

                <button type="submit" id="btnSaveRaport" class="w-full py-4 bg-green-600 text-white font-bold rounded-2xl shadow-lg active:scale-95 transition-all flex items-center justify-center gap-2">
                    <i class="fa-solid fa-save"></i> <span>Simpan & Buka PDF</span>
                </button>
            </form>
        </div>
    </div>

    <!-- Canvas tersembunyi untuk konversi gambar URL → Base64 -->
    <canvas id="hiddenCanvas" style="display:none;"></canvas>

    <NavbarGuru activeMenu="students" />
    <Toast />

    <!-- ============================================================ -->
    <!-- MODAL ONBOARDING HAFALAN -->
    <!-- ============================================================ -->
    <div id="modalOnboarding" class="fixed inset-0 bg-black/70 z-[80] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-sm rounded-3xl p-6 shadow-2xl">
            <div class="text-center mb-5">
                <div class="text-4xl mb-2">📖</div>
                <h3 class="font-bold text-gray-800 text-lg">Mulai Hafalan</h3>
                <p class="text-xs text-gray-400 mt-1">Tentukan posisi awal hafalan ananda sekarang.</p>
            </div>
            <div class="space-y-3">
                <div>
                    <label class="text-[10px] font-bold text-gray-500 uppercase">Surat Saat Ini</label>
                    <select id="onboardingSurah" class="w-full mt-1 px-3 py-2 bg-gray-50 rounded-xl text-sm border border-gray-200 font-medium"></select>
                </div>
                <div>
                    <label class="text-[10px] font-bold text-gray-500 uppercase">Sudah Hafal Sampai Ayat</label>
                    <select id="onboardingAyah" class="w-full mt-1 px-3 py-2 bg-gray-50 rounded-xl text-sm border border-gray-200 font-medium"></select>
                </div>
                <div class="bg-amber-50 border border-amber-200 rounded-xl p-3 text-center">
                    <p class="text-xs text-amber-700 font-bold">⚠️ Yakin nih? Kalo boong dijewer...</p>
                </div>
                <button onclick="submitOnboarding()" class="w-full py-3 bg-green-600 text-white font-bold rounded-2xl shadow-lg active:scale-95 transition-all">
                    <i class="fa-solid fa-check mr-2"></i>Simpan Posisi Awal
                </button>
                <button onclick="closeOnboardingModal()" class="w-full py-2 text-xs text-gray-400 font-medium">Nanti saja</button>
            </div>
        </div>
    </div>

    <!-- ============================================================ -->
    <!-- MODAL EDIT MANUAL CHECKPOINT (Teacher Override) -->
    <!-- ============================================================ -->
    <div id="modalEditCheckpoint" class="fixed inset-0 bg-black/70 z-[85] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-sm rounded-3xl p-6 shadow-2xl">
            <div class="flex justify-between items-center mb-5">
                <div>
                    <h3 class="font-bold text-gray-800">Edit Posisi Hafalan</h3>
                    <p class="text-[10px] text-gray-400 mt-0.5">Override manual oleh guru</p>
                </div>
                <button onclick="closeEditCheckpointModal()" class="text-gray-400 w-8 h-8 flex items-center justify-center rounded-xl hover:bg-gray-100">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="space-y-3">
                <div>
                    <label class="text-[10px] font-bold text-gray-500 uppercase">Surat</label>
                    <select id="editSurah" class="w-full mt-1 px-3 py-2 bg-gray-50 rounded-xl text-sm border border-gray-200 font-medium"></select>
                </div>
                <div>
                    <label class="text-[10px] font-bold text-gray-500 uppercase">Posisi Ayat (sudah hafal s.d.)</label>
                    <select id="editAyah" class="w-full mt-1 px-3 py-2 bg-gray-50 rounded-xl text-sm border border-gray-200 font-medium"></select>
                </div>
                <button onclick="submitEditCheckpoint()"
                    class="w-full py-3 bg-blue-600 text-white font-bold rounded-2xl shadow-lg active:scale-95 transition-all">
                    <i class="fa-solid fa-floppy-disk mr-2"></i>Simpan Perubahan
                </button>
            </div>
        </div>
    </div>

    <!-- ============================================================ -->
    <!-- MODAL INPUT HAFALAN HARIAN -->
    <!-- ============================================================ -->
    <div id="modalHafalan" class="fixed inset-0 bg-black/60 z-[75] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-sm rounded-3xl p-6 shadow-2xl">
            <div class="flex justify-between items-center mb-4">
                <h3 class="font-bold text-gray-800">Setor Hafalan Hari Ini</h3>
                <button onclick="closeHafalanModal()" class="text-gray-400"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div id="hafalanInfo" class="bg-green-50 border border-green-100 rounded-xl p-3 mb-4 text-sm text-green-800 font-medium text-center"></div>
            <p id="hafalanWarning" class="hidden text-center text-xs text-amber-600 font-bold mb-3 bg-amber-50 border border-amber-200 rounded-xl p-2"></p>
            <!-- Tab Mode: Maju / Mundur -->
            <div class="flex p-1 bg-gray-100 rounded-2xl mb-3">
                <button id="tabMaju" onclick="setHafalanMode('maju')"
                    class="flex-1 py-2 text-[10px] font-bold bg-white text-green-700 rounded-xl shadow-sm transition-all uppercase tracking-widest">
                    ▲ Setor Maju
                </button>
                <button id="tabMundur" onclick="setHafalanMode('mundur')"
                    class="flex-1 py-2 text-[10px] font-bold text-gray-400 hover:text-gray-600 transition-all uppercase tracking-widest">
                    ▼ Koreksi Mundur
                </button>
            </div>

            <!-- Grid tombol maju (default tampil) -->
            <div id="sectionMaju">
                <p class="text-[10px] font-bold text-gray-400 uppercase mb-2">Tambah berapa ayat?</p>
                <div id="hafalanBtnGrid" class="grid grid-cols-4 gap-2 mb-4"></div>
            </div>

            <!-- Grid tombol mundur (default hidden) -->
            <div id="sectionMundur" class="hidden">
                <p class="text-[10px] font-bold text-red-400 uppercase mb-2">Mundur berapa ayat?</p>
                <div id="hafalanBtnGridMundur" class="grid grid-cols-4 gap-2 mb-4"></div>
                <p class="text-[9px] text-gray-400 text-center">Jika mundur melewati batas surat, sistem otomatis pindah ke surat sebelumnya.</p>
            </div>

            <button onclick="closeHafalanModal()" class="w-full py-2.5 bg-gray-100 text-gray-600 text-sm font-bold rounded-xl">Tutup</button>
        </div>
    </div>
</Layout>

<div id="modalSusulan" class="fixed inset-0 bg-black/70 z-[90] hidden items-center justify-center p-4 backdrop-blur-sm">
    <div class="bg-white w-full max-w-sm rounded-3xl p-6 shadow-2xl text-center">
        <div class="w-16 h-16 bg-amber-50 text-amber-500 rounded-full flex items-center justify-center text-3xl mx-auto mb-4 shadow-inner border border-amber-100">
            <i class="fa-solid fa-graduation-cap"></i>
        </div>
        <h3 class="font-bold text-gray-800 text-lg mb-2">Ujian Susulan</h3>
        <p class="text-sm text-gray-500 mb-6 leading-relaxed" id="susulanMessage">Berikan ujian susulan untuk anak ini?</p>
        
        <div class="flex gap-3">
            <button onclick="closeSusulanModal()" class="flex-1 py-3.5 bg-gray-100 text-gray-500 font-bold rounded-2xl active:scale-95 transition-all">
                Batal
            </button>
            <button id="btnConfirmSusulan" class="flex-1 py-3.5 bg-amber-500 text-white font-bold rounded-2xl shadow-lg shadow-amber-500/30 active:scale-95 transition-all">
                Mulai Ujian
            </button>
