    // Kelompokkan izinDates & alpaDates ke ringkasan per-bulan
    const buildMonthlyAttendanceSummary = () => {
        const map = {};

        const add = (dateStr, type) => {
            const [y, m] = dateStr.split('-');
            const key = `${y}-${m}`;
            if (!map[key]) map[key] = { izin: 0, alpa: 0 };
            map[key][type]++;
        };

        attendanceDetailGlobal.izinDates.forEach(item => add(item.date, 'izin'));
        attendanceDetailGlobal.alpaDates.forEach(item => add(item.date, 'alpa'));

        return Object.keys(map).sort().map(key => {
            const [year, month] = key.split('-');
            const label = new Date(parseInt(year), parseInt(month) - 1, 1)
                .toLocaleDateString('id-ID', { month: 'long', year: 'numeric' });
            return { label, izin: map[key].izin, alpa: map[key].alpa };
        });
    };

    // Bangun teks insight berdasarkan pola alpa dan alasan izin dominan
    const buildAttendanceInsight = () => {
        const total = attendanceStatsGlobal.izin + attendanceStatsGlobal.alpa;
        if (total === 0) return null;

        // Hitung frekuensi sub-status izin
        const izinCount = {};
        attendanceDetailGlobal.izinDates.forEach(({ status }) => {
            izinCount[status] = (izinCount[status] || 0) + 1;
        });

        let dominanIzin = null, dominanIzinCount = 0;
        Object.entries(izinCount).forEach(([k, v]) => {
            if (v > dominanIzinCount) { dominanIzin = k; dominanIzinCount = v; }
        });

        const lines = [];

        // Insight alpha
        if (attendanceStatsGlobal.alpa > 0) {
            const pct = Math.round((attendanceStatsGlobal.alpa / total) * 100);
            if (pct >= 50) {
                lines.push(`⚠️ Perhatian: Lebih dari separuh ketidakhadiran (${attendanceStatsGlobal.alpa} hari, ${pct}%) adalah alpa tanpa keterangan. Mohon Ayah/Bunda lebih proaktif menghubungi guru bila ananda berhalangan hadir.`);
            } else if (attendanceStatsGlobal.alpa >= 3) {
                lines.push(`Terdapat ${attendanceStatsGlobal.alpa} hari alpa. Harap dikomunikasikan ke guru jika ada kendala kehadiran agar tidak tercatat alpa.`);
            }
        }

        // Insight izin dominan
        if (dominanIzin && dominanIzinCount > 0) {
            const label = dominanIzin.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
            if (dominanIzin.includes('sakit')) {
                lines.push(`Sebagian besar izin (${dominanIzinCount}x) disebabkan sakit. Pastikan ananda menjaga pola makan dan istirahat agar lebih jarang melewatkan pelajaran.`);
            } else if (dominanIzin.includes('keluarga') || dominanIzin.includes('acara')) {
                lines.push(`Beberapa izin (${dominanIzinCount}x) karena keperluan keluarga/acara. Bila memungkinkan, jadwalkan kegiatan di luar hari pengajian wajib.`);
            } else {
                lines.push(`Alasan izin terbanyak adalah "${label}" (${dominanIzinCount}x). Pastikan ananda mengulang materi yang terlewat di rumah.`);
            }
        }

        if (lines.length === 0) {
            lines.push(`Terdapat ${total} hari ketidakhadiran. Performa kehadiran ananda secara keseluruhan masih tergolong baik. Tetap jaga konsistensinya!`);
        }

        return lines.join('\n\n');
    };

    // ================================================================
    // HELPER FOTO: konversi URL gambar Supabase → Base64 via canvas
    // ================================================================
    const urlToBase64 = (url) => new Promise((resolve, reject) => {
        const img = new Image();
        img.crossOrigin = 'anonymous';
        img.onload = () => {
            const maxW = 300, maxH = 400;
            let w = img.naturalWidth, h = img.naturalHeight;
            if (w > maxW) { h = Math.round(h * maxW / w); w = maxW; }
            if (h > maxH) { w = Math.round(w * maxH / h); h = maxH; }
            const canvas = document.getElementById('hiddenCanvas');
            canvas.width = w; canvas.height = h;
            canvas.getContext('2d').drawImage(img, 0, 0, w, h);
            resolve(canvas.toDataURL('image/jpeg', 0.85));
        };
        img.onerror = () => reject(new Error('Gagal load: ' + url));
        img.src = url;
    });

