    // ================================================================
    // HELPER PDF: gambar satu tabel dengan header & baris data
    // col: [{ label, x, w }] — row: string[]
    // Kembalikan curY setelah tabel selesai
    // ================================================================
    const drawTable = (doc, curY, cols, rows, rowH = 8) => {
        const margin    = 15;
        const totalW    = cols.reduce((s, c) => s + c.w, 0);

        // Header
        doc.setFillColor(220, 220, 220);
        cols.forEach(c => doc.rect(c.x, curY, c.w, rowH, 'F'));
        doc.rect(margin, curY, totalW, rowH); // outer border
        cols.slice(1).forEach(c => doc.line(c.x, curY, c.x, curY + rowH)); // vertical dividers
        doc.setFont('helvetica', 'bold'); doc.setFontSize(8);
        cols.forEach(c => doc.text(c.label, c.x + c.w / 2, curY + rowH / 2 + 1.5, { align: 'center' }));
        curY += rowH;

        // Rows
        doc.setFont('helvetica', 'normal'); doc.setFontSize(8);
        rows.forEach((cells, idx) => {
            if (idx % 2 === 0) { doc.setFillColor(250, 250, 250); cols.forEach(c => doc.rect(c.x, curY, c.w, rowH, 'F')); }
            doc.rect(margin, curY, totalW, rowH);
            cols.slice(1).forEach(c => doc.line(c.x, curY, c.x, curY + rowH));
            cells.forEach((txt, i) => {
                const align = i === 0 ? 'left' : 'center';
                const xPos  = i === 0 ? cols[i].x + 3 : cols[i].x + cols[i].w / 2;
                doc.text(String(txt ?? '-'), xPos, curY + rowH / 2 + 1.5, { align });
            });
            curY += rowH;
        });

        return curY;
    };

