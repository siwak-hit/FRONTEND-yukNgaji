            doc.setFont('helvetica', 'bold'); doc.setFontSize(8);
            colAbsen.forEach(c => doc.text(c.label, c.x + c.w / 2, p2Y + rowH / 2 + 1.5, { align: 'center' }));
            p2Y += rowH;

            doc.setFont('helvetica', 'normal');
            doc.setFontSize(8);
            monthlySummary.forEach((row, idx) => {
                if (idx % 2 === 0) {
                    doc.setFillColor(250, 250, 250);
                    colAbsen.forEach(c => doc.rect(c.x, p2Y, c.w, rowH, 'F'));
                }
                doc.rect(margin, p2Y, contentW, rowH);
                colAbsen.slice(1).forEach(c => doc.line(c.x, p2Y, c.x, p2Y + rowH));

                doc.setTextColor(0, 0, 0);
                doc.text(row.label, colAbsen[0].x + 3, p2Y + rowH / 2 + 1.5);

                doc.setTextColor(row.izin > 0 ? 180 : 0, row.izin > 0 ? 120 : 0, 0);
                doc.text(row.izin > 0 ? `${row.izin} hari` : '-', colAbsen[1].x + colAbsen[1].w / 2, p2Y + rowH / 2 + 1.5, { align: 'center' });

                doc.setTextColor(row.alpa > 0 ? 180 : 0, 0, 0);
                doc.text(row.alpa > 0 ? `${row.alpa} hari` : '-', colAbsen[2].x + colAbsen[2].w / 2, p2Y + rowH / 2 + 1.5, { align: 'center' });

                doc.setTextColor(0, 0, 0);
                p2Y += rowH;
            });

            doc.setFillColor(225, 225, 225);
            colAbsen.forEach(c => doc.rect(c.x, p2Y, c.w, rowH, 'F'));
            doc.rect(margin, p2Y, contentW, rowH);
            colAbsen.slice(1).forEach(c => doc.line(c.x, p2Y, c.x, p2Y + rowH));
            doc.setFont('helvetica', 'bold'); doc.setFontSize(8);
            doc.text('TOTAL', colAbsen[0].x + 3, p2Y + rowH / 2 + 1.5);
            doc.text(`${attendanceStatsGlobal.izin} hari`, colAbsen[1].x + colAbsen[1].w / 2, p2Y + rowH / 2 + 1.5, { align: 'center' });
            doc.text(`${attendanceStatsGlobal.alpa} hari`, colAbsen[2].x + colAbsen[2].w / 2, p2Y + rowH / 2 + 1.5, { align: 'center' });
            p2Y += rowH + 8;

        } else {
            doc.setFillColor(240, 255, 244);
            doc.rect(margin, p2Y, contentW, 12, 'F');
            doc.rect(margin, p2Y, contentW, 12);
            doc.setFont('helvetica', 'italic'); doc.setFontSize(9);
            doc.setTextColor(30, 140, 60);
            doc.text('Masya Allah! Tidak ada catatan izin maupun alpa. Kehadiran sempurna!', margin + 3, p2Y + 8);
            doc.setTextColor(0, 0, 0);
            p2Y += 18;
        }

        // ---- G. INSIGHT KEHADIRAN ----
        const insightText = buildAttendanceInsight();
        if (insightText) {
            doc.setFont('helvetica', 'bold'); doc.setFontSize(10);
            doc.text('G. INSIGHT & REKOMENDASI KEHADIRAN', margin, p2Y); p2Y += 6;

            doc.setFont('helvetica', 'normal'); doc.setFontSize(9);
            const insLines  = doc.splitTextToSize(insightText, contentW - 8);
            const insBoxH   = Math.max(16, insLines.length * 4 + 8);
            
            doc.setFillColor(255, 243, 205);
            doc.rect(margin, p2Y, contentW, insBoxH, 'F');
            doc.setFillColor(245, 158, 11);
            doc.rect(margin, p2Y, 3, insBoxH, 'F');
            doc.rect(margin, p2Y, contentW, insBoxH);
            
            doc.setTextColor(0, 0, 0);
            doc.text(insLines, margin + 5, p2Y + 5);
            p2Y += insBoxH;
        }

        return doc;
    };

    // ================================================================
    // SUBMIT FORM RAPORT
    // ================================================================
    document.getElementById('formRaport').onsubmit = async (e) => {
        e.preventDefault();
        const pdfWindow = window.open('', '_blank');
        if (pdfWindow) pdfWindow.document.write('<html><body style="font-family:sans-serif;text-align:center;margin-top:20vh;"><h3>Memproses PDF Raport...</h3></body></html>');
        
        const payload = {
            id: lastRaportData ? lastRaportData.id : null,
            student_id: studentId,
            academic_grades:  { tajwid: document.getElementById('rapTajwid').value, fiqih: document.getElementById('rapFiqih').value, tauhid: document.getElementById('rapTauhid').value, quran: document.getElementById('rapQuran').value },
            behavior_grades:  { kedisiplinan: document.getElementById('rapSikap1').value, akhlak: document.getElementById('rapSikap2').value, keaktifan: document.getElementById('rapSikap3').value },
            teacher_note: document.getElementById('rapNote').value
        };

        try {
            const res = await fetch(`${API_URL}/api/raports`, { 
                method: 'POST', 
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' }, 
                body: JSON.stringify(payload) 
            });
            if (!res.ok) throw new Error();
            lastRaportData = (await res.json()).data;
            
            const doc = generatePdfWithJsPDF(payload, document.getElementById('rapName').value);
            const pdfUrl = URL.createObjectURL(doc.output('blob'));
            if (pdfWindow && !pdfWindow.closed) pdfWindow.location.href = pdfUrl;
            
            closeRaportModal();
            window.showToast?.('success', 'Berhasil', 'Raport tersimpan.');
        } catch (err) {
            if (pdfWindow) pdfWindow.close();
            closeRaportModal();
            window.showToast?.('danger', 'Error', 'Gagal memproses raport.');
        }
    };

    // ================================================================
    // HAFALAN — HELPER
    // ================================================================
    const getSurahById = (id) => JUZ_AMMA.find(s => s.id === id) || null;

    const renderCheckpointBadge = () => {
        const ui = document.getElementById('hafalanBadgeUI');
        if (!ui) return;
        const { current_surah_id, current_ayah } = studentCheckpoint;
        if (current_surah_id === null) {
            ui.innerHTML = '<span class="text-amber-500">Belum diset</span>';
            return;
        }
        const surah = getSurahById(current_surah_id);
        if (!surah) return;
        const sisa = surah.ayahs - current_ayah;
        ui.innerHTML = `
            <span>${surah.name}</span>
            <span class="text-[9px] text-green-500 font-bold block text-center">Ayat ${current_ayah}/${surah.ayahs}</span>
            ${sisa <= 3 ? `<span class="text-[8px] text-amber-500 font-bold block text-center">Sisa ${sisa} lagi tamat!</span>` : ''}
        `;
    };

    // ================================================================
    // HAFALAN — MODAL ONBOARDING
    // ================================================================
    const openOnboardingModal = () => {
        // Isi dropdown surat
        const surahSel = document.getElementById('onboardingSurah');
        surahSel.innerHTML = JUZ_AMMA.map(s =>
            `<option value="${s.id}">${s.id}. ${s.name} (${s.ayahs} ayat)</option>`
        ).join('');

        // Isi dropdown ayat berdasar surat pertama
        const updateAyahOptions = (surahId) => {
            const surah = getSurahById(parseInt(surahId));
            const ayahSel = document.getElementById('onboardingAyah');
            ayahSel.innerHTML = `<option value="0">Belum mulai (ayat 0)</option>` +
                Array.from({ length: surah.ayahs }, (_, i) => i + 1)
                    .map(n => `<option value="${n}">Ayat ${n}</option>`).join('');
        };

        surahSel.onchange = () => updateAyahOptions(surahSel.value);
        updateAyahOptions(surahSel.value);

        document.getElementById('modalOnboarding').classList.replace('hidden', 'flex');
    };

    window.closeOnboardingModal = () =>
        document.getElementById('modalOnboarding').classList.replace('flex', 'hidden');

    window.submitOnboarding = async () => {
        const surah_id = parseInt(document.getElementById('onboardingSurah').value);
        const ayah     = parseInt(document.getElementById('onboardingAyah').value);
        try {
            const res = await fetch(`${API_URL}/api/students/${studentId}/checkpoint`, {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify({ current_surah_id: surah_id, current_ayah: ayah })
            });
            if (!res.ok) throw new Error();
            studentCheckpoint = { current_surah_id: surah_id, current_ayah: ayah };
            renderCheckpointBadge();
            closeOnboardingModal();
            window.showToast?.('success', 'Berhasil', 'Posisi hafalan disimpan!');
        } catch {
            window.showToast?.('danger', 'Error', 'Gagal menyimpan posisi hafalan.');
        }
    };

    // ================================================================
    // HAFALAN — MODAL SETOR HARIAN
    // ================================================================
    const SETOR_OPTIONS = [1, 2, 3, 5, 7, 10];

    window.openHafalanModal = () => {
        const { current_surah_id, current_ayah } = studentCheckpoint;
        if (current_surah_id === null) { openOnboardingModal(); return; }

        const surah = getSurahById(current_surah_id);
        const sisa  = surah.ayahs - current_ayah;

        // Info header
        document.getElementById('hafalanInfo').innerHTML =
            `📖 <b>${surah.name}</b> — Ayat <b>${current_ayah}</b> dari <b>${surah.ayahs}</b>`;

        // Warning label jika mepet tamat
        const warnEl = document.getElementById('hafalanWarning');
        if (sisa <= 3 && sisa > 0) {
            warnEl.textContent = `⚡ ${surah.name} sisa ${sisa} ayat lagi tamat!`;
            warnEl.classList.remove('hidden');
        } else {
            warnEl.classList.add('hidden');
        }

        // ── Grid MAJU ──
        const SETOR_OPTIONS = [1, 2, 3, 5, 7, 10];
        const gridMaju = document.getElementById('hafalanBtnGrid');
        gridMaju.innerHTML = SETOR_OPTIONS.map(n => {
            const disabled = n > sisa;
            return `
                <button onclick="setorHafalan(${n})" ${disabled ? 'disabled' : ''}
                    class="py-3 rounded-xl font-bold text-sm transition-all active:scale-95
                        ${disabled ? 'bg-gray-100 text-gray-300 cursor-not-allowed' : 'bg-green-100 text-green-700 hover:bg-green-200'}">
                    +${n}
                </button>`;
        }).join('');

        // Tombol "Tamatkan sisa" jika sisa ada tapi tidak ada di opsi
        if (sisa > 0 && !SETOR_OPTIONS.includes(sisa)) {
            gridMaju.innerHTML += `
                <button onclick="setorHafalan(${sisa})"
                    class="col-span-4 py-3 rounded-xl font-bold text-sm bg-amber-100 text-amber-700 hover:bg-amber-200 transition-all active:scale-95">
                    🏁 Tamatkan sisa ${sisa} ayat
                </button>`;
        }

        // ── Grid MUNDUR ──
        const MUNDUR_OPTIONS = [1, 2, 3, 5, 7, 10];
        const gridMundur = document.getElementById('hafalanBtnGridMundur');
        gridMundur.innerHTML = MUNDUR_OPTIONS.map(n => {
            // Semua opsi mundur selalu aktif (backend handle cross-surah)
            return `
                <button onclick="setorHafalan(${-n})"
                    class="py-3 rounded-xl font-bold text-sm bg-red-100 text-red-600 hover:bg-red-200 transition-all active:scale-95">
                    −${n}
                </button>`;
        }).join('');

        // Reset ke mode maju tiap buka modal
        setHafalanMode('maju');

        document.getElementById('modalHafalan').classList.replace('hidden', 'flex');
    };

        // ================================================================
    // HAFALAN — EDIT MANUAL (Teacher Override)
    // ================================================================
    window.openEditCheckpointModal = () => {
        const surahSel = document.getElementById('editSurah');
        const { current_surah_id, current_ayah } = studentCheckpoint;

        surahSel.innerHTML = JUZ_AMMA.map(s =>
            `<option value="${s.id}" ${s.id === current_surah_id ? 'selected' : ''}>${s.id}. ${s.name} (${s.ayahs} ayat)</option>`
        ).join('');

        const updateEditAyah = (surahId) => {
            const surah = getSurahById(parseInt(surahId));
            document.getElementById('editAyah').innerHTML =
                `<option value="0">Belum mulai (ayat 0)</option>` +
                Array.from({ length: surah.ayahs }, (_, i) => i + 1)
                    .map(n => `<option value="${n}" ${n === current_ayah && parseInt(surahId) === current_surah_id ? 'selected' : ''}>${n === surah.ayahs ? `Ayat ${n} (TAMAT ✓)` : `Ayat ${n}`}</option>`)
                    .join('');
        };

        surahSel.onchange = () => updateEditAyah(surahSel.value);
        updateEditAyah(current_surah_id || 1);

        // Tutup menu titik tiga jika terbuka
        document.getElementById('hafalanMenu').classList.add('hidden');
        document.getElementById('modalEditCheckpoint').classList.replace('hidden', 'flex');
    };

    window.closeEditCheckpointModal = () =>
        document.getElementById('modalEditCheckpoint').classList.replace('flex', 'hidden');

    window.submitEditCheckpoint = async () => {
        const surah_id = parseInt(document.getElementById('editSurah').value);
        const ayah     = parseInt(document.getElementById('editAyah').value);
        try {
            const res = await fetch(`${API_URL}/api/students/${studentId}/checkpoint`, {
                method: 'PUT',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify({ current_surah_id: surah_id, current_ayah: ayah })
            });
            if (!res.ok) throw new Error();
            studentCheckpoint = { current_surah_id: surah_id, current_ayah: ayah };
            renderCheckpointBadge();
            closeEditCheckpointModal();
            window.showToast?.('success', 'Berhasil', 'Posisi hafalan diperbarui!');
        } catch {
            window.showToast?.('danger', 'Error', 'Gagal memperbarui posisi hafalan.');
        }
    };

        // ================================================================
    // HAFALAN — RESET ONBOARDING
    // ================================================================
    window.toggleHafalanMenu = () => {
        const menu = document.getElementById('hafalanMenu');
        menu.classList.toggle('hidden');
        // Tutup otomatis jika klik di luar
        const close = (e) => {
            if (!menu.contains(e.target) && !e.target.closest('[onclick="toggleHafalanMenu()"]')) {
                menu.classList.add('hidden');
                document.removeEventListener('click', close);
            }
        };
        if (!menu.classList.contains('hidden')) {
            setTimeout(() => document.addEventListener('click', close), 10);
        }
    };

    window.confirmResetHafalan = () => {
        document.getElementById('hafalanMenu').classList.add('hidden');
        if (!confirm('⚠️ Yakin mau reset semua data hafalan anak ini?\n\nData posisi surat & ayat akan kembali ke nol. Log hafalan tetap tersimpan.')) return;
        resetHafalan();
    };

    const resetHafalan = async () => {
        try {
            const res = await fetch(`${API_URL}/api/students/${studentId}/checkpoint`, {
                method: 'DELETE',
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (!res.ok) throw new Error();
            studentCheckpoint = { current_surah_id: null, current_ayah: 0 };
            renderCheckpointBadge();
            window.showToast?.('success', 'Reset Berhasil', 'Data hafalan direset. Onboarding akan muncul saat refresh.');
        } catch {
            window.showToast?.('danger', 'Error', 'Gagal mereset data hafalan.');
        }
    };

    window.closeHafalanModal = () =>
        document.getElementById('modalHafalan').classList.replace('flex', 'hidden');

    window.setorHafalan = async (jumlah) => {
        try {
            const res = await fetch(`${API_URL}/api/students/${studentId}/memorization`, {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify({ student_id: studentId, added_ayahs: jumlah })
            });
            const result = await res.json();
            if (!res.ok) throw new Error(result.message || 'Gagal');

            studentCheckpoint.current_surah_id = result.data.current_surah_id;
            studentCheckpoint.current_ayah     = result.data.current_ayah;

            renderCheckpointBadge();
            closeHafalanModal();

            let msg;
            if (result.data.promoted) {
                msg = result.data.next_surah === 'KHATAM JUZ AMMA 🎉'
                    ? `MASYA ALLAH! ${result.data.prev_surah} tamat! JUZ AMMA KHATAM! 🎉🎉🎉`
                    : `Masya Allah! Tamat ${result.data.prev_surah}! Lanjut → ${result.data.next_surah} 🎉`;
            } else if (result.data.demoted) {
                msg = `Dikoreksi mundur ke ${result.data.next_surah}, ayat ${result.data.current_ayah}.`;
            } else {
                msg = jumlah > 0
                    ? `+${jumlah} ayat tercatat! Semangat! 💪`
                    : `Koreksi −${Math.abs(jumlah)} ayat tersimpan.`;
            }
            window.showToast?.('success', jumlah > 0 ? 'Hafalan Dicatat' : 'Koreksi Disimpan', msg);
        } catch (err) {
            window.showToast?.('danger', 'Error', err.message || 'Gagal mencatat hafalan.');
        }
    };

    // ================================================================
    // HAFALAN — MODE MAJU/MUNDUR di modal harian
    // ================================================================
    let currentHafalanMode = 'maju';

    window.setHafalanMode = (mode) => {
        currentHafalanMode = mode;
        const isMaju = mode === 'maju';

        document.getElementById('tabMaju').className   = `flex-1 py-2 text-[10px] font-bold rounded-xl shadow-sm transition-all uppercase tracking-widest ${isMaju ? 'bg-white text-green-700' : 'text-gray-400 hover:text-gray-600'}`;
        document.getElementById('tabMundur').className = `flex-1 py-2 text-[10px] font-bold rounded-xl shadow-sm transition-all uppercase tracking-widest ${!isMaju ? 'bg-white text-red-600' : 'text-gray-400 hover:text-gray-600'}`;

        document.getElementById('sectionMaju').classList.toggle('hidden', !isMaju);
        document.getElementById('sectionMundur').classList.toggle('hidden', isMaju);
    };

    // ================================================================
    // PATCH generateSystemNote — suntikkan checkpoint ke prompt AI
    // ================================================================
    // (Ganti fungsi generateSystemNote yang sudah ada)
    window.generateSystemNote = async () => {
        const name = document.getElementById('rapName').value;
        const btn  = document.querySelector('button[onclick="generateSystemNote()"]');

        // Terjemahkan checkpoint ke teks
        const surah = getSurahById(studentCheckpoint.current_surah_id);
        const checkpointText = surah
            ? `Pencapaian Hafalan: Surah ${surah.name}, Ayat ${studentCheckpoint.current_ayah} dari ${surah.ayahs}`
            : 'Pencapaian Hafalan: belum diset';

        const payload = {
            studentName: name,
            academic:  {
                tajwid: document.getElementById('rapTajwid').value,
                fiqih:  document.getElementById('rapFiqih').value,
                tauhid: document.getElementById('rapTauhid').value,
                quran:  document.getElementById('rapQuran').value
            },
            behavior: {
                kedisiplinan: document.getElementById('rapSikap1').value,
                akhlak:       document.getElementById('rapSikap2').value,
                keaktifan:    document.getElementById('rapSikap3').value
            },
            checkpointText // dikirim ke backend untuk disuntikkan ke prompt AI
        };

        try {
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Loading...';
            const res = await fetch(`${API_URL}/api/raports/generate-note`, {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const result = await res.json();
            if (res.ok) {
                document.getElementById('rapNote').value = result.data;
                analisisAIGlobal = result.analisis || null;
            }
        } catch (e) { console.error(e); }
        finally { btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles"></i> Generate AI'; }
    };

    // ================================================================
    // DETEKSI ANAK TERTINGGAL — Banner di Tab Tugas AI
    // ================================================================
    const renderLagBanner = (lagData) => {
        // Hapus banner lama jika ada
        document.getElementById('lagBanner')?.remove();

        const SUBJECT_LABEL = { tajwid: 'Tajwid', fiqih: 'Fiqih', tauhid: 'Tauhid' };
        const laggingSubjects = Object.entries(lagData)
            .filter(([, v]) => v.isLagging)
            .map(([subject, v]) => ({ subject, ...v }));

        if (laggingSubjects.length === 0) return; // Tidak ada yang tertinggal

        // Buat banner HTML
        const banner = document.createElement('div');
        banner.id = 'lagBanner';
        banner.className = 'mb-4 bg-amber-50 border border-amber-200 rounded-2xl p-4 space-y-3';

        const itemsHtml = laggingSubjects.map(({ subject, classWeek, studentWeek, missedWeeks }) => {
            const missedLabel = missedWeeks.slice(0, 3).map(w => `Mg-${w}`).join(', ');
            const moreCount   = missedWeeks.length > 3 ? ` +${missedWeeks.length - 3} lagi` : '';
            return `
                <div class="bg-white rounded-xl p-3 border border-amber-100">
                    <div class="flex items-center justify-between mb-1">
                        <span class="text-xs font-black text-amber-700 uppercase">${SUBJECT_LABEL[subject]}</span>
                        <span class="text-[9px] font-bold bg-amber-100 text-amber-600 px-2 py-0.5 rounded-full">
                            Kelas: Mg-${classWeek} | Anak: Mg-${studentWeek || '0'}
                        </span>
                    </div>
                    <p class="text-[10px] text-gray-600 leading-relaxed">
                        Belum ujian pertemuan: <b class="text-amber-700">${missedLabel}${moreCount}</b>
                    </p>
                    <button onclick="openSusulanModal('${subject}', ${JSON.stringify(missedWeeks)})"
                        class="mt-2 w-full py-1.5 bg-amber-500 text-white text-[10px] font-bold rounded-lg active:scale-95 transition-all">
                        <i class="fa-solid fa-graduation-cap mr-1"></i> Berikan Ujian Susulan Mg-${missedWeeks[0]}
                    </button>
                </div>`;
        }).join('');

        banner.innerHTML = `
            <div class="flex items-center gap-2 mb-1">
                <i class="fa-solid fa-triangle-exclamation text-amber-500"></i>
                <p class="text-xs font-black text-amber-800 uppercase tracking-wide">Anak Ini Tertinggal!</p>
            </div>
            ${itemsHtml}`;

        // Sisipkan di atas todoContainer
        const todoContainer = document.getElementById('todoContainer');
        todoContainer.parentElement.insertBefore(banner, todoContainer);
    };

    // ================================================================
    // MODAL UJIAN SUSULAN (trigger dari banner)
    // ================================================================
    let pendingSusulanUrl = ''; // Variabel sementara untuk menyimpan URL tujuan

    window.openSusulanModal = (subject, missedWeeks) => {
        const targetWeek = missedWeeks[0];
        
        // 1. Update teks di dalam modal agar dinamis
        const msgEl = document.getElementById('susulanMessage');
        msgEl.innerHTML = `Buka halaman ujian susulan <b>${subject.toUpperCase()}</b> untuk <b>Pertemuan ${targetWeek}</b>?`;
        
        // 2. Simpan URL tujuan
        pendingSusulanUrl = `/consultations/fill?id=${studentId}&subject=${subject}&week=${targetWeek}`;
        
        // 3. Tampilkan modal
        document.getElementById('modalSusulan').classList.replace('hidden', 'flex');
    };

    window.closeSusulanModal = () => {
        document.getElementById('modalSusulan').classList.replace('flex', 'hidden');
        pendingSusulanUrl = ''; // Bersihkan memori
    };

    document.getElementById('btnConfirmSusulan').onclick = () => {
        // Tombol berubah jadi loading sebentar biar kerasa responsif
        const btn = document.getElementById('btnConfirmSusulan');
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Membuka...';
        btn.classList.add('opacity-80', 'pointer-events-none');

        // Pindah halaman
        if (pendingSusulanUrl) window.location.href = pendingSusulanUrl;
    };

    fetchData(); // Pastikan ini tetap ada di paling bawah
</script>