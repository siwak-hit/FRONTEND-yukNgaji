    const convertToGrade = (s) => s >= 85 ? 'A' : s >= 70 ? 'B' : s >= 60 ? 'C' : 'D';

    window.openRaportModal = () => {
        document.getElementById('rapName').value = document.getElementById('studentName').innerText;
        hapusFotoRaport();

        // --- RUMUS BOBOT AKADEMIK (30% Tugas, 70% Ujian) ---
        const calcWeightedScore = (subject, avgElementId) => {
            const weeklyScore = parseInt(document.getElementById(avgElementId).innerText) || 0;
            const examScore = studentExamResults.find(e => e.subject === subject)?.score || 0;
            
            // Hitung nilai akhir berbobot
            const finalScore = Math.round((weeklyScore * 0.3) + (examScore * 0.7));

            // Update UI teks breakdown di modal
            document.getElementById(`rapNum${subject.charAt(0).toUpperCase() + subject.slice(1)}Weekly`).innerText = weeklyScore;
            document.getElementById(`rapNum${subject.charAt(0).toUpperCase() + subject.slice(1)}Exam`).innerText = examScore;

            return convertToGrade(finalScore);
        };

        document.getElementById('rapTajwid').value = calcWeightedScore('tajwid', 'avgTajwid');
        document.getElementById('rapFiqih').value  = calcWeightedScore('fiqih', 'avgFiqih');
        document.getElementById('rapTauhid').value = calcWeightedScore('tauhid', 'avgTauhid');

        document.getElementById('rapHadir').innerText = attendanceStatsGlobal.hadir;
        document.getElementById('rapIzin').innerText  = attendanceStatsGlobal.izin;
        document.getElementById('rapAlpa').innerText  = attendanceStatsGlobal.alpa;

        let avgAkhlak = 0, avgDisiplinKuesioner = 0, avgAktif = 0, hasKonsulData = false;
        if (globalConsultations?.data?.length > 0) {
            hasKonsulData = true;
            const total = globalConsultations.data.length;
            avgAkhlak           = globalConsultations.data.reduce((s, c) => s + c.akhlak_score,   0) / total;
            avgDisiplinKuesioner = globalConsultations.data.reduce((s, c) => s + c.disiplin_score, 0) / total;
            avgAktif            = globalConsultations.data.reduce((s, c) => s + c.aktif_score,     0) / total;
        }

        const totalValidDays = attendanceStatsGlobal.hadir + attendanceStatsGlobal.izin + attendanceStatsGlobal.alpa;
        let attendanceScore = 100;
        if (totalValidDays > 0) attendanceScore = (attendanceStatsGlobal.hadir / totalValidDays) * 100;
        const finalDisiplin = hasKonsulData ? (avgDisiplinKuesioner + attendanceScore) / 2 : attendanceScore;

        if (lastRaportData) {
            document.getElementById('rapQuran').value  = lastRaportData.academic_grades.quran           || 'A';
            document.getElementById('rapSikap1').value = lastRaportData.behavior_grades.kedisiplinan    || 'A';
            document.getElementById('rapSikap2').value = lastRaportData.behavior_grades.akhlak          || 'A';
            document.getElementById('rapSikap3').value = lastRaportData.behavior_grades.keaktifan       || 'A';
            document.getElementById('rapNote').value   = lastRaportData.teacher_note                    || '';
        } else {
            document.getElementById('rapQuran').value  = 'A';
            document.getElementById('rapSikap1').value = (totalValidDays > 0 || hasKonsulData) ? convertToGrade(finalDisiplin) : 'C';
            document.getElementById('rapSikap2').value = hasKonsulData ? convertToGrade(avgAkhlak) : 'C';
            document.getElementById('rapSikap3').value = hasKonsulData ? convertToGrade(avgAktif)  : 'C';
            document.getElementById('rapNote').value   = '';
        }

        document.getElementById('modalRaport').classList.replace('hidden', 'flex');
