<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js" is:inline></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js" is:inline></script>

<script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const token = localStorage.getItem('token');
    const pathParts = window.location.pathname.split('/');
    const studentId = pathParts[pathParts.length - 1];

    if (!token) window.location.replace('/');

    // ================================================================
    // STUDENT NAVIGATOR — list semua siswa, navigasi prev/next, search
    // ================================================================
    let allStudents = [];       // [{id, name, grade}, ...]
    let currentStudentIndex = -1;
    let searchDebounceTimer = null;
    let studentExamResults = [];

    const loadAllStudents = async () => {
        try {
            const res = await fetch(`${API_URL}/api/students`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const json = await res.json();
            allStudents = (json.data || []).sort((a, b) => a.name.localeCompare(b.name, 'id'));
            currentStudentIndex = allStudents.findIndex(s => String(s.id) === String(studentId));
            updateNavigatorUI();
        } catch (e) {
            console.error('Gagal load daftar siswa:', e);
        }
    };

    const updateNavigatorUI = () => {
        const counter = document.getElementById('studentNavCounter');
        const input   = document.getElementById('studentSearchInput');
        const btnPrev = document.getElementById('btnPrevStudent');
        const btnNext = document.getElementById('btnNextStudent');

        if (currentStudentIndex >= 0) {
            counter.textContent = `${currentStudentIndex + 1}/${allStudents.length}`;
            input.placeholder   = allStudents[currentStudentIndex]?.name || 'Cari nama siswa...';
        } else {
            counter.textContent = `-/${allStudents.length}`;
        }

        btnPrev.disabled = currentStudentIndex <= 0;
        btnNext.disabled = currentStudentIndex >= allStudents.length - 1;
    };

    window.navigateStudent = (direction) => {
        const newIndex = currentStudentIndex + direction;
        if (newIndex < 0 || newIndex >= allStudents.length) return;
        const target = allStudents[newIndex];
        window.location.href = `/student/${target.id}`;
    };

    // Search dengan debounce
    const renderDropdown = (query) => {
        const dropdown = document.getElementById('studentSearchDropdown');
        if (!query.trim()) {
            dropdown.classList.add('hidden');
            dropdown.innerHTML = '';
            return;
        }

        const q = query.toLowerCase();
        const matched = allStudents.filter(s => s.name.toLowerCase().includes(q)).slice(0, 8);

        if (matched.length === 0) {
            dropdown.innerHTML = `<div class="px-4 py-3 text-xs text-gray-400 text-center">Tidak ditemukan</div>`;
            dropdown.classList.remove('hidden');
            return;
        }

        dropdown.innerHTML = matched.map((s, i) => {
            const highlighted = s.name.replace(
                new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi'),
                '<mark class="bg-yellow-100 text-yellow-800 rounded">$1</mark>'
            );
            const isActive = String(s.id) === String(studentId);
            return `
                <button onclick="goToStudent('${s.id}')"
                    class="w-full flex items-center gap-3 px-4 py-3 text-left hover:bg-gray-50 transition-colors ${isActive ? 'bg-green-50' : ''} ${i > 0 ? 'border-t border-gray-50' : ''}">
                    <div class="w-7 h-7 rounded-lg bg-green-100 text-green-600 text-[10px] font-black flex items-center justify-center flex-shrink-0">
                        ${s.name.substring(0, 2).toUpperCase()}
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-bold text-gray-800 truncate">${highlighted}</p>
                        <p class="text-[10px] text-gray-400 font-medium uppercase tracking-wide truncate">${s.grade || ''}</p>
                    </div>
                    ${isActive ? '<i class="fa-solid fa-circle-check text-green-500 text-xs flex-shrink-0"></i>' : ''}
                </button>`;
        }).join('');

        dropdown.classList.remove('hidden');
    };

    window.goToStudent = (id) => {
        document.getElementById('studentSearchDropdown').classList.add('hidden');
        document.getElementById('studentSearchInput').value = '';
        if (String(id) !== String(studentId)) {
            window.location.href = `/student/${id}`;
        }
    };

    // Event listeners untuk search
    document.getElementById('studentSearchInput').addEventListener('input', (e) => {
        clearTimeout(searchDebounceTimer);
        const val = e.target.value;
        searchDebounceTimer = setTimeout(() => renderDropdown(val), 280);
    });

    document.getElementById('studentSearchInput').addEventListener('focus', (e) => {
        if (e.target.value.trim()) renderDropdown(e.target.value);
    });

    // Tutup dropdown kalau klik di luar
    document.addEventListener('click', (e) => {
        const input    = document.getElementById('studentSearchInput');
        const dropdown = document.getElementById('studentSearchDropdown');
        if (!input.contains(e.target) && !dropdown.contains(e.target)) {
            dropdown.classList.add('hidden');
        }
    });

    // Panggil saat halaman load
    loadAllStudents();

    // ================================================================
    // TOGGLE STUDENT NAVIGATOR PANEL
    // ================================================================
    let navPanelOpen = false;

    window.toggleStudentNav = () => {
        const panel    = document.getElementById('studentNavPanel');
        const btn      = document.getElementById('btnToggleNav');
        const input    = document.getElementById('studentSearchInput');
        navPanelOpen   = !navPanelOpen;

        if (navPanelOpen) {
            panel.style.maxHeight  = '260px';
            panel.style.opacity    = '1';
            panel.style.marginTop  = '12px';
            btn.classList.remove('text-gray-400', 'bg-white', 'border-gray-100');
            btn.classList.add('text-green-600', 'bg-green-50', 'border-green-200');
            setTimeout(() => {
                panel.classList.remove('overflow-hidden');
                panel.classList.add('overflow-visible');
                input.focus();
            }, 320);
        } else {
            panel.classList.remove('overflow-visible');
            panel.classList.add('overflow-hidden');
            panel.style.maxHeight  = '0';
            panel.style.opacity    = '0';
            panel.style.marginTop  = '0';
            btn.classList.remove('text-green-600', 'bg-green-50', 'border-green-200');
            btn.classList.add('text-gray-400', 'bg-white', 'border-gray-100');
            document.getElementById('studentSearchDropdown').classList.add('hidden');
            input.value = '';
        }
    };
    
    let myChart = null;
    let attChart = null;
    let currentAvgRaw = 0;
    let lastRaportData = null;
    let attendanceStatsGlobal = { hadir: 0, izin: 0, alpa: 0 };
    let globalConsultations = null;
    let attendanceDetailGlobal = { izinDates: [], alpaDates: [] };
    let analisisAIGlobal = null;

    // ================================================================
    // DATA JUZ AMMA (Disusun mundur dari An-Nas ke An-Naba')
    // ================================================================
    const JUZ_AMMA = [
      { id: 1, name: "An-Nas", ayahs: 6 },
      { id: 2, name: "Al-Falaq", ayahs: 5 },
      { id: 3, name: "Al-Ikhlas", ayahs: 4 },
      { id: 4, name: "Al-Masad", ayahs: 5 },
      { id: 5, name: "An-Nasr", ayahs: 3 },
      { id: 6, name: "Al-Kafirun", ayahs: 6 },
      { id: 7, name: "Al-Kausar", ayahs: 3 },
      { id: 8, name: "Al-Ma'un", ayahs: 7 },
      { id: 9, name: "Quraisy", ayahs: 4 },
      { id: 10, name: "Al-Fil", ayahs: 5 },
      { id: 11, name: "Al-Humazah", ayahs: 9 },
      { id: 12, name: "Al-'Asr", ayahs: 3 },
      { id: 13, name: "At-Takasur", ayahs: 8 },
      { id: 14, name: "Al-Qari'ah", ayahs: 11 },
      { id: 15, name: "Al-'Adiyat", ayahs: 11 },
      { id: 16, name: "Az-Zalzalah", ayahs: 8 },
      { id: 17, name: "Al-Bayyinah", ayahs: 8 },
      { id: 18, name: "Al-Qadr", ayahs: 5 },
      { id: 19, name: "Al-'Alaq", ayahs: 19 },
      { id: 20, name: "At-Tin", ayahs: 8 },
      { id: 21, name: "Al-Insyirah", ayahs: 8 },
      { id: 22, name: "Ad-Duha", ayahs: 11 },
      { id: 23, name: "Al-Lail", ayahs: 21 },
      { id: 24, name: "Asy-Syams", ayahs: 15 },
      { id: 25, name: "Al-Balad", ayahs: 20 },
      { id: 26, name: "Al-Fajr", ayahs: 30 },
      { id: 27, name: "Al-Gasyiyah", ayahs: 26 },
      { id: 28, name: "Al-A'la", ayahs: 19 },
      { id: 29, name: "At-Tariq", ayahs: 17 },
      { id: 30, name: "Al-Buruj", ayahs: 22 },
      { id: 31, name: "Al-Insyiqaq", ayahs: 25 },
      { id: 32, name: "Al-Mutaffifin", ayahs: 36 },
      { id: 33, name: "Al-Infitar", ayahs: 19 },
      { id: 34, name: "At-Takwir", ayahs: 29 },
      { id: 35, name: "Abasa", ayahs: 42 },
      { id: 36, name: "An-Nazi'at", ayahs: 46 },
      { id: 37, name: "An-Naba'", ayahs: 40 }
    ];

    // State hafalan
    let studentCheckpoint = { current_surah_id: null, current_ayah: 0 }; // diisi saat fetchData

    // [BARU] State foto raport
    let selectedFotoBase64 = null; // null = tidak pakai foto
    let selectedFotoUrl    = null;

    // --- CHARTS INIT ---
    const initChart = (history) => {
        const canvas = document.getElementById('progressChart');
        if (!canvas) return;
        if (myChart) myChart.destroy();
        
        // 1. Kumpulkan SEMUA minggu yang ada (Entah dia ngerjain mapel apa saja)
        const allWeeks = new Set([
            ...history.tajwid.map(i => i.week),
            ...history.fiqih.map(i => i.week),
            ...history.tauhid.map(i => i.week)
        ]);
        
        // 2. Urutkan minggu dari terkecil ke terbesar
        const sortedWeeks = Array.from(allWeeks).sort((a,b) => a-b);
        const labels = sortedWeeks.length > 0 ? sortedWeeks.map(w => `Mg-${w}`) : ['Mg-1'];

        // 3. Petakan data agar pas dengan sumbu X (Jika tidak ada nilai di minggu itu, jadikan null)
        const mapData = (arr) => sortedWeeks.map(w => {
            const found = arr.find(item => item.week === w);
            return found ? found.score : null; 
        });

        myChart = new Chart(canvas.getContext('2d'), {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    { label: 'Tajwid', data: mapData(history.tajwid), borderColor: '#22c55e', backgroundColor: '#22c55e22', tension: 0.4, fill: true },
                    { label: 'Fiqih', data: mapData(history.fiqih), borderColor: '#3b82f6', tension: 0.4 },
                    { label: 'Tauhid', data: mapData(history.tauhid), borderColor: '#a855f7', tension: 0.4 }
                ]
            },
            options: { 
                responsive: true, 
                maintainAspectRatio: false, 
                plugins: { legend: { display: false } }, 
                scales: { y: { min: 0, max: 100 } },
                spanGaps: true // Sambung garis jika ada minggu yang bolong
            }
        });
    };

    const initAttChart = (stats) => {
        const canvas = document.getElementById('attendanceChart');
        if (!canvas) return;
        if (attChart) attChart.destroy();
        attChart = new Chart(canvas.getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: ['Hadir', 'Izin', 'Alpa'],
                datasets: [{ data: [stats.hadir, stats.izin, stats.alpa], backgroundColor: ['#22c55e', '#f59e0b', '#ef4444'], borderWidth: 0 }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, cutout: '70%' }
        });
    };

    let hasCan = false;
    let lastReceived = null;

    const infoBtn  = document.getElementById('infoKalengBtn');
    const modal    = document.getElementById('modalKaleng');
    const closeBtn = document.getElementById('closeModalKaleng');
    const messageEl = document.getElementById('kalengMessage');

    function getKalengMessage() {
        if (hasCan) return "⚠️ Anak ini belum balikkin kaleng infaq! (Jangan dikasih kaleng baru).";
        if (!lastReceived || lastReceived === "null") return "Anak ini belum pernah dikasih kaleng. Bisa diberikan pada Senin malam terdekat.";

        const nextDate = new Date(lastReceived);
        nextDate.setDate(nextDate.getDate() + 14);
        const today = new Date(); today.setHours(0,0,0,0); nextDate.setHours(0,0,0,0);
        const diffDays = Math.ceil((nextDate - today) / (1000 * 60 * 60 * 24));
        const tglStr = nextDate.toLocaleDateString('id-ID', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });

        if (diffDays > 0)  return `Belum dikasih kaleng infaq. Jangan lupa kasih <b>${diffDays} hari lagi</b><br><br><span class="text-sm text-gray-500">(${tglStr})</span>`;
        if (diffDays === 0) return `Belum dikasih kaleng infaq. <b>Bagikan malam ini!</b><br><br><span class="text-sm text-gray-500">(${tglStr})</span>`;
        return `Belum dikasih kaleng infaq. Sudah terlewat ${Math.abs(diffDays)} hari dari jadwal.<br><br><span class="text-sm text-gray-500">(Jadwal: ${tglStr})</span>`;
    }

    infoBtn.addEventListener('click', () => { messageEl.innerHTML = getKalengMessage(); modal.classList.remove('hidden'); });
    closeBtn.addEventListener('click', () => modal.classList.add('hidden'));

    // --- FETCH DATA ---
    const fetchData = async () => {
        try {
            const headers = { 'Authorization': `Bearer ${token}` };
            const [stdRes, progRes, todoRes, consRes, rapRes, attRes, lagRes, examRes] = await Promise.all([
                fetch(`${API_URL}/api/students/${studentId}`, { headers }),
                fetch(`${API_URL}/api/students/${studentId}/progress`, { headers }),
                fetch(`${API_URL}/api/students/${studentId}/todos`, { headers }),
                fetch(`${API_URL}/api/students/${studentId}/consultations`, { headers }),
                fetch(`${API_URL}/api/students/${studentId}/raports`, { headers }),
                fetch(`${API_URL}/api/students/${studentId}/attendance`, { headers }),
                fetch(`${API_URL}/api/students/${studentId}/lag-status`, { headers }),
                fetch(`${API_URL}/api/exams/student/${studentId}/results`, { headers }) // <--- INI TAMBAHANNYA
            ]);
            
            const examData = await examRes.json();
            studentExamResults = examData.data || [];

            const student  = await stdRes.json();
            const progress = await progRes.json();
            const todos    = await todoRes.json();
            globalConsultations = await consRes.json();
            const raports  = await rapRes.json();
            const attendance = await attRes.json();
            const lagStatus  = await lagRes.json();

            // Render banner tertinggal di tab Todo
            if (lagStatus.data) renderLagBanner(lagStatus.data);

            if (raports.data?.length > 0) lastRaportData = raports.data[0];

            document.getElementById('studentName').innerText    = student.data.name;
            document.getElementById('studentGrade').innerText   = student.data.grade;
            document.getElementById('studentInitial').innerText = student.data.name.substring(0, 2).toUpperCase();

            // Simpan checkpoint hafalan
            studentCheckpoint = {
                current_surah_id: student.data.current_surah_id ?? null,
                current_ayah:     student.data.current_ayah     ?? 0,
            };

            // Tampilkan badge pencapaian hafalan di profil
            renderCheckpointBadge();

            // Onboarding: tampilkan modal jika belum punya checkpoint
            if (studentCheckpoint.current_surah_id === null) {
                openOnboardingModal();
            }

            hasCan = student.data.has_infaq_can;
            lastReceived = student.data.last_can_received_at;
            const btnKaleng = document.getElementById('infoKalengBtn');
            const baseShape = 'w-10 h-10 rounded-xl shadow-sm flex items-center justify-center active:scale-95 transition-all border';
            if (hasCan) {
                btnKaleng.className = `${baseShape} bg-red-50 text-red-500 border-red-200`;
                btnKaleng.title = '⚠️ Belum Mengembalikan Kaleng (Klik info)';
            } else {
                btnKaleng.className = `${baseShape} bg-green-50 text-green-600 border-green-200`;
                btnKaleng.title = '⚠️ Belum dikasih kaleng (Klik info)';
            }
            btnKaleng.innerHTML = '<i class="fa-solid fa-jar text-lg"></i>';

            if (progress.data) {
                initChart(progress.data);
                const lastT  = progress.data.tajwid.slice(-1)[0]?.score || 0;
                const lastF  = progress.data.fiqih.slice(-1)[0]?.score  || 0;
                const lastTh = progress.data.tauhid.slice(-1)[0]?.score || 0;
                document.getElementById('avgTajwid').innerText = lastT;
                document.getElementById('avgFiqih').innerText  = lastF;
                document.getElementById('avgTauhid').innerText = lastTh;
                currentAvgRaw = (lastT + lastF + lastTh) / 3;
            }

            if (attendance.data) {
                const { stats, detail, todayStatus, performance } = attendance.data;
                attendanceStatsGlobal  = stats;
                attendanceDetailGlobal = detail || { izinDates: [], alpaDates: [] };
                
                initAttChart(stats);
                document.getElementById('statHadir').innerText       = stats.hadir;
                document.getElementById('statIzin').innerText        = stats.izin;
                document.getElementById('statAlpa').innerText        = stats.alpa;
                document.getElementById('statPerformance').innerText = performance;

                const badgeUI = document.getElementById('todayStatusUI');
                if (todayStatus === 'hadir')              badgeUI.innerHTML = '<i class="fa-solid fa-check text-green-500"></i> <span class="text-green-600">Hadir</span>';
                else if (todayStatus?.startsWith('izin')) badgeUI.innerHTML = '<i class="fa-solid fa-envelope text-amber-500"></i> <span class="text-amber-600">Izin</span>';
                else if (todayStatus === 'alpa')          badgeUI.innerHTML = '<i class="fa-solid fa-xmark text-red-500"></i> <span class="text-red-600">Alpa</span>';
                else                                      badgeUI.innerHTML = '<i class="fa-solid fa-circle-question text-gray-400"></i> <span class="text-gray-500">Belum</span>';
            }

            const todoContainer = document.getElementById('todoContainer');
            todoContainer.innerHTML = todos.data.length ? todos.data.map(item => `
                <div class="bg-white p-4 rounded-2xl border border-gray-100 shadow-sm flex items-start gap-4">
                    <button onclick="toggleTodo('${item.id}', '${item.status}')" class="mt-1 w-6 h-6 rounded-lg border-2 flex-shrink-0 flex items-center justify-center transition-colors ${item.status === 'done' ? 'bg-green-500 border-green-500 text-white' : 'border-gray-200 text-transparent'}"><i class="fa-solid fa-check text-[10px]"></i></button>
                    <div><h4 class="font-bold text-gray-800 text-sm ${item.status === 'done' ? 'line-through opacity-50' : ''}">${item.title}</h4><p class="text-xs text-gray-500 mt-1">${item.description}</p></div>
                </div>
            `).join('') : '<p class="text-center text-gray-400 text-sm py-4">Belum ada tugas.</p>';

            const consContainer = document.getElementById('consContainer');
            consContainer.innerHTML = globalConsultations.data.length ? globalConsultations.data.map(item => `
                <div class="bg-white p-5 rounded-3xl border border-gray-100 shadow-sm space-y-3">
                    <div class="flex justify-between items-center"><span class="text-[10px] font-bold bg-blue-50 text-blue-600 px-2 py-1 rounded-md uppercase">Mg ${item.week} • ${item.subject}</span><span class="text-[10px] text-gray-400 font-bold uppercase">${new Date(item.created_at).toLocaleDateString('id-ID')}</span></div>
                    <div class="grid grid-cols-3 gap-2 py-2 border-y border-dashed border-gray-100">
                        <div class="text-center"><p class="text-[9px] text-gray-400 font-bold uppercase">Akhlak</p><p class="text-sm font-black text-green-600">${item.akhlak_score}</p></div>
                        <div class="text-center border-x border-dashed border-gray-100"><p class="text-[9px] text-gray-400 font-bold uppercase">Disiplin</p><p class="text-sm font-black text-blue-600">${item.disiplin_score}</p></div>
                        <div class="text-center"><p class="text-[9px] text-gray-400 font-bold uppercase">Keaktifan</p><p class="text-sm font-black text-purple-600">${item.aktif_score}</p></div>
                    </div>
                    ${item.image_url ? `<img src="${item.image_url}" class="w-full h-48 object-cover object-top rounded-2xl border border-gray-100 mt-2 shadow-sm" alt="Foto Konsul">` : ''}
                </div>
            `).join('') : '<p class="text-center text-gray-400 text-sm py-4">Belum ada riwayat kuesioner.</p>';

        } catch (error) { console.error('fetchData Error:', error); }
    };

    window.toggleTodo = async (id, status) => { /* logic update todo... */ await fetchData(); };

    // --- SWITCHERS ---
    const setupTabs = (btn1, btn2, cnt1, cnt2) => {
        const btnAct = "flex-1 py-2.5 text-[10px] font-bold bg-white text-blue-600 rounded-xl shadow-sm transition-all uppercase tracking-widest";
        const btnPas = "flex-1 py-2.5 text-[10px] font-bold text-gray-400 hover:text-gray-600 transition-all uppercase tracking-widest";
