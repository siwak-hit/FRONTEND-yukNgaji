---
import Layout from '../../layouts/Layout.astro';
import Toast from '../../components/Toast.astro';
---

<Layout title="Exam Builder - yukNgaji">
    <div class="min-h-screen bg-gray-50 flex flex-col pb-32">
        
        <header class="sticky top-0 z-50 bg-white border-b border-gray-100 px-4 py-3 flex items-center justify-between">
            <div class="flex items-center gap-3 min-w-0">
              <button onclick="handleBack()" 
                class="w-10 h-10 bg-gray-50 hover:bg-gray-100 rounded-xl flex items-center justify-center text-gray-500 active:scale-95 transition"
                title="Kembali">
                <i class="fa-solid fa-chevron-left text-sm"></i>
              </button>
          
              <div class="min-w-0">
                <h1 id="uiTitle" class="font-bold text-gray-800 text-sm truncate">Memuat...</h1>
                <p id="uiMeta" class="text-[10px] font-semibold text-gray-400 uppercase tracking-widest truncate">-</p>
              </div>
            </div>
          
            <div class="flex items-center gap-2">
              <button onclick="previewExam()" 
                class="w-10 h-10 bg-indigo-50 hover:bg-indigo-100 text-indigo-600 rounded-xl flex items-center justify-center active:scale-95 transition border border-indigo-100"
                title="Preview (POV Siswa)">
                <i class="fa-solid fa-eye text-sm"></i>
              </button>
          
              <button id="btnSaveExam" onclick="saveExamAction()" 
                class="w-10 h-10 bg-gray-100 hover:bg-gray-200 text-gray-600 rounded-xl flex items-center justify-center active:scale-95 transition disabled:opacity-80 disabled:cursor-not-allowed"
                title="Simpan">
                <i class="fa-solid fa-save text-sm"></i>
              </button>
          
              <button id="btnTogglePublish" onclick="publishExamToggle()" 
                class="w-10 h-10 bg-green-600 hover:bg-green-700 text-white rounded-xl flex items-center justify-center active:scale-95 transition shadow-sm"
                title="Terbitkan Ujian">
                <i id="iconTogglePublish" class="fa-solid fa-paper-plane text-sm"></i>
              </button>
            </div>
        </header>

        <main class="flex-1 px-6 py-6 max-w-2xl mx-auto w-full">
            <div id="alertMinQuestions" class="bg-amber-50 border border-amber-200 p-4 rounded-2xl mb-6 flex items-start gap-3">
                <i class="fa-solid fa-circle-exclamation text-amber-500 mt-0.5"></i>
                <div>
                    <h4 class="text-sm font-bold text-amber-800">Status: Draft</h4>
                    <p class="text-xs text-amber-700/80 mt-1">Ujian belum bisa dikerjakan siswa. Anda wajib memiliki <b>minimal 10 soal</b> untuk dapat menerbitkan (Publish) ujian ini.</p>
                </div>
            </div>

            <div id="questionsContainer" class="space-y-6"></div>

            <button onclick="addEmptyQuestion()" class="w-full py-4 mt-6 bg-white border-2 border-dashed border-gray-300 text-gray-500 font-bold rounded-2xl hover:border-green-500 hover:text-green-600 transition-colors active:scale-95 flex items-center justify-center gap-2">
                <i class="fa-solid fa-plus"></i> Tambah Soal Baru
            </button>
        </main>
    </div>

    <div id="modalConfirmBack" class="fixed inset-0 bg-black/60 z-[100] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-sm rounded-2xl p-6 shadow-2xl relative animate-slide-up text-center border border-gray-100">
            <div class="w-16 h-16 bg-amber-50 text-amber-500 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4 border border-amber-100 shadow-inner">
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>
            <h3 class="font-black text-gray-800 text-lg mb-2">Perubahan Belum Disimpan!</h3>
            <p class="text-xs font-bold text-gray-500 leading-relaxed mb-6">
                Anda memiliki soal yang baru diketik dan belum disimpan. Yakin ingin keluar dari editor?
            </p>
            <div class="flex gap-3">
                <button onclick="closeBackModal()" class="flex-1 py-3 bg-gray-100 text-gray-500 font-bold rounded-xl active:scale-95 transition-all">Batal</button>
                <button onclick="forceBack()" class="flex-1 py-3 bg-red-600 text-white font-bold rounded-xl shadow-md shadow-red-600/20 active:scale-95 transition-all">Ya, Keluar</button>
            </div>
        </div>
    </div>

    <div id="modalConfirmPublish" class="fixed inset-0 bg-black/60 z-[100] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-sm rounded-2xl p-6 shadow-2xl relative animate-slide-up text-center border border-gray-100">
            <div id="publishModalIconWrap" class="w-16 h-16 bg-indigo-50 text-indigo-500 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4 border border-indigo-100 shadow-inner">
                <i id="publishModalIcon" class="fa-solid fa-paper-plane"></i>
            </div>
            <h3 id="publishModalTitle" class="font-black text-gray-800 text-lg mb-2">Terbitkan Ujian?</h3>
            <p id="publishModalDesc" class="text-xs font-bold text-gray-500 leading-relaxed mb-6">
                Ujian ini akan segera aktif dan langsung dapat diakses oleh siswa. Pastikan semua soal dan kunci jawaban sudah benar.
            </p>
            <div class="flex gap-3">
                <button onclick="closePublishModal()" class="flex-1 py-3 bg-gray-100 text-gray-500 font-bold rounded-xl active:scale-95 transition-all">Batal</button>
                <button id="btnConfirmPublish" class="flex-1 py-3 bg-indigo-600 text-white font-bold rounded-xl shadow-md shadow-indigo-600/20 active:scale-95 transition-all">Terbitkan</button>
            </div>
        </div>
    </div>
    
    <Toast />
</Layout>

<script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const token = localStorage.getItem('token');
    const examId = window.location.pathname.split('/').pop();

    let examConfig = {};
    let questionsData = [];
    
    // Pelacak Perubahan & Proses
    let isDirty = false; 
    let isSaving = false;

    // --- UI MANAGER: TOMBOL SIMPAN ---
    const setDirtyState = (state) => {
        isDirty = state;
        const btnSave = document.getElementById('btnSaveExam');
        if (!btnSave) return;

        if (state) {
            btnSave.disabled = false;
            btnSave.innerHTML = '<i class="fa-solid fa-save text-sm"></i>';
            btnSave.classList.remove('bg-green-50', 'text-green-600');
            btnSave.classList.add('bg-gray-100', 'text-gray-600', 'hover:bg-gray-200');
            btnSave.title = "Simpan Perubahan";
        } else {
            btnSave.disabled = true;
            btnSave.innerHTML = '<i class="fa-solid fa-check text-sm"></i>';
            btnSave.classList.remove('bg-gray-100', 'text-gray-600', 'hover:bg-gray-200');
            btnSave.classList.add('bg-green-50', 'text-green-600');
            btnSave.title = "Sudah Tersimpan";
        }
    };

    // --- UI MANAGER: SWITCH PUBLISHED / DRAFT ---
    const updatePublishUI = (isActive) => {
        const btnToggle = document.getElementById('btnTogglePublish');
        const iconToggle = document.getElementById('iconTogglePublish');
        const alertBox = document.getElementById('alertMinQuestions');

        if (isActive) {
            // Mode Aktif: Ubah ke mode Tarik ke Draft
            btnToggle.className = "w-10 h-10 bg-amber-500 hover:bg-amber-600 text-white rounded-xl flex items-center justify-center active:scale-95 transition shadow-sm";
            btnToggle.title = "Tarik ke Draft";
            iconToggle.className = "fa-solid fa-folder-open text-sm";
            
            alertBox.className = "bg-green-50 border border-green-200 p-4 rounded-2xl mb-6 flex items-start gap-3";
            alertBox.innerHTML = `<i class="fa-solid fa-check-circle text-green-500 mt-0.5"></i><div><h4 class="text-sm font-bold text-green-800">Status: Published (Aktif)</h4><p class="text-xs text-green-700/80 mt-1">Ujian ini sudah bisa diakses dan dikerjakan oleh siswa di Portal Ujian[cite: 1, 2].</p></div>`;
        } else {
            // Mode Draft: Ubah ke mode Terbitkan
            btnToggle.className = "w-10 h-10 bg-green-600 hover:bg-green-700 text-white rounded-xl flex items-center justify-center active:scale-95 transition shadow-sm";
            btnToggle.title = "Terbitkan Ujian";
            iconToggle.className = "fa-solid fa-paper-plane text-sm";

            alertBox.className = "bg-amber-50 border border-amber-200 p-4 rounded-2xl mb-6 flex items-start gap-3";
            alertBox.innerHTML = `<i class="fa-solid fa-circle-exclamation text-amber-500 mt-0.5"></i><div><h4 class="text-sm font-bold text-amber-800">Status: Draft</h4><p class="text-xs text-amber-700/80 mt-1">Ujian belum bisa dikerjakan siswa. Anda wajib memiliki <b>minimal 10 soal</b> untuk dapat menerbitkan ujian ini[cite: 1, 2].</p></div>`;
        }
    };

    const init = async () => {
        try {
            const res = await fetch(`${API_URL}/api/exams/${examId}`, { headers: { 'Authorization': `Bearer ${token}` }});
            const result = await res.json();
            
            if (res.ok) {
                examConfig = result.data;
                questionsData = result.data.questions || [];
                
                document.getElementById('uiTitle').innerText = examConfig.title;
                document.getElementById('uiMeta').innerText = `${examConfig.subject} • ${examConfig.duration_minutes} Menit`;
                
                // Set UI sesuai status DB
                updatePublishUI(examConfig.is_active);

                if(questionsData.length === 0) addEmptyQuestion();
                else renderAllQuestions();
                
                setDirtyState(false);
            }
        } catch (e) {
            console.error(e);
            window.showToast?.('danger', 'Error', 'Gagal memuat ujian.');
        }
    };

    // --- LOGIKA KEMBALI ---
    window.handleBack = () => {
        if (isDirty) document.getElementById('modalConfirmBack').classList.replace('hidden', 'flex');
        else window.location.href = '/exams';
    };
    window.closeBackModal = () => document.getElementById('modalConfirmBack').classList.replace('flex', 'hidden');
    window.forceBack = () => window.location.href = '/exams';

    // --- TAMBAH / HAPUS SOAL (Ubah jadi Dirty) ---
    window.addEmptyQuestion = () => {
        questionsData.push({ question: '', options: { A: '', B: '', C: '', D: '' }, correct_answer: 'A', hint: '', image_url: null });
        renderAllQuestions();
        window.scrollTo(0, document.body.scrollHeight);
        setDirtyState(true);
    };

    window.removeQuestion = (index) => {
        questionsData.splice(index, 1);
        renderAllQuestions();
        setDirtyState(true);
        window.showToast?.('warning', 'Dihapus', 'Soal dihapus dari tampilan (Simpan untuk mematenkan).');
    };

    // --- KETIKAN / UPLOAD (Ubah jadi Dirty) ---
    document.getElementById('questionsContainer').addEventListener('input', (e) => {
        const target = e.target;
        const index = parseInt(target.getAttribute('data-index'));
        const field = target.getAttribute('data-field');

        if (isNaN(index)) return;
        
        setDirtyState(true); 

        if (field === 'question') questionsData[index].question = target.value;
        else if (field === 'hint') questionsData[index].hint = target.value;
        else if (field === 'correct') questionsData[index].correct_answer = target.value;
        else if (field.startsWith('opt_')) {
            const optKey = field.split('_')[1];
            questionsData[index].options[optKey] = target.value;
        }
    });

    window.handleImageUpload = (e, index) => {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = (event) => {
                questionsData[index].image_url = event.target.result;
                renderAllQuestions(); 
                setDirtyState(true);
            };
            reader.readAsDataURL(file);
        }
    };

    window.removeImage = (index) => {
        questionsData[index].image_url = null;
        renderAllQuestions();
        setDirtyState(true);
    };

    const renderAllQuestions = () => {
        const container = document.getElementById('questionsContainer');
        container.innerHTML = questionsData.map((q, i) => `
            <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm relative transition-all">
                <div class="flex justify-between items-center mb-4">
                    <span class="w-8 h-8 bg-gray-800 text-white rounded-full flex items-center justify-center font-black text-sm shadow-md">${i+1}</span>
                    <button onclick="removeQuestion(${i})" class="text-xs font-bold text-red-500 hover:bg-red-50 px-3 py-1.5 rounded-lg transition-colors"><i class="fa-solid fa-trash mr-1"></i> Hapus</button>
                </div>
                <div class="space-y-4">
                    <div>
                        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Teks Soal</label>
                        <textarea data-index="${i}" data-field="question" rows="2" placeholder="Tulis pertanyaan di sini..." class="w-full mt-1 px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm font-medium text-gray-800 outline-none focus:ring-2 focus:ring-green-500">${q.question}</textarea>
                    </div>
                    <div>
                        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Gambar Soal (Opsional)</label>
                        ${q.image_url 
                            ? `<div class="mt-2 relative w-full h-40 bg-gray-100 rounded-xl overflow-hidden border border-gray-200"><img src="${q.image_url}" class="w-full h-full object-contain" /><button onclick="removeImage(${i})" class="absolute top-2 right-2 bg-red-600 text-white w-8 h-8 rounded-full shadow-lg flex items-center justify-center"><i class="fa-solid fa-xmark"></i></button></div>`
                            : `<div class="mt-2 relative w-full h-16 bg-gray-50 border-2 border-dashed border-gray-300 rounded-xl flex items-center justify-center hover:bg-gray-100 transition-colors"><input type="file" accept="image/*" onchange="handleImageUpload(event, ${i})" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" /><span class="text-xs font-bold text-gray-500"><i class="fa-solid fa-image mr-1"></i> Klik untuk unggah gambar</span></div>`
                        }
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-2">
                        ${['A', 'B', 'C', 'D'].map(opt => `
                            <div class="flex items-center bg-gray-50 border border-gray-200 rounded-xl overflow-hidden focus-within:ring-2 focus-within:ring-green-500">
                                <div class="w-10 bg-gray-200 flex items-center justify-center font-black text-gray-600">${opt}</div>
                                <input type="text" data-index="${i}" data-field="opt_${opt}" value="${q.options[opt] || ''}" placeholder="Pilihan ${opt}" class="flex-1 px-3 py-2.5 bg-transparent text-sm font-medium outline-none">
                            </div>
                        `).join('')}
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-4 border-t border-gray-100">
                        <div>
                            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Kunci Jawaban</label>
                            <select data-index="${i}" data-field="correct" class="w-full mt-1 px-3 py-2.5 bg-green-50 border border-green-200 text-green-700 rounded-xl text-sm font-black outline-none cursor-pointer">
                                ${['A','B','C','D'].map(opt => `<option value="${opt}" ${q.correct_answer === opt ? 'selected' : ''}>Kunci: ${opt}</option>`).join('')}
                            </select>
                        </div>
                        <div>
                            <label class="text-[10px] font-bold text-amber-500 uppercase tracking-widest"><i class="fa-solid fa-lightbulb"></i> Clue / Hint Siswa</label>
                            <input type="text" data-index="${i}" data-field="hint" value="${q.hint || ''}" placeholder="Bantuan jika siswa kesusahan..." class="w-full mt-1 px-3 py-2.5 bg-amber-50 border border-amber-200 rounded-xl text-sm font-medium text-amber-800 outline-none placeholder-amber-300">
                        </div>
                    </div>
                </div>
            </div>
        `).join('');
    };

    // --- MODAL PUBLISH / UNPUBLISH (DINAMIS) ---
    window.publishExamToggle = () => {
        // Validasi soal 10 hanya jika mau diterbitkan
        if (!examConfig.is_active && questionsData.length < 10) {
            window.showToast?.('warning', 'Gagal Terbit', 'Minimal harus ada 10 soal untuk bisa menerbitkan ujian[cite: 1, 2].');
            return;
        }
        
        const modalTitle = document.getElementById('publishModalTitle');
        const modalDesc = document.getElementById('publishModalDesc');
        const btnConfirm = document.getElementById('btnConfirmPublish');
        const iconModal = document.getElementById('publishModalIcon');
        const iconWrap = document.getElementById('publishModalIconWrap');

        if (examConfig.is_active) {
            // Setting Modal untuk "Tarik ke Draft"
            modalTitle.innerText = 'Tarik ke Draft?';
            modalDesc.innerText = 'Ujian akan ditarik dan disembunyikan. Siswa tidak akan bisa mengakses ujian ini lagi dari Portal mereka.';
            btnConfirm.innerText = 'Tarik ke Draft';
            btnConfirm.className = 'flex-1 py-3 bg-amber-500 text-white font-bold rounded-xl shadow-md shadow-amber-500/20 active:scale-95 transition-all';
            btnConfirm.onclick = () => forcePublish(false);
            iconModal.className = 'fa-solid fa-folder-open';
            iconWrap.className = 'w-16 h-16 bg-amber-50 text-amber-500 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4 border border-amber-100 shadow-inner';
        } else {
            // Setting Modal untuk "Terbitkan"
            modalTitle.innerText = 'Terbitkan Ujian?';
            modalDesc.innerText = 'Ujian ini akan segera aktif dan langsung dapat diakses oleh siswa[cite: 1, 2]. Pastikan semua soal sudah benar.';
            btnConfirm.innerText = 'Terbitkan';
            btnConfirm.className = 'flex-1 py-3 bg-indigo-600 text-white font-bold rounded-xl shadow-md shadow-indigo-600/20 active:scale-95 transition-all';
            btnConfirm.onclick = () => forcePublish(true);
            iconModal.className = 'fa-solid fa-paper-plane';
            iconWrap.className = 'w-16 h-16 bg-indigo-50 text-indigo-500 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4 border border-indigo-100 shadow-inner';
        }

        document.getElementById('modalConfirmPublish').classList.replace('hidden', 'flex');
    };
    
    window.closePublishModal = () => document.getElementById('modalConfirmPublish').classList.replace('flex', 'hidden');
    
    window.forcePublish = (targetStatus) => {
        const btn = document.getElementById('btnConfirmPublish');
        btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin mr-1"></i> ${targetStatus ? 'Menerbitkan...' : 'Menarik...'}`;
        btn.disabled = true;
        saveExamAction(targetStatus);
    };

    // --- API SIMPAN MASTER (MENG-HANDLE SAVE & PUBLISH BERSAMAAN) ---
    window.saveExamAction = async (targetActiveState = examConfig.is_active) => {
        if (isSaving) return; 
        if (targetActiveState === examConfig.is_active && !isDirty) return; // Ignore jika tombol dipaksa klik saat sudah saved

        isSaving = true;
        const btnSave = document.getElementById('btnSaveExam');

        // Tampilkan loading cuma kalau actionnya Save biasa
        if (targetActiveState === examConfig.is_active && btnSave) {
            btnSave.disabled = true;
            btnSave.innerHTML = '<i class="fa-solid fa-spinner fa-spin text-sm"></i>';
        }

        const payload = {
            title: examConfig.title,
            duration_minutes: examConfig.duration_minutes,
            is_active: targetActiveState,
            questions: questionsData
        };

        try {
            const res = await fetch(`${API_URL}/api/exams/${examId}`, {
                method: 'PUT',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            if (res.ok) {
                setDirtyState(false); 
                
                if (targetActiveState !== examConfig.is_active) {
                    // Update State dan UI SPA Jika status ujian berganti
                    examConfig.is_active = targetActiveState;
                    updatePublishUI(targetActiveState);
                    closePublishModal();
                    window.showToast?.('success', 'Status Berubah', targetActiveState ? 'Ujian telah Terbit!' : 'Ujian ditarik ke Draft.');
                } else {
                    window.showToast?.('success', 'Tersimpan', 'Draft disimpan dengan aman[cite: 1].');
                }
            } else {
                const err = await res.json();
                throw new Error(err.message);
            }
        } catch (e) {
            window.showToast?.('danger', 'Error', e.message || 'Gagal menyimpan[cite: 1, 2].');
            setDirtyState(true); 
        } finally {
            isSaving = false; 
            const btnPublish = document.getElementById('btnConfirmPublish');
            if (btnPublish) btnPublish.disabled = false;
        }
    };

    // --- Logika Preview POV Murid ---
    window.previewExam = () => {
        if (isDirty) {
            window.showToast?.('warning', 'Simpan Dulu', 'Ada perubahan yang belum disimpan[cite: 1, 2]. Simpan dulu sebelum melihat preview.');
            return;
        }
        if (questionsData.length === 0) {
            window.showToast?.('warning', 'Kosong', 'Belum ada soal untuk disimulasikan[cite: 1, 2].');
            return;
        }
        window.location.href = `/play/${examId}?preview=true`;
    };

    init();
</script>

<style>
    .animate-slide-up {
        animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes slideUp {
        0% { transform: translateY(20px) scale(0.95); opacity: 0; }
        100% { transform: translateY(0) scale(1); opacity: 1; }
    }
</style>