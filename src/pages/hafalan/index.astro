---
import Layout from '../../layouts/Layout.astro';
import NavbarGuru from '../../components/NavbarGuru.astro';
import Toast from '../../components/Toast.astro';
---

<Layout title="Hafalan Siswa / Anak - yukNgaji">
    <div class="px-5 py-7 pb-32 min-h-screen bg-gray-50 flex flex-col">
        
        <!-- HEADER -->
        <header class="flex justify-between items-center mb-7">
            <div>
                <p class="text-[10px] font-black text-green-500 uppercase tracking-[0.2em] mb-1">yukNgaji</p>
                <h1 class="text-2xl font-black text-gray-800 tracking-tight leading-none">Hafalan</h1>
                <p class="text-[10px] text-gray-400 mt-1 font-semibold uppercase tracking-widest">Pantau Setoran Siswa / Anak</p>
            </div>
            <button id="btnRefresh" class="w-11 h-11 bg-white border border-gray-200 text-gray-400 rounded-2xl flex items-center justify-center active:scale-95 transition-all shadow-sm hover:border-green-200 hover:text-green-500">
                <i class="fa-solid fa-rotate-right"></i>
            </button>
        </header>

        <!-- [BARU] HIGHLIGHT PERFORMA HAFALAN -->
        <div id="performaHighlight" class="hidden mb-6 grid-cols-2 gap-3 animate-slide-up">
            <!-- Paling Tinggi -->
            <div class="bg-gradient-to-br from-green-500 to-green-600 rounded-2xl p-4 text-white shadow-lg shadow-green-500/30 relative overflow-hidden active:scale-95 transition-transform cursor-pointer" id="cardHigh">
                <i class="fa-solid fa-crown absolute -right-2 -top-2 text-5xl text-white/20 rotate-12"></i>
                <p class="text-[9px] font-black uppercase tracking-widest text-green-100 mb-2">Tertinggi 🚀</p>
                <div class="flex items-center gap-3 relative z-10">
                    <div id="highAvatar" class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center font-black text-sm backdrop-blur-sm border border-white/30 shrink-0"></div>
                    <div class="min-w-0">
                        <h4 id="highName" class="font-black text-xs truncate capitalize">--</h4>
                        <p id="highSurah" class="text-[9px] font-bold text-green-100 truncate">--</p>
                    </div>
                </div>
            </div>
            
            <!-- Paling Bawah -->
            <div class="bg-gradient-to-br from-amber-400 to-orange-500 rounded-2xl p-4 text-white shadow-lg shadow-orange-500/30 relative overflow-hidden active:scale-95 transition-transform cursor-pointer" id="cardLow">
                <i class="fa-solid fa-seedling absolute -right-1 -bottom-2 text-5xl text-white/20 -rotate-12"></i>
                <p class="text-[9px] font-black uppercase tracking-widest text-amber-100 mb-2">Paling Bawah 🌱</p>
                <div class="flex items-center gap-3 relative z-10">
                    <div id="lowAvatar" class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center font-black text-sm backdrop-blur-sm border border-white/30 shrink-0"></div>
                    <div class="min-w-0">
                        <h4 id="lowName" class="font-black text-xs truncate capitalize">--</h4>
                        <p id="lowSurah" class="text-[9px] font-bold text-amber-100 truncate">--</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- SEARCH & FILTER -->
        <section class="mb-5 space-y-3">
            <div class="flex gap-2">
                <!-- Search Input -->
                <div class="relative flex-1">
                    <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-gray-300 text-xs"></i>
                    <input 
                        type="text" 
                        id="searchInput" 
                        class="w-full pl-10 pr-4 py-3 bg-white border border-gray-100 rounded-2xl text-xs font-semibold text-gray-700 placeholder:text-gray-300 focus:ring-2 focus:ring-green-400 focus:border-transparent transition-all shadow-sm outline-none" 
                        placeholder="Cari nama Siswa / Anak..."
                    >
                </div>
                
                <!-- Dropdown Surat -->
                <div class="relative w-2/5">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-3.5 pointer-events-none">
                        <i class="fa-solid fa-filter text-green-400 text-[10px]"></i>
                    </div>
                    <select id="surahFilter" class="w-full pl-9 pr-7 py-3 bg-white border border-gray-100 rounded-2xl text-[10px] font-bold text-gray-600 focus:ring-2 focus:ring-green-400 focus:border-transparent transition-all shadow-sm outline-none appearance-none cursor-pointer">
                        <option value="all">Semua Surat</option>
                    </select>
                    <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                        <i class="fa-solid fa-chevron-down text-gray-300 text-[9px]" id="surahFilterArrow"></i>
                    </div>
                </div>
            </div>

            <!-- Filter Chips (Status) -->
            <div class="flex gap-2 overflow-x-auto no-scrollbar pb-1" id="filterContainer">
                <button class="filter-chip px-4 py-2 bg-green-600 text-white rounded-xl text-[10px] font-black whitespace-nowrap transition-all shadow-sm" data-filter="all">
                    <i class="fa-solid fa-layer-group mr-1.5"></i>Semua
                </button>
                <button class="filter-chip px-4 py-2 bg-white text-gray-400 border border-gray-100 rounded-xl text-[10px] font-black whitespace-nowrap transition-all shadow-sm" data-filter="active">
                    <i class="fa-solid fa-circle-play mr-1.5 text-green-400"></i>Berjalan
                </button>
                <button class="filter-chip px-4 py-2 bg-white text-gray-400 border border-gray-100 rounded-xl text-[10px] font-black whitespace-nowrap transition-all shadow-sm" data-filter="empty">
                    <i class="fa-solid fa-circle-pause mr-1.5 text-gray-300"></i>Belum Mulai
                </button>
            </div>
        </section>

        <!-- STATS BAR (render via JS) -->
        <div id="statsBar" class="hidden mb-4 bg-white rounded-2xl border border-gray-100 shadow-sm px-4 py-3 flex items-center justify-between gap-3">
            <div class="text-center flex-1">
                <p class="text-[10px] font-black text-gray-800" id="statTotal">-</p>
                <p class="text-[8px] font-bold text-gray-400 uppercase tracking-widest mt-0.5">Total</p>
            </div>
            <div class="w-px h-6 bg-gray-100"></div>
            <div class="text-center flex-1">
                <p class="text-[10px] font-black text-green-600" id="statActive">-</p>
                <p class="text-[8px] font-bold text-gray-400 uppercase tracking-widest mt-0.5">Aktif</p>
            </div>
            <div class="w-px h-6 bg-gray-100"></div>
            <div class="text-center flex-1">
                <p class="text-[10px] font-black text-gray-400" id="statEmpty">-</p>
                <p class="text-[8px] font-bold text-gray-400 uppercase tracking-widest mt-0.5">Belum</p>
            </div>
        </div>

        <!-- STUDENT LIST — full column -->
        <section id="mainContent" class="flex flex-col gap-2.5">
            <div class="text-center py-12">
                <div class="w-12 h-12 bg-green-50 rounded-2xl flex items-center justify-center mx-auto mb-3">
                    <i class="fa-solid fa-spinner fa-spin text-green-500 text-lg"></i>
                </div>
                <p class="text-[10px] text-gray-400 font-black uppercase tracking-widest">Memuat data...</p>
            </div>
        </section>
        
    </div>

    <NavbarGuru activeMenu="hafalan" />
    <Toast />
</Layout>

<script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const token = localStorage.getItem('token');
    if (!token) window.location.replace('/');

    const JUZ_AMMA = [
        { id: 1, name: "An-Nas", ayahs: 6 },
        { id: 2, name: "Al-Falaq", ayahs: 5 },
        { id: 3, name: "Al-Ikhlas", ayahs: 4 },
        { id: 4, name: "Al-Masad", ayahs: 5 },
        { id: 5, name: "An-Nasr", ayahs: 3 },
        { id: 6, name: "Al-Kafirun", ayahs: 6 },
        { id: 7, name: "Al-Kausar", ayahs: 3 },
        { id: 8, name: "Al-Ma'un", ayahs: 7 },
        { id: 9, name: "Quraisy", ayahs: 4 },
        { id: 10, name: "Al-Fil", ayahs: 5 },
        { id: 11, name: "Al-Humazah", ayahs: 9 },
        { id: 12, name: "Al-'Asr", ayahs: 3 },
        { id: 13, name: "At-Takasur", ayahs: 8 },
        { id: 14, name: "Al-Qari'ah", ayahs: 11 },
        { id: 15, name: "Al-'Adiyat", ayahs: 11 },
        { id: 16, name: "Az-Zalzalah", ayahs: 8 },
        { id: 17, name: "Al-Bayyinah", ayahs: 8 },
        { id: 18, name: "Al-Qadr", ayahs: 5 },
        { id: 19, name: "Al-'Alaq", ayahs: 19 },
        { id: 20, name: "At-Tin", ayahs: 8 },
        { id: 21, name: "Al-Insyirah", ayahs: 8 },
        { id: 22, name: "Ad-Duha", ayahs: 11 },
        { id: 23, name: "Al-Lail", ayahs: 21 },
        { id: 24, name: "Asy-Syams", ayahs: 15 },
        { id: 25, name: "Al-Balad", ayahs: 20 },
        { id: 26, name: "Al-Fajr", ayahs: 30 },
        { id: 27, name: "Al-Gasyiyah", ayahs: 26 },
        { id: 28, name: "Al-A'la", ayahs: 19 },
        { id: 29, name: "At-Tariq", ayahs: 17 },
        { id: 30, name: "Al-Buruj", ayahs: 22 },
        { id: 31, name: "Al-Insyiqaq", ayahs: 25 },
        { id: 32, name: "Al-Mutaffifin", ayahs: 36 },
        { id: 33, name: "Al-Infitar", ayahs: 19 },
        { id: 34, name: "At-Takwir", ayahs: 29 },
        { id: 35, name: "Abasa", ayahs: 42 },
        { id: 36, name: "An-Nazi'at", ayahs: 46 },
        { id: 37, name: "An-Naba'", ayahs: 40 }
    ];

    let allStudents = [];
    let activeFilter = 'all';
    let searchQuery = '';
    let activeSurahFilter = 'all';

    const fetchStudents = async () => {
        const res = await fetch(`${API_URL}/api/students`, {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        const result = await res.json();
        if (res.ok) return result.data;
        throw new Error(result.message);
    };

    const updateSurahDropdown = () => {
        const dropdown = document.getElementById('surahFilter');
        if (!dropdown) return;

        const activeSurahIds = allStudents.map(s => s.current_surah_id).filter(id => id !== null);
        const surahCounts = activeSurahIds.reduce((acc, id) => {
            acc[id] = (acc[id] || 0) + 1;
            return acc;
        }, {});
        const uniqueSurahs = [...new Set(activeSurahIds)].sort((a, b) => a - b);

        let optionsHtml = `<option value="all">Semua Surat</option>`;
        uniqueSurahs.forEach(id => {
            const surah = JUZ_AMMA.find(s => s.id === id);
            if (surah) {
                optionsHtml += `<option value="${id}">${surah.name} (${surahCounts[id]})</option>`;
            }
        });

        const prevValue = dropdown.value; 
        dropdown.innerHTML = optionsHtml;
        if (uniqueSurahs.includes(parseInt(prevValue))) {
            dropdown.value = prevValue;
        } else {
            dropdown.value = 'all';
            activeSurahFilter = 'all';
        }
    };

    const updateStatsBar = () => {
        const statsBar = document.getElementById('statsBar');
        const total = allStudents.length;
        const active = allStudents.filter(s => s.current_surah_id).length;
        const empty = total - active;

        if (total > 0) {
            statsBar.classList.remove('hidden');
            statsBar.classList.add('flex');
            document.getElementById('statTotal').textContent = total;
            document.getElementById('statActive').textContent = active;
            document.getElementById('statEmpty').textContent = empty;
        }
    };

    const getProgressPercent = (student) => {
        if (!student.current_surah_id) return 0;
        const surah = JUZ_AMMA.find(s => s.id === student.current_surah_id);
        if (!surah) return 0;
        return Math.round((student.current_ayah / surah.ayahs) * 100);
    };

    const getHafalanStatus = (student) => {
        if (!student.current_surah_id) {
            return `
                <div class="flex items-center gap-2">
                    <span class="text-[9px] bg-gray-50 text-gray-400 font-bold px-2.5 py-1 rounded-md border border-gray-100 uppercase tracking-widest">Belum Mulai</span>
                </div>
            `;
        }
        
        const surah = JUZ_AMMA.find(s => s.id === student.current_surah_id);
        if (!surah) return `<span class="text-[9px] bg-red-50 text-red-500 font-bold px-2 py-1 rounded-lg">Error</span>`;

        return `
            <div class="flex flex-col items-end gap-0.5">
                <span class="text-[11px] font-black text-gray-800 uppercase tracking-wider">${surah.name}</span>
                <p class="text-[9px] font-bold text-gray-400">Ayat ${student.current_ayah} / ${surah.ayahs}</p>
            </div>
        `;
    };

    const getProgressBar = (student) => {
        if (!student.current_surah_id) return '';
        const pct = getProgressPercent(student);
        return `
            <div class="mt-3.5 pt-3.5 border-t border-gray-100 w-full">
                <div class="flex items-center justify-between mb-1.5">
                    <span class="text-[9px] font-bold text-gray-400">Progres Surat Ini</span>
                    <span class="text-[9px] font-black text-green-600">${pct}%</span>
                </div>
                <div class="w-full h-1.5 bg-gray-100 rounded-full overflow-hidden">
                    <div class="h-full bg-green-500 rounded-full transition-all" style="width: ${pct}%"></div>
                </div>
            </div>
        `;
    };

    const getAvatarColors = (name) => {
        const colors = [
            'bg-green-50 text-green-600',
            'bg-blue-50 text-blue-600',
            'bg-amber-50 text-amber-600',
            'bg-purple-50 text-purple-600',
            'bg-teal-50 text-teal-600',
        ];
        const index = name.charCodeAt(0) % colors.length;
        return colors[index];
    };

    const renderCards = () => {
        const container = document.getElementById('mainContent');
        let filtered = allStudents.filter(s => s.name.toLowerCase().includes(searchQuery.toLowerCase()));

        if (activeFilter === 'active') filtered = filtered.filter(s => s.current_surah_id);
        if (activeFilter === 'empty') filtered = filtered.filter(s => !s.current_surah_id);

        if (activeSurahFilter !== 'all') {
            filtered = filtered.filter(s => s.current_surah_id === parseInt(activeSurahFilter));
        }

        if (filtered.length === 0) {
            container.innerHTML = `
                <div class="text-center py-14 bg-white rounded-3xl border border-dashed border-gray-200 shadow-sm">
                    <div class="w-14 h-14 bg-gray-50 rounded-2xl flex items-center justify-center mx-auto mb-3">
                        <i class="fa-solid fa-users-slash text-2xl text-gray-200"></i>
                    </div>
                    <p class="text-xs text-gray-400 font-black uppercase tracking-widest">Tidak ditemukan</p>
                    <p class="text-[10px] text-gray-300 font-semibold mt-1">Coba ubah filter atau kata kunci</p>
                </div>
            `;
            return;
        }

        container.innerHTML = filtered.map((s, idx) => {
            const avatarColor = getAvatarColors(s.name);
            const isActive = !!s.current_surah_id;

            return `
            <div 
                onclick="window.location.href='/hafalan/detail?id=${s.id}'" 
                class="bg-white p-4 rounded-2xl border border-gray-100 shadow-sm active:scale-[0.99] transition-all cursor-pointer flex flex-col"
                style="animation: fadeUp 0.2s ease both; animation-delay: ${idx * 30}ms"
            >
                <!-- Info Atas -->
                <div class="flex items-center gap-3">
                    <!-- Avatar -->
                    <div class="relative shrink-0">
                        <div class="w-12 h-12 ${avatarColor} rounded-2xl flex items-center justify-center text-sm font-black">
                            ${s.name.substring(0, 2).toUpperCase()}
                        </div>
                        ${isActive ? `<div class="absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 bg-green-500 rounded-full border-2 border-white shadow-sm"></div>` : ''}
                    </div>

                    <!-- Info Anak -->
                    <div class="flex-1 min-w-0">
                        <h3 class="font-black text-gray-800 text-xs capitalize leading-tight truncate">${s.name}</h3>
                        <div class="flex items-center gap-1.5 mt-0.5">
                            <i class="fa-solid fa-graduation-cap text-[8px] text-gray-300"></i>
                            <p class="text-[9px] font-bold text-gray-400 uppercase tracking-wider">${s.grade}</p>
                        </div>
                    </div>

                    <!-- Status Hafalan -->
                    <div class="text-right shrink-0">
                        ${getHafalanStatus(s)}
                    </div>

                    <!-- Arrow -->
                    <i class="fa-solid fa-chevron-right text-[9px] text-gray-200 ml-1 shrink-0"></i>
                </div>
                
                <!-- Progress Bar di Bawah Info Atas -->
                ${getProgressBar(s)}
            </div>
        `}).join('');
    };

    // Filter Chips
    document.querySelectorAll('.filter-chip').forEach(chip => {
        chip.addEventListener('click', (e) => {
            const btn = e.currentTarget;
            document.querySelectorAll('.filter-chip').forEach(c => {
                c.className = "filter-chip px-4 py-2 bg-white text-gray-400 border border-gray-100 rounded-xl text-[10px] font-black whitespace-nowrap transition-all shadow-sm";
                // re-inject icon
                const filter = c.dataset.filter;
                const icons = { all: 'fa-layer-group', active: 'fa-circle-play', empty: 'fa-circle-pause' };
                const iconColors = { all: '', active: 'text-green-400', empty: 'text-gray-300' };
                const labels = { all: 'Semua', active: 'Berjalan', empty: 'Belum Mulai' };
                c.innerHTML = `<i class="fa-solid ${icons[filter]} mr-1.5 ${iconColors[filter]}"></i>${labels[filter]}`;
            });
            btn.className = "filter-chip active px-4 py-2 bg-green-600 text-white rounded-xl text-[10px] font-black whitespace-nowrap transition-all shadow-sm";
            
            // restore active icon
            const filter = btn.dataset.filter;
            const icons = { all: 'fa-layer-group', active: 'fa-circle-play', empty: 'fa-circle-pause' };
            const labels = { all: 'Semua', active: 'Berjalan', empty: 'Belum Mulai' };
            btn.innerHTML = `<i class="fa-solid ${icons[filter]} mr-1.5"></i>${labels[filter]}`;

            activeFilter = filter;
            renderCards();
        });
    });

    // Live Search
    let searchTimer;
    document.getElementById('searchInput').addEventListener('input', e => {
        clearTimeout(searchTimer);
        searchTimer = setTimeout(() => {
            searchQuery = e.target.value;
            renderCards();
        }, 200);
    });

    // Refresh
    document.getElementById('btnRefresh').addEventListener('click', () => {
        const btn = document.getElementById('btnRefresh');
        btn.innerHTML = '<i class="fa-solid fa-rotate-right fa-spin text-green-500"></i>';
        loadData();
    });

    // Init Load
    const loadData = async () => {
        try {
            allStudents = await fetchStudents();
            updateStatsBar();
            renderCards();
            updateSurahDropdown();
            updateHighlights();
        } catch (err) {
            document.getElementById('mainContent').innerHTML = `
                <div class="text-center py-12 bg-red-50 rounded-3xl border border-dashed border-red-200 shadow-sm">
                    <div class="w-12 h-12 bg-red-100 rounded-2xl flex items-center justify-center mx-auto mb-3">
                        <i class="fa-solid fa-triangle-exclamation text-xl text-red-400"></i>
                    </div>
                    <p class="text-xs text-red-500 font-black uppercase tracking-widest">Gagal memuat data</p>
                    <p class="text-[10px] text-red-400 mt-1">${err.message}</p>
                </div>`;
        } finally {
            document.getElementById('btnRefresh').innerHTML = '<i class="fa-solid fa-rotate-right"></i>';
        }
    };

    // Dropdown Surat
    document.getElementById('surahFilter')?.addEventListener('change', (e) => {
        activeSurahFilter = e.target.value;
        renderCards();
    });

    // [BARU] Fungsi Highlight Tertinggi & Terendah
    const updateHighlights = () => {
        const highlightContainer = document.getElementById('performaHighlight');
        
        // 1. Filter: Hanya ambil yang sudah mulai ngafal & abaikan akun testing
        const validStudents = allStudents.filter(s => {
            const nameLower = s.name.toLowerCase();
            const isTestingAccount = nameLower.includes('john doe') || nameLower.includes('xaviera');
            return s.current_surah_id !== null && !isTestingAccount;
        });

        // Kalau belum ada data valid, sembunyikan sectionnya
        if (validStudents.length === 0) {
            highlightContainer.classList.add('hidden');
            highlightContainer.classList.remove('grid');
            return;
        }

        // 2. Sorting: ID Surat lebih besar = progress lebih jauh (An-Nas = 1, An-Naba' = 37)
        validStudents.sort((a, b) => {
            if (b.current_surah_id !== a.current_surah_id) {
                return b.current_surah_id - a.current_surah_id; // Sortir Surat (Terbesar di atas)
            }
            return b.current_ayah - a.current_ayah; // Jika surat sama, Sortir Ayat (Terbesar di atas)
        });

        const highest = validStudents[0];
        const lowest = validStudents[validStudents.length - 1];
        
        const getSurahName = (id) => JUZ_AMMA.find(s => s.id === id)?.name || 'Error';

        // 3. Suntik Data Tertinggi
        document.getElementById('highAvatar').innerText = highest.name.substring(0, 2).toUpperCase();
        document.getElementById('highName').innerText = highest.name.split(' ')[0]; // Ambil nama panggilan
        document.getElementById('highSurah').innerText = `${getSurahName(highest.current_surah_id)} (Ayat ${highest.current_ayah})`;
        document.getElementById('cardHigh').onclick = () => window.location.href = `/hafalan/detail?id=${highest.id}`;

        // 4. Suntik Data Terendah
        document.getElementById('lowAvatar').innerText = lowest.name.substring(0, 2).toUpperCase();
        document.getElementById('lowName').innerText = lowest.name.split(' ')[0];
        document.getElementById('lowSurah').innerText = `${getSurahName(lowest.current_surah_id)} (Ayat ${lowest.current_ayah})`;
        document.getElementById('cardLow').onclick = () => window.location.href = `/hafalan/detail?id=${lowest.id}`;

        // Tampilkan UInya
        highlightContainer.classList.remove('hidden');
        highlightContainer.classList.add('grid');
    };

    loadData();
</script>

<style>
    .no-scrollbar::-webkit-scrollbar { display: none; }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>